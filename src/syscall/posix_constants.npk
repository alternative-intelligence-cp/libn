// posix_constants.npk — Complete POSIX/Linux constants for libn (v0.1.1)
//
// No C shims. All values sourced from:
//   - POSIX.1-2017 (IEEE Std 1003.1-2017)
//   - Linux kernel headers: include/uapi/linux/
//   - glibc headers: bits/fcntl.h, bits/mman.h, bits/signum.h, etc.
//   - Architecture: x86-64 (Linux ABI)
//
// Usage:
//   use "src/syscall/posix_constants.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// FILE OPEN FLAGS  (fcntl.h, O_* values for x86-64 Linux)
// ════════════════════════════════════════════════════════════════════════════

pub fixed int64:O_RDONLY    = 0i64;         // Open for reading only
pub fixed int64:O_WRONLY    = 1i64;         // Open for writing only
pub fixed int64:O_RDWR      = 2i64;         // Open for reading and writing
pub fixed int64:O_CREAT     = 64i64;        // Create if doesn't exist  (0100 octal)
pub fixed int64:O_EXCL      = 128i64;       // Error if already exists  (0200 octal)
pub fixed int64:O_NOCTTY    = 256i64;       // Don't assign controlling terminal
pub fixed int64:O_TRUNC     = 512i64;       // Truncate to zero on open
pub fixed int64:O_APPEND    = 1024i64;      // Writes always go to end
pub fixed int64:O_NONBLOCK  = 2048i64;      // Non-blocking I/O
pub fixed int64:O_DSYNC     = 4096i64;      // Data sync (fdatasync on write)
pub fixed int64:O_FASYNC    = 8192i64;      // Enable SIGIO on I/O
pub fixed int64:O_DIRECT    = 16384i64;     // Direct I/O (bypass page cache)
pub fixed int64:O_LARGEFILE = 32768i64;     // Large file support (obsolete on x86-64)
pub fixed int64:O_DIRECTORY = 65536i64;     // Fail if not a directory
pub fixed int64:O_NOFOLLOW  = 131072i64;    // Don't follow symlinks
pub fixed int64:O_NOATIME   = 262144i64;    // Don't update atime on read
pub fixed int64:O_CLOEXEC   = 524288i64;    // Close-on-exec (FD_CLOEXEC)
pub fixed int64:O_SYNC      = 1052672i64;   // Full data+metadata sync (O_DSYNC|O_RSYNC)
pub fixed int64:O_PATH      = 2097152i64;   // Path-only fd (no I/O)
pub fixed int64:O_TMPFILE   = 4194304i64;   // Unnamed temp file (dir must be writable)
pub fixed int64:O_NDELAY    = O_NONBLOCK;   // Alias for O_NONBLOCK

// ════════════════════════════════════════════════════════════════════════════
// SEEK WHENCE VALUES  (unistd.h)
// ════════════════════════════════════════════════════════════════════════════

pub fixed int64:SEEK_SET = 0i64;    // Seek from beginning of file
pub fixed int64:SEEK_CUR = 1i64;    // Seek from current position
pub fixed int64:SEEK_END = 2i64;    // Seek from end of file
pub fixed int64:SEEK_DATA = 3i64;   // Next location containing data (SEEK_HOLE/DATA)
pub fixed int64:SEEK_HOLE = 4i64;   // Next hole (sparse file support)

// ════════════════════════════════════════════════════════════════════════════
// FILE PERMISSION MODES  (sys/stat.h S_I* values)
// ════════════════════════════════════════════════════════════════════════════

// File type masks
pub fixed int64:S_IFMT   = 61440i64;    // 0170000 — type field bitmask
pub fixed int64:S_IFSOCK = 49152i64;    // 0140000 — socket
pub fixed int64:S_IFLNK  = 40960i64;   // 0120000 — symbolic link
pub fixed int64:S_IFREG  = 32768i64;   // 0100000 — regular file
pub fixed int64:S_IFBLK  = 24576i64;   // 0060000 — block device
pub fixed int64:S_IFDIR  = 16384i64;   // 0040000 — directory
pub fixed int64:S_IFCHR  = 8192i64;    // 0020000 — character device
pub fixed int64:S_IFIFO  = 4096i64;    // 0010000 — FIFO/named pipe

// SUID/SGID/sticky
pub fixed int64:S_ISUID  = 2048i64;    // 04000 — set-user-ID bit
pub fixed int64:S_ISGID  = 1024i64;    // 02000 — set-group-ID bit
pub fixed int64:S_ISVTX  = 512i64;     // 01000 — sticky bit

// Owner permissions
pub fixed int64:S_IRWXU  = 448i64;     // 0700 — owner: rwx
pub fixed int64:S_IRUSR  = 256i64;     // 0400 — owner: read
pub fixed int64:S_IWUSR  = 128i64;     // 0200 — owner: write
pub fixed int64:S_IXUSR  = 64i64;      // 0100 — owner: execute

// Group permissions
pub fixed int64:S_IRWXG  = 56i64;      // 070  — group: rwx
pub fixed int64:S_IRGRP  = 32i64;      // 040  — group: read
pub fixed int64:S_IWGRP  = 16i64;      // 020  — group: write
pub fixed int64:S_IXGRP  = 8i64;       // 010  — group: execute

// Other permissions
pub fixed int64:S_IRWXO  = 7i64;       // 07   — other: rwx
pub fixed int64:S_IROTH  = 4i64;       // 04   — other: read
pub fixed int64:S_IWOTH  = 2i64;       // 02   — other: write
pub fixed int64:S_IXOTH  = 1i64;       // 01   — other: execute

// Commonly used combined modes
pub fixed int64:MODE_644 = 420i64;     // rw-r--r--  (user rw, group r, other r)
pub fixed int64:MODE_755 = 493i64;     // rwxr-xr-x  (user rwx, group rx, other rx)
pub fixed int64:MODE_777 = 511i64;     // rwxrwxrwx  (all permissions)
pub fixed int64:MODE_600 = 384i64;     // rw-------  (user rw only)
pub fixed int64:MODE_700 = 448i64;     // rwx------  (user rwx only)
pub fixed int64:MODE_400 = 256i64;     // r--------  (user read only)

// ════════════════════════════════════════════════════════════════════════════
// ACCESS CHECK MODES  (unistd.h, faccessat flags)
// ════════════════════════════════════════════════════════════════════════════

pub fixed int64:F_OK = 0i64;    // Test existence
pub fixed int64:R_OK = 4i64;    // Test read permission
pub fixed int64:W_OK = 2i64;    // Test write permission
pub fixed int64:X_OK = 1i64;    // Test execute permission

// AT flags (for *at() syscalls)
pub fixed int64:AT_FDCWD            = -100i64;  // Use current working directory
pub fixed int64:AT_SYMLINK_NOFOLLOW = 256i64;   // Don't follow symlinks
pub fixed int64:AT_REMOVEDIR        = 512i64;   // Remove directory instead of file
pub fixed int64:AT_SYMLINK_FOLLOW   = 1024i64;  // Follow symlinks
pub fixed int64:AT_EACCESS          = 512i64;   // Use effective UID/GID for access check
pub fixed int64:AT_EMPTY_PATH       = 4096i64;  // Allow empty path (use fd directly)
pub fixed int64:AT_NO_AUTOMOUNT     = 2048i64;  // Don't trigger automount
pub fixed int64:AT_STATX_SYNC_AS_STAT = 0i64;  // statx sync behaviour
pub fixed int64:AT_STATX_FORCE_SYNC   = 8192i64;
pub fixed int64:AT_STATX_DONT_SYNC    = 16384i64;

// ════════════════════════════════════════════════════════════════════════════
// MMAP PROTECTION FLAGS  (sys/mman.h PROT_*)
// ════════════════════════════════════════════════════════════════════════════

pub fixed int64:PROT_NONE  = 0i64;    // Page cannot be accessed
pub fixed int64:PROT_READ  = 1i64;    // Page can be read
pub fixed int64:PROT_WRITE = 2i64;    // Page can be written
pub fixed int64:PROT_EXEC  = 4i64;    // Page can be executed
pub fixed int64:PROT_RW    = 3i64;    // Read + write (convenience alias)
pub fixed int64:PROT_RWX   = 7i64;    // Read + write + execute (for JIT)

// ════════════════════════════════════════════════════════════════════════════
// MMAP MAP FLAGS  (sys/mman.h MAP_*)
// ════════════════════════════════════════════════════════════════════════════

pub fixed int64:MAP_SHARED          = 1i64;       // Share changes with other mappings
pub fixed int64:MAP_PRIVATE         = 2i64;       // Private copy-on-write mapping
pub fixed int64:MAP_FIXED           = 16i64;      // Exact address — replace any existing
pub fixed int64:MAP_ANONYMOUS       = 32i64;      // Not backed by file (fd=-1, offset=0)
pub fixed int64:MAP_ANON            = 32i64;      // Alias for MAP_ANONYMOUS
pub fixed int64:MAP_GROWSDOWN       = 256i64;     // Stack-like segment
pub fixed int64:MAP_DENYWRITE       = 2048i64;    // ETXTBSY on write to mapped file
pub fixed int64:MAP_EXECUTABLE      = 4096i64;    // Mark as executable
pub fixed int64:MAP_LOCKED          = 8192i64;    // Lock pages in memory
pub fixed int64:MAP_NORESERVE       = 16384i64;   // Don't reserve swap space
pub fixed int64:MAP_POPULATE        = 32768i64;   // Prefault page tables
pub fixed int64:MAP_NONBLOCK        = 65536i64;   // POPULATE: don't block on page fault
pub fixed int64:MAP_STACK           = 131072i64;  // Allocation for stack
pub fixed int64:MAP_HUGETLB         = 262144i64;  // Use huge pages
pub fixed int64:MAP_SYNC            = 524288i64;  // Sync mapping (DAX)
pub fixed int64:MAP_FIXED_NOREPLACE = 1048576i64; // Fixed: EEXIST if addr occupied
pub fixed int64:MAP_UNINITIALIZED   = 67108864i64; // Don't zero anonymous pages

// Convenience combinations used in libn
pub fixed int64:MAP_ANON_PRIV = 34i64;   // MAP_PRIVATE|MAP_ANONYMOUS — most common

// madvise hints (SYS_MADVISE arg3)
pub fixed int64:MADV_NORMAL      = 0i64;
pub fixed int64:MADV_RANDOM      = 1i64;
pub fixed int64:MADV_SEQUENTIAL  = 2i64;
pub fixed int64:MADV_WILLNEED    = 3i64;
pub fixed int64:MADV_DONTNEED    = 4i64;
pub fixed int64:MADV_FREE        = 8i64;
pub fixed int64:MADV_REMOVE      = 9i64;
pub fixed int64:MADV_MERGEABLE   = 12i64;
pub fixed int64:MADV_HUGEPAGE    = 14i64;
pub fixed int64:MADV_NOHUGEPAGE  = 15i64;
pub fixed int64:MADV_DONTDUMP    = 16i64;
pub fixed int64:MADV_DODUMP      = 17i64;
pub fixed int64:MADV_WIPEONFORK  = 18i64;
pub fixed int64:MADV_KEEPONFORK  = 19i64;
pub fixed int64:MADV_COLD        = 20i64;
pub fixed int64:MADV_PAGEOUT     = 21i64;
pub fixed int64:MADV_POPULATE_READ  = 22i64;
pub fixed int64:MADV_POPULATE_WRITE = 23i64;

// mremap flags
pub fixed int64:MREMAP_MAYMOVE   = 1i64;
pub fixed int64:MREMAP_FIXED     = 2i64;
pub fixed int64:MREMAP_DONTUNMAP = 4i64;

// ════════════════════════════════════════════════════════════════════════════
// SIGNAL NUMBERS  (signal.h — x86-64 Linux, same as POSIX)
// ════════════════════════════════════════════════════════════════════════════

pub fixed int64:SIGHUP    = 1i64;    // Hangup
pub fixed int64:SIGINT    = 2i64;    // Terminal interrupt (Ctrl+C)
pub fixed int64:SIGQUIT   = 3i64;    // Terminal quit (Ctrl+\)
pub fixed int64:SIGILL    = 4i64;    // Illegal instruction
pub fixed int64:SIGTRAP   = 5i64;    // Trace/breakpoint trap
pub fixed int64:SIGABRT   = 6i64;    // Abort signal
pub fixed int64:SIGBUS    = 7i64;    // Bus error (bad memory access)
pub fixed int64:SIGFPE    = 8i64;    // Floating-point exception
pub fixed int64:SIGKILL   = 9i64;    // Kill signal (cannot be caught)
pub fixed int64:SIGUSR1   = 10i64;   // User-defined signal 1
pub fixed int64:SIGSEGV   = 11i64;   // Segmentation fault
pub fixed int64:SIGUSR2   = 12i64;   // User-defined signal 2
pub fixed int64:SIGPIPE   = 13i64;   // Broken pipe
pub fixed int64:SIGALRM   = 14i64;   // Timer signal from alarm()
pub fixed int64:SIGTERM   = 15i64;   // Termination signal (graceful)
pub fixed int64:SIGSTKFLT = 16i64;   // Stack fault on coprocessor (unused)
pub fixed int64:SIGCHLD   = 17i64;   // Child stopped or terminated
pub fixed int64:SIGCONT   = 18i64;   // Continue if stopped
pub fixed int64:SIGSTOP   = 19i64;   // Stop process (cannot be caught)
pub fixed int64:SIGTSTP   = 20i64;   // Terminal stop (Ctrl+Z)
pub fixed int64:SIGTTIN   = 21i64;   // Background read from terminal
pub fixed int64:SIGTTOU   = 22i64;   // Background write to terminal
pub fixed int64:SIGURG    = 23i64;   // Urgent data on socket
pub fixed int64:SIGXCPU   = 24i64;   // CPU time limit exceeded
pub fixed int64:SIGXFSZ   = 25i64;   // File size limit exceeded
pub fixed int64:SIGVTALRM = 26i64;   // Virtual timer signal
pub fixed int64:SIGPROF   = 27i64;   // Profiling timer signal
pub fixed int64:SIGWINCH  = 28i64;   // Terminal window size change
pub fixed int64:SIGIO     = 29i64;   // I/O possible (async I/O)
pub fixed int64:SIGPOLL   = 29i64;   // Synonym for SIGIO
pub fixed int64:SIGPWR    = 30i64;   // Power failure restart
pub fixed int64:SIGSYS    = 31i64;   // Bad system call
pub fixed int64:SIGUNUSED = 31i64;   // Synonym for SIGSYS

// Real-time signals (POSIX 1003.1b)
pub fixed int64:SIGRTMIN  = 34i64;   // First real-time signal
pub fixed int64:SIGRTMAX  = 64i64;   // Last real-time signal

// sigaction SA_* flags
pub fixed int64:SA_NOCLDSTOP = 1i64;
pub fixed int64:SA_NOCLDWAIT = 2i64;
pub fixed int64:SA_SIGINFO   = 4i64;       // Handler receives siginfo_t
pub fixed int64:SA_RESTORER  = 67108864i64; // 0x4000000 — required on x86-64
pub fixed int64:SA_ONSTACK   = 134217728i64; // 0x8000000 — use alternate stack
pub fixed int64:SA_RESTART   = 268435456i64; // 0x10000000 — restart interrupted syscalls
pub fixed int64:SA_NODEFER   = 1073741824i64; // 0x40000000 — don't mask signal
pub fixed int64:SA_RESETHAND = -2147483648i64; // 0x80000000 — reset to SIG_DFL after

// Special handler values (stored as int64 function pointer slots)
pub fixed int64:SIG_DFL = 0i64;    // Default signal action
pub fixed int64:SIG_IGN = 1i64;    // Ignore signal
pub fixed int64:SIG_ERR = -1i64;   // Error from signal()

// sigprocmask how values
pub fixed int64:SIG_BLOCK   = 0i64;    // Block signals in set
pub fixed int64:SIG_UNBLOCK = 1i64;    // Unblock signals in set
pub fixed int64:SIG_SETMASK = 2i64;    // Set mask to set

