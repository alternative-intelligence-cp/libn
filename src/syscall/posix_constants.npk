// ════════════════════════════════════════════════════════════════════════════
// FCNTL COMMANDS  (fcntl.h F_* commands)
// ════════════════════════════════════════════════════════════════════════════

pub fixed int64:F_DUPFD         = 0i64;    // Duplicate file descriptor
pub fixed int64:F_GETFD         = 1i64;    // Get file descriptor flags
pub fixed int64:F_SETFD         = 2i64;    // Set file descriptor flags
pub fixed int64:F_GETFL         = 3i64;    // Get file status flags
pub fixed int64:F_SETFL         = 4i64;    // Set file status flags
pub fixed int64:F_GETLK         = 5i64;    // Get record locking info
pub fixed int64:F_SETLK         = 6i64;    // Set record locking info
pub fixed int64:F_SETLKW        = 7i64;    // Set record locking (blocking)
pub fixed int64:F_SETOWN        = 8i64;    // Set owner for SIGIO
pub fixed int64:F_GETOWN        = 9i64;    // Get owner for SIGIO
pub fixed int64:F_SETSIG        = 10i64;   // Set signal sent for I/O
pub fixed int64:F_GETSIG        = 11i64;   // Get signal sent for I/O
pub fixed int64:F_GETLK64       = 12i64;   // Get record locking info (64-bit)
pub fixed int64:F_SETLK64       = 13i64;   // Set record locking (64-bit)
pub fixed int64:F_SETLKW64      = 14i64;   // Set record locking (blocking, 64-bit)
pub fixed int64:F_SETOWN_EX     = 15i64;   // Set owner with struct
pub fixed int64:F_GETOWN_EX     = 16i64;   // Get owner with struct
pub fixed int64:F_GETOWNER_UIDS = 17i64;   // Get UIDs of signal receivers
pub fixed int64:F_OFD_GETLK     = 36i64;   // Open file description lock: get
