pub fixed int64:CLONE_PARENT_SETTID  = 1048576i64;     // 0x00100000 — Write tid to arg3
pub fixed int64:CLONE_CHILD_CLEARTID = 2097152i64;     // 0x00200000 — Clear tid on exit
