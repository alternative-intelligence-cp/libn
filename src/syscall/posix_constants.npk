// ════════════════════════════════════════════════════════════════════════════
// WAIT STATUS MACROS (as functions — sys/wait.h WIFEXITED etc.)
// ════════════════════════════════════════════════════════════════════════════

// These are used like: if wait_exited(status) { code = wait_exit_code(status); }
// status is the raw int32 returned by wait4/waitpid

pub fixed int64:WNOHANG    = 1i64;    // Don't block if no child has exited
pub fixed int64:WUNTRACED  = 2i64;    // Report stopped children
pub fixed int64:WCONTINUED = 8i64;    // Report continued children

