pub fixed int64:CLONE_UNTRACED       = 8388608i64;     // 0x00800000 — No forced ptrace
pub fixed int64:CLONE_CHILD_SETTID   = 16777216i64;    // 0x01000000 — Write tid to arg4
pub fixed int64:CLONE_NEWCGROUP      = 33554432i64;    // 0x02000000 — New cgroup ns
pub fixed int64:CLONE_NEWUTS         = 67108864i64;    // 0x04000000 — New UTS ns
