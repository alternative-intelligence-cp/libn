pub func:strbuf_appendf5 = int64(int64:sb, int64:fmt,
                                  int64:a0, int64:a1, int64:a2, int64:a3, int64:a4) {
    if sb == 0i64 { pass -1i64; }
    stack byte:tmp[4096];
    int64:tmp_ptr = &tmp[0] as int64;
    drop str_snprintf5(tmp_ptr, STRBUF_FMT_BUF, fmt, a0, a1, a2, a3, a4);
