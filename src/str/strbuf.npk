}

// ════════════════════════════════════════════════════════════════════════════
// Truncation and trimming
// ════════════════════════════════════════════════════════════════════════════

// strbuf_truncate — Shorten the content to at most n bytes.
// No-op if n >= current len.
pub func:strbuf_truncate = void(int64:sb, int64:n) {
    if sb == 0i64 { pass; }
    *StrBuf:s = sb as *StrBuf;
    if n >= s.len { pass; }
    if n < 0i64 { n = 0i64; }
    s.len = n;
    (s.ptr as *byte)[s.len] = 0u8;
}

// strbuf_strip_trailing_newline — Remove a trailing '\n' (and optional '\r').
// Useful for cleaning up line-read output.
pub func:strbuf_strip_trailing_newline = void(int64:sb) {
    if sb == 0i64 { pass; }
    *StrBuf:s = sb as *StrBuf;
    *byte:p = s.ptr as *byte;
    if s.len > 0i64 && p[s.len - 1i64] == 10u8 {   // '\n'
        s.len = s.len - 1i64;
        p[s.len] = 0u8;
    }
    if s.len > 0i64 && p[s.len - 1i64] == 13u8 {   // '\r'
        s.len = s.len - 1i64;
        p[s.len] = 0u8;
    }
}

// ════════════════════════════════════════════════════════════════════════════
// I/O integration
// ════════════════════════════════════════════════════════════════════════════

// strbuf_write_to_fd — Write the buffer content to a raw file descriptor.
// Uses libn_write_all for reliable full-write behavior.
// Returns number of bytes written, or -1 on error.
pub func:strbuf_write_to_fd = int64(int64:sb, int64:fd) {
    if sb == 0i64 { pass 0i64; }
    *StrBuf:s = sb as *StrBuf;
    if s.len == 0i64 { pass 0i64; }
    Result<int64>:r = libn_write_all(fd, s.ptr, s.len);
    if r.is_error { pass -1i64; }
    pass r.value;
}
