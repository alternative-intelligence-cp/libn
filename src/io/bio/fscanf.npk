    argv[0] = a0; argv[1] = a1; argv[2] = a2; argv[3] = a3;
    argv[4] = a4; argv[5] = a5; argv[6] = a6; argv[7] = a7;
    src[0] = SCAN_SRC_STRING; src[1] = str; src[2] = 0i64;
    pass bio_scan_engine(&src[0] as int64, fmt, &argv[0] as int64, 8i64);
}

