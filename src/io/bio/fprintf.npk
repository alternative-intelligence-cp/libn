pub func:asprintf4 = int64(int64:out_len, int64:fmt,
                           int64:a0, int64:a1, int64:a2, int64:a3) {
    Result<int64>:len_res = str_snprintf4(0i64, 0i64, fmt, a0, a1, a2, a3);
