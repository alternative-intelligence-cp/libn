// ════════════════════════════════════════════════════════════════════════════
// asprintf — Render into a heap-allocated buffer, sized to fit the output.
//
// Unlike sprintf/snprintf, asprintf does not require the caller to pre-size a
// buffer. It renders into the 4096-uint8 stack buffer first; if the output fits,
// it allocates exactly (len+1) bytes and copies. If the format output exceeds
// 4095 bytes, the result is truncated (@cast_unchecked<snprintf>(same) — a known limitation
// lifted in v0.7.x when the growable buffer is introduced).
//
// Returns a heap pointer (as int64) that the caller must free with mem_free().
// Writes the string length (without NUL) to *out_len if out_len != 0.
// Returns 0 on allocation failure.
// ════════════════════════════════════════════════════════════════════════════

pub func:asprintf0 = int64(int64:out_len, int64:fmt) {
    Result<int64>:len_res = str_snprintf0(0i64, 0i64, fmt);
    if (len_res.is_error) { pass -1i64; }
    int64:len = len_res.value;
    int64:p = raw mem_malloc(len + 1i64);
    if (p == 0i64) { pass 0i64; }
    drop(str_snprintf0(p, len + 1i64, fmt));
    if (out_len != 0i64) { (@cast_unchecked<int64->>(out_len))[0] = len; }
    pass p;
};

pub func:asprintf1 = int64(int64:out_len, int64:fmt, int64:a0) {
    Result<int64>:len_res = str_snprintf1(0i64, 0i64, fmt, a0);
    if (len_res.is_error) { pass -1i64; }
    int64:len = len_res.value;
    int64:p = raw mem_malloc(len + 1i64);
    if (p == 0i64) { pass 0i64; }
    drop(str_snprintf1(p, len + 1i64, fmt, a0));
    if (out_len != 0i64) { (@cast_unchecked<int64->>(out_len))[0] = len; }
    pass p;
};

