// ════════════════════════════════════════════════════════════════════════════
// io_dprintf* — Linux-style "dprintf" (@cast_unchecked<fprintf>(same), different name).
//
// Provided so code ported from Linux can use the familiar name.
// ════════════════════════════════════════════════════════════════════════════

pub func:io_dprintf0 = int64(int64:fd, int64:fmt) {
    pass io_fprintf0(fd, fmt);
};

pub func:io_dprintf1 = int64(int64:fd, int64:fmt, int64:a0) {
    pass io_fprintf1(fd, fmt, a0);
};

pub func:io_dprintf2 = int64(int64:fd, int64:fmt, int64:a0, int64:a1) {
    pass io_fprintf2(fd, fmt, a0, a1);
};

