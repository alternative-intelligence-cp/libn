    pass io_fprintf3(fd, fmt, a0, a1, a2);
};

// ════════════════════════════════════════════════════════════════════════════
// io_sprintf* — Render to a caller-supplied buffer (thin wrappers on strfmt).
//
// These are provided for completeness / naming consistency. For most uses,
// call str_snprintfN directly.
// ════════════════════════════════════════════════════════════════════════════

pub func:io_sprintf0 = int64(int64:buf, int64:buf_size, int64:fmt) {
    pass str_snprintf0(buf, buf_size, fmt);
};

pub func:io_sprintf1 = int64(int64:buf, int64:buf_size, int64:fmt, int64:a0) {
    pass raw str_snprintf1(buf, buf_size, fmt, a0);
};

pub func:io_sprintf2 = int64(int64:buf, int64:buf_size, int64:fmt, int64:a0, int64:a1) {
    pass str_snprintf2(buf, buf_size, fmt, a0, a1);
};

