// syscall_numbers.npk — Complete Linux x86-64 syscall number table
//
// This is the authoritative syscall number reference for libn on x86-64.
// All numbers are from the Linux kernel source: arch/x86/entry/syscalls/syscall_64.tbl
// Verified against Linux 6.x.
//
// Usage:
//   use "../syscall/syscall_numbers.npk".*;
//   int64:fd = sys(SYS_OPEN, path, flags, mode);
//
// Syscall tiers in Nitpick:
//   sys(N, ...)    — safe tier (~55 whitelisted), returns Result<int64>
//   sys!!(N, ...)  — full tier (all syscalls), returns Result<int64>
//   sys!!!(N, ...) — raw tier (bare int64, no Result wrapping)

