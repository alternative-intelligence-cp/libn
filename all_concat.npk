pub func:io_printf3 = int64(int64:fmt, int64:a0, int64:a1, int64:a2) {
    pass io_fprintf3(STDOUT_FD, fmt, a0, a1, a2);
};

pub func:io_eprintf3 = int64(int64:fmt, int64:a0, int64:a1, int64:a2) {
