// ════════════════════════════════════════════════════════════════════════════
// io_perror — Print "prefix: error message\n" to stderr.
//
// Analogous to C's perror(). Uses the errno value stored in the global
// errno cell. Translates to a human-readable string via err_name().
//
// Example:
//   io_perror("open");   // prints: "open: No such file or directory\n"
// ════════════════════════════════════════════════════════════════════════════

pub func:io_perror = int64(int64:prefix) {
      // Print: "prefix: errno_string\n"
      // We compose this with two writes to avoid needing a format arg for the prefix.
    if (prefix != 0i64) {
        int64:r = raw io_write_str(STDERR_FD, prefix);
        if (r < 0i64) { pass r; }
        int64:colon_space = @cast_unchecked<int64>(@": ");
        int64:r2 = raw io_write_str(STDERR_FD, colon_space);
        if (r2 < 0i64) { pass r2; }
    }
      // errno is the global set by the last failing syscall
      // We use libn errno literal name @cast_unchecked<a>((e.g., "ENOENT")) proxy
      // for the human-readable message until a strerror() table exists (v0.4.5).
      // For now, print the numeric errno @cast_unchecked<a>(value) placeholder.
    stack uint8[32]:num_buf;
    int64:e = @cast_unchecked<int64>(libn_errno);
      // render decimal errno value
    int64:i = 31i64;
    (@cast_unchecked<uint8->>(@num_buf))[i] = 0u8;
    i = i - 1i64;
    if (e <= 0i64) {
        (@cast_unchecked<uint8->>(@num_buf))[i] = 48u8;    // '0'
        i = i - 1i64;
    } else {
        int64:v = e;
        while (v > 0i64) {
            (@cast_unchecked<uint8->>(@num_buf))[i] = @cast_unchecked<uint8>((48i64 + (v % 10i64)));
            v = v / 10i64;
            i = i - 1i64;
        }
    }
    int64:num_start = (@cast_unchecked<int64>(@num_buf)) + i + 1i64;
    Result<int64>:r3 = io_write_str(STDERR_FD, num_start);
    if (r3.is_error) { return r3; }
    pass io_write_newline(STDERR_FD);
};

// strerror.npk — errno to human-readable string table (v0.6.1)
//
// Provides strerror(), strerror_r(), and perror() — the standard way to
// convert an errno value into a descriptive message string.
//
// This replaces the placeholder numeric-errno output in io_perror() (printf.npk)
// with actual POSIX error strings.
//
// Implementation:
//   Linear scan through a static table of (errno_value, string) pairs.
//   For the ~130 errno values in Linux x86-64, a linear scan is fast enough.
//   A hash table or perfect hash is planned for v0.18.x if profiling warrants.
//
// Error strings match glibc strerror() text exactly, enabling cross-platform
// output compatibility (test output, log correlation, etc.).
//
// strerror(0) returns "Success" (POSIX: undefined, but glibc returns "Success").
// strerror(unknown) returns "Unknown error N".

use "../../mem/mmap.npk".*;
use "../../syscall/syscall_numbers.npk".*;
use "../../syscall/syscall.npk".*;
use "../../syscall/errno.npk".*;
use "../../str/strlen.npk".*;
use "../../str/strconv.npk".*;
use "../../mem/memcpy.npk".*;
use "../../io/bio/file.npk".*;
use "../../io/bio/fio.npk".*;
use "../../io/bio/fchar.npk".*;
use "../../io/bio/fstr.npk".*;
use "../../io/bio/stdfiles.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// Internal errno string table
//
// Format: interleaved int64/string pairs in a flat array.
// Each entry is: [errno_number_as_int64][NUL-terminated string pointer].
// Terminated by an entry with errno_number = -1.
//
// In Nitpick, string literals are NUL-terminated uint8 sequences with a fixed
// address. We build the @cast_unchecked<a>(table) struct-array for clarity.
//
// Note: strings are @cast_unchecked<compile>(stored)-time constants in the binary's read-only
// data section. No heap allocation.
// ════════════════════════════════════════════════════════════════════════════

struct:ErrEntry = {
    int64:code;
    int64:msg;      // pointer to string literal
};

// The table. strerror() does a linear scan.
// Coverage: all POSIX-required errnos + common Linux extensions.
// Source: Linux man-pages errno(3), glibc strerror() text.

fixed int64[135]:errno_table = [
    @cast_unchecked<int64>(@"Success"),
    @cast_unchecked<int64>(@"Operation not permitted"),
    @cast_unchecked<int64>(@"No such file or directory"),
    @cast_unchecked<int64>(@"No such process"),
    @cast_unchecked<int64>(@"Interrupted system call"),
    @cast_unchecked<int64>(@"Input/output error"),
    @cast_unchecked<int64>(@"No such device or address"),
    @cast_unchecked<int64>(@"Argument list too long"),
    @cast_unchecked<int64>(@"Exec format error"),
    @cast_unchecked<int64>(@"Bad file descriptor"),
    @cast_unchecked<int64>(@"No child processes"),
    @cast_unchecked<int64>(@"Resource temporarily unavailable"),
    @cast_unchecked<int64>(@"Cannot allocate memory"),
    @cast_unchecked<int64>(@"Permission denied"),
    @cast_unchecked<int64>(@"Bad address"),
    @cast_unchecked<int64>(@"Block device required"),
    @cast_unchecked<int64>(@"Device or resource busy"),
    @cast_unchecked<int64>(@"File exists"),
    @cast_unchecked<int64>(@"Invalid cross-device link"),
    @cast_unchecked<int64>(@"No such device"),
    @cast_unchecked<int64>(@"Not a directory"),
    @cast_unchecked<int64>(@"Is a directory"),
    @cast_unchecked<int64>(@"Invalid argument"),
    @cast_unchecked<int64>(@"Too many open files in system"),
    @cast_unchecked<int64>(@"Too many open files"),
    @cast_unchecked<int64>(@"Inappropriate ioctl for device"),
    @cast_unchecked<int64>(@"Text file busy"),
    @cast_unchecked<int64>(@"File too large"),
    @cast_unchecked<int64>(@"No space left on device"),
    @cast_unchecked<int64>(@"Illegal seek"),
    @cast_unchecked<int64>(@"Read-only file system"),
    @cast_unchecked<int64>(@"Too many links"),
    @cast_unchecked<int64>(@"Broken pipe"),
    @cast_unchecked<int64>(@"Numerical argument out of domain"),
    @cast_unchecked<int64>(@"Numerical result out of range"),
    @cast_unchecked<int64>(@"Resource deadlock avoided"),
    @cast_unchecked<int64>(@"File name too long"),
    @cast_unchecked<int64>(@"No locks available"),
    @cast_unchecked<int64>(@"Function not implemented"),
    @cast_unchecked<int64>(@"Directory not empty"),
    @cast_unchecked<int64>(@"Too many levels of symbolic links"),
    0i64,
    @cast_unchecked<int64>(@"No message of desired type"),
    @cast_unchecked<int64>(@"Identifier removed"),
    0i64,
    0i64,
    0i64,
    0i64,
    0i64,
    0i64,
    0i64,
    0i64,
    0i64,
    0i64,
    0i64,
    0i64,
    0i64,
    0i64,
    0i64,
    0i64,
    0i64,
    @cast_unchecked<int64>(@"No data available"),
    @cast_unchecked<int64>(@"Timer expired"),
    @cast_unchecked<int64>(@"Out of streams resources"),
    0i64,
    0i64,
    0i64,
    @cast_unchecked<int64>(@"Link has been severed"),
    0i64,
    0i64,
    0i64,
    @cast_unchecked<int64>(@"Protocol error"),
    @cast_unchecked<int64>(@"Multihop attempted"),
    0i64,
    @cast_unchecked<int64>(@"Bad message"),
    @cast_unchecked<int64>(@"Value too large for defined data type"),
    0i64,
    0i64,
    0i64,
    0i64,
    0i64,
    0i64,
    0i64,
    0i64,
    @cast_unchecked<int64>(@"Invalid or incomplete multibyte or wide character"),
    0i64,
