// ════════════════════════════════════════════════════════════════════════════
// libn_err TYPE
//
// All pub functions in libn return Result<T> where the error field is a tbb8
// (6-bit tag uint8). The errno value is stored @cast_unchecked<the>(directly) tag.
// This allows Result<int64>{err: @cast_unchecked<tbb8>(ENOENT), ...} patterns.
//
// For values > 127 (EOWNERDEAD, ENOTRECOVERABLE, ERFKILL, EHWPOISON),
// the err field is clamped — these are rare and callers must use the full
// errno path if precision is needed.
//
// Error propagation convention:
//   pass result_value       — success path, sets is_error=false
//   fail ENOENT             — error path, sets is_error=true, err=@cast_unchecked<tbb8>(ENOENT)
//   fail ERR_OVERFLOW       — error path with a libn internal error code
//
// libn internal error codes (outside POSIX range, high values):
//   ERR_OVERFLOW   — integer overflow / result doesn't fit in return type
//   ERR_BADARG     — bad argument (NULL pointer, zero length, etc.)
//   ERR_INTERNAL   — internal libn bug (assert-failed state)
//   ERR_UNSUPPORTED — operation not supported on this architecture
// ════════════════════════════════════════════════════════════════════════════

pub fixed int64:ERR_OVERFLOW    = -10i64;    // libn: integer overflow
pub fixed int64:ERR_BADARG      = -11i64;    // libn: bad argument
pub fixed int64:ERR_EOF         = -12i64;    // libn: unexpected EOF
pub fixed int64:ERR_INTERNAL    = -13i64;    // libn: internal error
pub fixed int64:ERR_UNSUPPORTED = -14i64;    // libn: unsupported on this arch
pub fixed int64:ERR_TRUNCATED   = -15i64;    // libn: result was truncated (snprintf)
pub fixed int64:ERR_NOTFOUND    = -16i64;    // libn: not found (different from ENOENT)
pub fixed int64:ERR_AGAIN       = -17i64;    // libn: try again (non-blocking, maps to EAGAIN)

// ════════════════════════════════════════════════════════════════════════════
// CORE ERROR FUNCTIONS
//
// These are the building blocks of libn error propagation.
// Every module uses err_from_syscall() to wrap raw syscall returns.
// ════════════════════════════════════════════════════════════════════════════

// err_from_syscall — Convert a raw syscall return value to Result<int64>.
//
// Linux syscall ABI: on error, returns -errno (negative errno code).
// On success, returns a non-negative value (fd, uint8 count, 0, etc.).
//
// This function is the single canonical conversion point. All libn wrappers
// for SYS_* calls MUST use this (or inline the same logic via fail/pass).
pub func:err_from_syscall = int64(int64:ret) {
    if (ret >= 0i64) {
        pass ret;
    }
      // Negate to get the positive errno code
    int64:e = 0i64 - ret;
      // Clamp to known range (defensive: kernel shouldn't give us > 133 but guard anyway)
    if (e < 1i64 || e > ERRNO_MAX) {
        fail @cast_unchecked<tbb32>(ERR_INTERNAL);
    }
    fail @cast_unchecked<tbb32>(e);
};

// errno_is_retriable — Returns true if the error code means "try again later".
// Used to implement retry loops around non-blocking I/O and signal-interrupted calls.
//
// The two canonical retriable errors:
//   EINTR  — syscall interrupted by a signal; restart the syscall
//   EAGAIN — resource not available right now; wait and retry
//   EWOULDBLOCK — synonym for EAGAIN on Linux (same value: 11)
pub func:errno_is_retriable = bool(int64:e) {
    pass e == EINTR || e == EAGAIN;
};

// errno_is_fatal — Returns true if the error is unrecoverable regardless of retries.
// Useful for fast-fail logic in I/O loops.
pub func:errno_is_fatal = bool(int64:e) {
    pass e == EBADF   ||
         e == EINVAL  ||
         e == ENOTSOCK ||
         e == ENOMEM  ||
         e == EFAULT;
};

// err_str — Returns a static string describing the errno code.
// NO allocation. The returned pointer is to a string literal in BSS.
// NOT thread-safe in the sense that different errno values return different literals,
// but each literal is immutable so concurrent reads are safe.
//
// For errno values outside [0, ERRNO_MAX], returns "Unknown error".
pub func:err_str = int64(int64:e) {
      // The compiler will generate a jump table for this pick.
    pick (e) {
        (0i64) { pass @cast_unchecked<int64>(@"Success"); },
        (1i64) { pass @cast_unchecked<int64>(@"Operation not permitted"); },
        (2i64) { pass @cast_unchecked<int64>(@"No such file or directory"); },
        (3i64) { pass @cast_unchecked<int64>(@"No such process"); },
        (4i64) { pass @cast_unchecked<int64>(@"Interrupted system call"); },
        (5i64) { pass @cast_unchecked<int64>(@"Input/output error"); },
        (6i64) { pass @cast_unchecked<int64>(@"No such device or address"); },
        (7i64) { pass @cast_unchecked<int64>(@"Argument list too long"); },
        (8i64) { pass @cast_unchecked<int64>(@"Exec format error"); },
        (9i64) { pass @cast_unchecked<int64>(@"Bad file descriptor"); },
        (10i64) { pass @cast_unchecked<int64>(@"No child processes"); },
        (11i64) { pass @cast_unchecked<int64>(@"Resource temporarily unavailable"); },
        (12i64) { pass @cast_unchecked<int64>(@"Out of memory"); },
        (13i64) { pass @cast_unchecked<int64>(@"Permission denied"); },
        (14i64) { pass @cast_unchecked<int64>(@"Bad address"); },
        (15i64) { pass @cast_unchecked<int64>(@"Block device required"); },
        (16i64) { pass @cast_unchecked<int64>(@"Device or resource busy"); },
        (17i64) { pass @cast_unchecked<int64>(@"File exists"); },
        (18i64) { pass @cast_unchecked<int64>(@"Cross-device link"); },
        (19i64) { pass @cast_unchecked<int64>(@"No such device"); },
        (20i64) { pass @cast_unchecked<int64>(@"Not a directory"); },
        (21i64) { pass @cast_unchecked<int64>(@"Is a directory"); },
        (22i64) { pass @cast_unchecked<int64>(@"Invalid argument"); },
        (23i64) { pass @cast_unchecked<int64>(@"Too many open files in system"); },
        (24i64) { pass @cast_unchecked<int64>(@"Too many open files"); },
        (25i64) { pass @cast_unchecked<int64>(@"Inappropriate ioctl for device"); },
        (26i64) { pass @cast_unchecked<int64>(@"Text file busy"); },
        (27i64) { pass @cast_unchecked<int64>(@"File too large"); },
        (28i64) { pass @cast_unchecked<int64>(@"No space left on device"); },
        (29i64) { pass @cast_unchecked<int64>(@"Illegal seek"); },
        (30i64) { pass @cast_unchecked<int64>(@"Read-only file system"); },
        (31i64) { pass @cast_unchecked<int64>(@"Too many links"); },
        (32i64) { pass @cast_unchecked<int64>(@"Broken pipe"); },
        (33i64) { pass @cast_unchecked<int64>(@"Numerical argument out of domain"); },
        (34i64) { pass @cast_unchecked<int64>(@"Numerical result out of range"); },
        (35i64) { pass @cast_unchecked<int64>(@"Resource deadlock avoided"); },
        (36i64) { pass @cast_unchecked<int64>(@"File name too long"); },
        (37i64) { pass @cast_unchecked<int64>(@"No locks available"); },
        (38i64) { pass @cast_unchecked<int64>(@"Function not implemented"); },
        (39i64) { pass @cast_unchecked<int64>(@"Directory not empty"); },
        (40i64) { pass @cast_unchecked<int64>(@"Too many levels of symbolic links"); },
        (42i64) { pass @cast_unchecked<int64>(@"No message of desired type"); },
        (43i64) { pass @cast_unchecked<int64>(@"Identifier removed"); },
        (60i64) { pass @cast_unchecked<int64>(@"Device not a stream"); },
        (61i64) { pass @cast_unchecked<int64>(@"No data available"); },
        (62i64) { pass @cast_unchecked<int64>(@"Timer expired"); },
        (63i64) { pass @cast_unchecked<int64>(@"Out of streams resources"); },
        (71i64) { pass @cast_unchecked<int64>(@"Protocol error"); },
        (74i64) { pass @cast_unchecked<int64>(@"Bad message"); },
        (75i64) { pass @cast_unchecked<int64>(@"Value too large for defined data type"); },
        (84i64) { pass @cast_unchecked<int64>(@"Invalid or incomplete multibyte character"); },
        (88i64) { pass @cast_unchecked<int64>(@"Socket operation on non-socket"); },
        (89i64) { pass @cast_unchecked<int64>(@"Destination address required"); },
        (90i64) { pass @cast_unchecked<int64>(@"Message too long"); },
        (91i64) { pass @cast_unchecked<int64>(@"Protocol wrong type for socket"); },
        (92i64) { pass @cast_unchecked<int64>(@"Protocol not available"); },
        (93i64) { pass @cast_unchecked<int64>(@"Protocol not supported"); },
        (94i64) { pass @cast_unchecked<int64>(@"Socket type not supported"); },
        (95i64) { pass @cast_unchecked<int64>(@"Operation not supported"); },
        (96i64) { pass @cast_unchecked<int64>(@"Protocol family not supported"); },
        (97i64) { pass @cast_unchecked<int64>(@"Address family not supported by protocol"); },
        (98i64) { pass @cast_unchecked<int64>(@"Address already in use"); },
        (99i64) { pass @cast_unchecked<int64>(@"Cannot assign requested address"); },
        (100i64) { pass @cast_unchecked<int64>(@"Network is down"); },
        (101i64) { pass @cast_unchecked<int64>(@"Network is unreachable"); },
        (102i64) { pass @cast_unchecked<int64>(@"Network dropped connection on reset"); },
        (103i64) { pass @cast_unchecked<int64>(@"Software caused connection abort"); },
        (104i64) { pass @cast_unchecked<int64>(@"Connection reset by peer"); },
        (105i64) { pass @cast_unchecked<int64>(@"No buffer space available"); },
        (106i64) { pass @cast_unchecked<int64>(@"Transport endpoint already connected"); },
        (107i64) { pass @cast_unchecked<int64>(@"Transport endpoint not connected"); },
        (108i64) { pass @cast_unchecked<int64>(@"Cannot send after transport endpoint shutdown"); },
        (110i64) { pass @cast_unchecked<int64>(@"Connection timed out"); },
        (111i64) { pass @cast_unchecked<int64>(@"Connection refused"); },
        (112i64) { pass @cast_unchecked<int64>(@"Host is down"); },
        (113i64) { pass @cast_unchecked<int64>(@"No route to host"); },
        (114i64) { pass @cast_unchecked<int64>(@"Operation already in progress"); },
        (115i64) { pass @cast_unchecked<int64>(@"Operation now in progress"); },
        (116i64) { pass @cast_unchecked<int64>(@"Stale file handle"); },
        (122i64) { pass @cast_unchecked<int64>(@"Disk quota exceeded"); },
        (125i64) { pass @cast_unchecked<int64>(@"Operation canceled"); },
        (130i64) { pass @cast_unchecked<int64>(@"Owner died"); },
        (131i64) { pass @cast_unchecked<int64>(@"State not recoverable"); },
          // libn internal error codes
        (-10i64) { pass @cast_unchecked<int64>(@"libn: integer overflow"); },
        (-11i64) { pass @cast_unchecked<int64>(@"libn: bad argument"); },
        (-12i64) { pass @cast_unchecked<int64>(@"libn: unexpected EOF"); },
        (-13i64) { pass @cast_unchecked<int64>(@"libn: internal error"); },
        (-14i64) { pass @cast_unchecked<int64>(@"libn: unsupported operation"); },
        (-15i64) { pass @cast_unchecked<int64>(@"libn: result truncated"); },
        (-16i64) { pass @cast_unchecked<int64>(@"libn: not found"); },
        (-17i64) { pass @cast_unchecked<int64>(@"libn: try again"); },
        (*) { pass @cast_unchecked<int64>(@"Unknown error"); }
    }
};

// ════════════════════════════════════════════════════════════════════════════
// LIBN_ERRNO — Process-global errno store (pre-TLS placeholder)
//
// In v0.13.6, this will become a TLS-backed variable accessed via FS:[offset].
// Until then, it is a module-level mutable integer representing the last error
// seen by the calling thread.
//
// DO NOT use this directly in new code — always propagate via Result<T>.
// It exists only for compatibility with legacy C-style errno checks.
// ════════════════════════════════════════════════════════════════════════════

pub int64:libn_errno = 0i64;

// libn_errno_set — Store a raw errno code (called by sys wrappers on error).
// This will be replaced by a TLS write in v0.13.6.
pub func:libn_errno_set = NIL(int64:e) {
    libn_errno = e;
};

pub func:errno_set = NIL(int64:e) {
    libn_errno = e;
};

// libn_errno_get — Read the stored errno code.
// Returns the raw int64 errno value (positive, per POSIX convention).
pub func:libn_errno_get = int64() {
    pass libn_errno;
};

// void_result — Internal helper: returns a void-shaped Result.
// Used to satisfy the Result<T> return discipline where a function is truly void.
func:void_result = int64() {
    pass 0i64;
};

// errno_clear — Clear the error code
pub func:errno_clear = NIL() { drop(libn_errno_set(0i64)); };

// syscall.npk — Safe and full syscall wrappers for libn (v0.1.3 / v0.1.4)
//
// This module is the heart of libn's kernel interface. It provides three tiers:
//
//   sys_safe(nr, ...)    — whitelisted set of ~55 "safe" syscalls. Always returns
//                          Result<int64>. The whitelist excludes dangerous ops like
//                          write to arbitrary fds, exec, clone, etc.
//
//   sys_full(nr, ...)    — all syscalls, returns Result<int64>. For calls that
//                          are dangerous or require careful use (fork, clone, exec,
//                          mprotect with PROT_EXEC, etc.). Callers must justify use.
//
//   sys_raw(nr, ...)     — bare int64 return, no Result wrapping, no error checking.
//                          Only for: _start (before Result machinery is initialized),
//                          exit_group (doesn't return), and assembly trampolines.
//
// All three tiers call into the Nitpick sys() / sys!!() / sys!!!() builtins.
// The distinction is documentation + compile-time audit surface, not runtime overhead.
//
// Syscall argument convention (x86-64 Linux):
//   rdi=arg1, rsi=arg2, rdx=arg3, r10=arg4, r8=arg5, r9=arg6
//   rax=syscall number (input) and return value (output)
//
// Note on argument counts:
//   Nitpick's sys() accepts up to 6 arguments after the syscall number.
//   Unused arguments MUST be @cast_unchecked<0i64>(passed) (not omitted) to avoid ABI issues.
//
// Usage:
//   use "../syscall/syscall.npk".*;
//   use "../syscall/syscall_numbers.npk".*;
//   use "../syscall/errno.npk".*;
//
//   // Open a file:
//   Result<int64>:r = sys_safe(SYS_READ, fd, buf_ptr, nbytes, 0i64, 0i64, 0i64);
//   if r.is_error { fail r.error; }
//   int64:nread = r.value;
//
//   // Exit (doesn't return — use sys_raw):
//   sys_raw(SYS_EXIT_GROUP, code, 0i64, 0i64, 0i64, 0i64, 0i64);

use "../syscall/syscall_numbers.npk".*;
use "../syscall/errno.npk".*;
use "../syscall/posix_constants.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// TIER 1: sys_safe — Whitelisted safe syscalls
//
// These are syscalls that:
//   1. Have bounded, reversible effects
//   2. Cannot directly corrupt process state or other processes
//   3. Are safe to call from any context without special precautions
//
// The whitelist exists @cast_unchecked<a>(not) security boundary @cast_unchecked<an>(but) API quality signal:
// if your code needs sys_full(), you should stop and think about whether you
// really need that power and whether you've handled all failure modes.
// ════════════════════════════════════════════════════════════════════════════

// Safe syscall whitelist (compile-time check in future; for now: documentation).
// nr must be one of: SYS_READ, SYS_WRITE (to known fds), SYS_OPEN, SYS_CLOSE,
//   SYS_STAT, SYS_FSTAT, SYS_LSTAT, SYS_LSEEK, SYS_MMAP, SYS_MUNMAP,
//   SYS_MPROTECT (no PROT_EXEC), SYS_MADVISE, SYS_BRK, SYS_MREMAP,
//   SYS_DUP, SYS_DUP2, SYS_DUP3, SYS_PIPE, SYS_PIPE2,
//   SYS_FCNTL (F_GETFL, F_SETFL, F_GETFD, F_SETFD, F_DUPFD, F_DUPFD_CLOEXEC),
//   SYS_IOCTL (safe subset: TIOCGWINSZ, FIONREAD),
//   SYS_GETPID, SYS_GETPPID, SYS_GETTID, SYS_GETUID, SYS_GETGID,
//   SYS_GETEUID, SYS_GETEGID,
//   SYS_CLOCK_GETTIME, SYS_CLOCK_GETRES, SYS_GETTIMEOFDAY,
//   SYS_NANOSLEEP, SYS_SCHED_YIELD,
//   SYS_OPENAT, SYS_NEWFSTATAT, SYS_UNLINKAT, SYS_MKDIRAT,
//   SYS_GETDENTS64, SYS_GETCWD, SYS_READLINKAT,
//   SYS_STATX, SYS_GETRANDOM,
//   SYS_FUTEX (FUTEX_WAIT, FUTEX_WAKE, FUTEX_WAIT_PRIVATE, FUTEX_WAKE_PRIVATE),
//   SYS_SET_TID_ADDRESS, SYS_SCHED_GETAFFINITY

pub func:sys_safe = int64(int64:nr, int64:a1, int64:a2, int64:a3, int64:a4, int64:a5, int64:a6) {
    int64:ret = sys!!!(nr, a1, a2, a3, a4, a5, a6);
    return err_from_syscall(ret);
};

// Convenience overloads for common arities (avoid callers having to pad with 0i64).
// These exist because Nitpick does not yet support default arguments.

pub func:sys1 = int64(int64:nr, int64:a1) {
    return sys_safe(nr, a1, 0i64, 0i64, 0i64, 0i64, 0i64);
};

pub func:sys2 = int64(int64:nr, int64:a1, int64:a2) {
    return sys_safe(nr, a1, a2, 0i64, 0i64, 0i64, 0i64);
};

pub func:sys3 = int64(int64:nr, int64:a1, int64:a2, int64:a3) {
    return sys_safe(nr, a1, a2, a3, 0i64, 0i64, 0i64);
};

pub func:sys4 = int64(int64:nr, int64:a1, int64:a2, int64:a3, int64:a4) {
    return sys_safe(nr, a1, a2, a3, a4, 0i64, 0i64);
};

pub func:sys5 = int64(int64:nr, int64:a1, int64:a2, int64:a3, int64:a4, int64:a5) {
    return sys_safe(nr, a1, a2, a3, a4, a5, 0i64);
};

// ════════════════════════════════════════════════════════════════════════════
// TIER 2: sys_full — All syscalls, dangerous operations included
//
// Use for: fork, clone, execve, mprotect(PROT_EXEC), kill, arch_prctl,
//          set_tid_address, seccomp, prctl, etc.
//
// Every call site using sys_full MUST have a comment explaining WHY it needs
// the full tier and not sys_safe. This is enforced by code review, not by
// the compiler (yet — v0.50.x will add compile-time audit annotations).
// ════════════════════════════════════════════════════════════════════════════

pub func:sys_full = int64(int64:nr, int64:a1, int64:a2, int64:a3, int64:a4, int64:a5, int64:a6) {
    int64:ret = sys!!!(nr, a1, a2, a3, a4, a5, a6);
    return err_from_syscall(ret);
};

pub func:sys_full1 = int64(int64:nr, int64:a1) {
    return sys_full(nr, a1, 0i64, 0i64, 0i64, 0i64, 0i64);
};

pub func:sys_full2 = int64(int64:nr, int64:a1, int64:a2) {
    return sys_full(nr, a1, a2, 0i64, 0i64, 0i64, 0i64);
};

pub func:sys_full3 = int64(int64:nr, int64:a1, int64:a2, int64:a3) {
    return sys_full(nr, a1, a2, a3, 0i64, 0i64, 0i64);
};

pub func:sys_full4 = int64(int64:nr, int64:a1, int64:a2, int64:a3, int64:a4) {
    return sys_full(nr, a1, a2, a3, a4, 0i64, 0i64);
};

pub func:sys_full5 = int64(int64:nr, int64:a1, int64:a2, int64:a3, int64:a4, int64:a5) {
    return sys_full(nr, a1, a2, a3, a4, a5, 0i64);
};

// ════════════════════════════════════════════════════════════════════════════
// TIER 3: sys_raw — Bare int64 return, no Result wrapping
//
// The only valid uses:
//   1. _start entry point (Result machinery not yet initialized)
//   2. SYS_EXIT / SYS_EXIT_GROUP (these never return, Result is meaningless)
//   3. Assembly trampolines that need the raw ABI value (clone child side)
//
// All other uses of sys_raw are bugs. Code review will reject them.
// ════════════════════════════════════════════════════════════════════════════

pub func:sys_raw = int64(int64:nr, int64:a1, int64:a2, int64:a3, int64:a4, int64:a5, int64:a6) {
      // sys!!!() is the Nitpick bare syscall — returns int64 directly.
    int64:ret = sys!!!(nr, a1, a2, a3, a4, a5, a6);
    pass ret;
};

// ════════════════════════════════════════════════════════════════════════════
// HIGH-LEVEL WRAPPER FAMILY: Specific safe wrappers for the most common calls
//
// These wrappers provide a typed, self-documenting API over the raw syscall tier.
// They are the primary API surface used by higher-level libn modules (mem, str,
// io, proc, etc.). They handle:
//   - Correct argument casting (pointer → int64 where needed)
//   - EINTR retry where appropriate
//   - Sane defaults (e.g., O_CLOEXEC always set on new fds)
// ════════════════════════════════════════════════════════════════════════════

// ── Process identity ────────────────────────────────────────────────

pub func:libn_getpid = int64() {
    pass raw sys1(SYS_GETPID, 0i64);
};

pub func:libn_getppid = int64() {
    pass raw sys1(SYS_GETPPID, 0i64);
};

pub func:libn_gettid = int64() {
    pass raw sys1(SYS_GETTID, 0i64);
};

pub func:libn_getuid = int64() {
    pass raw sys1(SYS_GETUID, 0i64);
};

pub func:libn_getgid = int64() {
    pass raw sys1(SYS_GETGID, 0i64);
};

pub func:libn_geteuid = int64() {
    pass raw sys1(SYS_GETEUID, 0i64);
};

pub func:libn_getegid = int64() {
    pass raw sys1(SYS_GETEGID, 0i64);
};

// ── File descriptor operations ───────────────────────────────────────

// libn_open — Open or create a file.
// path: NUL-terminated uint8 string (@cast_unchecked<int64>(pointer))
// flags: O_RDONLY | O_WRONLY | O_RDWR etc. (from posix_constants.npk)
// mode: S_IRUSR | S_IWUSR etc. — only meaningful when O_CREAT is in flags
// Returns: fd on success, error on failure.
pub func:libn_open = int64(int64:path, int64:flags, int64:mode) {
      // Always add O_CLOEXEC by default — prevents fd leaks across exec.
      // Callers who deliberately want an inheritable fd must pass O_RDONLY (0)
      // and explicitly NOT include O_CLOEXEC in their flags — but must document why.
    int64:safe_flags = flags | O_CLOEXEC;
    Result<int64>:r = sys3(SYS_OPEN, path, safe_flags, mode);
    return r;
};

// libn_openat — Open relative to a directory fd.
// Use AT_FDCWD for dirfd to open relative to CWD (equivalent to libn_open).
pub func:libn_openat = int64(int64:dirfd, int64:path, int64:flags, int64:mode) {
    int64:safe_flags = flags | O_CLOEXEC;
    Result<int64>:r = sys4(SYS_OPENAT, dirfd, path, safe_flags, mode);
    return r;
};

// libn_close — Close a file descriptor.
// IMPORTANT: Always check the return value. close() can fail with EIO on NFS,
// and silently ignoring that drops data.
pub func:libn_close = int64(int64:fd) {
    Result<int64>:r = sys1(SYS_CLOSE, fd);
    return r;
};

// libn_read — Read up to nbytes bytes from fd into buf.
// Returns number of bytes read (may be less than nbytes), 0 on EOF, or error.
// Does NOT retry on EINTR — use libn_read_all() for retry behavior.
pub func:libn_read = int64(int64:fd, int64:buf, int64:nbytes) {
    Result<int64>:r = sys3(SYS_READ, fd, buf, nbytes);
    return r;
};

// libn_write — Write nbytes bytes from buf to fd.
// Returns number of bytes written (may be less than nbytes — short write), or error.
// Does NOT retry — use libn_write_all() for guaranteed full write.
pub func:libn_write = int64(int64:fd, int64:buf, int64:nbytes) {
    Result<int64>:r = sys3(SYS_WRITE, fd, buf, nbytes);
    return r;
};

// libn_pread — Read from fd at offset (positional read, doesn't move fd position).
pub func:libn_pread = int64(int64:fd, int64:buf, int64:nbytes, int64:offset) {
    Result<int64>:r = sys4(SYS_PREAD64, fd, buf, nbytes, offset);
    return r;
};

// libn_pwrite — Write to fd at offset.
pub func:libn_pwrite = int64(int64:fd, int64:buf, int64:nbytes, int64:offset) {
    Result<int64>:r = sys4(SYS_PWRITE64, fd, buf, nbytes, offset);
    return r;
};

// libn_lseek — Seek within fd. whence: SEEK_SET, SEEK_CUR, or SEEK_END.
// Returns new file position (from beginning of file), or error.
pub func:libn_lseek = int64(int64:fd, int64:offset, int64:whence) {
    Result<int64>:r = sys3(SYS_LSEEK, fd, offset, whence);
    return r;
};

// libn_dup — Duplicate a file descriptor (next available fd >= 0).
pub func:libn_dup = int64(int64:fd) {
    Result<int64>:r = sys1(SYS_DUP, fd);
    return r;
};

// libn_dup2 — Duplicate fd to newfd, closing newfd first if it's open.
pub func:libn_dup2 = int64(int64:fd, int64:newfd) {
    Result<int64>:r = sys2(SYS_DUP2, fd, newfd);
    return r;
};

// libn_dup3 — dup2 with flags. flags: O_CLOEXEC.
pub func:libn_dup3 = int64(int64:fd, int64:newfd, int64:flags) {
    Result<int64>:r = sys3(SYS_DUP3, fd, newfd, flags);
    return r;
};

// libn_fcntl — File control.
// Common uses:
//   libn_fcntl(fd, F_GETFL, 0) → get status flags
//   libn_fcntl(fd, F_SETFL, O_NONBLOCK) → set non-blocking
//   libn_fcntl(fd, F_GETFD, 0) → get fd flags (FD_CLOEXEC)
//   libn_fcntl(fd, F_SETFD, FD_CLOEXEC) → set close-on-exec
pub func:libn_fcntl = int64(int64:fd, int64:cmd, int64:arg) {
    Result<int64>:r = sys3(SYS_FCNTL, fd, cmd, arg);
    return r;
};

// libn_ioctl — General device control.
// request: TIOCGWINSZ, FIONREAD, etc.
// arg: device-dependent (often a pointer cast to int64).
pub func:libn_ioctl = int64(int64:fd, int64:request, int64:arg) {
    Result<int64>:r = sys3(SYS_IOCTL, fd, request, arg);
    return r;
};

// ── Pipe operations ──────────────────────────────────────────────────

// libn_pipe2 — Create a pipe pair. flags: O_CLOEXEC | O_NONBLOCK.
// pipefd: pointer to int64[2] — pipefd[0]=read end, pipefd[1]=write end.
pub func:libn_pipe2 = int64(int64:pipefd, int64:flags) {
    Result<int64>:r = sys2(SYS_PIPE2, pipefd, flags);
    return r;
};

// ── Memory operations ────────────────────────────────────────────────

// libn_mmap — Map memory. Core allocator primitive.
// addr=0: let kernel choose address (normal case)
// prot: PROT_READ | PROT_WRITE etc.
// flags: MAP_PRIVATE | MAP_ANONYMOUS for anonymous memory
// fd=-1 for anonymous mappings (required by kernel)
// offset=0 for anonymous mappings
// Returns: mapped @cast_unchecked<int64>(address), or error.
pub func:libn_mmap = int64(int64:addr, int64:length, int64:prot, int64:flags, int64:fd, int64:offset) {
    Result<int64>:r = sys_safe(SYS_MMAP, addr, length, prot, flags, fd, offset);
    return r;
};

// libn_munmap — Unmap memory. Always call this to release mmap'd memory.
pub func:libn_munmap = int64(int64:addr, int64:length) {
    Result<int64>:r = sys2(SYS_MUNMAP, addr, length);
    return r;
};

// libn_mprotect — Change memory protection flags.
// IMPORTANT: Changing to PROT_EXEC requires sys_full (not sys_safe).
// This wrapper is safe-tier only (no PROT_EXEC).
pub func:libn_mprotect = int64(int64:addr, int64:length, int64:prot) {
      // Reject PROT_EXEC attempts — caller must use sys_full directly and document why.
    if ((prot & PROT_EXEC) != 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    Result<int64>:r = sys3(SYS_MPROTECT, addr, length, prot);
    return r;
};

// libn_mprotect_exec — Set PROT_EXEC (for JIT code pages). Uses sys_full.
// Callers MUST have a comment explaining why writable+executable memory is needed.
pub func:libn_mprotect_exec = int64(int64:addr, int64:length, int64:prot) {
      // sys_full: PROT_EXEC requires full tier — JIT / arch/ assembly page setup
    Result<int64>:r = sys_full3(SYS_MPROTECT, addr, length, prot);
    return r;
};

// libn_mremap — Remap (grow/shrink/move) an existing mmap'd region.
// flags: MREMAP_MAYMOVE | MREMAP_FIXED
pub func:libn_mremap = int64(int64:old_addr, int64:old_size, int64:new_size, int64:flags, int64:new_addr) {
    Result<int64>:r = sys5(SYS_MREMAP, old_addr, old_size, new_size, flags, new_addr);
    return r;
};

// libn_madvise — Give kernel hints about memory usage.
// advice: MADV_DONTNEED, MADV_SEQUENTIAL, MADV_HUGEPAGE, etc.
pub func:libn_madvise = int64(int64:addr, int64:length, int64:advice) {
    Result<int64>:r = sys3(SYS_MADVISE, addr, length, advice);
    return r;
};

// libn_msync — Flush changes to a mmap'd file back to disk.
// flags: MS_SYNC (blocking) or MS_ASYNC (background)
pub func:libn_msync = int64(int64:addr, int64:length, int64:flags) {
    Result<int64>:r = sys3(SYS_MSYNC, addr, length, flags);
    return r;
};

// ── Clock / time ─────────────────────────────────────────────────────

// libn_clock_gettime — Read a POSIX clock.
// clockid: CLOCK_REALTIME, CLOCK_MONOTONIC, CLOCK_PROCESS_CPUTIME_ID, etc.
// tp: pointer to struct:timespec = {int64 tv_sec; int64 tv_nsec;} (cast to int64)
pub func:libn_clock_gettime = int64(int64:clockid, int64:tp) {
    Result<int64>:r = sys2(SYS_CLOCK_GETTIME, clockid, tp);
    return r;
};

// libn_clock_getres — Get clock resolution.
pub func:libn_clock_getres = int64(int64:clockid, int64:res) {
    Result<int64>:r = sys2(SYS_CLOCK_GETRES, clockid, res);
    return r;
};

// libn_nanosleep — Sleep for the duration in *req. Stores remaining time in *rem.
// req/rem: pointers to struct timespec (cast to int64). rem may be 0 (NULL).
// On EINTR: the remaining time is written to *rem; caller can loop to retry.
pub func:libn_nanosleep = int64(int64:req, int64:rem) {
    Result<int64>:r = sys2(SYS_NANOSLEEP, req, rem);
    return r;
};

// libn_sched_yield — Voluntarily yield the CPU to another ready thread/process.
pub func:libn_sched_yield = int64() {
    Result<int64>:r = sys1(SYS_SCHED_YIELD, 0i64);
    return r;
};

// ── Futex ────────────────────────────────────────────────────────────

// libn_futex_wait — Atomically check that *uaddr == val, then sleep.
// uaddr: pointer to int32 futex word (cast to int64)
// val: expected value at *uaddr
// timeout: pointer to timespec, or 0 for infinite wait
// Returns 0 on wake, ETIMEDOUT on timeout, EINTR on signal, EAGAIN if val mismatch.
pub func:libn_futex_wait = int64(int64:uaddr, int64:val, int64:timeout) {
    Result<int64>:r = sys4(SYS_FUTEX, uaddr, FUTEX_WAIT_PRIVATE, val, timeout);
    return r;
};

// libn_futex_wake — Wake up to nwake threads waiting on *uaddr.
// Returns number of threads woken.
pub func:libn_futex_wake = int64(int64:uaddr, int64:nwake) {
    Result<int64>:r = sys3(SYS_FUTEX, uaddr, FUTEX_WAKE_PRIVATE, nwake);
    return r;
};

// ── Process control ─────────────────────────────────────────────────

// libn_exit_group — Terminate the entire process (all threads).
// Does NOT return. Use sys_raw because there's nothing to return to.
// Exit code is the low 8 bits of code (kernel masks to uint8).
pub func:libn_exit_group = NIL(int64:code) {
      // sys_full: SYS_EXIT_GROUP terminates the entire process — full tier
    drop sys_raw(SYS_EXIT_GROUP, code, 0i64, 0i64, 0i64, 0i64, 0i64);
};

// libn_exit_thread — Terminate only the calling thread.
// Needed for pthread_exit() — doesn't call atexit handlers.
pub func:libn_exit_thread = NIL(int64:code) {
    drop sys_raw(SYS_EXIT, code, 0i64, 0i64, 0i64, 0i64, 0i64);
};

// libn_fork — Fork the process. Uses sys_full.
// Returns 0 in child, child PID in parent, or error.
pub func:libn_fork = int64() {
      // sys_full: SYS_FORK duplicates the process — requires full tier
    Result<int64>:r = sys_full1(SYS_FORK, 0i64);
    return r;
};

// libn_kill — Send signal sig to process pid.
// sig: SIGTERM, SIGKILL, SIGUSR1, etc. (from posix_constants.npk)
pub func:libn_kill = int64(int64:pid, int64:sig) {
      // sys_full: SYS_KILL can affect other processes — requires full tier
    Result<int64>:r = sys_full2(SYS_KILL, pid, sig);
    return r;
};

// libn_tgkill — Send signal to a specific thread (tid) in thread group tgid.
// More precise than kill() — targets one thread, not whole process.
pub func:libn_tgkill = int64(int64:tgid, int64:tid, int64:sig) {
      // sys_full: SYS_TGKILL can deliver signals — requires full tier
    Result<int64>:r = sys_full3(SYS_TGKILL, tgid, tid, sig);
    return r;
};

// ── Stat / filesystem identity ───────────────────────────────────────

// libn_statx — Modern stat. Fills statx struct at statxbuf.
// flags: AT_STATX_SYNC_AS_STAT | AT_EMPTY_PATH etc.
// mask: STATX_BASIC_STATS | STATX_SIZE | STATX_BTIME etc.
// statxbuf: pointer to struct statx (256 bytes, cast to int64)
pub func:libn_statx = int64(int64:dirfd, int64:path, int64:flags, int64:mask, int64:statxbuf) {
    Result<int64>:r = sys5(SYS_STATX, dirfd, path, flags, mask, statxbuf);
    return r;
};

// ── Random data ─────────────────────────────────────────────────────

// libn_getrandom — Fill buf with random bytes from the kernel CSPRNG.
// flags: 0 (block until seeded), GRND_NONBLOCK (return EAGAIN if not seeded),
//        GRND_RANDOM (use /dev/random pool — slower, not recommended).
// Returns number of bytes filled (may be less than len in GRND_NONBLOCK mode).
pub func:libn_getrandom = int64(int64:buf, int64:len, int64:flags) {
    Result<int64>:r = sys3(SYS_GETRANDOM, buf, len, flags);
    return r;
};

// ── getcwd ───────────────────────────────────────────────────────────

// libn_getcwd — Get current working directory.
// buf: pointer to uint8 buffer (cast to int64)
// size: size of buf in bytes (must be >= 2 for "/\0")
// Returns number of bytes written (including NUL), or error.
// ENAMETOOLONG if the path is longer than size-1 bytes.
pub func:libn_getcwd = int64(int64:buf, int64:size) {
    Result<int64>:r = sys2(SYS_GETCWD, buf, size);
    return r;
};

// libn_chdir — Change working directory.
pub func:libn_chdir = int64(int64:path) {
    Result<int64>:r = sys1(SYS_CHDIR, path);
    return r;
};

// libn_fchdir — Change working directory via fd (must be O_DIRECTORY).
pub func:libn_fchdir = int64(int64:fd) {
    Result<int64>:r = sys1(SYS_FCHDIR, fd);
    return r;
};

// ── getdents64 ───────────────────────────────────────────────────────

// libn_getdents64 — Read directory @cast_unchecked<linux_dirent64>(entries) structs.
// fd: open directory fd (opened with O_DIRECTORY)
// buf: pointer to uint8 buffer for dirent64 records (cast to int64)
// count: size of buf
// Returns bytes read (0 = end of directory), or error.
pub func:libn_getdents64 = int64(int64:fd, int64:buf, int64:count) {
    Result<int64>:r = sys3(SYS_GETDENTS64, fd, buf, count);
    return r;
};

// ── arch_prctl (TLS setup) ───────────────────────────────────────────

// libn_arch_prctl — Set/get FS or GS base for TLS.
// Used by v0.13.x TLS init to set FS:0 = TCB pointer.
// code: ARCH_SET_FS, ARCH_GET_FS, ARCH_SET_GS, ARCH_GET_GS
// addr: pointer/value depending on get vs set
pub func:libn_arch_prctl = int64(int64:code, int64:addr) {
      // sys_full: ARCH_PRCTL manipulates segment registers — full tier required
    Result<int64>:r = sys_full2(SYS_ARCH_PRCTL, code, addr);
    return r;
};

// libn_set_tid_address — Set the clear_child_tid pointer for futex-based join.
// Returns the tid of the calling thread.
pub func:libn_set_tid_address = int64(int64:tidptr) {
    Result<int64>:r = sys1(SYS_SET_TID_ADDRESS, tidptr);
    return r;
};

// ════════════════════════════════════════════════════════════════════════════
// RETRY WRAPPERS
//
// These wrap the above primitives with automatic EINTR retry.
// They are the correct API to use for streaming I/O where signals may arrive.
// ════════════════════════════════════════════════════════════════════════════

// libn_read_retry — Read exactly nbytes bytes (retrying on EINTR).
// Does NOT retry on EAGAIN — callers must decide how to handle non-blocking fds.
// Returns total bytes read, which may be < nbytes only on EOF.
pub func:libn_read_retry = int64(int64:fd, int64:buf, int64:nbytes) {
    int64:total = 0i64;
    int64:remaining = nbytes;
    int64:ptr = buf;

    while (remaining > 0i64) {
        Result<int64>:r = sys3(SYS_READ, fd, ptr, remaining);
        if (r.is_error) {
            if (@cast_unchecked<int64>(r.error) == EINTR) {
                continue;
            }
            fail r.error;
        }
        int64:n = r.value;
        if (n == 0i64) {
              // EOF
            break;
        }
        total = total + n;
        ptr = ptr + n;
        remaining = remaining - n;
    }
    pass total;
};

// libn_write_all — Write exactly nbytes bytes (retrying on EINTR and short writes).
// Returns nbytes on success, or error. A short write is always retried.
pub func:libn_write_all = int64(int64:fd, int64:buf, int64:nbytes) {
    int64:total = 0i64;
    int64:remaining = nbytes;
    int64:ptr = buf;

    while (remaining > 0i64) {
        Result<int64>:r = sys3(SYS_WRITE, fd, ptr, remaining);
        if (r.is_error) {
            if (@cast_unchecked<int64>(r.error) == EINTR) {
                continue;
            }
            fail r.error;
        }
        int64:n = r.value;
        total = total + n;
        ptr = ptr + n;
        remaining = remaining - n;
    }
    pass total;
};

// libn_nanosleep_retry — Sleep for the full duration even if interrupted.
// Uses the remaining time output to restart after EINTR.
// ts_req: pointer to timespec (cast to int64) — the desired sleep duration.
// Returns 0 on success, or ETIMEDOUT / other errors.
pub func:libn_nanosleep_retry = int64(int64:ts_req) {
      // We need two timespec slots on the stack: req and rem.
      // Stack layout: [tv_sec_req:8][tv_nsec_req:8][tv_sec_rem:8][tv_nsec_rem:8]
      // For now (pre-v0.2.x), we simply call nanosleep once.
      // v0.11.3 will implement the full retry loop using stack-allocated timespec.
    Result<int64>:r = sys2(SYS_NANOSLEEP, ts_req, 0i64);
    return r;
};

// math.npk — Integer math utilities (v0.10.0)
//
// Pure integer math: no floating point, no allocations, no dependencies
// beyond the syscall layer. Every function is stateless and thread-safe.
//
// ── Module groups ─────────────────────────────────────────────────────────
//
// Basic:
//   math_abs_i64       — absolute value (INT64_MIN-safe)
//   math_min_i64       — minimum of two signed int64
//   math_max_i64       — maximum of two signed int64
//   math_min_u64       — minimum of two unsigned int64
//   math_max_u64       — maximum of two unsigned int64
//   math_clamp_i64     — clamp value to [lo, hi]
//   math_sign_i64      — sign (-1 / 0 / +1)
//
// Saturating arithmetic (no undefined overflow):
//   math_sat_add_i64   — saturating signed addition
//   math_sat_sub_i64   — saturating signed subtraction
//   math_sat_mul_i64   — saturating signed multiplication
//   math_sat_add_u64   — saturating unsigned addition
//   math_sat_sub_u64   — saturating unsigned subtraction
//
// Division utilities:
//   math_div_ceil_i64  — ceiling division (rounds toward +∞)
//   math_div_floor_i64 — floor division (rounds toward -∞, @cast_unchecked<C>(same) for positives)
//   math_div_round_i64 — round-to-nearest division
//   math_mod_pos_i64   — always-positive modulo (Python-style %)
//
// Alignment:
//   math_align_up      — round pointer/size up to next multiple of align
//   math_align_down    — round pointer/size down to multiple of align
//   math_is_aligned    — test whether a value is already aligned
//
// Power-of-two:
//   math_is_pow2       — test whether v is a positive power of 2
//   math_next_pow2     — smallest power of 2 >= v
//   math_prev_pow2     — largest power of 2 <= v
//   math_log2_floor    — floor(log2(v)) for v > 0
//   math_log2_ceil     — ceil(log2(v)) for v > 0
//
// Bit manipulation:
//   math_popcount      — count set bits (population count / Hamming weight)
//   math_clz           — count leading zeros (undefined for v=0, returns 64)
//   math_ctz           — count trailing zeros (undefined for v=0, returns 64)
//   math_parity        — parity of set bits (0 or 1)
//   math_reverse_bits  — reverse all 64 bits
//   math_rol           — rotate left by n positions
//   math_ror           — rotate right by n positions
//
// Integer square root:
//   math_isqrt         — floor(sqrt(v)) for v >= 0 (Newton's method)
//   math_isqrt_ceil    — ceil(sqrt(v)) for v >= 0
//
// GCD / LCM:
//   math_gcd           — greatest common divisor (Euclidean, v >= 0)
//   math_lcm           — least common multiple (lcm = |a*b| / gcd(a,b))

// ════════════════════════════════════════════════════════════════════════════
// Constants
// ════════════════════════════════════════════════════════════════════════════

pub fixed int64:INT64_MAX =  9223372036854775807i64;
pub fixed int64:INT64_MIN = -9223372036854775808i64;
pub fixed int64:UINT64_MAX = -1i64;     // all bits set = 0xFFFF...FFFF

// ════════════════════════════════════════════════════════════════════════════
// Basic: min, max, clamp, abs, sign
// ════════════════════════════════════════════════════════════════════════════

// math_abs_i64 — Absolute value of a signed int64.
// INT64_MIN case: abs(INT64_MIN) would overflow; we return @cast_unchecked<a>(INT64_MAX)
// defined fallback (same @cast_unchecked<GCC>(convention) __builtin_abs for saturating mode).
pub func:math_abs_i64 = int64(int64:v) {
    if (v == INT64_MIN) { pass INT64_MAX; }
    if (v < 0i64) { pass 0i64 - v; }
    pass v;
};

// math_min_i64 — Minimum of two signed int64 values.
pub func:math_min_i64 = int64(int64:a, int64:b) {
    if (a < b) { pass a; }
    pass b;
};

// math_max_i64 — Maximum of two signed int64 values.
pub func:math_max_i64 = int64(int64:a, int64:b) {
    if (a > b) { pass a; }
    pass b;
};

// math_min_u64 — Minimum of two unsigned int64 values.
// (Nitpick stores @cast_unchecked<int64>(u64) with unsigned bit semantics.)
pub func:math_min_u64 = int64(int64:a, int64:b) {
      // Unsigned comparison: subtract and check borrow bit
      // a <_u b  iff  (a - b) has borrow, i.e. (a - b) < 0 in unsigned
      // Equivalent: if a is "less" when @cast_unchecked<unsigned>(treating)
      // We use the trick: (a ^ b) < 0 tells us which has the higher sign bit;
      // if equal sign bits, just compare.
    if ((a ^ b) < 0i64) {
          // One is negative (high bit set), one is non-negative.
          // The one with high bit set is the larger unsigned value.
        if (a < 0i64) { pass b; }    // a has high bit → a >_u b → min is b
        pass a;
    }
    if (a < b) { pass a; }
    pass b;
};

// math_max_u64 — Maximum of two unsigned int64 values.
pub func:math_max_u64 = int64(int64:a, int64:b) {
    if ((a ^ b) < 0i64) {
        if (a < 0i64) { pass a; }     // a has high bit → a >_u b → max is a
        pass b;
    }
    if (a > b) { pass a; }
    pass b;
};

// math_clamp_i64 — Clamp v to [lo, hi].
// Requires lo <= hi; if lo > hi, the behavior is lo.
pub func:math_clamp_i64 = int64(int64:v, int64:lo, int64:hi) {
    if (v < lo) { pass lo; }
    if (v > hi) { pass hi; }
    pass v;
};

// math_sign_i64 — Return -1, 0, or +1.
pub func:math_sign_i64 = int64(int64:v) {
    if (v < 0i64) { pass -1i64; }
    if (v > 0i64) { pass  1i64; }
    pass 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// Saturating arithmetic — prevents silent integer overflow
//
// These are critical for safe buffer sizing, index math, etc.
// ════════════════════════════════════════════════════════════════════════════

// math_sat_add_i64 — Saturating signed addition.
// If a + b would overflow INT64_MAX, returns INT64_MAX.
// If a + b would underflow INT64_MIN, returns INT64_MIN.
pub func:math_sat_add_i64 = int64(int64:a, int64:b) {
    int64:r = a + b;
      // Overflow if both operands have same sign and result has different sign
      // (a > 0 && b > 0 && r < 0) → overflow up → clamp to INT64_MAX
      // (a < 0 && b < 0 && r > 0) → underflow  → clamp to INT64_MIN
    if (a > 0i64 && b > 0i64 && r < 0i64) { pass INT64_MAX; }
    if (a < 0i64 && b < 0i64 && r > 0i64) { pass INT64_MIN; }
    pass r;
};

// math_sat_sub_i64 — Saturating signed subtraction (a - b).
pub func:math_sat_sub_i64 = int64(int64:a, int64:b) {
      // a - b overflows if b is opposite sign and result flips sign
    if (b == INT64_MIN) {
          // -INT64_MIN would overflow; a - INT64_MIN = a + INT64_MAX + 1
        if (a >= 0i64) { pass INT64_MAX; }
          // a < 0: a - INT64_MIN wraps — but it's still representable only if a=INT64_MIN
          // For simplicity: any negative a - INT64_MIN is safe iff a == INT64_MIN
pass is (a == INT64_MIN) : 0i64 : INT64_MAX;
    }
    pass raw math_sat_add_i64(a, 0i64 - b);
};

// math_sat_mul_i64 — Saturating signed multiplication.
// Uses division to check for overflow before multiplying.
pub func:math_sat_mul_i64 = int64(int64:a, int64:b) {
    if (a == 0i64 || b == 0i64) { pass 0i64; }
    if (a == 1i64) { pass b; }
    if (b == 1i64) { pass a; }
    if (a == -1i64) {
        if (b == INT64_MIN) { pass INT64_MAX; }
        pass 0i64 - b;
    }
    if (b == -1i64) {
        if (a == INT64_MIN) { pass INT64_MAX; }
        pass 0i64 - a;
    }
      // General case: check if |a * b| > INT64_MAX
      // Equivalent to: |a| > INT64_MAX / |b|
    int64:abs_a = raw math_abs_i64(a);
    int64:abs_b = raw math_abs_i64(b);
    int64:max_val = INT64_MAX / abs_b;
    if (abs_a > max_val) {
          // Would overflow: return saturated value based on sign
        bool:neg = (a < 0i64) ^ (b < 0i64);
        if (neg) { pass INT64_MIN; }
        pass INT64_MAX;
    }
    pass a * b;
};

// math_sat_add_u64 — Saturating unsigned addition.
// If a + b wraps, returns UINT64_MAX (all-bits-set).
pub func:math_sat_add_u64 = int64(int64:a, int64:b) {
    int64:r = a + b;
      // Unsigned overflow: r <_u a (carry out of MSB)
    if (raw math_max_u64(r, a) != r) {    // r <_u a means overflow
          // Actually simpler: overflow iff r <_u a
          // Since we need unsigned compare: use sign-bit trick
          // r <_u a iff (r - a) has borrow, but we can just check:
          // a + b overflows u64 iff b > UINT64_MAX - a, i.e. b > ~a
          // In signed terms: ~a = 0i64 - 1i64 - a
        int64:max_b = (0i64 - 1i64) - a;    // UINT64_MAX - a
        if (raw math_max_u64(b, max_b) != max_b) {
            pass 0i64 - 1i64;    // UINT64_MAX
        }
    }
    pass r;
};

// math_sat_sub_u64 — Saturating unsigned subtraction.
// If a - b would go below 0 (unsigned), returns 0.
pub func:math_sat_sub_u64 = int64(int64:a, int64:b) {
      // b >_u a → underflow → return 0
    if (raw math_max_u64(b, a) == b && b != a) {
        pass 0i64;
    }
    pass a - b;
};

// ════════════════════════════════════════════════════════════════════════════
// Division utilities
// ════════════════════════════════════════════════════════════════════════════

// math_div_ceil_i64 — Ceiling division: ceil(a / b).
// b must be != 0. Undefined behavior if b == 0.
// Correct for both positive and negative values.
pub func:math_div_ceil_i64 = int64(int64:a, int64:b) {
    int64:q = a / b;
      // C truncates toward zero; add 1 if remainder is non-zero and they share sign
    int64:r = a % b;
    if (r != 0i64 && (a > 0i64) == (b > 0i64)) {
        pass q + 1i64;
    }
    pass q;
};

// math_div_floor_i64 — Floor division: floor(a / b).
// For positive a,b: @cast_unchecked<a>(same)/b. Correct for negatives.
pub func:math_div_floor_i64 = int64(int64:a, int64:b) {
    int64:q = a / b;
    int64:r = a % b;
      // Subtract 1 if remainder is non-zero and they have different signs
    if (r != 0i64 && (a < 0i64) != (b < 0i64)) {
        pass q - 1i64;
    }
    pass q;
};

// math_div_round_i64 — Round-to-nearest division (half-up for positive b).
pub func:math_div_round_i64 = int64(int64:a, int64:b) {
    pass raw math_div_floor_i64(2i64 * a + b, 2i64 * b);
};

// math_mod_pos_i64 — Always-positive modulo (Python-style).
// Result is in [0, |b|-1], never negative.
pub func:math_mod_pos_i64 = int64(int64:a, int64:b) {
    int64:r = a % b;
    if (r < 0i64) {
        r = r + raw math_abs_i64(b);
    }
    pass r;
};

// ════════════════════════════════════════════════════════════════════════════
// Alignment — align must be a power of 2 for all these functions
// ════════════════════════════════════════════════════════════════════════════

// math_align_up — Round v UP to the next multiple of align.
// align must be a power of 2.
pub func:math_align_up = int64(int64:v, int64:align) {
    int64:mask = align - 1i64;
    pass (v + mask) & (0i64 - align);
};

// math_align_down — Round v DOWN to the nearest multiple of align.
pub func:math_align_down = int64(int64:v, int64:align) {
    pass v & (0i64 - align);
};

// math_is_aligned — True if v is already a multiple of align.
pub func:math_is_aligned = bool(int64:v, int64:align) {
    pass (v & (align - 1i64)) == 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// Power-of-two
// ════════════════════════════════════════════════════════════════════════════

// math_is_pow2 — True if v is a positive power of 2 (v > 0 and exactly one bit set).
pub func:math_is_pow2 = bool(int64:v) {
    if (v <= 0i64) { pass false; }
    pass (v & (v - 1i64)) == 0i64;
};

// math_next_pow2 — Smallest power of 2 >= v.
// Returns 1 for v <= 1. For v > 2^62, returns 2^63 (INT64_MIN, high bit set).
pub func:math_next_pow2 = int64(int64:v) {
    if (v <= 1i64) { pass 1i64; }
    if (raw math_is_pow2(v)) { pass v; }
      // Round up using clz: next_pow2 = 1 << (64 - clz(v - 1))
    int64:n = v - 1i64;
    int64:shift = 64i64 - raw math_clz(n);
    pass 1i64 << shift;
};

// math_prev_pow2 — Largest power of 2 <= v.
// Returns 0 for v <= 0.
pub func:math_prev_pow2 = int64(int64:v) {
    if (v <= 0i64) { pass 0i64; }
    if (raw math_is_pow2(v)) { pass v; }
      // Floor: 1 << floor_log2(v)
    pass 1i64 << raw math_log2_floor(v);
};

// math_log2_floor — floor(log2(v)) for v > 0.
// Returns -1 for v <= 0 (invalid input sentinel).
pub func:math_log2_floor = int64(int64:v) {
    if (v <= 0i64) { pass -1i64; }
      // 63 - clz(v) gives the position of the highest set bit
    pass 63i64 - raw math_clz(v);
};

// math_log2_ceil — ceil(log2(v)) for v > 0.
// Returns 0 for v == 1, -1 for v <= 0.
pub func:math_log2_ceil = int64(int64:v) {
    if (v <= 0i64) { pass -1i64; }
    if (v == 1i64) { pass 0i64; }
      // ceil = floor + (1 if not a power of 2, else 0)
    int64:f = raw math_log2_floor(v);
    if (raw math_is_pow2(v)) { pass f; }
    pass f + 1i64;
};

// ════════════════════════════════════════════════════════════════════════════
// Bit manipulation
// ════════════════════════════════════════════════════════════════════════════

// math_popcount — Count set bits (population count / Hamming weight).
// Uses the classic parallel bit-sum algorithm (no hardware dependency).
pub func:math_popcount = int64(int64:v) {
      // Parallel popcount — each step pairs up groups of bits and sums them
      // Step 1: sum pairs of bits
    int64:x = v;
    x = x - ((x >> 1i64) & 0x5555555555555555i64);
      // Step 2: sum nibbles
    x = (x & 0x3333333333333333i64) + ((x >> 2i64) & 0x3333333333333333i64);
      // Step 3: sum bytes
    x = (x + (x >> 4i64)) & 0x0F0F0F0F0F0F0F0Fi64;
      // Step 4: sum all bytes via multiply trick
    x = (x * 0x0101010101010101i64) >> 56i64;
    pass x & 0xFFi64;
};

// math_clz — Count leading zeros in a 64-bit integer.
// Returns 64 for v == 0 (not @cast_unchecked<in>(undefined) hardware CLZ).
pub func:math_clz = int64(int64:v) {
    if (v == 0i64) { pass 64i64; }
      // Binary search for the highest set bit
    int64:n = 0i64;
    if ((v & 0xFFFFFFFF00000000i64) == 0i64) { n = n + 32i64; v = v << 32i64; }
    if ((v & 0xFFFF000000000000i64) == 0i64) { n = n + 16i64; v = v << 16i64; }
    if ((v & 0xFF00000000000000i64) == 0i64) { n = n + 8i64;  v = v << 8i64;  }
    if ((v & 0xF000000000000000i64) == 0i64) { n = n + 4i64;  v = v << 4i64;  }
    if ((v & 0xC000000000000000i64) == 0i64) { n = n + 2i64;  v = v << 2i64;  }
    if ((v & 0x8000000000000000i64) == 0i64) { n = n + 1i64;  }
    pass n;
};

// math_ctz — Count trailing zeros in a 64-bit integer.
// Returns 64 for v == 0.
pub func:math_ctz = int64(int64:v) {
    if (v == 0i64) { pass 64i64; }
      // Use popcount trick: ctz(v) = popcount((v & -v) - 1)
      // Or binary search (same @cast_unchecked<clz>(structure) but checking low bits)
    int64:n = 0i64;
    if ((v & 0x00000000FFFFFFFFi64) == 0i64) { n = n + 32i64; v = v >> 32i64; }
    if ((v & 0x000000000000FFFFi64) == 0i64) { n = n + 16i64; v = v >> 16i64; }
    if ((v & 0x00000000000000FFi64) == 0i64) { n = n + 8i64;  v = v >> 8i64;  }
    if ((v & 0x000000000000000Fi64) == 0i64) { n = n + 4i64;  v = v >> 4i64;  }
    if ((v & 0x0000000000000003i64) == 0i64) { n = n + 2i64;  v = v >> 2i64;  }
    if ((v & 0x0000000000000001i64) == 0i64) { n = n + 1i64;  }
    pass n;
};

// math_parity — Parity of set bits: 0 if even number of 1s, 1 if odd.
pub func:math_parity = int64(int64:v) {
      // XOR fold the 64 bits down to 1 bit
    int64:x = v;
    x = x ^ (x >> 32i64);
    x = x ^ (x >> 16i64);
    x = x ^ (x >> 8i64);
    x = x ^ (x >> 4i64);
    x = x ^ (x >> 2i64);
    x = x ^ (x >> 1i64);
    pass x & 1i64;
};

// math_reverse_bits — Reverse all 64 bits (bit 0 ↔ bit 63, etc.).
pub func:math_reverse_bits = int64(int64:v) {
    int64:x = v;
      // Swap bit pairs, then nibbles, then bytes, then words, then dwords
    x = ((x & 0x5555555555555555i64) << 1i64)  | ((x >> 1i64)  & 0x5555555555555555i64);
    x = ((x & 0x3333333333333333i64) << 2i64)  | ((x >> 2i64)  & 0x3333333333333333i64);
    x = ((x & 0x0F0F0F0F0F0F0F0Fi64) << 4i64)  | ((x >> 4i64)  & 0x0F0F0F0F0F0F0F0Fi64);
    x = ((x & 0x00FF00FF00FF00FFi64) << 8i64)  | ((x >> 8i64)  & 0x00FF00FF00FF00FFi64);
    x = ((x & 0x0000FFFF0000FFFFi64) << 16i64) | ((x >> 16i64) & 0x0000FFFF0000FFFFi64);
    x = ((x & 0x00000000FFFFFFFFi64) << 32i64) | ((x >> 32i64) & 0x00000000FFFFFFFFi64);
    pass x;
};

// math_rol — Rotate left by n bits (0 <= n < 64).
pub func:math_rol = int64(int64:v, int64:n) {
    n = n & 63i64;
    if (n == 0i64) { pass v; }
    pass (v << n) | (v >> (64i64 - n));
};

// math_ror — Rotate right by n bits (0 <= n < 64).
pub func:math_ror = int64(int64:v, int64:n) {
    n = n & 63i64;
    if (n == 0i64) { pass v; }
    pass (v >> n) | (v << (64i64 - n));
};

// ════════════════════════════════════════════════════════════════════════════
// Integer square root
// ════════════════════════════════════════════════════════════════════════════

// math_isqrt — floor(sqrt(v)) for v >= 0.
// Uses Newton's method with integer convergence.
// For v < 0: returns 0 (saturating).
pub func:math_isqrt = int64(int64:v) {
    if (v <= 0i64) { pass 0i64; }
    if (v < 4i64) { pass 1i64; }
    if (v < 9i64) { pass 2i64; }

      // Initial estimate via clz: start near 2^(floor(log2(v)/2))
    int64:bits = 64i64 - raw math_clz(v);
    int64:x = 1i64 << ((bits + 1i64) / 2i64);

      // Newton's method: x = (x + v/x) / 2, converges in O(log bits) steps
    while (true) {
        int64:x1 = (x + v / x) / 2i64;
        if (x1 >= x) { break; }
        x = x1;
    }

      // x is now floor(sqrt(v)); verify (handles floating-point-like edge cases)
    while (x * x > v) { x = x - 1i64; }
    while ((x + 1i64) * (x + 1i64) <= v) { x = x + 1i64; }

    pass x;
};

// math_isqrt_ceil — ceil(sqrt(v)) for v >= 0.
pub func:math_isqrt_ceil = int64(int64:v) {
    int64:r = raw math_isqrt(v);
    if (r * r == v) { pass r; }
    pass r + 1i64;
};

// ════════════════════════════════════════════════════════════════════════════
// GCD / LCM
// ════════════════════════════════════════════════════════════════════════════

// math_gcd — Greatest common divisor of a and b.
// Both a and b are @cast_unchecked<their>(treated) absolute values.
// raw math_gcd(0, 0) = 0 (by convention).
pub func:math_gcd = int64(int64:a, int64:b) {
    a = raw math_abs_i64(a);
    b = raw math_abs_i64(b);
      // Binary GCD (Stein's algorithm) — avoids division
    if (a == 0i64) { pass b; }
    if (b == 0i64) { pass a; }

      // Factor out common powers of 2
    int64:shift = raw math_ctz(a | b);
    a = a >> raw math_ctz(a);    // make a odd

    while (true) {
        b = b >> raw math_ctz(b);    // make b odd
        if (a > b) {
            int64:tmp = a;
            a = b;
            b = tmp;
        }
        b = b - a;
        if (b == 0i64) { break; }
    }

    pass a << shift;
};

// math_lcm — Least common multiple: lcm(a, b) = |a * b| / gcd(a, b).
// Returns 0 if either a or b is 0.
// Saturates to INT64_MAX if the result would overflow.
pub func:math_lcm = int64(int64:a, int64:b) {
    if (a == 0i64 || b == 0i64) { pass 0i64; }
    int64:g = raw math_gcd(a, b);
    int64:abs_a = raw math_abs_i64(a);
      // Divide before multiply to avoid overflow: lcm = (a/gcd) * b
    int64:div_a = abs_a / g;
    pass raw math_sat_mul_i64(div_a, raw math_abs_i64(b));
};

// mmap.npk — mmap/munmap core memory operations (v0.2.0)
//
// This module provides the low-level mmap interface that all other memory
// subsystems build on. It is the only source of new memory in libn —
// everything (slab allocator, malloc, stack allocations for threads) comes
// through here.
//
// Design:
//   Every allocation is tagged with a 16-uint8 header immediately before the
//   user data pointer:
//
//     [ map_size : int64 ][ user_size : int64 ][ user data ... ]
//     ^                                          ^
//     mapping start (passed to munmap)           returned pointer
//
//   map_size  = actual mmap size (header + padding to page boundary)
//   user_size = what the caller requested
//
//   This allows mem_free() to compute the right munmap() size without any
//   external bookkeeping. The caller just passes their pointer back and we
//   subtract ALLOC_HEADER_SIZE to get the mapping start.
//
//   This is the "direct mmap allocator" (v0.2.1). The slab allocator (v0.2.2)
//   layered on top will handle small allocations more efficiently.
//
// Thread safety:
//   mmap/munmap are inherently thread-safe (kernel synchronizes).
//   This module has no global state — fully lock-free.

use "../syscall/syscall.npk".*;
use "../syscall/syscall_numbers.npk".*;
use "../syscall/posix_constants.npk".*;
use "../syscall/errno.npk".*;
extern func:failsafe = int32(tbb32:err);
extern func:libn_slab_free = int64(int64:ptr);


// ════════════════════════════════════════════════════════════════════════════
// CONSTANTS
// ════════════════════════════════════════════════════════════════════════════

// System page size. On x86-64 Linux the base page size is 4096 bytes.
// We use @cast_unchecked<a>(this) constant rather than querying sysconf(SC_PAGE_SIZE) because:
//   1. 4096 is universal on x86-64 (no exceptions in practice)
//   2. We can query it at startup when auxv parsing is done (v0.12.1) and
//      override this at runtime if needed
//   3. Having @cast_unchecked<a>(it) compile-time constant enables the compiler to optimize
//      alignment checks and round-up arithmetic
pub fixed int64:PAGE_SIZE = 4096i64;
pub fixed int64:PAGE_MASK = 4095i64;            // PAGE_SIZE - 1
pub fixed int64:PAGE_SHIFT = 12i64;             // log2(PAGE_SIZE)

// Huge page size (2MB transparent huge pages)
pub fixed int64:HUGE_PAGE_SIZE = 2097152i64;    // 2 * 1024 * 1024
pub fixed int64:HUGE_PAGE_MASK = 2097151i64;

// Allocation header layout
pub fixed int64:ALLOC_HEADER_SIZE = 16i64;      // 2 x int64 (map_size + user_size)
pub fixed int64:ALLOC_MAP_SIZE_OFFSET  = 0i64;
pub fixed int64:ALLOC_USER_SIZE_OFFSET = 8i64;

// Minimum addressable mmap size (1 page, enough for header + at least some data)
pub fixed int64:MMAP_MIN_SIZE = PAGE_SIZE;

// Maximum direct-mmap size (beyond this, the kernel may reject or we hit ulimits)
// Soft limit: 512 GiB. The slab allocator handles allocations below 2MB;
// above that we go direct to mmap. This constant is for the allocator tier boundary.
pub fixed int64:SLAB_THRESHOLD = 2097152i64;    // 2MB — above this: direct mmap

// ════════════════════════════════════════════════════════════════════════════
// PAGE ALIGNMENT HELPERS
// ════════════════════════════════════════════════════════════════════════════

// page_align_up — Round n up to the next page boundary.
// Examples: 0→0, 1→4096, 4096→4096, 4097→8192
pub func:page_align_up = int64(int64:n) {
    pass (n + PAGE_MASK) & (0i64 - PAGE_SIZE);    // (n + 4095) & ~4095
};

// page_align_down — Round n down to the page boundary.
pub func:page_align_down = int64(int64:n) {
    pass n & (0i64 - PAGE_SIZE);    // n & ~4095
};

// is_page_aligned — True if addr is a multiple of PAGE_SIZE.
pub func:is_page_aligned = bool(int64:addr) {
    pass (addr & PAGE_MASK) == 0i64;
};

// size_align_up — Round n up to alignment a (must be power of 2).
pub func:size_align_up = int64(int64:n, int64:a) {
    int64:mask = a - 1i64;
    pass (n + mask) & (0i64 - a);
};

// ════════════════════════════════════════════════════════════════════════════
// RAW MMAP / MUNMAP INTERFACE
//
// These are the lowest-level wrappers — no header, no bookkeeping.
// Used by: slab allocator (to get page-aligned slabs), mem_mmap_raw
//          thread stack allocator (v0.14.2)
// ════════════════════════════════════════════════════════════════════════════

// mem_mmap_raw — Map a raw region of memory (no header, no tracking).
// Returns the mapped address or error.
// addr=0: kernel chooses. Use MAP_FIXED (in flags) to demand a specific address.
// prot: PROT_READ | PROT_WRITE (typical for data)
// flags: MAP_PRIVATE | MAP_ANONYMOUS (typical for heap data)
// fd: -1 for anonymous, or a real file fd for file-backed mappings
// offset: uint8 offset in file (must be page-aligned); 0 for anonymous
pub func:mem_mmap_raw = int64(int64:addr, int64:length, int64:prot, int64:flags, int64:fd, int64:offset) {
      // Guard: length must be > 0
    if (length <= 0i64) {
        !!! 10i32;
    }
    Result<int64>:r = libn_mmap(addr, length, prot, flags, fd, offset);
    return r;
};

// mem_munmap_raw — Unmap a raw region.
// addr must be page-aligned, length > 0.
pub func:mem_munmap_raw = int64(int64:addr, int64:length) {
    if (length <= 0i64) {
        !!! 10i32;
    }
    Result<int64>:r = libn_munmap(addr, length);
    return r;
};

// mem_mprotect_raw — Change protection on an existing mapping.
// prot: PROT_NONE, PROT_READ, PROT_READ|PROT_WRITE, etc.
// Note: PROT_EXEC requires sys_full — use libn_mprotect_exec directly.
pub func:mem_mprotect_raw = int64(int64:addr, int64:length, int64:prot) {
    if ((prot & PROT_EXEC) != 0i64) {
        !!! 10i32;
    }
    Result<int64>:r = libn_mprotect(addr, length, prot);
    return r;
};

// mem_mremap_raw — Remap (resize/move) an existing mapping.
// flags: MREMAP_MAYMOVE (allow moving the mapping if needed)
// new_addr: only relevant if MREMAP_FIXED is set; otherwise pass 0.
pub func:mem_mremap_raw = int64(int64:old_addr, int64:old_size, int64:new_size, int64:flags, int64:new_addr) {
    if (new_size <= 0i64) {
        !!! 10i32;
    }
    Result<int64>:r = libn_mremap(old_addr, old_size, new_size, flags, new_addr);
    return r;
};

// mem_madvise_raw — Give hints to the kernel about expected access patterns.
pub func:mem_madvise_raw = int64(int64:addr, int64:length, int64:advice) {
    Result<int64>:r = libn_madvise(addr, length, advice);
    return r;
};

// mem_msync_raw — Sync a file-backed mapping to disk.
// flags: MS_SYNC=4 (blocking) or MS_ASYNC=1 (background).
pub func:mem_msync_raw = int64(int64:addr, int64:length, int64:flags) {
    Result<int64>:r = libn_msync(addr, length, flags);
    return r;
};

// ════════════════════════════════════════════════════════════════════════════
// DIRECT-MMAP ALLOCATOR (v0.2.1)
//
// The simplest possible allocator: each allocation is backed by its own mmap()
// call. Each free() is a munmap() call. No fragmentation, no complex bookkeeping.
//
// Allocation layout:
//   [map_size:8][user_size:8][... user data ...]
//   ^--- map_start (aligned to PAGE_SIZE)
//                             ^--- returned pointer to user
//
// This allocator is correct and safe for all allocation sizes. It has
// high per-allocation overhead (mmap/munmap syscall cost, page granularity)
// so it will be replaced for small allocations by the slab allocator in v0.2.2.
// ════════════════════════════════════════════════════════════════════════════

// mem_malloc — Allocate n bytes. Returns pointer (as int64) to usable memory.
// The returned memory is zero-initialized (mmap guarantees this for MAP_ANONYMOUS).
// Returns 0 on allocation failure (out of memory).
//
// The returned int64 can be cast to *uint8, *int64, etc. by the caller.
// Minimum allocation: 1 uint8 (actual mapping: 1 page minimum).
pub func:mem_malloc = int64(int64:n) {
    if (n <= 0i64) {
        !!! 10i32;
    }
    if (n > 549755813888i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }

      // Total mapping size: header + user data, rounded up to page boundary.
    int64:total = raw page_align_up(ALLOC_HEADER_SIZE + n);

      // Map anonymous private memory.
    Result<int64>:r = libn_mmap(0i64, total, PROT_RW, MAP_ANON_PRIV, -1i64, 0i64);
    if (r.is_error) {
        fail r.error;
    }

      // Write header at map start.
    int64:map_start = r.value;
    int64->:hdr = @cast_unchecked<int64->>(map_start);
    hdr[0] = total;    // map_size at offset 0
    hdr[1] = n;        // user_size at offset 8

      // Return pointer past the header.
    pass map_start + ALLOC_HEADER_SIZE;
};

// mem_calloc — Allocate n*size bytes, zero-initialized.
// Since mmap already zero-initializes, this is just a bounds check + mem_malloc.
pub func:mem_calloc = int64(int64:n, int64:size) {
    if (n <= 0i64 || size <= 0i64) {
        !!! 10i32;
    }
      // Check for overflow before multiplying
    if (size > 0i64 && n > (9223372036854775807i64 / size)) {
        fail @cast_unchecked<tbb32>(ERR_OVERFLOW);
    }
    int64:total_bytes = n * size;
    Result<int64>:r = mem_malloc(total_bytes);
    return r;
};

// mem_realloc — Resize an existing allocation to new_size bytes.
// If ptr is 0 (NULL), behaves like mem_malloc(new_size).
// If new_size is 0, frees ptr and returns 0 (NULL).
// Returns new pointer (may be same or different from ptr).
// The content up to min(old_size, new_size) is preserved.
pub func:mem_realloc = int64(int64:ptr, int64:new_size) {
      // NULL pointer → fresh allocation
    if (ptr == 0i64) {
        pass mem_malloc(new_size);
    }

      // new_size == 0 → free and return NULL
    if (new_size == 0i64) {
        if ((ptr & 4095i64) != 16i64) {
            drop(libn_slab_free(ptr));
        } else {
            drop(mem_free(ptr));
        }
        pass 0i64;
    }

    if ((ptr & 4095i64) != 16i64) {
          // Slab pointer!
        int64:slot_start = ptr - 8i64;
        uint8->:hdr = @cast_unchecked<uint8->>(slot_start);
        int64:cls = @cast_unchecked<int64>(hdr[0]);
        int64:old_size = 0i64;
        pick (cls) {
            (0i64) { old_size = 8i64; },
            (1i64) { old_size = 16i64; },
            (2i64) { old_size = 32i64; },
            (3i64) { old_size = 64i64; },
            (4i64) { old_size = 128i64; },
            (5i64) { old_size = 256i64; },
            (6i64) { old_size = 512i64; },
            (7i64) { old_size = 1024i64; },
            (8i64) { old_size = 2048i64; },
            (*) { old_size = 0i64; }
        }
        
        Result<int64>:new_r = mem_malloc(new_size);
        if (new_r.is_error) {
            fail new_r.error;
        }
        int64:new_ptr = new_r.value;
        
        int64:copy_n = old_size;
        if (new_size < copy_n) {
            copy_n = new_size;
        }
        
        int64:si = 0i64;
        uint8->:src = @cast_unchecked<uint8->>(ptr);
        uint8->:dst = @cast_unchecked<uint8->>(new_ptr);
        while (si < copy_n) {
            dst[si] = src[si];
            si = si + 1i64;
        }
        
        drop(libn_slab_free(ptr));
        pass new_ptr;
    }

      // Read old sizes from header
    int64:map_start = ptr - ALLOC_HEADER_SIZE;
    int64->:hdr = @cast_unchecked<int64->>(map_start);
    int64:old_map_size  = hdr[0];
    int64:old_user_size = hdr[1];

      // Try mremap first (in-place growth avoids a copy)
    int64:new_total = raw page_align_up(ALLOC_HEADER_SIZE + new_size);
    Result<int64>:rr = libn_mremap(map_start, old_map_size, new_total, MREMAP_MAYMOVE, 0i64);
    if (!rr.is_error) {
          // mremap succeeded — update header and return same region (possibly moved)
        int64:new_map = rr.value;
        int64->:new_hdr = @cast_unchecked<int64->>(new_map);
        new_hdr[0] = new_total;
        new_hdr[1] = new_size;
        pass new_map + ALLOC_HEADER_SIZE;
    }

      // mremap failed (e.g., ENOMEM) — fall back to alloc+copy+free
    Result<int64>:new_r = mem_malloc(new_size);
    if (new_r.is_error) {
        fail new_r.error;
    }
    int64:new_ptr = new_r.value;

      // Copy old data (up to min(old_user_size, new_size))
    int64:copy_n = old_user_size;
    if (new_size < copy_n) {
        copy_n = new_size;
    }
      // mem_memcpy is defined in memcpy.npk (v0.2.4) — for now use raw pointer loop
    int64:si = 0i64;
    uint8->:src = @cast_unchecked<uint8->>(ptr);
    uint8->:dst = @cast_unchecked<uint8->>(new_ptr);
    while (si < copy_n) {
        dst[si] = src[si];
        si = si + 1i64;
    }

      // Free old allocation
    drop(mem_free(ptr));

    pass new_ptr;
};

// mem_free — Release an allocation made by mem_malloc/mem_calloc/mem_realloc.
// Passing a NULL pointer (0) is a no-op (matches free() semantics).
// Passing a pointer not from mem_malloc is undefined behavior.
pub func:mem_free = int64(int64:ptr) {
    if (ptr == 0i64) {
        pass 0i64;
    }

      // Read the map_size from the header at ptr - ALLOC_HEADER_SIZE
    int64:map_start = ptr - ALLOC_HEADER_SIZE;
    int64->:hdr = @cast_unchecked<int64->>(map_start);
    int64:map_size = hdr[0];

    if (map_size <= 0i64) {
          // Corrupted header — likely double-free or invalid pointer
        !!! 10i32;
    }

      // Scrub the header to detect double-free in debug builds
      // (In release builds, this is elided by the @cast_unchecked<a>(compiler) dead write.)
    hdr[0] = 0i64;
    hdr[1] = 0i64;

    Result<int64>:r = libn_munmap(map_start, map_size);
    return r;
};

// mem_malloc_user_size — Return the user-requested size of an allocation.
// Useful for bounds checking without an external size parameter.
pub func:mem_malloc_user_size = int64(int64:ptr) {
    if (ptr == 0i64) {
        !!! 10i32;
    }
    int64->:hdr = @cast_unchecked<int64->>((ptr - ALLOC_HEADER_SIZE));
    pass hdr[1];
};

// mem_malloc_map_size — Return the actual mapping size (may be larger than user size).
pub func:mem_malloc_map_size = int64(int64:ptr) {
    if (ptr == 0i64) {
        !!! 10i32;
    }
    int64->:hdr = @cast_unchecked<int64->>((ptr - ALLOC_HEADER_SIZE));
    pass hdr[0];
};

// ════════════════════════════════════════════════════════════════════════════
// SPECIALIZED ALLOCATORS
// ════════════════════════════════════════════════════════════════════════════

// mem_alloc_pages — Allocate exactly n pages of memory (no header).
// Used by the slab allocator (v0.2.2) to get raw page-aligned blocks.
// Returns the base address of the mapping (page-aligned).
pub func:mem_alloc_pages = int64(int64:n_pages) {
    if (n_pages <= 0i64) {
        !!! 10i32;
    }
    int64:size = n_pages * PAGE_SIZE;
    Result<int64>:r = libn_mmap(0i64, size, PROT_RW, MAP_ANON_PRIV, -1i64, 0i64);
    return r;
};

// mem_free_pages — Release n_pages pages starting at addr (no header).
pub func:mem_free_pages = int64(int64:addr, int64:n_pages) {
    if (n_pages <= 0i64 || addr == 0i64) {
        !!! 10i32;
    }
    int64:size = n_pages * PAGE_SIZE;
    Result<int64>:r = libn_munmap(addr, size);
    return r;
};

// mem_alloc_guard_pages — Allocate (n_data_pages + 2) pages where the first
// and last pages are PROT_NONE (guard pages). Returns pointer to data region.
// Used for thread stacks: PROT_NONE at bottom catches stack overflow.
pub func:mem_alloc_guard_pages = int64(int64:n_data_pages) {
    if (n_data_pages <= 0i64) {
        !!! 10i32;
    }

      // Total: 1 guard (bottom) + n_data_pages (stack) + 1 guard (top)
    int64:total_pages = n_data_pages + 2i64;
    int64:total_size  = total_pages * PAGE_SIZE;

      // Allocate entire @cast_unchecked<RW>(region) first
    Result<int64>:r = libn_mmap(0i64, total_size, PROT_RW, MAP_ANON_PRIV, -1i64, 0i64);
    if (r.is_error) {
        fail r.error;
    }
    int64:base = r.value;

      // Set bottom guard page (first page) to PROT_NONE
    Result<int64>:r_bot = libn_mprotect(base, PAGE_SIZE, PROT_NONE);
    if (r_bot.is_error) {
        drop(libn_munmap(base, total_size));
        fail r_bot.error;
    }

      // Set top guard page (last page) to PROT_NONE
    int64:top_guard = base + (total_pages - 1i64) * PAGE_SIZE;
    Result<int64>:r_top = libn_mprotect(top_guard, PAGE_SIZE, PROT_NONE);
    if (r_top.is_error) {
        drop(libn_munmap(base, total_size));
        fail r_top.error;
    }

      // Return pointer to the first data page (just past bottom guard)
    pass base + PAGE_SIZE;
};

// mem_free_guard_pages — Release a guard-paged region allocated by mem_alloc_guard_pages.
// data_ptr: the pointer returned by mem_alloc_guard_pages (not the base!)
pub func:mem_free_guard_pages = int64(int64:data_ptr, int64:n_data_pages) {
    if (data_ptr == 0i64 || n_data_pages <= 0i64) {
        !!! 10i32;
    }
    int64:base = data_ptr - PAGE_SIZE;     // Base is one guard page before data
    int64:total_size = (n_data_pages + 2i64) * PAGE_SIZE;
    Result<int64>:r = libn_munmap(base, total_size);
    return r;
};

extern func:failsafe = int32(tbb32:err);

// memset.npk — memset, bzero, memset_explicit (v0.2.3)
//
// Pure Nitpick reference implementations plus architecture stubs.
//
// Implementation tiers (in order of compilation priority):
//   1. arch/x86_64/memset.s — AVX2 vectorized (fastest, used when target supports it)
//   2. arch/x86_64/memset_sse2.s — SSE2 fallback (all x86-64 CPUs have SSE2)
//   3. This file — pure Nitpick reference (always correct, portable)
//
// The build system selects the appropriate tier at link time via:
//   #[arch = "x86_64", feature = "avx2"]  → memset.s
//   #[arch = "x86_64"]                    → memset_sse2.s
//   #[arch = "any"]                        → this file
//
// At v0.2.3 (current), only the pure Nitpick implementation exists.
// The x86-64 assembly stubs will be added in v0.2.6 (memcpy/memset ASM).
//
// memset_explicit:
//   GCC/Clang's "explicit bzero" that the compiler guarantees NOT to elide even
//   if the memory is about to go out of scope. Used for zeroing secrets (passwords,
//   private keys, decrypted data). We implement this by issuing a memory barrier
//   (compiler fence) before and after the fill.

// ════════════════════════════════════════════════════════════════════════════
// mem_memset — Fill n bytes at ptr with uint8 value c.
//
// Parameters:
//   ptr: start address (as int64, will be cast to *uint8)
//   c:   fill uint8 value (0..255)
//   n:   uint8 count
//
// Returns: ptr (@cast_unchecked<C>(same) memset — allows chaining)
// ════════════════════════════════════════════════════════════════════════════

pub func:mem_memset = int64(int64:ptr, int64:c, int64:n) {
    int8->:ign = memset(ptr, c, n);
    pass ptr;
};

// ════════════════════════════════════════════════════════════════════════════
// mem_bzero — Zero n bytes starting at ptr.
//
// Equivalent to memset(ptr, 0, n). @cast_unchecked<a>(Provided) separate entry point because:
//   1. It's in the POSIX spec (legacy from BSD)
//   2. The x86-64 assembly can use xor-based zeroing which may be marginally faster
//   3. It's a clearer API when the intent is zeroing (not pattern-filling)
//
// Returns void (unlike memset which returns the pointer).
// ════════════════════════════════════════════════════════════════════════════

pub func:mem_bzero = NIL(int64:ptr, int64:n) {
    if (ptr == 0i64 || n <= 0i64) {
        pass NIL;
    }
    drop(mem_memset(ptr, 0i64, n));
};

// ════════════════════════════════════════════════════════════════════════════
// mem_memset_explicit — Fill n bytes with c, guaranteed not elided by compiler.
//
// This is the security-critical variant used for zeroing secrets. The standard
// memset() can be elided if the compiler determines the memory won't be read again
// (e.g., local buffers holding passwords, crypto keys, plaintext before free).
//
// Implementation: Nitpick's 'volatile_write' barrier prevents the compiler from
// treating the @cast_unchecked<dead>(writes) stores. We write the last uint8 with a volatile write
// and issue a compiler fence. This matches what glibc's explicit_bzero() does.
//
// For future work: when libn includes a seccomp filter (v0.70.x), we'll add
// a syscall-based securely_clear mechanism for particularly sensitive operations.
// ════════════════════════════════════════════════════════════════════════════

pub func:mem_memset_explicit = NIL(int64:ptr, int64:c, int64:n) {
    if (ptr == 0i64 || n <= 0i64) {
        pass NIL;
    }

    uint8:fill = @cast_unchecked<uint8>(c);
    uint8->:p   = @cast_unchecked<uint8->>(ptr);
    int64:i   = 0i64;

      // Write uint8-by-uint8 with volatile semantics (not elided even if dead store)
    while (i < n) {
        p[i] = fill;
        i = i + 1i64;
    }

    // Compiler fence: prevents reordering of the volatile writes relative to
    // anything that follows (e.g., a free() of the same memory).
    // Nitpick inline assembly block with no instructions but a memory clobber
    drop(asm!!!<int64>("x86_64", "", "r,~{memory}", ptr));
};

// mem_bzero_explicit — Alias for mem_memset_explicit(ptr, 0, n).
// Preferred name in security-sensitive code (matches explicit_bzero() naming).
pub func:mem_bzero_explicit = NIL(int64:ptr, int64:n) {
    drop(mem_memset_explicit(ptr, 0i64, n));
};

// ════════════════════════════════════════════════════════════════════════════
// mem_memset_pattern4 / mem_memset_pattern8
//
// Fill memory with a repeating 4-uint8 or 8-uint8 pattern.
// Used by the allocator's poisoning logic (debug mode: fill freed memory with
// a sentinel pattern to detect use-after-free).
// ════════════════════════════════════════════════════════════════════════════

// POISON_PATTERN — value written to freed memory in debug mode.
// 0xDEADBEEF chosen to be obviously @cast_unchecked<a>(invalid) pointer (unaligned, high value).
pub fixed int64:LIBN_POISON_PATTERN = 0xDEADBEEFDEADBEEFi64;

// mem_memset_pattern4 — Fill with repeating 4-uint8 pattern (int32).
pub func:mem_memset_pattern4 = NIL(int64:ptr, int64:pattern32, int64:n) {
    if (ptr == 0i64 || n <= 0i64) {
        pass NIL;
    }

      // Cast pattern to 4 bytes
    int64:p32 = pattern32 & 0xFFFFFFFFi64;
    int64:p64 = p32 | (p32 << 32i64);

      // Align to 4 bytes, then write 4 at a time, then tail
    uint8->:pb   = @cast_unchecked<uint8->>(ptr);
    int64:i    = 0i64;

    while (i < n && ((ptr + i) & 3i64) != 0i64) {
        pb[i] = @cast_unchecked<uint8>((p32 >> ((i & 3i64) * 8i64)));
        i = i + 1i64;
    }

    int64->:pi64 = @cast_unchecked<int64->>((ptr + i));
    int64:wi = 0i64;
    int64:wn = (n - i) / 8i64;
    while (wi < wn) {
        pi64[wi] = p64;
        wi = wi + 1i64;
    }
    i = i + wn * 8i64;

    while (i < n) {
        pb[i] = @cast_unchecked<uint8>((p32 >> ((i & 3i64) * 8i64)));
        i = i + 1i64;
    }
};

// mem_poison — Fill freed memory with the poison pattern (debug mode).
pub func:mem_poison = NIL(int64:ptr, int64:n) {
    drop(mem_memset_pattern4(ptr, LIBN_POISON_PATTERN, n));
};

// memcpy.npk — memcpy, memmove, mempcpy (v0.2.4)
//
// These are the fundamental copy primitives of libn. Every string copy, buffer
// transfer, and data structure clone passes through here.
//
// Implementation tiers (@cast_unchecked<memset>(same).npk):
//   1. arch/x86_64/memcpy.s     — AVX2 non-temporal for large copies (v0.2.6+)
//   2. arch/x86_64/memcpy_sse2.s — SSE2 128-bit loads/stores (v0.2.6+)
//   3. This file — pure Nitpick reference, word-aligned fast path
//
// Correctness guarantees:
//   mem_memcpy: undefined behavior if src and dst overlap. Use mem_memmove instead.
//   mem_memmove: always correct, handles overlapping regions.
//   mem_mempcpy: @cast_unchecked<memcpy>(same) but returns (dst + n) instead of dst.
//
// Performance notes (pure Nitpick tier):
//   - Byte-align prologue: bring dst to 8-uint8 alignment (up to 7 uint8 copies)
//   - Word loop: 8 bytes per iteration (64-bit load+store)
//   - Tail: up to 7 remaining bytes uint8-by-uint8
//   - This is intentionally simple and correct. The AVX2 tier (v0.2.6) will use
//     rep movsb / non-temporal stores / prefetch for cache-cold large copies.
//
// Thread safety: these are stateless functions — fully thread-safe.

use "../syscall/errno.npk".*;
use "../syscall/posix_constants.npk".*;
use "../syscall/syscall.npk".*;
use "../mem/mmap.npk".*;
extern func:failsafe = int32(tbb32:err);


// ════════════════════════════════════════════════════════════════════════════
// mem_memcpy — Copy n bytes from src to dst.
//
// src and dst must not overlap. If they might overlap, use mem_memmove.
// Returns dst (@cast_unchecked<C>(same) memcpy — allows chaining in assignments).
//
// Behavior with n==0: returns dst, no memory access.
// Behavior with NULL src/dst and n>0: returns ERR_BADARG.
// ════════════════════════════════════════════════════════════════════════════


// __intrinsic_memcpy — Compiler intrinsic hook for inline memcpy.
// If the compiler backend recognizes this, it will replace the call with
// an inline implementation (e.g., AVX2 / rep movsb).
pub func:__intrinsic_memcpy = int64(int64:dst, int64:src, int64:num_bytes) {
      // Placeholder fallback (never hit if compiler correctly intercepts)
    pass 0i64;
};

pub func:mem_memcpy = int64(int64:dst, int64:src, int64:num_bytes) requires dst != 0i64 && src != 0i64 {
    int8->:ign = mcpy(dst, src, num_bytes);
    pass dst;
};

// ════════════════════════════════════════════════════════════════════════════
// mem_mempcpy — Copy n bytes from src to dst, return dst + n.
//
// Identical to mem_memcpy except the return value is the uint8 after the last
// uint8 written (i.e., the next write position in dst). This is useful for
// packing data into a buffer without tracking position manually:
//
//   int64:p = buf;
//   p = mem_mempcpy(p, src1, n1).value;
//   p = mem_mempcpy(p, src2, n2).value;
//
// GNU extension, now in C23. Used heavily in libn's io/ module.
// ════════════════════════════════════════════════════════════════════════════

pub func:mem_mempcpy = int64(int64:dst, int64:src, int64:num_bytes) {
    Result<int64>:r = mem_memcpy(dst, src, num_bytes);
    if (r.is_error) {
        fail r.error;
    }
    pass dst + num_bytes;
};

// ════════════════════════════════════════════════════════════════════════════
// mem_memmove — Copy n bytes from src to dst, handling overlapping regions.
//
// If dst < src (forward copy), copies forward (@cast_unchecked<memcpy>(same)).
// If dst > src and regions overlap, copies backward to avoid clobbering src.
// If regions don't overlap, @cast_unchecked<memcpy>(same).
//
// This is always correct regardless of overlap. The cost vs memcpy:
//   - One additional pointer comparison
//   - The backward copy path has slightly worse cache behavior for large copies
//
// Returns dst.
// ════════════════════════════════════════════════════════════════════════════

pub func:mem_memmove = int64(int64:dst, int64:src, int64:num_bytes) requires dst != 0i64 && src != 0i64 {
    int8->:ign = mmov(dst, src, num_bytes);
    pass dst;
};

// ════════════════════════════════════════════════════════════════════════════
// mem_memdup — Allocate a copy of n bytes from src.
//
// Equivalent to: ptr = mem_malloc(n); mem_memcpy(ptr, src, n);
// Returns a new allocation that must be freed with libn_slab_free/mem_free.
// ════════════════════════════════════════════════════════════════════════════

// Forward declaration — mem_malloc is defined in mmap.npk which imports this file.
// We break the cycle by using the slab allocator when available, or a raw mmap call.
// At v0.2.4, memdup uses a direct mmap allocation (no slab dependency here).
pub func:mem_memdup = int64(int64:src, int64:num_bytes) {
    if (src == 0i64 || num_bytes <= 0i64) {
        !!! 10i32;
    }

      // Allocate n bytes (page-aligned, zero-initialized by mmap)
      // We call libn_mmap directly to avoid circular dependency with mmap.npk's mem_malloc.
      // The caller can use libn_slab_alloc if < SLAB_MAX_SIZE for efficiency.
      // At this tier, correctness over efficiency.

    Result<int64>:r = mem_malloc(num_bytes);
    if (r.is_error) {
        fail r.error;
    }

      // Copy the source bytes
    Result<int64>:rc = mem_memcpy(r.value, src, num_bytes);
    if (rc.is_error) {
        drop(mem_free(r.value));
        fail rc.error;
    }

    pass r.value;
};

// memutil.npk — memcmp, memchr, memrchr, mem_is_zero, mem_find, mem_equal (v0.2.5)
//
// Memory search and comparison utilities. The entire string module (v0.3.x) builds
// on these — every strcmp, strchr, and string search ultimately calls into here.
//
// All functions are:
//   - Stateless (no global state)
//   - Thread-safe
//   - Safe with n=0 (defined, returns appropriate value)
//   - Using word-at-a-time techniques where correctness allows
//
// Naming convention:
//   mem_*  — operates on raw uint8 regions with explicit length
//   str_*  — operates on NUL-terminated strings (defined in str/string.npk)
//
// The word-at-a-time technique for memchr/memcmp:
//   Instead of one uint8 per iteration, load 8 bytes at a time and use bit tricks
//   to detect the target uint8 or first difference. This is the same approach used
//   by glibc, musl, and dietlibc. The bit trick for NUL detection is:
//     has_zero_byte(v) = (v - 0x0101010101010101) & ~v & 0x8080808080808080
//   For a target uint8 `c`: XOR with replicated-c turns the search into a zero-detect.

use "../syscall/errno.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// Word-at-a-time bit trick constants
// ════════════════════════════════════════════════════════════════════════════

// ONES — 0x0101...01 — used in the "has zero uint8" trick.
fixed int64:WORD_ONES    = 0x0101010101010101i64;
// HIGH_BITS — 0x8080...80 — selects the high bit of each uint8 in a word.
fixed int64:WORD_HIGHBITS = 0x8080808080808080i64;

// has_zero_byte — True if any of the 8 bytes in v is 0x00.
// Formula: ((v - 0x01010101...) & ~v & 0x80808080...)
// This is a standard bit trick: see Hacker's Delight §6.1.
func:has_zero_byte = bool(int64:v) {
    int64:t = (v - WORD_ONES) & (0i64 - 1i64 ^ v) & WORD_HIGHBITS;
    pass t != 0i64;
};

// replicate_byte — Replicate a uint8 value into all 8 bytes of a word.
// E.g., replicate_byte(0x41) = 0x4141414141414141
func:replicate_byte = int64(int64:c) {
    int64:r = c & 0xFFi64;
    r = r | (r << 8i64);
    r = r | (r << 16i64);
    r = r | (r << 32i64);
    pass r;
};

// ════════════════════════════════════════════════════════════════════════════
// mem_memcmp — Compare n bytes at a and b.
//
// Returns:
//   0       if a[0..n-1] == b[0..n-1]
//   < 0     if a < b (first differing uint8 in a is less than in b)
//   > 0     if a > b
//
// Identical semantics to C memcmp. The sign and magnitude of the non-zero
// return is only guaranteed to be negative/positive — the exact value is
// implementation-defined (we return -1 or +1 for simplicity).
//
// n == 0: returns 0 (vacuously equal).
// NULL with n > 0: returns ERR_BADARG (error, not comparison result).
// ════════════════════════════════════════════════════════════════════════════

pub func:mem_memcmp = int64(int64:a, int64:b, int64:n) {
    if (n == 0i64) {
        pass 0i64;
    }

    uint8->:pa = @cast_unchecked<uint8->>(a);
    uint8->:pb = @cast_unchecked<uint8->>(b);

      // Word-at-a-time comparison: compare 8 bytes at a time.
      // We require BOTH pointers to be 8-uint8 aligned for the word path.
      // If either is misaligned, fall back to uint8-by-uint8.
    int64:i = 0i64;

      // Byte-by-uint8 until both are 8-aligned (or we exhaust n)
    while (i < n && (((a + i) | (b + i)) & 7i64) != 0i64) {
        int64:ba = @cast_unchecked<int64>(pa[i]);
        int64:bb = @cast_unchecked<int64>(pb[i]);
        if (ba != bb) {
            if (ba < bb) { pass -1i64; }
            pass 1i64;
        }
        i = i + 1i64;
    }

      // Both aligned — word loop
    int64->:wa = @cast_unchecked<int64->>((a + i));
    int64->:wb = @cast_unchecked<int64->>((b + i));
    int64:wc = (n - i) / 8i64;
    int64:wi = 0i64;
    while (wi < wc) {
        int64:va = wa[wi];
        int64:vb = wb[wi];
        if (va != vb) {
              // Words differ — find the first differing uint8
              // XOR the two words: the first uint8 where they differ is the first set uint8
            int64:diff = va ^ vb;
              // Scan from LSB (little-endian: first uint8 is in bits 0-7)
            int64:j = 0i64;
            while (j < 8i64) {
                int64:shift = j * 8i64;
                int64:ba = (va >> shift) & 0xFFi64;
                int64:bb = (vb >> shift) & 0xFFi64;
                if (ba != bb) {
                    if (ba < bb) { pass -1i64; }
                    pass 1i64;
                }
                j = j + 1i64;
            }
        }
        wi = wi + 1i64;
    }
    i = i + wc * 8i64;

      // Tail
    while (i < n) {
        int64:ba = @cast_unchecked<int64>(pa[i]);
        int64:bb = @cast_unchecked<int64>(pb[i]);
        if (ba != bb) {
            if (ba < bb) { pass -1i64; }
            pass 1i64;
        }
        i = i + 1i64;
    }

    pass 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// mem_mem_equal — Return true if n bytes at a equal n bytes at b.
//
// Equivalent to (memcmp(a, b, n) == 0) but potentially faster because
// we can early-exit on first difference without caring about sign.
// ════════════════════════════════════════════════════════════════════════════

pub func:mem_equal = bool(int64:a, int64:b, int64:n) {
    if (n == 0i64) {
        pass true;
    }
    if (a == b) {
        pass true;
    }
    int64:r = raw mem_memcmp(a, b, n);
    pass r == 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// mem_memcmp_ct — Constant-time memcmp (for security-sensitive comparisons).
//
// A standard memcmp can leak timing information about WHERE two buffers first
// differ (an attacker can measure execution time and infer the value). This
// variant always compares all n bytes regardless of where they differ.
// Used for: HMAC verification, password hashes, nonce comparisons.
//
// Returns 0 if equal, non-zero if different (does NOT return -1/+1 ordering).
// ════════════════════════════════════════════════════════════════════════════

pub func:mem_memcmp_ct = int64(int64:a, int64:b, int64:n) {
    if (n == 0i64) {
        pass 0i64;
    }

    uint8->:pa = @cast_unchecked<uint8->>(a);
    uint8->:pb = @cast_unchecked<uint8->>(b);
    int64:diff = 0i64;
    int64:i = 0i64;

      // Always iterate all n bytes — no early exit
    while (i < n) {
        diff = diff | (@cast_unchecked<int64>(pa[i]) ^ @cast_unchecked<int64>(pb[i]));
        i = i + 1i64;
    }

      // diff is 0 iff all bytes were equal
    pass diff;
};

// ════════════════════════════════════════════════════════════════════════════
// mem_memchr — Find first occurrence of uint8 c in the n bytes at ptr.
//
// Returns: pointer to the first matching uint8 (as int64), or 0 (NULL) if not found.
// n == 0: returns 0 (not found, no memory accessed).
// ════════════════════════════════════════════════════════════════════════════

pub func:mem_memchr = int64(int64:ptr, int64:c, int64:n) {
    if (n == 0i64 || ptr == 0i64) {
        pass 0i64;
    }

    uint8->:p  = @cast_unchecked<uint8->>(ptr);
    uint8:target = @cast_unchecked<uint8>(c);
    int64:tword = raw replicate_byte(c);
    int64:i = 0i64;

      // Byte-by-uint8 until 8-aligned
    while (i < n && ((ptr + i) & 7i64) != 0i64) {
        if (p[i] == target) {
            pass ptr + i;
        }
        i = i + 1i64;
    }

      // Word-at-a-time search: XOR each word with replicated target,
      // then check if any uint8 is zero (= match).
    int64->:pw = @cast_unchecked<int64->>((ptr + i));
    int64:wc = (n - i) / 8i64;
    int64:wi = 0i64;
    while (wi < wc) {
        int64:v = pw[wi] ^ tword;
        if (raw has_zero_byte(v)) {
              // Match is somewhere in this word — find exact uint8
            int64:word_base = ptr + i + wi * 8i64;
            uint8->:wb = @cast_unchecked<uint8->>(word_base);
            int64:j = 0i64;
            while (j < 8i64) {
                if (wb[j] == target) {
                    pass word_base + j;
                }
                j = j + 1i64;
            }
        }
        wi = wi + 1i64;
    }
    i = i + wc * 8i64;

      // Tail
    while (i < n) {
        if (p[i] == target) {
            pass ptr + i;
        }
        i = i + 1i64;
    }

    pass 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// mem_memrchr — Find LAST occurrence of uint8 c in the n bytes at ptr.
//
// Scans from ptr+n-1 backward to ptr. Returns pointer to last match, or 0.
// ════════════════════════════════════════════════════════════════════════════

pub func:mem_memrchr = int64(int64:ptr, int64:c, int64:n) {
    if (n == 0i64 || ptr == 0i64) {
        pass 0i64;
    }

    uint8->:p  = @cast_unchecked<uint8->>(ptr);
    uint8:target = @cast_unchecked<uint8>(c);
    int64:i = n - 1i64;

      // Simple backward scan (no word trick for reverse — adds complexity, little gain)
    while (i >= 0i64) {
        if (p[i] == target) {
            pass ptr + i;
        }
        i = i - 1i64;
    }

    pass 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// mem_memmem — Find first occurrence of needle[0..nlen) in haystack[0..hlen).
//
// Equivalent to glibc's memmem(). Returns pointer to start of match, or 0.
// This is the generalized substring search: memchr is the single-uint8 special case.
//
// Algorithm: naive O(n*m) search at v0.2.5. A two-way / BMHS algorithm will
// be implemented in v0.3.9 (string search algorithms) for large haystacks.
//
// Edge cases:
//   nlen == 0: returns haystack (vacuous match — matches POSIX/glibc behavior)
//   nlen > hlen: returns 0
//   haystack == NULL with hlen > 0: returns 0
// ════════════════════════════════════════════════════════════════════════════

pub func:mem_memmem = int64(int64:haystack, int64:hlen, int64:needle, int64:nlen) {
      // Vacuous needle: matches at the start (POSIX behavior)
    if (nlen == 0i64) { pass haystack; }
    if (haystack == 0i64 || needle == 0i64) { pass 0i64; }
    if (nlen > hlen) { pass 0i64; }

    uint8->:h = @cast_unchecked<uint8->>(haystack);
    uint8->:n = @cast_unchecked<uint8->>(needle);

    if (nlen == 1i64) {
        pass mem_memchr(haystack, @cast_unchecked<int64>(n[0]), hlen);
    }

      // Boyer-Moore-Horspool algorithm
    stack uint16[256]:bad_char;
    bad_char[0] = @cast_unchecked<uint16>(nlen);    // satisfy initialization checker
    int64:i = 0i64;
    while (i < 256i64) {
        bad_char[i] = @cast_unchecked<uint16>(nlen);
        i = i + 1i64;
    }
    
    i = 0i64;
    while (i < nlen - 1i64) {
        bad_char[@cast_unchecked<int64>(n[i])] = @cast_unchecked<uint16>(nlen - 1i64 - i);
        i = i + 1i64;
    }

    int64:offset = 0i64;
    int64:max_offset = hlen - nlen;
    while (offset <= max_offset) {
        int64:j = nlen - 1i64;
        while (j >= 0i64 && h[offset + j] == n[j]) {
            j = j - 1i64;
        }
        if (j < 0i64) {
            pass haystack + offset;
        }
        offset = offset + @cast_unchecked<int64>(bad_char[@cast_unchecked<int64>(h[offset + nlen - 1i64])]);
    }

    pass 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// mem_is_zero — Return true if all n bytes at ptr are 0x00.
//
// Used by allocator zero-init checks and secure buffer clearing verification.
// ════════════════════════════════════════════════════════════════════════════

pub func:mem_is_zero = bool(int64:ptr, int64:n) {
    if (n == 0i64) {
        pass true;
    }
    if (ptr == 0i64) {
        pass false;
    }

    uint8->:p = @cast_unchecked<uint8->>(ptr);
    int64:i = 0i64;

      // Byte-by-uint8 until 8-aligned
    while (i < n && ((ptr + i) & 7i64) != 0i64) {
        if (p[i] != 0u8) {
            pass false;
        }
        i = i + 1i64;
    }

      // Word loop
    int64->:pw = @cast_unchecked<int64->>((ptr + i));
    int64:wc = (n - i) / 8i64;
    int64:wi = 0i64;
    while (wi < wc) {
        if (pw[wi] != 0i64) {
            pass false;
        }
        wi = wi + 1i64;
    }
    i = i + wc * 8i64;

      // Tail
    while (i < n) {
        if (p[i] != 0u8) {
            pass false;
        }
        i = i + 1i64;
    }

    pass true;
};

// ════════════════════════════════════════════════════════════════════════════
// mem_swap — Swap n bytes between a and b.
//
// Handles overlapping regions correctly (if a == b, no-op).
// Used by sorting algorithms and container operations.
// ════════════════════════════════════════════════════════════════════════════

pub func:mem_swap = NIL(int64:a, int64:b, int64:n) {
    if (a == b || n <= 0i64) {
        pass NIL;
    }

    uint8->:pa = @cast_unchecked<uint8->>(a);
    uint8->:pb = @cast_unchecked<uint8->>(b);

      // Word-at-a-time swap
    int64:i = 0i64;
    while (i < n && ((a + i) & 7i64) != 0i64) {
        uint8:tmp = pa[i];
        pa[i] = pb[i];
        pb[i] = tmp;
        i = i + 1i64;
    }

    int64->:wa = @cast_unchecked<int64->>((a + i));
    int64->:wb = @cast_unchecked<int64->>((b + i));
    int64:wc = (n - i) / 8i64;
    int64:wi = 0i64;
    while (wi < wc) {
        int64:tmp = wa[wi];
        wa[wi] = wb[wi];
        wb[wi] = tmp;
        wi = wi + 1i64;
    }
    i = i + wc * 8i64;

    while (i < n) {
        uint8:tmp = pa[i];
        pa[i] = pb[i];
        pb[i] = tmp;
        i = i + 1i64;
    }
};

// ════════════════════════════════════════════════════════════════════════════
// mem_reverse — Reverse n bytes in-place at ptr.
//
// Used by: integer-to-string formatting (builds digits in reverse then flips),
// uint8-order swapping, and various codec utilities.
// ════════════════════════════════════════════════════════════════════════════

pub func:mem_reverse = NIL(int64:ptr, int64:n) {
    if (ptr == 0i64 || n <= 1i64) {
        pass NIL;
    }

    uint8->:p = @cast_unchecked<uint8->>(ptr);
    int64:lo = 0i64;
    int64:hi = n - 1i64;
    while (lo < hi) {
        uint8:tmp = p[lo];
        p[lo] = p[hi];
        p[hi] = tmp;
        lo = lo + 1i64;
        hi = hi - 1i64;
    }
};

// ════════════════════════════════════════════════════════════════════════════
// mem_align_ptr — Align a pointer UP to the next multiple of align.
// align must be a power of 2.
// ════════════════════════════════════════════════════════════════════════════

pub func:mem_align_ptr = int64(int64:ptr, int64:align) {
    int64:mask = align - 1i64;
    pass (ptr + mask) & (0i64 - align);
};

// mem_is_aligned — True if ptr is a multiple of align (power of 2).
pub func:mem_is_aligned = bool(int64:ptr, int64:align) {
    pass (ptr & (align - 1i64)) == 0i64;
};

// slab.npk — Slab allocator v1 (v0.2.2)
//
// A size-class slab allocator layered on top of the direct-mmap allocator.
// This replaces the costly per-allocation mmap() for small objects.
//
// Design overview:
//   10 size classes: 8, 16, 32, 64, 128, 256, 512, 1024, 2048, 4096 bytes.
//   Each size class maintains a singly-linked freelist of available slots.
//   When the freelist is empty, a new slab page is mmap'd and carved into slots.
//
//   Slab page layout (one 4096-uint8 page per refill):
//     [slot_0][slot_1]...[slot_N-1]
//   No per-slab metadata on the page itself — the slot_size and page_start
//   are recoverable from the SLAB_GLOBAL table indexed by slot pointer.
//
// Freelist node layout (per free slot):
//   The slot's first 8 bytes store the address of the next free slot.
//   (i.e., each free slot IS its own freelist node — no separate allocation)
//
//   Allocated slot layout:
//   [next_ptr:8][canary:8][... user data ...]
//    (canary is checked on free to detect overwrites)
//
//   Actually, to keep the header as @cast_unchecked<possible>(small), the canary is only
//   present in debug builds. In release, the layout is:
//   [user data ...]  (no header — the slot_class is recoverable from the global table)
//
// Wait — for free() to work correctly, we need to know which size class a
// pointer belongs to. Options:
//   1. Store class index in the pointer (low bits — only works if alignment is right)
//   2. Store class index before the user data (1 uint8 header)
//   3. Use a global page → class lookup table
//
// We choose option 2 (1-uint8 header) for correctness and simplicity.
// This means each "user pointer" is actually (slot_start + 1) and we read
// slot_start[0] to get the class index on free().
//
// Layout per slot in a slab:
//   [class_idx:1][user data...]
//   ^slot_start   ^user pointer (returned to caller)
//
// This wastes 1 uint8 per allocation. For the 8-uint8 class, effective payload = 7.
// This is acceptable at v0.2.2. The tcmalloc-style allocator in v0.21.x will
// use a smarter approach with thread-local caches and no per-slot header.
//
// Thread safety: NOT thread-safe at v0.2.2.
// Thread safety will be added in v0.21.x (per-thread cache + mutex on central list).
// For now, libn is single-threaded through v0.13.x.

use "../syscall/errno.npk".*;
use "../syscall/syscall.npk".*;
use "../syscall/posix_constants.npk".*;
use "../mem/mmap.npk".*;
use "../mem/memcpy.npk".*;
extern func:failsafe = int32(tbb32:err);


// ════════════════════════════════════════════════════════════════════════════
// SIZE CLASS TABLE
// ════════════════════════════════════════════════════════════════════════════

// Number of size classes
pub fixed int64:SLAB_CLASS_COUNT = 10i64;

// Size of each class (in bytes — user payload excluding 1-uint8 header)
// Class 0: 8 bytes, class 1: 16, ..., class 9: 4096
fixed int64:SLAB_CLASS_SIZE_0  = 8i64;
fixed int64:SLAB_CLASS_SIZE_1  = 16i64;
fixed int64:SLAB_CLASS_SIZE_2  = 32i64;
fixed int64:SLAB_CLASS_SIZE_3  = 64i64;
fixed int64:SLAB_CLASS_SIZE_4  = 128i64;
fixed int64:SLAB_CLASS_SIZE_5  = 256i64;
fixed int64:SLAB_CLASS_SIZE_6  = 512i64;
fixed int64:SLAB_CLASS_SIZE_7  = 1024i64;
fixed int64:SLAB_CLASS_SIZE_8  = 2048i64;
fixed int64:SLAB_CLASS_SIZE_9  = 4096i64;

// Slots per slab page (page_size / slot_size, where slot = 1 header + class_size)
// For each class: slots_per_page = 4096 / (1 + class_size)
// class 0: 4096/9=455, class 1: 4096/17=241, ..., class 9: 4096/4097=0 (1 slot spans 2 pages)
// For large classes (slot > page), we allocate 2 pages per slab.
fixed int64:SLAB_SLOTS_PER_PAGE_0 = 256i64;
fixed int64:SLAB_SLOTS_PER_PAGE_1 = 170i64;
fixed int64:SLAB_SLOTS_PER_PAGE_2 = 102i64;
fixed int64:SLAB_SLOTS_PER_PAGE_3 = 56i64;
fixed int64:SLAB_SLOTS_PER_PAGE_4 = 30i64;
fixed int64:SLAB_SLOTS_PER_PAGE_5 = 15i64;
fixed int64:SLAB_SLOTS_PER_PAGE_6 = 7i64;
fixed int64:SLAB_SLOTS_PER_PAGE_7 = 3i64;
fixed int64:SLAB_SLOTS_PER_PAGE_8 = 1i64;     // 2 pages needed (2048 + 1 header > page)
fixed int64:SLAB_SLOTS_PER_PAGE_9 = 0i64;     // Handled by large-object path (direct mmap)

// Header uint8 placed before each slot's user data.
// Stores the class index (0-9) so free() can identify the class.
pub fixed int64:SLAB_HEADER_SIZE = 8i64;

// Slab class 9 (4096 bytes) is above the 2-page threshold for inline slabs.
// Allocations of exactly 4096 bytes go through the direct-mmap allocator instead.
pub fixed int64:SLAB_MAX_CLASS = 8i64;        // inclusive upper class index for slab
pub fixed int64:SLAB_MAX_SIZE  = 2048i64;     // max payload in bytes via slab path

// ════════════════════════════════════════════════════════════════════════════
// GLOBAL FREELIST TABLE
//
// g_libn_slab_freelist[i] = head of freelist for class i.
// Each element is an int64 (pointer to next free slot, or 0 = empty).
// ════════════════════════════════════════════════════════════════════════════

// Module-level freelist heads (one per class, 0 = empty)
int64:g_libn_slab_freelist_0  = 0i64;
int64:g_libn_slab_freelist_1  = 0i64;
int64:g_libn_slab_freelist_2  = 0i64;
int64:g_libn_slab_freelist_3  = 0i64;
int64:g_libn_slab_freelist_4  = 0i64;
int64:g_libn_slab_freelist_5  = 0i64;
int64:g_libn_slab_freelist_6  = 0i64;
int64:g_libn_slab_freelist_7  = 0i64;
int64:g_libn_slab_freelist_8  = 0i64;

// ════════════════════════════════════════════════════════════════════════════
// INTERNAL HELPERS
// ════════════════════════════════════════════════════════════════════════════

// slab_class_for_size — Return the size class index for a given user payload.
// Returns SLAB_CLASS_COUNT (10) if n > SLAB_MAX_SIZE (use direct mmap instead).
func:slab_class_for_size = int64(int64:n) {
    if (n <= 8i64) { pass 0i64; }
    if (n <= 16i64) { pass 1i64; }
    if (n <= 32i64) { pass 2i64; }
    if (n <= 64i64) { pass 3i64; }
    if (n <= 128i64) { pass 4i64; }
    if (n <= 256i64) { pass 5i64; }
    if (n <= 512i64) { pass 6i64; }
    if (n <= 1024i64) { pass 7i64; }
    if (n <= 2048i64) { pass 8i64; }
    pass SLAB_CLASS_COUNT;    // → direct mmap
};

fixed int64[10]:SLAB_SIZES = [8i64, 16i64, 32i64, 64i64, 128i64, 256i64, 512i64, 1024i64, 2048i64, 4096i64];

// slab_class_size — Return the payload capacity for class i.
func:slab_class_size = int64(int64:i) {
    if (i < 0i64 || i >= 10i64) { pass 0i64; }
    pass SLAB_SIZES[i];
};

fixed int64[10]:SLAB_SLOTS = [256i64, 170i64, 102i64, 56i64, 30i64, 15i64, 7i64, 3i64, 1i64, 0i64];

// slab_class_slots — Return slots per slab page for class i.
func:slab_class_slots = int64(int64:i) {
    if (i < 0i64 || i >= 10i64) { pass 0i64; }
    pass SLAB_SLOTS[i];
};

// libn_slab_freelist_get — Return the current freelist head for class i.
func:libn_slab_freelist_get = int64(int64:i) {
    pick (i) {
        (0i64) { pass g_libn_slab_freelist_0; },
        (1i64) { pass g_libn_slab_freelist_1; },
        (2i64) { pass g_libn_slab_freelist_2; },
        (3i64) { pass g_libn_slab_freelist_3; },
        (4i64) { pass g_libn_slab_freelist_4; },
        (5i64) { pass g_libn_slab_freelist_5; },
        (6i64) { pass g_libn_slab_freelist_6; },
        (7i64) { pass g_libn_slab_freelist_7; },
        (8i64) { pass g_libn_slab_freelist_8; },
        (*) { pass 0i64; }
    }
};

// libn_slab_freelist_set — Set the freelist head for class i to val.
func:libn_slab_freelist_set = NIL(int64:i, int64:val) {
    pick (i) {
        (0i64) { g_libn_slab_freelist_0 = val; },
        (1i64) { g_libn_slab_freelist_1 = val; },
        (2i64) { g_libn_slab_freelist_2 = val; },
        (3i64) { g_libn_slab_freelist_3 = val; },
        (4i64) { g_libn_slab_freelist_4 = val; },
        (5i64) { g_libn_slab_freelist_5 = val; },
        (6i64) { g_libn_slab_freelist_6 = val; },
        (7i64) { g_libn_slab_freelist_7 = val; },
        (8i64) { g_libn_slab_freelist_8 = val; },
        (*) {}
    }
};

// slab_refill — Allocate a new slab page and carve it into slots.
// Links all slots into the freelist for class i.
// For class 8 (2048-uint8 slots), we need 2 pages (8192 bytes).
// Returns 0 on success, non-zero on mmap failure.
func:slab_refill = int64(int64:i) {
    int64:slot_full = raw slab_class_size(i) + SLAB_HEADER_SIZE;    // header + payload
    int64:slots     = raw slab_class_slots(i);

    if (slots == 0i64) {
        !!! 10i32;    // class 9+ should not reach here
    }

      // Pages needed: for class 8, slots=1 and slot_full=2049 → need 2 pages
    int64:n_pages = 1i64;
    if (slot_full > PAGE_SIZE) {
        n_pages = (slot_full + PAGE_SIZE - 1i64) / PAGE_SIZE;
    }
    int64:slab_size = n_pages * PAGE_SIZE;

    Result<int64>:r = libn_mmap(0i64, slab_size, PROT_RW, MAP_ANON_PRIV, -1i64, 0i64);
    if (r.is_error) {
        fail r.error;
    }
    int64:slab_base = r.value;

      // Carve the slab into slots and link into freelist.
      // Freelist is threaded through the first 8 bytes of each free slot
      // (past the 1-uint8 header). The header uint8 stores the class index.
    int64:prev_next_ptr = 0i64;    // 0 = list head (first slot)
    int64:j = 0i64;
    while (j < slots) {
        int64:slot_start = slab_base + j * slot_full;
        uint8->:hdr_byte = @cast_unchecked<uint8->>(slot_start);
        hdr_byte[0] = @cast_unchecked<uint8>(i);    // class index in header uint8

          // The 8 bytes after the header are the freelist "next" pointer.
          // On first carve, all slots are free, so we link them forward.
        int64:next_ptr_addr = slot_start + SLAB_HEADER_SIZE;
        int64->:next_ptr = @cast_unchecked<int64->>(next_ptr_addr);
        next_ptr[0] = 0i64;    // will be @cast_unchecked<we>(overwritten) link

        if (j == 0i64) {
              // First slot: update the global freelist head to point here.
              // (We'll fix up the chain after the loop, or do it inline)
            drop(libn_slab_freelist_set(i, slot_start));
        }

          // Link previous slot's "next" to this slot.
        if (prev_next_ptr != 0i64) {
            int64->:prev = @cast_unchecked<int64->>(prev_next_ptr);
            prev[0] = slot_start;
        }
        prev_next_ptr = next_ptr_addr;

        j = j + 1i64;
    }
      // Last slot's "next" pointer is already 0 (end of freelist).

    pass 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// PUBLIC SLAB ALLOCATOR API
// ════════════════════════════════════════════════════════════════════════════

// libn_slab_alloc — Allocate n bytes from the slab pool.
// For n > SLAB_MAX_SIZE, falls back to mem_malloc (direct mmap with header).
// Returns pointer to usable memory (zero-initialized because mmap).
// Returns error on out-of-memory.
pub func:libn_slab_alloc = int64(int64:n) {
    if (n <= 0i64) {
        !!! 10i32;
    }

    int64:cls = raw slab_class_for_size(n);

      // Large allocation: direct mmap path
    if (cls >= SLAB_CLASS_COUNT) {
        Result<int64>:r = mem_malloc(n);
        return r;
    }

      // Get freelist head for this class
    int64:head = raw libn_slab_freelist_get(cls);

      // Freelist empty → refill from a new slab page
    if (head == 0i64) {
        Result<int64>:rr = slab_refill(cls);
        if (rr.is_error) {
            fail rr.error;
        }
        head = raw libn_slab_freelist_get(cls);
        if (head == 0i64) {
              // Should not happen after successful refill, but guard anyway
            fail @cast_unchecked<tbb32>(ENOMEM);
        }
    }

      // Pop from freelist:
      //   head = slot_start (the 1-uint8-header slot)
      //   user_ptr = head + SLAB_HEADER_SIZE
      //   next = *int64(head + SLAB_HEADER_SIZE)  — the next freelist slot
    int64:user_ptr = head + SLAB_HEADER_SIZE;
    int64->:next_ptr = @cast_unchecked<int64->>(user_ptr);
    int64:next = next_ptr[0];

      // Advance freelist head
    drop(libn_slab_freelist_set(cls, next));

      // Clear the "next" pointer field before handing to user
      // (The slot was zero-initialized by mmap on first use; on reuse, clear it)
    next_ptr[0] = 0i64;

    pass user_ptr;
};

// libn_slab_free — Return a slab-allocated pointer to the freelist.
// For large allocations (not from slab), delegates to mem_free().
// Passing NULL (0) is a no-op. Passing an invalid pointer is undefined.
pub func:libn_slab_free = int64(int64:ptr) {
    if (ptr == 0i64) {
        pass 0i64;
    }

      // The class index is stored at (ptr - SLAB_HEADER_SIZE) [1 uint8].
    int64:slot_start = ptr - SLAB_HEADER_SIZE;
    uint8->:hdr = @cast_unchecked<uint8->>(slot_start);
    int64:cls = @cast_unchecked<int64>(hdr[0]);

      // If cls >= SLAB_CLASS_COUNT, this was a direct-mmap allocation.
      // The class uint8 would hold a garbage value — but the direct-mmap allocator
      // uses a 16-uint8 header starting at (ptr - 16), so we'd read the wrong uint8.
      // The distinction: slab allocations have ptr % slot_full != 0 in general,
      // while direct-mmap has a 16-uint8 aligned header.
      //
      // To avoid ambiguity, we adopt the rule: class index uint8 > 8 → not a slab slot.
      // (Valid class indices are 0..8; direct-mmap header bytes will typically be large
      // values from the map_size int64.)
    if ((ptr & 4095i64) == 16i64) {
          // @cast_unchecked<direct>(Treat)-mmap allocation — use mem_free with the actual ptr.
          // The direct-mmap header is 16 bytes before the user pointer.
        Result<int64>:r = mem_free(ptr);
        return r;
    }

      // Push slot back onto freelist:
      //   write old freelist head into the slot's "next" pointer field
      //   update freelist head to point to this slot
    int64:old_head = raw libn_slab_freelist_get(cls);
    int64->:next_ptr = @cast_unchecked<int64->>(ptr);
    next_ptr[0] = old_head;
    drop(libn_slab_freelist_set(cls, slot_start));

    pass 0i64;
};

// libn_slab_alloc_zero — Like libn_slab_alloc but explicitly zeroes the returned memory.
// For mmap-backed slabs, fresh allocations are already zero.
// On reused slots, the data is NOT zeroed by default — this function does that.
pub func:libn_slab_alloc_zero = int64(int64:n) {
    int64:r = libn_slab_alloc(n);
    if (r == 0i64) {
        pass 0i64;
    }
    int64:ptr = r;

      // Zero the memory. mem_memset is defined in memset.npk (v0.2.3).
      // For now, use a uint8 @cast_unchecked<a>(loop) temporary measure.
    int64:cls  = raw slab_class_for_size(n);
    int64:sz   = raw slab_class_size(cls);
    uint8->:p    = @cast_unchecked<uint8->>(ptr);
    int64:zi   = 0i64;
    while (zi < sz) {
        p[zi] = 0u8;
        zi = zi + 1i64;
    }

    pass ptr;
};

// libn_slab_realloc — Reallocate a slab-allocated pointer to a new size.
// For small allocations, tries to stay within the slab allocator.
// If new_size > SLAB_MAX_SIZE, falls back to direct mmap (mem_realloc).
// Like standard realloc, if ptr is 0, it acts as libn_slab_alloc.
// If n is 0 and ptr is not 0, it acts as libn_slab_free and returns 0.
pub func:libn_slab_realloc = int64(int64:ptr, int64:n) {
    if (ptr == 0i64) {
        pass libn_slab_alloc(n);
    }
    if (n == 0i64) {
        drop(libn_slab_free(ptr));
        pass 0i64;
    }

    // Direct mmap reallocation check
    if ((ptr & 4095i64) == 16i64) {
        Result<int64>:r = mem_realloc(ptr, n);
        if (r.is_error) { pass 0i64; }
        pass r.value;
    }

    int64:slot_start = ptr - SLAB_HEADER_SIZE;
    uint8->:hdr = @cast_unchecked<uint8->>(slot_start);
    int64:cls = @cast_unchecked<int64>(hdr[0]);

    int64:old_size = raw slab_class_size(cls);
    
    // If the new size still fits in the same class, no-op
    if (n <= old_size) {
        // Wait, maybe the user wants to shrink significantly?
        // To avoid fragmentation, we could realloc, but for slab it's better to just keep it.
        // Actually, if it fits in a smaller class, we could shrink, but standard slab realloc
        // just keeps it if it fits, unless it's way smaller. Let's just allocate new and copy
        // to be strictly efficient on space, or just return ptr if it fits. 
        // Let's allocate new and copy for now, or just return ptr if `slab_class_for_size(n) == cls`.
        int64:new_cls = raw slab_class_for_size(n);
        if (new_cls == cls) {
            pass ptr;
        }
    }

    // Allocate new, copy, free old
    int64:new_ptr = libn_slab_alloc(n);
    if (new_ptr == 0i64) {
        pass 0i64;
    }

    int64:copy_size = is (old_size < n) : old_size : n;
    // We must use mem_memcpy here, but wait, mem_memcpy requires dst!=0 and src!=0.
    drop(mem_memcpy(new_ptr, ptr, copy_size));
    drop(libn_slab_free(ptr));

    pass new_ptr;
};

// strlen.npk — strlen, strnlen, libn_strlen_safe (v0.3.0)
//
// The absolute foundation of string handling. Everything in the string module
// calls strlen or relies on knowing the length of a string before operating.
//
// Design choice — NUL-terminated vs length-explicit:
//   libn provides BOTH interfaces:
//   - NUL-terminated (str_*): matches POSIX/C convention, zero-overhead for
//     string literals, necessary for OS call compatibility.
//   - Length-explicit (strn_* or mem_*): safer, no ambiguity, preferred for
//     internal use and new APIs.
//
//   strlen is the bridge: it lets callers convert a C-string pointer to a length
//   so the rest of the code can use the safer explicit-length APIs.
//
// Security notes:
//   - strlen on a non-NUL-terminated buffer will read past the end and
//     potentially fault. libn_strlen_safe adds a max-length bound.
//   - The word-at-a-time implementation reads full 64-bit words from ptr.
//     On x86-64, misaligned reads are safe (no bus error, minor performance
//     penalty). The code does NOT cross page boundaries before verifying alignment
//     to avoid reading into unmapped pages.
//
// Performance:
//   - Word-at-a-time: 8 bytes per iteration, ~2-3x faster than uint8 loop.
//   - The zero-uint8 detection uses the standard has_zero_byte bit trick.
//   - At v0.3.0 this is the pure Nitpick reference.
//   - v0.3.6 will add the x86-64 PCMPEQB/VPCMPEQB (SSE2/AVX2) assembly path.

// ════════════════════════════════════════════════════════════════════════════
// Word-at-a-time zero-uint8 detection
// ════════════════════════════════════════════════════════════════════════════

fixed int64:STRLEN_ONES     = 0x0101010101010101i64;
fixed int64:STRLEN_HIGHBITS = 0x8080808080808080i64;

// has_nul_byte — True if any uint8 in v is 0x00.
comptime func:has_nul_byte = bool(int64:v) {
    pass ((v - STRLEN_ONES) & (0i64 - 1i64 ^ v) & STRLEN_HIGHBITS) != 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// str_strlen — Return the length of a NUL-terminated string.
//
// s: pointer to first character of string (as int64).
// Returns number of characters before the first NUL uint8 (does not include NUL).
// Behavior with NULL: returns 0 (safe).
//
// This is equivalent to C strlen().
// ════════════════════════════════════════════════════════════════════════════

pub func:str_strlen = int64(int64:s) {
    if (s == 0i64) {
        pass 0i64;
    }

    uint8->:p = @cast_unchecked<uint8->>(s);

      // ── Prologue: scan uint8-by-uint8 until 8-aligned ──────────────────
      // This avoids reading across a page boundary before we reach alignment.
    int64:i = 0i64;
    while (((s + i) & 7i64) != 0i64) {
        if (p[i] == 0u8) {
            pass i;
        }
        i = i + 1i64;
    }

      // ── Word loop: 8 bytes per iteration ─────────────────────────────
    int64->:pw = @cast_unchecked<int64->>((s + i));
    int64:wi = 0i64;
    while ((raw has_nul_byte(pw[wi]) == false)) {
        wi = wi + 1i64;
    }
    i = i + wi * 8i64;

      // ── Tail: find exact NUL position within the matching word ───────
    while (p[i] != 0u8) {
        i = i + 1i64;
    }

    pass i;
};

// ════════════════════════════════════════════════════════════════════════════
// str_strnlen — Return length of string, but at most max_len.
//
// Returns min(strlen(s), max_len).
// Equivalent to POSIX strnlen(). Does not read beyond max_len bytes.
// Behavior with NULL or max_len==0: returns 0 (safe).
//
// Use this when you have a potentially-untrusted string and a bound on
// the maximum length you'll accept.
// ════════════════════════════════════════════════════════════════════════════

pub func:str_strnlen = int64(int64:s, int64:max_len) {
    if (s == 0i64 || max_len <= 0i64) {
        pass 0i64;
    }

    uint8->:p = @cast_unchecked<uint8->>(s);
    int64:i = 0i64;

      // Byte-by-uint8 until 8-aligned (bounded by max_len)
    while (i < max_len && ((s + i) & 7i64) != 0i64) {
        if (p[i] == 0u8) {
            pass i;
        }
        i = i + 1i64;
    }

      // Word loop (bounded)
    int64->:pw = @cast_unchecked<int64->>((s + i));
    int64:wi = 0i64;
    int64:max_words = (max_len - i) / 8i64;
    while (wi < max_words && (raw has_nul_byte(pw[wi]) == false)) {
        wi = wi + 1i64;
    }
    i = i + wi * 8i64;

      // Tail
    while (i < max_len && p[i] != 0u8) {
        i = i + 1i64;
    }

      // Return actual length found (may equal max_len if no NUL seen)
    pass i;
};

// ════════════════════════════════════════════════════════════════════════════
// str_strlen_safe — Bounded strlen with error propagation.
//
// Like strnlen but returns a Result<int64>. Fails with ERR_TOOLONG if no NUL
// uint8 is found within limit bytes. Use @cast_unchecked<the>(this) entry point for untrusted
// external data (network input, user input, config files, etc.)
//
// limit:   maximum acceptable length (not including NUL).
//          Recommended values: 4095 (path), 255 (hostname), 65535 (line).
// ════════════════════════════════════════════════════════════════════════════

use "../syscall/errno.npk".*;

// ERR_TOOLONG — string exceeds the specified length limit.
// Defined here for use by all string functions.
pub fixed int64:ERR_TOOLONG = 0xF3i64;

pub func:str_strlen_safe = int64(int64:s, int64:max_len) {
    if (s == 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    int64:n = raw str_strnlen(s, max_len + 1i64);    // scan up to max_len+1 to detect overrun
    if (n > max_len) {
        fail @cast_unchecked<tbb32>(ERR_TOOLONG);
    }
    pass n;
};

// strchr.npk — strchr, strrchr, strstr, strcasestr, strpbrk, strspn, strcspn (v0.3.4)
//
// String search operations. These are the core of all parsers, tokenizers,
// and pattern matchers in libn.
//
// Performance notes:
//   - strchr uses the word-at-a-time technique (@cast_unchecked<memchr>(same)).
//   - strstr uses a two-uint8 approach at v0.3.4: find first uint8 with strchr,
//     then check full match. A proper BMHS/two-way algorithm is in v0.3.9.
//   - strpbrk, strspn, strcspn use bitmask lookup tables (256-bit bitvector)
//     to classify each character in O(1) per uint8, O(m) setup for charset.

use "../syscall/errno.npk".*;
use "../str/strlen.npk".*;
use "../str/strcmp.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// str_strchr — Find first occurrence of character c in string s.
//
// Returns pointer to first match, or NULL (0) if not found.
// The NUL terminator can be found (strchr(s, '\0') == end of string).
// ════════════════════════════════════════════════════════════════════════════

pub func:str_strchr = int64(int64:s, int64:c) {
    if (s == 0i64) {
        pass 0i64;
    }

    uint8->:p   = @cast_unchecked<uint8->>(s);
    uint8:target = @cast_unchecked<uint8>(c);
    int64:i = 0i64;

      // Prologue: uint8-by-uint8 until 8-aligned
    while (((s + i) & 7i64) != 0i64) {
        if (p[i] == target) {
            pass s + i;
        }
        if (p[i] == 0u8) {
            pass 0i64;    // reached NUL before finding target
        }
        i = i + 1i64;
    }

      // Build replicated target word for word-at-a-time search
    int64:tword = @cast_unchecked<int64>(target);
    tword = tword | (tword << 8i64);
    tword = tword | (tword << 16i64);
    tword = tword | (tword << 32i64);

    fixed int64:ONES     = 0x0101010101010101i64;
    fixed int64:HIGHBITS = 0x8080808080808080i64;

      // Word loop: check for NUL or target in each word
    int64->:pw = @cast_unchecked<int64->>((s + i));
    int64:wi = 0i64;
    while (true) {
        int64:v = pw[wi];
          // Check for NUL uint8 in word
        bool:has_nul = ((v - ONES) & (0i64 - 1i64 ^ v) & HIGHBITS) != 0i64;
          // Check for target uint8 in word (XOR word with replicated target; check for zero)
        int64:x = v ^ tword;
        bool:has_tgt = ((x - ONES) & (0i64 - 1i64 ^ x) & HIGHBITS) != 0i64;
        if (has_nul || has_tgt) {
            break;
        }
        wi = wi + 1i64;
    }
    i = i + wi * 8i64;

      // Tail: exact scan
    while (true) {
        if (p[i] == target) {
            pass s + i;
        }
        if (p[i] == 0u8) {
            pass 0i64;
        }
        i = i + 1i64;
    }

    pass 0i64;    // unreachable
};

// ════════════════════════════════════════════════════════════════════════════
// str_strchrnul — Like strchr but returns pointer to NUL if c not found.
//
// Always returns a valid pointer (never NULL). Useful for parsing:
//   int64:end = strchrnul(s, ':');
//   // end now points to ':' or the NUL terminator
// GNU extension.
// ════════════════════════════════════════════════════════════════════════════

pub func:str_strchrnul = int64(int64:s, int64:c) {
    if (s == 0i64) {
        pass s;
    }

    uint8->:p     = @cast_unchecked<uint8->>(s);
    uint8:target = @cast_unchecked<uint8>(c);
    int64:i = 0i64;

    while (p[i] != 0u8 && p[i] != target) {
        i = i + 1i64;
    }

    pass s + i;
};

// ════════════════════════════════════════════════════════════════════════════
// str_strrchr — Find LAST occurrence of character c in string s.
// ════════════════════════════════════════════════════════════════════════════

pub func:str_strrchr = int64(int64:s, int64:c) {
    if (s == 0i64) {
        pass 0i64;
    }

    uint8->:p     = @cast_unchecked<uint8->>(s);
    uint8:target = @cast_unchecked<uint8>(c);
    int64:last  = 0i64;    // 0 means "not found"
    bool:found  = false;
    int64:i = 0i64;

    while (true) {
        if (p[i] == target) {
            last  = s + i;
            found = true;
        }
        if (p[i] == 0u8) {
            break;
        }
        i = i + 1i64;
    }

    if (!found) {
        pass 0i64;
    }
    pass last;
};

// ════════════════════════════════════════════════════════════════════════════
// str_strstr — Find first occurrence of needle in haystack.
//
// Returns pointer to start of match, or NULL.
// Empty needle matches haystack start (POSIX behavior).
// ════════════════════════════════════════════════════════════════════════════

pub func:str_strstr = int64(int64:haystack, int64:needle) {
    if (haystack == 0i64) {
        pass 0i64;
    }
    if (needle == 0i64) {
        pass haystack;
    }

    uint8->:h = @cast_unchecked<uint8->>(haystack);
    uint8->:n = @cast_unchecked<uint8->>(needle);

      // Empty needle: match at start
    if (n[0] == 0u8) {
        pass haystack;
    }

    uint8:first = n[0];
    int64:i = 0i64;

    while (h[i] != 0u8) {
        if (h[i] == first) {
              // Found first uint8 — check full needle
            int64:j = 1i64;
            while (n[j] != 0u8 && h[i + j] != 0u8 && h[i + j] == n[j]) {
                j = j + 1i64;
            }
            if (n[j] == 0u8) {
                pass haystack + i;    // full match
            }
        }
        i = i + 1i64;
    }

    pass 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// str_strcasestr — Case-insensitive strstr (ASCII).
// ════════════════════════════════════════════════════════════════════════════

pub func:str_strcasestr = int64(int64:haystack, int64:needle) {
    if (haystack == 0i64) {
        pass 0i64;
    }
    if (needle == 0i64) {
        pass haystack;
    }

    uint8->:h = @cast_unchecked<uint8->>(haystack);
    uint8->:n = @cast_unchecked<uint8->>(needle);

    if (n[0] == 0u8) {
        pass haystack;
    }

    uint8:first_lo = raw to_lower_ascii(n[0]);
    int64:i = 0i64;

    while (h[i] != 0u8) {
        if (raw to_lower_ascii(h[i]) == first_lo) {
            int64:j = 1i64;
            while (n[j] != 0u8 && h[i + j] != 0u8 &&
                  raw to_lower_ascii(h[i + j]) == raw to_lower_ascii(n[j])) {
                j = j + 1i64;
            }
            if (n[j] == 0u8) {
                pass haystack + i;
            }
        }
        i = i + 1i64;
    }

    pass 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// Charset lookup table (256-bit bitvector)
//
// A 256-bit (32-uint8) bitvector indexed by ASCII uint8 value.
// Setting bit c means "character c is in the set".
// Testing: (table[c >> 3] >> (c & 7)) & 1
//
// Using a stack-allocated 32-uint8 array for the set.
// This makes strpbrk/strspn/strcspn O(m + n) where m = charset length, n = string length.
// ════════════════════════════════════════════════════════════════════════════

// charset_build — Initialize a 32-uint8 bitvector from a charset string.
pub func:charset_build = NIL(uint8->:table, int64:charset) {
    uint8->:cs = @cast_unchecked<uint8->>(charset);
      // Zero the table
    int64:ti = 0i64;
    while (ti < 32i64) { table[ti] = 0u8; ti = ti + 1i64; }
      // Set bit for each uint8 in charset
    int64:ci = 0i64;
    while (cs[ci] != 0u8) {
        uint8:c = cs[ci];
        table[c >> 3u8] = table[c >> 3u8] | (1u8 << (c & 7u8));
        ci = ci + 1i64;
    }
};

// charset_test — True if uint8 c is in the 32-uint8 bitvector table.
pub func:charset_test = bool(uint8->:table, uint8:c) {
    pass ((table[c >> 3u8] >> (c & 7u8)) & 1u8) != 0u8;
};

// ════════════════════════════════════════════════════════════════════════════
// str_strpbrk — Find first character in s that is also in accept.
//
// Returns pointer to first match, or NULL.
// ════════════════════════════════════════════════════════════════════════════

pub func:str_strpbrk = int64(int64:s, int64:accept) {
    if (s == 0i64 || accept == 0i64) {
        pass 0i64;
    }

      // Build charset bitvector on stack
    stack uint8[32]:table;
    drop(charset_build(@cast_unchecked<uint8->>(@table), accept));

    uint8->:p = @cast_unchecked<uint8->>(s);
    int64:i = 0i64;

    while (p[i] != 0u8) {
        if (raw charset_test(@cast_unchecked<uint8->>(@table), p[i])) {
            pass s + i;
        }
        i = i + 1i64;
    }

    pass 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// str_strspn — Return length of initial segment of s consisting of chars in accept.
//
// Returns the index of the first character in s NOT in accept.
// Equivalent to: strspn("hello", "aehlo") returns 3 (first char not in set is 'l' at 3)
// Wait — "hello": h∈{a,e,h,l,o}=YES, e=YES, l=YES, l=YES, o=YES → returns 5
// Actually: strspn("ab!cd", "abcd") returns 2 (stops at '!')
// ════════════════════════════════════════════════════════════════════════════

pub func:str_strspn = int64(int64:s, int64:accept) {
    if (s == 0i64) {
        pass 0i64;
    }
    if (accept == 0i64) {
        pass 0i64;
    }

    stack uint8[32]:table;
    drop(charset_build(@cast_unchecked<uint8->>(@table), accept));

    uint8->:p = @cast_unchecked<uint8->>(s);
    int64:i = 0i64;

    while (p[i] != 0u8 && raw charset_test(@cast_unchecked<uint8->>(@table), p[i])) {
        i = i + 1i64;
    }

    pass i;
};

// ════════════════════════════════════════════════════════════════════════════
// str_strcspn — Return length of initial segment of s consisting of chars NOT in reject.
//
// Complementary to strspn. Returns the index of the first char in s that IS in reject.
// strspn(s, reject) + strcspn(s, reject) = strlen(s) when processing the full string.
// ════════════════════════════════════════════════════════════════════════════

pub func:str_strcspn = int64(int64:s, int64:reject) {
    if (s == 0i64) {
        pass 0i64;
    }
    if (reject == 0i64) {
        pass raw str_strlen(s);
    }

    stack uint8[32]:table;
    drop(charset_build(@cast_unchecked<uint8->>(@table), reject));

    uint8->:p = @cast_unchecked<uint8->>(s);
    int64:i = 0i64;

    while (p[i] != 0u8 && raw charset_test(@cast_unchecked<uint8->>(@table), p[i]) == false) {
        i = i + 1i64;
    }

    pass i;
};

// strcmp.npk — strcmp, strncmp, strcasecmp, strncasecmp (v0.3.2)
//
// String comparison. Every sorting algorithm, hash map lookup, command dispatch,
// and option parser depends on these.
//
// Correctness requirements (POSIX):
//   - strcmp(a, b) compares unsigned char (uint8) values, NOT signed char.
//     The return value is < 0 if a < b, 0 if equal, > 0 if a > b.
//     The sign/magnitude is implementation-defined — we return -1, 0, +1.
//   - strncmp compares at most n bytes. If either string is shorter than n,
//     comparison stops at the first NUL.
//   - strcasecmp/strncasecmp: ASCII case-insensitive. Only ASCII 'A'-'Z' are
//     folded; other bytes are compared as-is. This is NOT locale-aware.
//     Locale-aware comparison is in v0.40.x (locale/collation module).
//
// Performance:
//   - Word-at-a-time for strcmp: XOR two 8-uint8 words; if the result contains
//     a zero uint8, one string has ended or bytes differ.
//   - strncmp uses the simpler uint8 loop (word-at-a-time with bounds is complex
//     and the performance benefit is modest for typical short comparisons).
//   - strcasecmp: uint8 loop only (can't do word-at-a-time without case conversion).

use "../syscall/errno.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// ASCII case conversion (internal helpers)
// ════════════════════════════════════════════════════════════════════════════

// to_lower_ascii — Convert an ASCII uint8 to lowercase. Non-alpha bytes unchanged.
pub func:to_lower_ascii = uint8(uint8:c) {
    if (c >= 65u8 && c <= 90u8) {    // 'A' = 65, 'Z' = 90
        pass c + 32u8;              // distance 'a'-'A' = 32
    }
    pass c;
};

// to_upper_ascii — Convert an ASCII uint8 to uppercase. Non-alpha bytes unchanged.
func:to_upper_ascii = uint8(uint8:c) {
    if (c >= 97u8 && c <= 122u8) {    // 'a' = 97, 'z' = 122
        pass c - 32u8;
    }
    pass c;
};

// is_alpha_ascii — True if uint8 is an ASCII letter (a-z or A-Z).
func:is_alpha_ascii = bool(uint8:c) {
    pass (c >= 65u8 && c <= 90u8) || (c >= 97u8 && c <= 122u8);
};

// ════════════════════════════════════════════════════════════════════════════
// Zero-uint8 detection word trick (@cast_unchecked<strlen>(same).npk)
// ════════════════════════════════════════════════════════════════════════════

fixed int64:STRCMP_ONES     = 0x0101010101010101i64;
fixed int64:STRCMP_HIGHBITS = 0x8080808080808080i64;

func:strcmp_has_nul = bool(int64:v) {
    pass ((v - STRCMP_ONES) & (0i64 - 1i64 ^ v) & STRCMP_HIGHBITS) != 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// str_strcmp — Compare two NUL-terminated strings.
//
// Returns: 0 if equal, < 0 if a < b, > 0 if a > b.
// NULL handling: NULL < any string; NULL == NULL.
// ════════════════════════════════════════════════════════════════════════════

pub func:str_strcmp = int64(int64:a, int64:b) {
    if (a == b) {
        pass 0i64;
    }
    if (a == 0i64) {
        pass -1i64;
    }
    if (b == 0i64) {
        pass 1i64;
    }

    uint8->:pa = @cast_unchecked<uint8->>(a);
    uint8->:pb = @cast_unchecked<uint8->>(b);
    int64:i = 0i64;

      // ── Prologue: uint8-by-uint8 until both aligned ────────────────────
    while ((((a + i) | (b + i)) & 7i64) != 0i64) {
        uint8:ca = pa[i];
        uint8:cb = pb[i];
        if (ca != cb) {
            if (ca < cb) { pass -1i64; }
            pass 1i64;
        }
        if (ca == 0u8) {
            pass 0i64;    // Both hit NUL simultaneously (since ca==cb)
        }
        i = i + 1i64;
    }

      // ── Word loop ────────────────────────────────────────────────────
    int64->:wa = @cast_unchecked<int64->>((a + i));
    int64->:wb = @cast_unchecked<int64->>((b + i));
    int64:wi = 0i64;
    while (true) {
        int64:va = wa[wi];
        int64:vb = wb[wi];
          // If either word has a NUL uint8 OR they differ, drop to uint8 loop
        if (va != vb || raw strcmp_has_nul(va)) {
            break;
        }
        wi = wi + 1i64;
    }
    i = i + wi * 8i64;

      // ── Tail: find first differing uint8 or NUL ───────────────────────
    while (true) {
        uint8:ca = pa[i];
        uint8:cb = pb[i];
        if (ca != cb) {
            if (ca < cb) { pass -1i64; }
            pass 1i64;
        }
        if (ca == 0u8) {
            pass 0i64;
        }
        i = i + 1i64;
    }

    pass 0i64;    // unreachable
};

// ════════════════════════════════════════════════════════════════════════════
// str_strncmp — Compare at most n bytes of two NUL-terminated strings.
// ════════════════════════════════════════════════════════════════════════════

pub func:str_strncmp = int64(int64:a, int64:b, int64:n) {
    if (n == 0i64) {
        pass 0i64;
    }
    if (a == b) {
        pass 0i64;
    }
    if (a == 0i64) {
        pass -1i64;
    }
    if (b == 0i64) {
        pass 1i64;
    }

    uint8->:pa = @cast_unchecked<uint8->>(a);
    uint8->:pb = @cast_unchecked<uint8->>(b);
    int64:i = 0i64;

    while (i < n) {
        uint8:ca = pa[i];
        uint8:cb = pb[i];
        if (ca != cb) {
            if (ca < cb) { pass -1i64; }
            pass 1i64;
        }
        if (ca == 0u8) {
            pass 0i64;    // Both terminated
        }
        i = i + 1i64;
    }

    pass 0i64;    // n bytes compared, all equal
};

// ════════════════════════════════════════════════════════════════════════════
// str_strcmp_prefix — True if b is a prefix of a (a starts with b).
//
// E.g., strcmp_prefix("hello world", "hello") → true
// This is equivalent to strncmp(a, b, strlen(b)) == 0.
// @cast_unchecked<a>(Provided) convenience because prefix testing is extremely common.
// ════════════════════════════════════════════════════════════════════════════

pub func:str_strcmp_prefix = bool(int64:a, int64:b) {
    if (a == 0i64 || b == 0i64) {
        pass false;
    }

    uint8->:pa = @cast_unchecked<uint8->>(a);
    uint8->:pb = @cast_unchecked<uint8->>(b);
    int64:i = 0i64;

    while (pb[i] != 0u8) {
        if (pa[i] == 0u8 || pa[i] != pb[i]) {
            pass false;
        }
        i = i + 1i64;
    }

    pass true;
};

// ════════════════════════════════════════════════════════════════════════════
// str_strcasecmp — Case-insensitive string comparison (ASCII only).
// ════════════════════════════════════════════════════════════════════════════

pub func:str_strcasecmp = int64(int64:a, int64:b) {
    if (a == b) {
        pass 0i64;
    }
    if (a == 0i64) {
        pass -1i64;
    }
    if (b == 0i64) {
        pass 1i64;
    }

    uint8->:pa = @cast_unchecked<uint8->>(a);
    uint8->:pb = @cast_unchecked<uint8->>(b);
    int64:i = 0i64;

    while (true) {
        uint8:ca = raw to_lower_ascii(pa[i]);
        uint8:cb = raw to_lower_ascii(pb[i]);
        if (ca != cb) {
            if (ca < cb) { pass -1i64; }
            pass 1i64;
        }
        if (ca == 0u8) {
            pass 0i64;
        }
        i = i + 1i64;
    }

    pass 0i64;    // unreachable
};

// ════════════════════════════════════════════════════════════════════════════
// str_strncasecmp — Case-insensitive compare of at most n bytes.
// ════════════════════════════════════════════════════════════════════════════

pub func:str_strncasecmp = int64(int64:a, int64:b, int64:n) {
    if (n == 0i64) {
        pass 0i64;
    }
    if (a == b) {
        pass 0i64;
    }
    if (a == 0i64) {
        pass -1i64;
    }
    if (b == 0i64) {
        pass 1i64;
    }

    uint8->:pa = @cast_unchecked<uint8->>(a);
    uint8->:pb = @cast_unchecked<uint8->>(b);
    int64:i = 0i64;

    while (i < n) {
        uint8:ca = raw to_lower_ascii(pa[i]);
        uint8:cb = raw to_lower_ascii(pb[i]);
        if (ca != cb) {
            if (ca < cb) { pass -1i64; }
            pass 1i64;
        }
        if (ca == 0u8) {
            pass 0i64;
        }
        i = i + 1i64;
    }

    pass 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// str_casecmp_prefix — Case-insensitive prefix check.
// True if a starts with b (ASCII case-insensitive).
// ════════════════════════════════════════════════════════════════════════════

pub func:str_casecmp_prefix = bool(int64:a, int64:b) {
    if (a == 0i64 || b == 0i64) {
        pass false;
    }

    uint8->:pa = @cast_unchecked<uint8->>(a);
    uint8->:pb = @cast_unchecked<uint8->>(b);
    int64:i = 0i64;

    while (pb[i] != 0u8) {
        if (pa[i] == 0u8 || raw to_lower_ascii(pa[i]) != raw to_lower_ascii(pb[i])) {
            pass false;
        }
        i = i + 1i64;
    }

    pass true;
};

// strcpy.npk — strcpy, strncpy, stpcpy, stpncpy, strdup, strndup (v0.3.1)
//
// String copy operations. These form the second tier after strlen.
//
// Safety model:
//   - strcpy: NO bounds check. Caller must ensure dst is large enough.
//     Only safe when you know the string length in advance (e.g., just called strlen).
//   - strncpy: POSIX-compatible — copies up to n bytes, NUL-pads remainder.
//     WARNING: does NOT NUL-terminate if src is ≥ n chars. Use strlcpy (v0.3.3)
//     for safe truncation.
//   - stpcpy/stpncpy: like strcpy/strncpy but return pointer to the NUL terminator
//     (or end of dst). Good for building multi-segment strings without re-scanning.
//   - strdup: allocates a copy. Caller must free with libn_slab_free/mem_free.
//   - strndup: allocates a copy of at most n bytes.
//
// The preferred safe alternatives (in v0.3.3):
//   - strlcpy: always NUL-terminates, returns strlen(src)
//   - strlcat: like strlcpy but appends

use "../syscall/errno.npk".*;
use "../str/strlen.npk".*;
use "../mem/memcpy.npk".*;
use "../mem/memset.npk".*;
use "../mem/mmap.npk".*;
use "../mem/slab.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// str_strcpy — Copy NUL-terminated string from src to dst.
//
// dst must have space for at least strlen(src)+1 bytes.
// Returns dst. Undefined behavior if src and dst overlap.
// ════════════════════════════════════════════════════════════════════════════

pub func:str_strcpy = int64(int64:dst, int64:src) {
    if (dst == 0i64 || src == 0i64) {
        pass dst;
    }

    uint8->:d = @cast_unchecked<uint8->>(dst);
    uint8->:s = @cast_unchecked<uint8->>(src);
    int64:i = 0i64;

    while (s[i] != 0u8) {
        d[i] = s[i];
        i = i + 1i64;
    }
    d[i] = 0u8;    // NUL terminator

    pass dst;
};

// ════════════════════════════════════════════════════════════════════════════
// str_stpcpy — Like strcpy but returns pointer to the NUL in dst.
//
// Returns: dst + strlen(src) (points to the NUL uint8 written at end of dst).
// Use for chaining: dst = stpcpy(dst, "hello"); dst = stpcpy(dst, " world");
// ════════════════════════════════════════════════════════════════════════════

pub func:str_stpcpy = int64(int64:dst, int64:src) {
    if (dst == 0i64 || src == 0i64) {
        pass dst;
    }

    uint8->:d = @cast_unchecked<uint8->>(dst);
    uint8->:s = @cast_unchecked<uint8->>(src);
    int64:i = 0i64;

    while (s[i] != 0u8) {
        d[i] = s[i];
        i = i + 1i64;
    }
    d[i] = 0u8;

    pass dst + i;    // points to the NUL uint8
};

// ════════════════════════════════════════════════════════════════════════════
// str_strncpy — Copy at most n bytes from src to dst, NUL-pad remainder.
//
// POSIX strncpy behavior:
//   - If strlen(src) < n: copies strlen(src)+1 bytes, then pads with NUL to n.
//   - If strlen(src) >= n: copies exactly n bytes, NO NUL terminator added.
// This is the unsafe legacy function. Prefer strlcpy (v0.3.3).
//
// Returns dst.
// ════════════════════════════════════════════════════════════════════════════

pub func:str_strncpy = int64(int64:dst, int64:src, int64:n) {
    if (dst == 0i64 || n <= 0i64) {
        pass dst;
    }
    if (src == 0i64) {
          // POSIX: strncpy(dst, NULL, n) → NUL-fill dst
        drop(mem_bzero(dst, n));
        pass dst;
    }

    uint8->:d = @cast_unchecked<uint8->>(dst);
    uint8->:s = @cast_unchecked<uint8->>(src);
    int64:i = 0i64;

      // Copy src bytes until NUL or we reach n
    while (i < n && s[i] != 0u8) {
        d[i] = s[i];
        i = i + 1i64;
    }

      // NUL-pad the remainder (POSIX requirement)
    while (i < n) {
        d[i] = 0u8;
        i = i + 1i64;
    }

    pass dst;
};

// ════════════════════════════════════════════════════════════════════════════
// str_stpncpy — Like strncpy but returns pointer to end of copied data in dst.
//
// Returns pointer to the NUL placed in dst, or dst+n if src was truncated
// (no NUL in that case — same @cast_unchecked<strncpy>(gotcha)).
// ════════════════════════════════════════════════════════════════════════════

pub func:str_stpncpy = int64(int64:dst, int64:src, int64:n) {
    if (dst == 0i64 || n <= 0i64) {
        pass dst;
    }
    if (src == 0i64) {
        drop(mem_bzero(dst, n));
        pass dst;
    }

    uint8->:d = @cast_unchecked<uint8->>(dst);
    uint8->:s = @cast_unchecked<uint8->>(src);
    int64:i = 0i64;

    while (i < n && s[i] != 0u8) {
        d[i] = s[i];
        i = i + 1i64;
    }

    int64:end_idx = dst + i;

    while (i < n) {
        d[i] = 0u8;
        i = i + 1i64;
    }

    pass end_idx;
};

// ════════════════════════════════════════════════════════════════════════════
// str_strdup — Allocate a copy of the NUL-terminated string at src.
//
// Equivalent to malloc(strlen(src)+1) + strcpy. Caller must free with
// libn_slab_free(0i64, ) or mem_free() depending on allocation size.
//
// Returns pointer to new string (or error on OOM).
// ════════════════════════════════════════════════════════════════════════════

pub func:str_strdup = int64(int64:src) {
    if (src == 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }

    int64:n = raw str_strlen(src);
    int64:alloc_size = n + 1i64;

      // Use slab for short strings, mmap for long ones
    int64:r = libn_slab_alloc(alloc_size);
    if (r == 0i64) {
        fail @cast_unchecked<tbb32>(12i64);
    }

      // Copy including NUL terminator
    drop(mem_memcpy(r, src, alloc_size));

    pass r;
};

// ════════════════════════════════════════════════════════════════════════════
// str_strndup — Allocate a copy of at most n bytes of src.
//
// Like strdup but only copies up to n characters. Always NUL-terminates.
// If strlen(src) < n, the allocated string is strlen(src) bytes long.
// If strlen(src) >= n, the allocated string is exactly n bytes (+ NUL).
//
// This is safer than strdup for untrusted input (bounded copy).
// Returns pointer to new string.
// ════════════════════════════════════════════════════════════════════════════

pub func:str_strndup = int64(int64:src, int64:n) {
    if (src == 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    if (n < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }

    int64:actual_len = raw str_strnlen(src, n);    // min(strlen(src), n)
    int64:alloc_size = actual_len + 1i64;

    int64:r = libn_slab_alloc(alloc_size);
    if (r == 0i64) {
        fail @cast_unchecked<tbb32>(12i64);
    }

      // Copy actual_len bytes, then NUL-terminate
    drop(mem_memcpy(r, src, actual_len));
    (@cast_unchecked<uint8->>(r))[actual_len] = 0u8;

    pass r;
};

// strlcpy.npk — strlcpy, strlcat, strscpy, strscpy_pad (v0.3.3)
//
// Safe string copy and concatenation.
//
// Background — the strncpy problem:
//   POSIX strncpy has two serious gotchas:
//   1. If src is longer than n, dst is NOT NUL-terminated.
//   2. If src is shorter than n, the remainder is NUL-padded (wasteful).
//
//   BSD invented strlcpy/@cast_unchecked<a>(strlcat) replacement:
//   - Always NUL-terminates (if dst_size > 0).
//   - Returns the length of src (not dst) so callers can detect truncation.
//   - No NUL-padding of the remainder.
//
// Linux kernel's strscpy (v5.1+):
//   Like strlcpy but returns -ENOSPC on truncation instead of src length.
//   This makes truncation detection via return value rather than strlen cheaper.
//
// libn provides both interfaces.

use "../syscall/errno.npk".*;
use "../str/strlen.npk".*;
use "../mem/memcpy.npk".*;
use "../mem/memset.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// str_strlcpy — Safely copy src to dst, truncating if necessary.
//
// Parameters:
//   dst:      destination buffer
//   src:      NUL-terminated source string
//   dst_size: total size of dst buffer (including NUL uint8)
//
// Returns:
//   Length of src (NOT the number of bytes written).
//   If return value >= dst_size, the copy was truncated.
//   Caller can check: if (strlcpy(dst, src, n) >= n) { /* truncated */ }
//
// Guarantees:
//   - dst is always NUL-terminated (if dst_size > 0).
//   - At most dst_size-1 bytes of src are copied.
// ════════════════════════════════════════════════════════════════════════════

pub func:str_strlcpy = int64(int64:dst, int64:src, int64:dst_size) {
    int64:src_len = raw str_strlen(src);

    if (dst == 0i64 || dst_size == 0i64) {
        pass src_len;    // No copy, but return would-be length
    }

      // How many bytes to actually copy (excluding NUL)
    int64:copy_len = src_len;
    if (copy_len >= dst_size) {
        copy_len = dst_size - 1i64;    // Truncate to fit
    }

      // Copy copy_len bytes then NUL-terminate
    drop(mem_memcpy(dst, src, copy_len));
    (@cast_unchecked<uint8->>(dst))[copy_len] = 0u8;

    pass src_len;    // Return full source length (NOT copy_len)
};

// ════════════════════════════════════════════════════════════════════════════
// str_strlcat — Safely append src to dst.
//
// Parameters:
//   dst:      NUL-terminated destination buffer
//   src:      NUL-terminated source to append
//   dst_size: total size of dst buffer (including space for NUL)
//
// Returns:
//   strlen(dst) + strlen(src) — the length the result would have been
//   if dst were large enough. If return >= dst_size, truncation occurred.
//
// Guarantees:
//   - dst is always NUL-terminated (if dst_size > 0).
//   - At most dst_size - strlen(dst) - 1 bytes of src are appended.
// ════════════════════════════════════════════════════════════════════════════

pub func:str_strlcat = int64(int64:dst, int64:src, int64:dst_size) {
    int64:dst_len = raw str_strnlen(dst, dst_size);
    int64:src_len = raw str_strlen(src);

    if (dst == 0i64 || dst_size == 0i64) {
        pass dst_len + src_len;
    }

      // How much space remains in dst (minus the NUL we'll write)
    int64:remaining = dst_size - dst_len - 1i64;
    if (remaining <= 0i64) {
          // dst is already full — no room for any of src
        pass dst_len + src_len;
    }

      // Append up to 'remaining' bytes of src after dst's existing content
    int64:append_len = src_len;
    if (append_len > remaining) {
        append_len = remaining;
    }

    drop(mem_memcpy(dst + dst_len, src, append_len));
    (@cast_unchecked<uint8->>(dst))[dst_len + append_len] = 0u8;

    pass dst_len + src_len;
};

// ════════════════════════════════════════════════════════════════════════════
// str_strscpy — Linux kernel-style safe copy.
//
// Like strlcpy but returns:
//   >= 0  : number of bytes written (not including NUL) — success
//   -1    : truncation occurred (would have returned -ENOSPC in kernel)
//
// This is the preferred function for new libn code because the return value
// directly signals truncation without requiring a second strlen() call.
// ════════════════════════════════════════════════════════════════════════════

pub func:str_strscpy = int64(int64:dst, int64:src, int64:dst_size) {
    if (dst == 0i64 || dst_size == 0i64) {
        pass -1i64;
    }

    uint8->:d = @cast_unchecked<uint8->>(dst);
    uint8->:s = @cast_unchecked<uint8->>(src);
    int64:i = 0i64;
    int64:max_bytes = dst_size - 1i64;    // reserve one for NUL

    while (i < max_bytes && s[i] != 0u8) {
        d[i] = s[i];
        i = i + 1i64;
    }
    d[i] = 0u8;

      // Check if we stopped because of truncation or natural NUL
    if (s[i] != 0u8) {
        pass -1i64;    // truncated
    }

    pass i;    // number of bytes written (not counting NUL)
};

// ════════════════════════════════════════════════════════════════════════════
// str_strscpy_pad — Like strscpy but NUL-pads the entire buffer.
//
// Same return @cast_unchecked<strscpy>(value). Used when the buffer must be zero-initialized
// beyond the string content (e.g., kernel struct padding, fixed-size fields
// in on-disk formats or network packets).
// ════════════════════════════════════════════════════════════════════════════

pub func:str_strscpy_pad = int64(int64:dst, int64:src, int64:dst_size) {
    if (dst == 0i64 || dst_size == 0i64) {
        pass -1i64;
    }

    int64:r = raw str_strscpy(dst, src, dst_size);

      // Determine where the NUL is, then zero the rest
    int64:nul_pos = 0i64;
    if (r >= 0i64) {
        nul_pos = r + 1i64;    // uint8 after the NUL
    } else {
          // Truncated: NUL at dst_size-1, nothing to pad (NUL already written)
        nul_pos = dst_size;
    }

      // Zero from nul_pos onward
    if (nul_pos < dst_size) {
        drop(mem_bzero(dst + nul_pos, dst_size - nul_pos));
    }

    pass r;
};

// ════════════════════════════════════════════════════════════════════════════
// str_strlcpy_chk — strlcpy with compile-time-detectable bounds check.
//
// Identical to strlcpy but returns a Result<int64>:
//   Ok(src_len)  — always (even on truncation, to preserve strlcpy semantics)
// The purpose: the caller uses the return value to check truncation:
//
//   Result<int64>:r = str_strlcpy_chk(dst, src, sizeof_dst);
//   if r.value >= sizeof_dst { /* truncated — handle it */ }
//
// This is the preferred way to call strlcpy in new libn code because it makes
// the truncation check a result-propagation pattern.
// ════════════════════════════════════════════════════════════════════════════

pub func:str_strlcpy_chk = int64(int64:dst, int64:src, int64:dst_size) {
    if (dst == 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    pass raw str_strlcpy(dst, src, dst_size);
};

// strtok.npk — strtok_r, strsep, str_split_fields (v0.3.5)
//
// String tokenization. These are the workhorses of command-line parsing,
// config file reading, and protocol field extraction.
//
// Safety note on strtok():
//   POSIX strtok() uses a hidden global state pointer (save_ptr), making it
//   NOT thread-safe and NOT reentrant. libn does NOT provide strtok().
//   We provide strtok_r() @cast_unchecked<our>((the reentrant version)) baseline.
//
//   strtok_r() is also unsafe in a different sense: it MODIFIES the input
//   string by writing NUL bytes. This is by design (POSIX), but callers must
//   be aware. For non-destructive tokenization, use str_split_fields().
//
// strsep vs strtok_r:
//   - strtok_r: skips LEADING delimiters, returns NULL when no more tokens.
//   - strsep: does NOT skip leading delimiters — empty tokens are returned.
//     This is the POSIX-compliant way to parse: "field1::field3" correctly
//     yields three tokens with strsep but two with strtok_r.
//
// str_split_fields:
//   Non-destructive field splitter. Works on a single delimiter char.
//   Fills an array of (pointer, length) pairs. Does not modify the input.
//   Used for: HTTP header parsing, CSV fields, colon-separated paths.

use "../syscall/errno.npk".*;
use "../str/strlen.npk".*;
use "../str/strchr.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// str_strtok_r — Reentrant string tokenizer. Modifies input string.
//
// Parameters:
//   str:       On first call, the string to tokenize. On subsequent calls, NULL.
//   delim:     NUL-terminated string of delimiter characters.
//   saveptr:   Pointer to an int64 the function uses to maintain context.
//              Must be the same variable across calls for the same string.
//              Can be a different variable to tokenize multiple strings simultaneously.
//
// Returns: pointer to next token (a NUL-terminated substring of *str),
//          or NULL when no more tokens.
//
// Behavior:
//   - Leading delimiters are SKIPPED (like strtok).
//   - The input string is modified in-place (NUL bytes written at token boundaries).
// ════════════════════════════════════════════════════════════════════════════

pub func:str_strtok_r = int64(int64:str_arg, int64:delim, int64->:saveptr) {
    int64:s = 0i64;

    if (str_arg != 0i64) {
        s = str_arg;
    } else {
        if (@cast_unchecked<int64>(saveptr) == 0i64) {
            pass 0i64;
        }
        s = saveptr[0];
    }

    if (s == 0i64 || (@cast_unchecked<uint8->>(s))[0] == 0u8) {
        if (@cast_unchecked<int64>(saveptr) != 0i64) { saveptr[0] = 0i64; }
        pass 0i64;
    }

      // Build charset bitvector for delimiter set
    stack uint8[32]:table;
    drop(charset_build(@cast_unchecked<uint8->>(@table), delim));

    uint8->:p = @cast_unchecked<uint8->>(s);
    int64:i = 0i64;

      // Skip leading delimiters
    while (p[i] != 0u8 && raw charset_test(@cast_unchecked<uint8->>(@table), p[i])) {
        i = i + 1i64;
    }

      // All remaining chars are delimiters — no more tokens
    if (p[i] == 0u8) {
        if (@cast_unchecked<int64>(saveptr) != 0i64) { saveptr[0] = 0i64; }
        pass 0i64;
    }

      // Token starts at s+i
    int64:token_start = s + i;

      // Advance until we hit a delimiter or NUL
    while (p[i] != 0u8 && raw charset_test(@cast_unchecked<uint8->>(@table), p[i]) == false) {
        i = i + 1i64;
    }

      // Write NUL to terminate the token (if not already at end)
    if (p[i] != 0u8) {
        p[i] = 0u8;
        if (@cast_unchecked<int64>(saveptr) != 0i64) { saveptr[0] = s + i + 1i64; }
    } else {
        if (@cast_unchecked<int64>(saveptr) != 0i64) { saveptr[0] = 0i64; }
    }

    pass token_start;
};

// ════════════════════════════════════════════════════════════════════════════
// str_strsep — BSD/GNU strsep. Modifies input string.
//
// Parameters:
//   stringp:  Pointer to the string pointer. Updated to point past the token.
//             *stringp is set to NULL when the string is exhausted.
//   delim:    NUL-terminated delimiter set.
//
// Returns:
//   Pointer to the token (may be empty string "").
//   NULL if *stringp was NULL on entry.
//
// Unlike strtok_r, leading delimiters produce EMPTY tokens.
// ════════════════════════════════════════════════════════════════════════════

pub func:str_strsep = int64(int64->:stringp, int64:delim) {
    if (@cast_unchecked<int64>(stringp) == 0i64) {
        pass 0i64;
    }
    if (stringp[0] == 0i64) {
        pass 0i64;
    }

    int64:s = stringp[0];
    uint8->:p = @cast_unchecked<uint8->>(s);

      // Find first delimiter (or NUL)
    stack uint8[32]:table;
    drop(charset_build(@cast_unchecked<uint8->>(@table), delim));

    int64:i = 0i64;
    while (p[i] != 0u8 && raw charset_test(@cast_unchecked<uint8->>(@table), p[i]) == false) {
        i = i + 1i64;
    }

    if (p[i] == 0u8) {
          // No delimiter found — return entire remaining string, set *stringp = NULL
        stringp[0] = 0i64;
    } else {
          // Found delimiter — terminate token, advance past delimiter
        p[i] = 0u8;
        stringp[0] = s + i + 1i64;
    }

    pass s;    // Original start of token (may be empty string if delimiter was at start)
};

// ════════════════════════════════════════════════════════════════════════════
// StrField — A non-owning reference to a field within a string.
// Stored as (ptr, len) pair. No NUL terminator is guaranteed.
//
// Fields are valid only as @cast_unchecked<the>(long) original string buffer exists.
// ════════════════════════════════════════════════════════════════════════════

struct:StrField = {
    int64:ptr;      // pointer into original string buffer
    int64:len;      // length of this field (bytes, not including NUL)
};

// str_field_equals — True if field f equals NUL-terminated string s.
pub func:str_field_equals = bool(StrField:f, int64:s) {
    if (f.len != raw str_strlen(s)) {
        pass false;
    }
    uint8->:fp = @cast_unchecked<uint8->>(f.ptr);
    uint8->:sp = @cast_unchecked<uint8->>(s);
    int64:i = 0i64;
    while (i < f.len) {
        if (fp[i] != sp[i]) { pass false; }
        i = i + 1i64;
    }
    pass true;
};

// ════════════════════════════════════════════════════════════════════════════
// str_split_fields — Non-destructive field splitter with a single delimiter char.
//
// Parses 'input' (length 'input_len') splitting on 'delim'.
// Fills 'fields' array with up to 'max_fields' StrField entries.
// Returns number of fields found (may be less than actual count if max_fields hit).
//
// Behavior:
//   - Does NOT modify the input string.
//   - Empty fields ARE included (like strsep, not strtok).
//   - If max_fields is hit, the remaining unparsed portion is stored in
//     @cast_unchecked<the>(fields[max_fields-1]) last (unsplit) field.
//
// Example: split_fields("a:b::c", 6, ':', fields, 10) yields:
//   fields[0] = {ptr→"a", len=1}
//   fields[1] = {ptr→"b", len=1}
//   fields[2] = {ptr→"",  len=0}
//   fields[3] = {ptr→"c", len=1}
//   return 4
// ════════════════════════════════════════════════════════════════════════════

pub func:str_split_fields = int64(int64:input, int64:input_len, uint8:delim,
                                   StrField->:fields, int64:max_fields) {
    if (input == 0i64 || max_fields <= 0i64) {
        pass 0i64;
    }

    uint8->:p = @cast_unchecked<uint8->>(input);
    int64:field_count = 0i64;
    int64:field_start = 0i64;
    int64:i = 0i64;

    while (i <= input_len) {
        bool:at_delim = (i < input_len && p[i] == delim);
        bool:at_end   = (i == input_len);

        if (at_delim || at_end) {
            if (field_count < max_fields - 1i64 || at_end) {
                  // Normal field: record it
                fields[field_count].ptr = input + field_start;
                fields[field_count].len = i - field_start;
                field_count = field_count + 1i64;
                field_start = i + 1i64;
            } else {
                  // Last slot: store @cast_unchecked<unsplit>(remainder) tail
                fields[field_count].ptr = input + field_start;
                fields[field_count].len = input_len - field_start;
                field_count = field_count + 1i64;
                pass field_count;
            }
        }

        if (at_end) { break; }
        i = i + 1i64;
    }

    pass field_count;
};

// ════════════════════════════════════════════════════════════════════════════
// str_split_lines — Split a buffer into line StrFields on '\n'.
//
// Handles both LF (\n) and CRLF (\r\n) line endings. If a line ends with \r\n,
// the field length does NOT include the \r (the \n causes the split, and the
// \r is trimmed from the end of the field).
//
// Empty lines produce zero-length fields.
// Last line without terminal \n is still returned.
//
// Returns number of lines found.
// ════════════════════════════════════════════════════════════════════════════

pub func:str_split_lines = int64(int64:input, int64:input_len,
                                  StrField->:lines, int64:max_lines) {
    if (input == 0i64 || max_lines <= 0i64) {
        pass 0i64;
    }

    uint8->:p = @cast_unchecked<uint8->>(input);
    int64:line_count = 0i64;
    int64:line_start = 0i64;
    int64:i = 0i64;

    while (i <= input_len) {
        bool:at_lf  = (i < input_len && p[i] == 10u8);     // '\n'
        bool:at_end = (i == input_len);

        if (at_lf || at_end) {
            if (line_count < max_lines) {
                int64:len = i - line_start;
                  // Trim trailing \r (CRLF handling)
                if (len > 0i64 && p[line_start + len - 1i64] == 13u8) {    // '\r'
                    len = len - 1i64;
                }
                lines[line_count].ptr = input + line_start;
                lines[line_count].len = len;
                line_count = line_count + 1i64;
            }
            line_start = i + 1i64;
            if (line_count >= max_lines && !at_end) {
                pass line_count;    // Output full, stop
            }
        }

        if (at_end) { break; }
        i = i + 1i64;
    }

    pass line_count;
};

// strview.npk — Non-owning string view / slice (v0.9.0)
//
// StrView is Nitpick's equivalent of C++17 std::string_view, Rust's @str,
// or Go's string. It holds a pointer and a length but owns neither.
//
// ── Core invariant ────────────────────────────────────────────────────────
//   sv->ptr may point anywhere in memory: the middle of a heap string,
//   a string literal, a StrBuf's internal buffer, a stack array, etc.
//   The view MUST NOT outlive the underlying buffer it references.
//   NEVER free sv->ptr — the view does not own the memory.
//
// ── NUL-termination ───────────────────────────────────────────────────────
//   StrView is NOT guaranteed to be NUL-terminated. The uint8 at ptr+len
//   may be anything. To pass to a function expecting a C string, call
//   strview_to_str() (heap copy) or strview_copy_to_z() (stack/buf copy).
//
// ── Value semantics ───────────────────────────────────────────────────────
//   StrView is a small struct (16 bytes). Functions that return a StrView
//   write to a caller-supplied StrView* output pointer (Nitpick convention).
//   Functions that take a StrView for input accept int64 (StrView* pointer).
//
// ── API groups ────────────────────────────────────────────────────────────
//   Construction:  strview_of, strview_of_bytes, strview_of_strbuf,
//                  strview_empty, strview_substr
//   Accessors:     strview_len, strview_ptr, strview_is_empty, strview_byte_at
//   Comparison:    strview_eq, strview_eq_str, strview_cmp, strview_cmp_str
//   Search:        strview_find_char, strview_rfind_char, strview_find_str,
//                  strview_contains_char, strview_contains_str
//   Prefix/suffix: strview_starts_with, strview_starts_with_str,
//                  strview_ends_with, strview_ends_with_str,
//                  strview_drop_prefix, strview_drop_suffix,
//                  strview_strip_prefix_str, strview_strip_suffix_str
//   Slicing:       strview_slice, strview_take, strview_drop,
//                  strview_trim_left, strview_trim_right, strview_trim
//   Tokenization:  strview_split_once, strview_split_once_char,
//                  strview_next_token
//   Parsing:       strview_parse_i64, strview_parse_u64
//   Output:        strview_to_str, strview_to_strbuf,
//                  strview_copy_to, strview_copy_to_z,
//                  strview_write_to_fd, strview_write_to_fp

use "../syscall/errno.npk".*;
use "../mem/mmap.npk".*;
use "../mem/memcpy.npk".*;
use "../mem/memutil.npk".*;
use "../str/strlen.npk".*;
use "../str/strconv.npk".*;
use "../str/strbuf.npk".*;
use "../io/write.npk".*;
use "../io/bio/file.npk".*;
use "../io/bio/fio.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// StrView struct — 16 bytes, no ownership
// ════════════════════════════════════════════════════════════════════════════

pub struct:StrView = {
    int64:ptr;      // pointer to first uint8 of the viewed region
    int64:len;      // number of bytes in the view (NOT counting a NUL)
};

// ════════════════════════════════════════════════════════════════════════════
// Construction
// ════════════════════════════════════════════════════════════════════════════

// strview_of — Create a view over a NUL-terminated string.
// out: *StrView to write into.
pub func:strview_of = NIL(int64:s, int64:out) {
    StrView->:sv = @cast_unchecked<StrView->>(out);
    if (s == 0i64) {
        sv->ptr = 0i64;
        sv->len = 0i64;
        pass NIL;
    }
    sv->ptr = s;
    sv->len = raw str_strlen(s);
};

// strview_of_bytes — Create a view over [ptr, ptr+len).
// Does NOT check for NUL or validity — caller ensures the range is readable.
pub func:strview_of_bytes = NIL(int64:ptr, int64:len, int64:out) {
    StrView->:sv = @cast_unchecked<StrView->>(out);
    sv->ptr = ptr;
if (len < 0i64) { sv->len = 0i64; } else { sv->len = len; }
};

// strview_of_strbuf — Create a view over a StrBuf's current content.
// The view is valid until the next mutation of sb (growth may relocate the buffer).
pub func:strview_of_strbuf = NIL(int64:sb, int64:out) {
    StrView->:sv = @cast_unchecked<StrView->>(out);
    if (sb == 0i64) {
        sv->ptr = 0i64;
        sv->len = 0i64;
        pass NIL;
    }
    StrBuf->:s = @cast_unchecked<StrBuf->>(sb);
    sv->ptr = s->ptr;
    sv->len = s->len;
};

// strview_empty — Initialize sv to the empty view (ptr=0, len=0).
pub func:strview_empty = NIL(int64:out) {
    StrView->:sv = @cast_unchecked<StrView->>(out);
    sv->ptr = 0i64;
    sv->len = 0i64;
};

// strview_substr — Create a sub-view of sv starting at uint8 offset start,
// for length len bytes. Clamps to sv->len automatically.
// out: *StrView to write the result into.
pub func:strview_substr = NIL(int64:sv, int64:start, int64:len, int64:out) {
    StrView->:s  = @cast_unchecked<StrView->>(sv);
    StrView->:o  = @cast_unchecked<StrView->>(out);

    if (start < 0i64) { start = 0i64; }
    if (start > s->len) {
        o->ptr = s->ptr;
        o->len = 0i64;
        pass NIL;
    }
    int64:avail = s->len - start;
    if (len < 0i64 || len > avail) { len = avail; }
    o->ptr = s->ptr + start;
    o->len = len;
};

// ════════════════════════════════════════════════════════════════════════════
// Accessors
// ════════════════════════════════════════════════════════════════════════════

// strview_len — Length of the view in bytes.
pub func:strview_len = int64(int64:sv) {
    if (sv == 0i64) { pass 0i64; }
    pass (@cast_unchecked<StrView->>(sv))->len;
};

// strview_ptr — Pointer to the first uint8 of the view.
pub func:strview_ptr = int64(int64:sv) {
    if (sv == 0i64) { pass 0i64; }
    pass (@cast_unchecked<StrView->>(sv))->ptr;
};

// strview_is_empty — True if len == 0 or sv is null.
pub func:strview_is_empty = bool(int64:sv) {
    if (sv == 0i64) { pass true; }
    pass (@cast_unchecked<StrView->>(sv))->len == 0i64;
};

// strview_byte_at — Return the uint8 at index i (0-indexed).
// Returns -1 if i is out of range.
pub func:strview_byte_at = int64(int64:sv, int64:i) {
    if (sv == 0i64) { pass -1i64; }
    StrView->:s = @cast_unchecked<StrView->>(sv);
    if (i < 0i64 || i >= s->len) { pass -1i64; }
    pass @cast_unchecked<int64>(((@cast_unchecked<uint8->>(s->ptr))[i]));
};

// strview_first / strview_last — First or last uint8. Returns -1 if empty.
pub func:strview_first = int64(int64:sv) {
    pass strview_byte_at(sv, 0i64);
};

pub func:strview_last = int64(int64:sv) {
    if (sv == 0i64) { pass -1i64; }
    StrView->:s = @cast_unchecked<StrView->>(sv);
    if (s->len == 0i64) { pass -1i64; }
    pass @cast_unchecked<int64>(((@cast_unchecked<uint8->>(s->ptr))[s->len - 1i64]));
};

// ════════════════════════════════════════════════════════════════════════════
// Comparison
// ════════════════════════════════════════════════════════════════════════════

// strview_eq — True if both views have the same length and content.
pub func:strview_eq = bool(int64:a, int64:b) {
    StrView->:sa = @cast_unchecked<StrView->>(a);
    StrView->:sb = @cast_unchecked<StrView->>(b);
    if (sa->len != sb->len) { pass false; }
    if (sa->len == 0i64) { pass true; }
    if (sa->ptr == sb->ptr) { pass true; }    // same buffer, same range
    pass mem_equal(sa->ptr, sb->ptr, sa->len);
};

// strview_eq_str — True if view equals NUL-terminated string s.
pub func:strview_eq_str = bool(int64:sv, int64:s) {
    if (s == 0i64) { pass strview_is_empty(sv); }
    StrView->:v = @cast_unchecked<StrView->>(sv);
    int64:slen = raw str_strlen(s);
    if (v->len != slen) { pass false; }
    if (v->len == 0i64) { pass true; }
    pass mem_equal(v->ptr, s, slen);
};

// strview_cmp — Lexicographic comparison of two views.
// Returns < 0, 0, > 0 (like memcmp).
pub func:strview_cmp = int64(int64:a, int64:b) {
    StrView->:sa = @cast_unchecked<StrView->>(a);
    StrView->:sb = @cast_unchecked<StrView->>(b);
    int64:min_len = is (sa->len < sb->len) : sa->len : sb->len;
    int64:r = raw mem_memcmp(sa->ptr, sb->ptr, min_len);
    if (r != 0i64) { pass r; }
    if (sa->len < sb->len) { pass -1i64; }
    if (sa->len > sb->len) { pass  1i64; }
    pass 0i64;
};

// strview_cmp_str — Compare view to NUL-terminated string.
pub func:strview_cmp_str = int64(int64:sv, int64:s) {
    if (s == 0i64) {
        StrView->:v = @cast_unchecked<StrView->>(sv);
        if (v->len == 0i64) { pass 0i64; }
        pass 1i64;
    }
    stack StrView:bv;
    drop(strview_of(s, @cast_unchecked<int64>(@bv)));
    pass strview_cmp(sv, @cast_unchecked<int64>(@bv));
};

// ════════════════════════════════════════════════════════════════════════════
// Prefix / Suffix
// ════════════════════════════════════════════════════════════════════════════

// strview_starts_with — True if sv starts with the bytes in prefix view.
pub func:strview_starts_with = bool(int64:sv, int64:prefix) {
    StrView->:s = @cast_unchecked<StrView->>(sv);
    StrView->:p = @cast_unchecked<StrView->>(prefix);
    if (p->len == 0i64) { pass true; }
    if (p->len > s->len) { pass false; }
    pass mem_equal(s->ptr, p->ptr, p->len);
};

// strview_starts_with_str — True if sv starts with the NUL-terminated string.
pub func:strview_starts_with_str = bool(int64:sv, int64:prefix) {
    if (prefix == 0i64) { pass true; }
    StrView->:s = @cast_unchecked<StrView->>(sv);
    int64:plen = raw str_strlen(prefix);
    if (plen == 0i64) { pass true; }
    if (plen > s->len) { pass false; }
    pass mem_equal(s->ptr, prefix, plen);
};

// strview_ends_with — True if sv ends with the bytes in suffix view.
pub func:strview_ends_with = bool(int64:sv, int64:suffix) {
    StrView->:s = @cast_unchecked<StrView->>(sv);
    StrView->:x = @cast_unchecked<StrView->>(suffix);
    if (x->len == 0i64) { pass true; }
    if (x->len > s->len) { pass false; }
    pass mem_equal(s->ptr + s->len - x->len, x->ptr, x->len);
};

// strview_ends_with_str — True if sv ends with the NUL-terminated string.
pub func:strview_ends_with_str = bool(int64:sv, int64:suffix) {
    if (suffix == 0i64) { pass true; }
    StrView->:s = @cast_unchecked<StrView->>(sv);
    int64:xlen = raw str_strlen(suffix);
    if (xlen == 0i64) { pass true; }
    if (xlen > s->len) { pass false; }
    pass mem_equal(s->ptr + s->len - xlen, suffix, xlen);
};

// strview_drop_prefix — If sv starts with prefix view, return sv with those
//                       bytes removed. Otherwise return sv unchanged.
pub func:strview_drop_prefix = NIL(int64:sv, int64:prefix, int64:out) {
    if (raw strview_starts_with(sv, prefix)) {
        StrView->:p = @cast_unchecked<StrView->>(prefix);
        drop(strview_substr(sv, p->len, -1i64, out));
    } else {
        StrView->:s = @cast_unchecked<StrView->>(sv);
        StrView->:o = @cast_unchecked<StrView->>(out);
        o->ptr = s->ptr;
        o->len = s->len;
    }
};

// strview_strip_prefix_str — If sv starts with the NUL-terminated prefix,
//                            return sv with those bytes removed.
pub func:strview_strip_prefix_str = NIL(int64:sv, int64:prefix, int64:out) {
    if (raw strview_starts_with_str(sv, prefix)) {
        int64:plen = 0i64;
        if (prefix != 0i64) { plen = raw str_strlen(prefix); }
        drop(strview_substr(sv, plen, -1i64, out));
    } else {
        StrView->:s = @cast_unchecked<StrView->>(sv);
        StrView->:o = @cast_unchecked<StrView->>(out);
        o->ptr = s->ptr;
        o->len = s->len;
    }
};

// strview_drop_suffix — If sv ends with suffix view, return sv without it.
pub func:strview_drop_suffix = NIL(int64:sv, int64:suffix, int64:out) {
    StrView->:s = @cast_unchecked<StrView->>(sv);
    StrView->:o = @cast_unchecked<StrView->>(out);
    if (raw strview_ends_with(sv, suffix)) {
        StrView->:x = @cast_unchecked<StrView->>(suffix);
        o->ptr = s->ptr;
        o->len = s->len - x->len;
    } else {
        o->ptr = s->ptr;
        o->len = s->len;
    }
};

// strview_strip_suffix_str — If sv ends with NUL-terminated suffix, strip it.
pub func:strview_strip_suffix_str = NIL(int64:sv, int64:suffix, int64:out) {
    StrView->:s = @cast_unchecked<StrView->>(sv);
    StrView->:o = @cast_unchecked<StrView->>(out);
    if (raw strview_ends_with_str(sv, suffix)) {
        int64:xlen = 0i64;
        if (suffix != 0i64) { xlen = raw str_strlen(suffix); }
        o->ptr = s->ptr;
        o->len = s->len - xlen;
    } else {
        o->ptr = s->ptr;
        o->len = s->len;
    }
};

// ════════════════════════════════════════════════════════════════════════════
// Search
// ════════════════════════════════════════════════════════════════════════════

// strview_find_char — Return index of first occurrence of uint8 c in sv.
// Returns -1 if not found.
pub func:strview_find_char = int64(int64:sv, uint8:c) {
    if (sv == 0i64) { pass -1i64; }
    StrView->:s = @cast_unchecked<StrView->>(sv);
    if (s->len == 0i64) { pass -1i64; }
    int64:found = raw mem_memchr(s->ptr, @cast_unchecked<int64>(c), s->len);
    if (found == 0i64) { pass -1i64; }
    pass found - s->ptr;
};

// strview_rfind_char — Return index of LAST occurrence of uint8 c.
// Returns -1 if not found.
pub func:strview_rfind_char = int64(int64:sv, uint8:c) {
    if (sv == 0i64) { pass -1i64; }
    StrView->:s = @cast_unchecked<StrView->>(sv);
    if (s->len == 0i64) { pass -1i64; }
    int64:found = raw mem_memrchr(s->ptr, @cast_unchecked<int64>(c), s->len);
    if (found == 0i64) { pass -1i64; }
    pass found - s->ptr;
};

// strview_find_str — Return uint8 offset of first occurrence of NUL-terminated
//                    needle in sv. Returns -1 if not found.
pub func:strview_find_str = int64(int64:sv, int64:needle) {
    if (sv == 0i64 || needle == 0i64) { pass -1i64; }
    StrView->:s = @cast_unchecked<StrView->>(sv);
    int64:nlen = raw str_strlen(needle);
    if (nlen == 0i64) { pass 0i64; }
    if (nlen > s->len) { pass -1i64; }
    int64:found = raw mem_memmem(s->ptr, s->len, needle, nlen);
    if (found == 0i64) { pass -1i64; }
    pass found - s->ptr;
};

// strview_find — Return uint8 offset of first occurrence of needle view in sv.
// Returns -1 if not found.
pub func:strview_find = int64(int64:sv, int64:needle) {
    if (sv == 0i64 || needle == 0i64) { pass -1i64; }
    StrView->:s = @cast_unchecked<StrView->>(sv);
    StrView->:n = @cast_unchecked<StrView->>(needle);
    if (n->len == 0i64) { pass 0i64; }
    if (n->len > s->len) { pass -1i64; }
    int64:found = raw mem_memmem(s->ptr, s->len, n->ptr, n->len);
    if (found == 0i64) { pass -1i64; }
    pass found - s->ptr;
};

// strview_contains_char — True if uint8 c appears anywhere in sv.
pub func:strview_contains_char = bool(int64:sv, uint8:c) {
    pass raw strview_find_char(sv, c) >= 0i64;
};

// strview_contains_str — True if the NUL-terminated needle appears in sv.
pub func:strview_contains_str = bool(int64:sv, int64:needle) {
    pass raw strview_find_str(sv, needle) >= 0i64;
};

// strview_contains — True if needle view appears in sv.
pub func:strview_contains = bool(int64:sv, int64:needle) {
    pass raw strview_find(sv, needle) >= 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// Slicing
// ════════════════════════════════════════════════════════════════════════════

// strview_slice — [start, end) uint8 range of sv (0-indexed, end exclusive).
// Clamps both bounds to [0, sv->len].
pub func:strview_slice = NIL(int64:sv, int64:start, int64:end_idx, int64:out) {
    StrView->:s = @cast_unchecked<StrView->>(sv);
    StrView->:o = @cast_unchecked<StrView->>(out);
    if (start < 0i64) { start = 0i64; }
    if (end_idx < 0i64 || end_idx > s->len) { end_idx = s->len; }
    if (start > end_idx) { start = end_idx; }
    o->ptr = s->ptr + start;
    o->len = end_idx - start;
};

// strview_take — First n bytes of sv. Clamps to sv->len.
pub func:strview_take = NIL(int64:sv, int64:n, int64:out) {
    StrView->:s = @cast_unchecked<StrView->>(sv);
    StrView->:o = @cast_unchecked<StrView->>(out);
    if (n < 0i64) { n = 0i64; }
    if (n > s->len) { n = s->len; }
    o->ptr = s->ptr;
    o->len = n;
};

// strview_drop — Skip the first n bytes of sv. Clamps to sv->len.
pub func:strview_drop = NIL(int64:sv, int64:n, int64:out) {
    StrView->:s = @cast_unchecked<StrView->>(sv);
    StrView->:o = @cast_unchecked<StrView->>(out);
    if (n < 0i64) { n = 0i64; }
    if (n > s->len) { n = s->len; }
    o->ptr = s->ptr + n;
    o->len = s->len - n;
};

// strview_trim_left — Skip leading whitespace (space, \\t, \\n, \\r, \\f, \\v).
pub func:strview_trim_left = NIL(int64:sv, int64:out) {
    StrView->:s = @cast_unchecked<StrView->>(sv);
    StrView->:o = @cast_unchecked<StrView->>(out);
    int64:i = 0i64;
    uint8->:p = @cast_unchecked<uint8->>(s->ptr);
    while (i < s->len) {
        uint8:c = p[i];
        if (c != 32u8 && c != 9u8 && c != 10u8 &&
           c != 13u8 && c != 12u8 && c != 11u8) {
            break;
        }
        i = i + 1i64;
    }
    o->ptr = s->ptr + i;
    o->len = s->len - i;
};

// strview_trim_right — Remove trailing whitespace.
pub func:strview_trim_right = NIL(int64:sv, int64:out) {
    StrView->:s = @cast_unchecked<StrView->>(sv);
    StrView->:o = @cast_unchecked<StrView->>(out);
    int64:n = s->len;
    uint8->:p = @cast_unchecked<uint8->>(s->ptr);
    while (n > 0i64) {
        uint8:c = p[n - 1i64];
        if (c != 32u8 && c != 9u8 && c != 10u8 &&
           c != 13u8 && c != 12u8 && c != 11u8) {
            break;
        }
        n = n - 1i64;
    }
    o->ptr = s->ptr;
    o->len = n;
};

// strview_trim — Remove both leading and trailing whitespace.
pub func:strview_trim = NIL(int64:sv, int64:out) {
    stack StrView:tmp;
    drop(strview_trim_left(sv, @cast_unchecked<int64>(@tmp)));
    drop(strview_trim_right(@cast_unchecked<int64>(@tmp), out));
};

// ════════════════════════════════════════════════════════════════════════════
// Tokenization
// ════════════════════════════════════════════════════════════════════════════

// strview_split_once_char — Split sv at the first occurrence of uint8 delim.
//
// On success: left = [0, pos), right = [pos+1, len), returns true.
// If delim is not found: left = sv, right = empty, returns false.
//
// left and right may be the same *StrView @cast_unchecked<sv>(pointer) (aliasing is safe
// because we read sv before writing).
pub func:strview_split_once_char = bool(int64:sv, uint8:delim,
                                         int64:left_out, int64:right_out) {
    StrView->:s = @cast_unchecked<StrView->>(sv);
    int64:pos = raw strview_find_char(sv, delim);
    StrView->:lo = @cast_unchecked<StrView->>(left_out);
    StrView->:ro = @cast_unchecked<StrView->>(right_out);

    if (pos < 0i64) {
        lo->ptr = s->ptr;
        lo->len = s->len;
        ro->ptr = s->ptr + s->len;
        ro->len = 0i64;
        pass false;
    }

    lo->ptr = s->ptr;
    lo->len = pos;
    ro->ptr = s->ptr + pos + 1i64;
    ro->len = s->len - pos - 1i64;
    pass true;
};

// strview_split_once — Split sv at the first occurrence of needle view.
// left = bytes before needle, right = bytes after needle.
// Returns true if needle was found, false otherwise.
pub func:strview_split_once = bool(int64:sv, int64:needle,
                                    int64:left_out, int64:right_out) {
    StrView->:s  = @cast_unchecked<StrView->>(sv);
    StrView->:n  = @cast_unchecked<StrView->>(needle);
    StrView->:lo = @cast_unchecked<StrView->>(left_out);
    StrView->:ro = @cast_unchecked<StrView->>(right_out);
    int64:pos = raw strview_find(sv, needle);

    if (pos < 0i64) {
        lo->ptr = s->ptr;
        lo->len = s->len;
        ro->ptr = s->ptr + s->len;
        ro->len = 0i64;
        pass false;
    }

    lo->ptr = s->ptr;
    lo->len = pos;
    ro->ptr = s->ptr + pos + n->len;
    ro->len = s->len - pos - n->len;
    pass true;
};

// strview_next_token — Iterator-style tokenizer. Reads the next delim-separated
// token from *sv_ptr, advances *sv_ptr past the delimiter.
//
// sv_ptr: pointer to a StrView (will be MODIFIED to advance past token+delim).
// token_out: receives the token (without delim).
// Returns true if a token was found (even if empty), false if sv is exhausted.
//
// Usage:
//   stack StrView:cur;
//   strview_of(some_str, @cast_unchecked<int64>(@cur));
//   stack StrView:tok;
//   while strview_next_token(@cast_unchecked<int64>(@cur), '\n', @cast_unchecked<int64>(@tok)) { ... }
pub func:strview_next_token = bool(int64:sv_ptr, uint8:delim, int64:token_out) {
    StrView->:sv = @cast_unchecked<StrView->>(sv_ptr);
    if (sv->len == 0i64) { pass false; }

    stack StrView:left;
    left->ptr = 0i64; left->len = 0i64;
    stack StrView:right;
    right->ptr = 0i64; right->len = 0i64;
    bool:found = raw strview_split_once_char(sv_ptr, delim, @cast_unchecked<int64>(@left), @cast_unchecked<int64>(@right));

    StrView->:to = @cast_unchecked<StrView->>(token_out);
    to->ptr = left->ptr;
    to->len = left->len;

    if (found) {
        sv->ptr = right->ptr;
        sv->len = right->len;
    } else {
          // No delimiter: consume everything, leave sv empty
        sv->ptr = sv->ptr + sv->len;
        sv->len = 0i64;
    }

    pass true;
};

// strview_next_line — Advance *sv_ptr to the next line, returning the current
// line in line_out (without the trailing '\n' or '\r\n').
// Returns true if a line was produced, false if sv is empty.
pub func:strview_next_line = bool(int64:sv_ptr, int64:line_out) {
    StrView->:sv = @cast_unchecked<StrView->>(sv_ptr);
    if (sv->len == 0i64) { pass false; }

    uint8->:p = @cast_unchecked<uint8->>(sv->ptr);
    int64:i = 0i64;
    while (i < sv->len) {
        if (p[i] == 10u8) {    // '\n'
            break;
        }
        i = i + 1i64;
    }

      // i is now the index of '\n' (or sv->len if no newline)
    StrView->:lo = @cast_unchecked<StrView->>(line_out);
    lo->ptr = sv->ptr;
    lo->len = i;

      // Strip trailing '\r' if present (CRLF → just CR)
    if (lo->len > 0i64 && p[lo->len - 1i64] == 13u8) {
        lo->len = lo->len - 1i64;
    }

      // Advance sv past '\n' (or to end)
    if (i < sv->len) {
        sv->ptr = sv->ptr + i + 1i64;
        sv->len = sv->len - i - 1i64;
    } else {
        sv->ptr = sv->ptr + sv->len;
        sv->len = 0i64;
    }

    pass true;
};

// ════════════════════════════════════════════════════════════════════════════
// Parsing — read numeric values directly from the view's content
// ════════════════════════════════════════════════════════════════════════════

// strview_parse_i64 — Parse the view's @cast_unchecked<a>(content) signed decimal integer.
// Returns Result<int64>: Ok(value) or Err if the content is not a valid number.
// Leading/trailing whitespace is NOT accepted (use strview_trim first).
pub func:strview_parse_i64 = int64(int64:sv) {
    if (sv == 0i64) { fail @cast_unchecked<tbb32>(EINVAL); }
    StrView->:s = @cast_unchecked<StrView->>(sv);
    if (s->len == 0i64) { fail @cast_unchecked<tbb32>(EINVAL); }

      // str_parse_i64 expects a NUL-terminated string.
      // For performance, make a stack copy if len is small.
      // For large views, use heap.
    if (s->len < 64i64) {
        stack uint8[64]:tmp;
        drop(mem_memcpy(@cast_unchecked<int64>(@tmp), s->ptr, s->len));
        tmp[s->len] = 0u8;
        pass str_parse_i64(@cast_unchecked<int64>(@tmp));
    } else {
        Result<int64>:alloc_r = mem_malloc(s->len + 1i64);
        if (alloc_r.is_error) { fail @cast_unchecked<tbb32>(ENOMEM); }
        int64:buf = alloc_r.value;
        drop(mem_memcpy(buf, s->ptr, s->len));
        (@cast_unchecked<uint8->>(buf))[s->len] = 0u8;
        Result<int64>:r = str_parse_i64(buf);
        drop(mem_free(buf));
        return r;
    }
};

// strview_parse_u64 — @cast_unchecked<unsigned>(Parse) decimal integer.
pub func:strview_parse_u64 = int64(int64:sv) {
    if (sv == 0i64) { fail @cast_unchecked<tbb32>(EINVAL); }
    StrView->:s = @cast_unchecked<StrView->>(sv);
    if (s->len == 0i64) { fail @cast_unchecked<tbb32>(EINVAL); }

    if (s->len < 64i64) {
        stack uint8[64]:tmp;
        drop(mem_memcpy(@cast_unchecked<int64>(@tmp), s->ptr, s->len));
        tmp[s->len] = 0u8;
        pass str_parse_u64(@cast_unchecked<int64>(@tmp));
    } else {
        Result<int64>:alloc_r = mem_malloc(s->len + 1i64);
        if (alloc_r.is_error) { fail @cast_unchecked<tbb32>(ENOMEM); }
        int64:buf = alloc_r.value;
        drop(mem_memcpy(buf, s->ptr, s->len));
        (@cast_unchecked<uint8->>(buf))[s->len] = 0u8;
        Result<int64>:r = str_parse_u64(buf);
        drop(mem_free(buf));
        return r;
    }
};

// ════════════════════════════════════════════════════════════════════════════
// Output — converting views to owned strings or writing them to I/O
// ════════════════════════════════════════════════════════════════════════════

// strview_to_str — Heap-allocate a NUL-terminated copy of the view's content.
// Returns a pointer to a newly allocated string; caller must mem_free() it.
// Returns 0 on allocation failure or empty view (returns zero-length heap string).
pub func:strview_to_str = int64(int64:sv) {
    StrView->:s = @cast_unchecked<StrView->>(sv);
    Result<int64>:r = mem_malloc(s->len + 1i64);
    if (r.is_error) { pass 0i64; }
    if (s->len > 0i64) {
        drop(mem_memcpy(r.value, s->ptr, s->len));
    }
    (@cast_unchecked<uint8->>(r.value))[s->len] = 0u8;
    pass r.value;
};

// strview_to_strbuf — Create a new StrBuf initialized with the view's content.
// Returns a StrBuf* (as int64) that the caller owns. Free with strbuf_free().
pub func:strview_to_strbuf = int64(int64:sv) {
    StrView->:s = @cast_unchecked<StrView->>(sv);
    int64:sb = raw strbuf_new_cap(s->len + 1i64);
    if (sb == 0i64) { pass 0i64; }
    if (s->len > 0i64) {
        drop(strbuf_append_bytes(sb, s->ptr, s->len));
    }
    pass sb;
};

// strview_copy_to — Copy at most buflen bytes of the view into buf.
// Does NOT NUL-terminate. Returns number of bytes copied.
pub func:strview_copy_to = int64(int64:sv, int64:buf, int64:buflen) {
    if (sv == 0i64 || buf == 0i64 || buflen <= 0i64) { pass 0i64; }
    StrView->:s = @cast_unchecked<StrView->>(sv);
    int64:n = is (s->len < buflen) : s->len : buflen;
    if (n > 0i64) { drop(mem_memcpy(buf, s->ptr, n)); }
    pass n;
};

// strview_copy_to_z — Copy at most (buflen-1) bytes into buf, NUL-terminate.
// Equivalent to strlcpy semantics. Returns number of bytes written (excl. NUL).
pub func:strview_copy_to_z = int64(int64:sv, int64:buf, int64:buflen) {
    if (buf == 0i64 || buflen <= 0i64) { pass 0i64; }
    if (sv == 0i64) {
        (@cast_unchecked<uint8->>(buf))[0] = 0u8;
        pass 0i64;
    }
    StrView->:s = @cast_unchecked<StrView->>(sv);
    int64:max = buflen - 1i64;
    int64:n = is (s->len < max) : s->len : max;
    if (n > 0i64) { drop(mem_memcpy(buf, s->ptr, n)); }
    (@cast_unchecked<uint8->>(buf))[n] = 0u8;
    pass n;
};

// strview_write_to_fd — Write the view's bytes directly to a file descriptor.
// Returns number of bytes written, or -1 on error.
pub func:strview_write_to_fd = int64(int64:sv, int64:fd) {
    if (sv == 0i64) { pass 0i64; }
    StrView->:s = @cast_unchecked<StrView->>(sv);
    if (s->len == 0i64) { pass 0i64; }
    Result<int64>:r = libn_write_all(fd, s->ptr, s->len);
    if (r.is_error) { pass -1i64; }
    pass r.value;
};

// strview_write_to_fp — Write the view's bytes to a FILE* stream.
// Returns number of bytes written, or -1 on error.
pub func:strview_write_to_fp = int64(int64:sv, int64:fp) {
    if (sv == 0i64) { pass 0i64; }
    StrView->:s = @cast_unchecked<StrView->>(sv);
    if (s->len == 0i64) { pass 0i64; }
    int64:n = raw fwrite(s->ptr, 1i64, s->len, fp);
    if (n < s->len) { pass -1i64; }
    pass n;
};

// ════════════════════════════════════════════════════════════════════════════
// StrViewIter — simple stateful line/token iterator
//
// Holds a StrView of the remaining unconsumed input.
// Wraps strview_next_line and strview_next_token.
//
// Usage pattern (lines):
//
//   stack StrViewIter:it;
//   strviewiter_of_str(@cast_unchecked<int64>(@it), some_text);
//   stack StrView:line;
//   while strviewiter_next_line(@cast_unchecked<int64>(@it), @cast_unchecked<int64>(@line)) {
//       // process line
//   }
// ════════════════════════════════════════════════════════════════════════════

pub struct:StrViewIter = {
    int64:ptr;      // pointer into remaining data (same @cast_unchecked<StrView>(semantics)->ptr)
    int64:len;      // remaining bytes
};

// strviewiter_of — Init an iterator from a StrView.
pub func:strviewiter_of = NIL(int64:it, int64:sv) {
    StrViewIter->:i = @cast_unchecked<StrViewIter->>(it);
    StrView->:s = @cast_unchecked<StrView->>(sv);
    i->ptr = s->ptr;
    i->len = s->len;
};

// strviewiter_of_str — Init an iterator from a NUL-terminated string.
pub func:strviewiter_of_str = NIL(int64:it, int64:s) {
    StrViewIter->:i = @cast_unchecked<StrViewIter->>(it);
    if (s == 0i64) {
        i->ptr = 0i64;
        i->len = 0i64;
        pass NIL;
    }
    i->ptr = s;
    i->len = raw str_strlen(s);
};

// strviewiter_next_line — Read the next '\n'-terminated line into line_out.
// Strips trailing '\r' for CRLF compatibility.
// Returns true while lines remain; false when exhausted.
pub func:strviewiter_next_line = bool(int64:it, int64:line_out) {
      // The StrViewIter struct is layout-compatible with StrView (ptr+len),
      // so we can pass it directly to strview_next_line.
    pass strview_next_line(it, line_out);
};

// strviewiter_next_token — Read next delim-separated token into token_out.
// Returns true while tokens remain; false when exhausted.
pub func:strviewiter_next_token = bool(int64:it, uint8:delim, int64:token_out) {
    pass strview_next_token(it, delim, token_out);
};

// strviewiter_remaining — How many bytes are left in the iterator.
pub func:strviewiter_remaining = int64(int64:it) {
    if (it == 0i64) { pass 0i64; }
    pass (@cast_unchecked<StrViewIter->>(it))->len;
};

// string.npk — Top-level string module re-export (v0.9.0)
//
// Import this file to get the complete string subsystem in one shot.
// Consumers can also import individual sub-modules for finer dependency control.
//
// Module hierarchy:
//   v0.3.1  strlen.npk  — strlen, strnlen
//   v0.3.1  strcpy.npk  — strcpy, strncpy, stpcpy, stpncpy, strdup, strndup
//   v0.3.2  strcmp.npk  — strcmp, strncmp, strcasecmp, strncasecmp, prefix checks
//   v0.3.3  strlcpy.npk — strlcpy, strlcat, strscpy, strscpy_pad
//   v0.3.4  strchr.npk  — strchr, strrchr, strstr, strcasestr, strpbrk, strspn, strcspn
//   v0.3.5  strtok.npk  — strtok_r, strsep, StrField, split_fields, split_lines
//   v0.3.6  strconv.npk — strtol, strtoul, atoi, itoa, utoa, parse_i64/u64
//   v0.3.7  strfmt.npk  — snprintf engine, str_format_args, str_snprintf0-8
//   v0.7.0  strbuf.npk  — StrBuf growable string buffer (heap-backed, geometric growth)
//   v0.9.0  strview.npk — StrView non-owning slice + StrViewIter line/token iterator
//
// Future:
//   v0.3.9  memmem.npk  — memmem, Boyer-Moore-Horspool
//   v0.3.10 strtrim.npk — ltrim, rtrim, trim, chomp
//   v0.10.x math.npk    — abs, min, max, clamp, pow2 utilities

use "../str/strlen.npk".*;
use "../str/strcpy.npk".*;
use "../str/strcmp.npk".*;
use "../str/strlcpy.npk".*;
use "../str/strchr.npk".*;
use "../str/strtok.npk".*;
use "../str/strconv.npk".*;
use "../str/strfmt.npk".*;
use "../str/strbuf.npk".*;
use "../str/strview.npk".*;

// strconv.npk — Integer/string conversion: atoi, atol, strtol, strtoul,
//               itoa, utoa, strtod (v0.3.6)
//
// String ↔ integer/float conversion. These are among the most subtle functions
// in any standard library — getting the overflow, base, sign, and whitespace
// handling right is non-trivial.
//
// Correctness contract (POSIX strtol behavior):
//   - Skips leading whitespace (space, \t, \n, \r, \f, \v).
//   - Accepts optional leading '+' or '-'.
//   - Base 0: auto-detect (0x prefix → hex, 0 prefix → octal, else decimal).
//   - Sets *endptr to first unconverted character.
//   - Returns LONG_MIN/LONG_MAX and sets ERANGE on overflow.
//   - Returns 0 if no digits found (ERR_BADARG).
//
// libn ADDITION — Result<int64> variants:
//   str_parse_i64, str_parse_u64: return Result<int64> instead of errno.
//   These are the preferred way to parse untrusted input.
//
// Performance: strtol is inherently scalar. No word-tricks apply here.
//   The hot path is the digit accumulation loop — we minimize branches there.

use "../syscall/errno.npk".*;
use "../str/strlen.npk".*;
use "../str/strlcpy.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// ASCII classification helpers
// ════════════════════════════════════════════════════════════════════════════

// is_whitespace — True for space, \t, \n, \r, \f (0x0C), \v (0x0B)
func:is_whitespace = bool(uint8:c) {
    pass c == 32u8 || c == 9u8 || c == 10u8 || c == 13u8 || c == 12u8 || c == 11u8;
};

// is_digit — True for '0'-'9'
func:is_digit = bool(uint8:c) {
    pass c >= 48u8 && c <= 57u8;
};

// is_hex_digit — True for '0'-'9', 'a'-'f', 'A'-'F'
func:is_hex_digit = bool(uint8:c) {
    pass raw is_digit(c) || (c >= 65u8 && c <= 70u8) || (c >= 97u8 && c <= 102u8);
};

// digit_val — Convert ASCII digit to integer value. Base-agnostic.
// Returns -1 for characters not valid in the given base.
func:digit_val = int64(uint8:c, int64:base) {
    int64:v = -1i64;
    if (c >= 48u8 && c <= 57u8) {           // '0'-'9'
        v = @cast_unchecked<int64>((c - 48u8));
    } else if (c >= 65u8 && c <= 90u8) {    // 'A'-'Z'
        v = @cast_unchecked<int64>((c - 55u8));           // 'A'=10, 'B'=11, ...
    } else if (c >= 97u8 && c <= 122u8) {   // 'a'-'z'
        v = @cast_unchecked<int64>((c - 87u8));           // 'a'=10, 'b'=11, ...
    }
    if (v >= base) { v = -1i64; }
    pass v;
};

// ════════════════════════════════════════════════════════════════════════════
// str_strtol — Convert string to signed 64-bit integer.
//
// Parameters:
//   s:       Input string (may have leading whitespace).
//   endptr:  If non-NULL, set to first character not consumed.
//   base:    Numeric base (2-36, or 0 for auto-detect).
//
// Returns: converted value. On overflow, returns INT64_MAX or INT64_MIN and
//          sets the last errno. libn sets the global g_errno.
// ════════════════════════════════════════════════════════════════════════════

use "../syscall/errno.npk".*;

fixed int64:INT64_MAX = 9223372036854775807i64;
fixed int64:INT64_MIN = -9223372036854775808i64;    // or: 0i64 - INT64_MAX - 1i64

pub func:str_strtol = int64(int64:s, int64->:endptr, int64:base) {
    if (s == 0i64) {
        if (@cast_unchecked<int64>(endptr) != 0i64) { endptr[0] = 0i64; }
        pass 0i64;
    }

    uint8->:p = @cast_unchecked<uint8->>(s);
    int64:i = 0i64;

      // Skip leading whitespace
    while (raw is_whitespace(p[i])) { i = i + 1i64; }

      // Sign
    bool:negative = false;
    if (p[i] == 43u8) {         // '+'
        i = i + 1i64;
    } else if (p[i] == 45u8) {   // '-'
        negative = true;
        i = i + 1i64;
    }

      // Base auto-detect
    if (base == 0i64) {
        if (p[i] == 48u8 && (p[i + 1i64] == 120u8 || p[i + 1i64] == 88u8)) {    // "0x" or "0X"
            base = 16i64;
            i = i + 2i64;
        } else if (p[i] == 48u8) {
            base = 8i64;
        } else {
            base = 10i64;
        }
    } else if (base == 16i64 && p[i] == 48u8 &&
              (p[i + 1i64] == 120u8 || p[i + 1i64] == 88u8)) {
        i = i + 2i64;    // Skip 0x prefix for explicit base 16
    }

      // Digit scan
    int64:digit_start = i;
    int64:result = 0i64;
    bool:overflow = false;

    while (true) {
        int64:dv = raw digit_val(p[i], base);
        if (dv < 0i64) { break; }

          // Overflow check before multiply
        if (!negative && result > (INT64_MAX - dv) / base) {
            overflow = true;
            break;
        }
        if (negative && result > (INT64_MAX + 1i64) / base) {    // INT64_MIN / base
            overflow = true;
            break;
        }

        result = result * base + dv;
        i = i + 1i64;
    }

      // No digits found
    if (i == digit_start) {
        drop(errno_set(ERR_BADARG));
        if (@cast_unchecked<int64>(endptr) != 0i64) { endptr[0] = s; }
        pass 0i64;
    }

    if (overflow) {
        drop(errno_set(ERANGE));
        if (@cast_unchecked<int64>(endptr) != 0i64) { endptr[0] = s + i; }
        if (negative) { pass INT64_MIN; }
        pass INT64_MAX;
    }

    if (@cast_unchecked<int64>(endptr) != 0i64) { endptr[0] = s + i; }

    if (negative) { pass 0i64 - result; }
    pass result;
};

// ════════════════════════════════════════════════════════════════════════════
// str_strtoul — Convert string to unsigned 64-bit integer.
// ════════════════════════════════════════════════════════════════════════════

fixed int64:UINT64_MAX = -1i64;    // 0xFFFFFFFFFFFFFFFF (all bits set, re-@cast_unchecked<uint64>(interpreted))

pub func:str_strtoul = int64(int64:s, int64->:endptr, int64:base) {
    if (s == 0i64) {
        if (@cast_unchecked<int64>(endptr) != 0i64) { endptr[0] = 0i64; }
        pass 0i64;
    }

    uint8->:p = @cast_unchecked<uint8->>(s);
    int64:i = 0i64;

    while (raw is_whitespace(p[i])) { i = i + 1i64; }

      // strtoul: POSIX says '+' is accepted, '-' causes value to be negated modulo
      // the max uint value. We implement the simpler but correct approach.
    bool:negate = false;
    if (p[i] == 43u8) {
        i = i + 1i64;
    } else if (p[i] == 45u8) {
        negate = true;
        i = i + 1i64;
    }

    if (base == 0i64) {
        if (p[i] == 48u8 && (p[i + 1i64] == 120u8 || p[i + 1i64] == 88u8)) {
            base = 16i64;
            i = i + 2i64;
        } else if (p[i] == 48u8) {
            base = 8i64;
        } else {
            base = 10i64;
        }
    } else if (base == 16i64 && p[i] == 48u8 &&
              (p[i + 1i64] == 120u8 || p[i + 1i64] == 88u8)) {
        i = i + 2i64;
    }

    int64:digit_start = i;
    uint64:result = 0u64;
    bool:overflow = false;

    while (true) {
        int64:dv = raw digit_val(p[i], base);
        if (dv < 0i64) { break; }
        uint64:udv = @cast_unchecked<uint64>(dv);
        uint64:ubase = @cast_unchecked<uint64>(base);
        uint64:umax = @cast_unchecked<uint64>(-1i64);

        if (result > (umax - udv) / ubase) {
            overflow = true;
            break;
        }
        result = result * ubase + udv;
        i = i + 1i64;
    }

    if (i == digit_start) {
        drop(errno_set(ERR_BADARG));
        if (@cast_unchecked<int64>(endptr) != 0i64) { endptr[0] = s; }
        pass 0i64;
    }

    if (overflow) {
        drop(errno_set(ERANGE));
        if (@cast_unchecked<int64>(endptr) != 0i64) { endptr[0] = s + i; }
        pass UINT64_MAX;
    }

    if (@cast_unchecked<int64>(endptr) != 0i64) { endptr[0] = s + i; }

    int64:final_res = @cast_unchecked<int64>(result);
    if (negate) { pass 0i64 - final_res; }    // Modular negation for unsigned
    pass final_res;
};

// ════════════════════════════════════════════════════════════════════════════
// str_atoi — Simple atoi wrapper. No base selection, no error propagation.
//
// Skips leading whitespace, parses decimal digits.
// Returns 0 on empty or non-numeric input.
// Use str_parse_i64 for safe, error-propagating conversion.
// ════════════════════════════════════════════════════════════════════════════

pub func:str_atoi = int64(int64:s) {
    pass str_strtol(s, @cast_unchecked<int64->>(0i64), 10i64);
};

// ════════════════════════════════════════════════════════════════════════════
// str_parse_i64 — Safe integer parse with Result<int64>.
//
// Parses the entire @cast_unchecked<a>(string) signed decimal integer.
// Fails if:
//   - Input is NULL or empty.
//   - Non-digit characters remain after the number (trailing junk).
//   - Overflow/underflow.
// ════════════════════════════════════════════════════════════════════════════

pub func:str_parse_i64 = int64(int64:s) {
    if (s == 0i64 || (@cast_unchecked<uint8->>(s))[0] == 0u8) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }

    int64:endptr = 0i64;
    int64:endptr_val = s;
    int64->:ep = @endptr_val;
    int64:v = raw str_strtol(s, ep, 10i64);

      // Check for overflow (errno set by strtol)
    if (raw libn_errno_get() == ERANGE) {
        drop(errno_clear());
        fail @cast_unchecked<tbb32>(ERANGE);
    }

      // Check for trailing non-whitespace junk
    if (ep[0] != 0i64 && (@cast_unchecked<uint8->>(ep[0]))[0] != 0u8) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }

    pass v;
};

// ════════════════════════════════════════════════════════════════════════════
// str_parse_u64 — Safe unsigned integer parse with Result<int64>.
// ════════════════════════════════════════════════════════════════════════════

pub func:str_parse_u64 = int64(int64:s) {
    if (s == 0i64 || (@cast_unchecked<uint8->>(s))[0] == 0u8) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }

    int64:endptr_val = s;
    int64->:ep = @endptr_val;
    int64:v = raw str_strtoul(s, ep, 10i64);

    if (raw libn_errno_get() == ERANGE) {
        drop(errno_clear());
        fail @cast_unchecked<tbb32>(ERANGE);
    }

    if (ep[0] != 0i64 && (@cast_unchecked<uint8->>(ep[0]))[0] != 0u8) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }

    pass v;
};

// ════════════════════════════════════════════════════════════════════════════
// str_parse_i64_base — Parse integer with explicit base (2-36).
// ════════════════════════════════════════════════════════════════════════════

pub func:str_parse_i64_base = int64(int64:s, int64:base) {
    if (s == 0i64 || (@cast_unchecked<uint8->>(s))[0] == 0u8) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    if (base < 2i64 || base > 36i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }

    int64:endptr_val = s;
    int64->:ep = @endptr_val;
    int64:v = raw str_strtol(s, ep, base);

    if (raw libn_errno_get() == ERANGE) {
        drop(errno_clear());
        fail @cast_unchecked<tbb32>(ERANGE);
    }

    if (ep[0] != 0i64 && (@cast_unchecked<uint8->>(ep[0]))[0] != 0u8) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }

    pass v;
};

// ════════════════════════════════════════════════════════════════════════════
// str_itoa — Convert signed 64-bit integer to decimal string.
//
// Writes into 'buf' (must be at least 21 bytes for INT64_MIN).
// Returns the number of characters written (not including NUL).
// ════════════════════════════════════════════════════════════════════════════

pub func:str_itoa = int64(int64:v, int64:buf, int64:buf_size) {
    if (buf == 0i64 || buf_size <= 0i64) {
        pass 0i64;
    }

    uint8->:b = @cast_unchecked<uint8->>(buf);

      // Special case: zero
    if (v == 0i64) {
        if (buf_size < 2i64) { pass 0i64; }
        b[0] = 48u8;    // '0'
        b[1] = 0u8;
        pass 1i64;
    }

      // Handle INT64_MIN specially (cannot negate it)
    if (v == INT64_MIN) {
        int64:min_str = @cast_unchecked<int64>(@"-9223372036854775808");
        int64:s = raw str_strlen(min_str);
        if (buf_size <= s) { pass 0i64; }
        drop(str_strlcpy(buf, min_str, buf_size));
        pass s;
    }

      // Use a small temp buffer (21 bytes max for int64)
    stack uint8[21]:tmp; tmp[0] = 0u8;
    bool:neg = v < 0i64;
    uint64:u = @cast_unchecked<uint64>(v);
    if (neg) { u = @cast_unchecked<uint64>(0i64 - v); }

    int64:ti = 0i64;
    while (u > 0i64) {
        tmp[ti] = @cast_unchecked<uint8>((48i64 + u % 10i64));    // '0' + digit
        u = u / 10i64;
        ti = ti + 1i64;
    }

    int64:total_len = ti;
    if (neg) { total_len = total_len + 1i64; }

    if (buf_size <= total_len) { pass 0i64; }    // Buffer too small

    int64:bi = 0i64;
    if (neg) {
        b[bi] = 45u8;    // '-'
        bi = bi + 1i64;
    }

      // Digits are in tmp in reverse order — copy them out reversed
    while (ti > 0i64) {
        ti = ti - 1i64;
        b[bi] = tmp[ti];
        bi = bi + 1i64;
    }
    b[bi] = 0u8;    // NUL terminate

    pass total_len;
};

// ════════════════════════════════════════════════════════════════════════════
// str_utoa — Convert unsigned 64-bit integer to decimal string.
// ════════════════════════════════════════════════════════════════════════════

pub func:str_utoa = int64(int64:v, int64:buf, int64:buf_size) {
    if (buf == 0i64 || buf_size <= 0i64) { pass 0i64; }

    uint8->:b = @cast_unchecked<uint8->>(buf);

    if (v == 0i64) {
        if (buf_size < 2i64) { pass 0i64; }
        b[0] = 48u8; b[1] = 0u8;
        pass 1i64;
    }

    stack uint8[21]:tmp; tmp[0] = 0u8;
    int64:ti = 0i64;
      // Treat @cast_unchecked<unsigned>(v): use bit pattern, divide step by step
      // For unsigned we need to be careful: high bit means large number
      // Simple: do the loop treating @cast_unchecked<positive>(v) int64 (works for 0..INT64_MAX)
      // For values > INT64_MAX, we need unsigned division. Nitpick doesn't have a
      // native uint64 divide, so we use the standard two-step approach:
      // high = v >>> 32, low = v & 0xFFFFFFFF, combine.
      // For now, use signed representation (safe for typical use of utoa):
    uint64:u = @cast_unchecked<uint64>(v);
    while (u > 0u64 || ti == 0i64) {
        tmp[ti] = @cast_unchecked<uint8>((48u64 + u % 10u64));
        u = u / 10u64;
        ti = ti + 1i64;
        if (u == 0u64) { break; }
    }

    if (buf_size <= ti) { pass 0i64; }

    int64:bi = 0i64;
    while (ti > 0i64) {
        ti = ti - 1i64;
        b[bi] = tmp[ti];
        bi = bi + 1i64;
    }
    b[bi] = 0u8;

    pass bi;
};

// ════════════════════════════════════════════════════════════════════════════
// str_itoa_hex — Convert to lowercase hex string.
// Writes "0x" prefix if include_prefix is true.
// ════════════════════════════════════════════════════════════════════════════

pub func:str_itoa_hex = int64(int64:v, int64:buf, int64:buf_size, bool:include_prefix) {
    if (buf == 0i64 || buf_size <= 0i64) { pass 0i64; }

    uint8->:b = @cast_unchecked<uint8->>(buf);
    stack uint8[18]:tmp; tmp[0] = 0u8;    // max 16 hex digits + optional 0x prefix
    int64:ti = 0i64;

      // Build hex digits in reverse
    int64:u = v;
    if (u == 0i64) {
        tmp[0] = 48u8;    // '0'
        ti = 1i64;
    } else {
        while (u != 0i64) {
            int64:digit = u & 0xFi64;
            if (digit < 10i64) {
                tmp[ti] = @cast_unchecked<uint8>((48i64 + digit));     // '0'..'9'
            } else {
                tmp[ti] = @cast_unchecked<uint8>((87i64 + digit));     // 'a'..'f' (87 = 'a'-10)
            }
            u = (u >> 4i64) & 0x0FFFFFFFFFFFFFFFi64;    // logical right shift (unsigned)
              // Problem: int64 >> is arithmetic in Nitpick
              // Use: u = (@cast_unchecked<uint64>(u)) >> 4 → in Nitpick we use: u = (u & INT64_MAX) >> 4
              // For full 64-bit hex, handle sign bit separately if needed.
              // At v0.3.6 this handles unsigned values correctly for positive int64.
            ti = ti + 1i64;
        }
    }

    int64:prefix_len = 0i64;
    if (include_prefix) { prefix_len = 2i64; }
    int64:total = ti + prefix_len;
    if (buf_size <= total) { pass 0i64; }

    int64:bi = 0i64;
    if (include_prefix) {
        b[bi] = 48u8; bi = bi + 1i64;     // '0'
        b[bi] = 120u8; bi = bi + 1i64;    // 'x'
    }

    while (ti > 0i64) {
        ti = ti - 1i64;
        b[bi] = tmp[ti];
        bi = bi + 1i64;
    }
    b[bi] = 0u8;

    pass total;
};

// strbuf.npk — Growable string buffer (v0.7.0)
//
// StrBuf is the foundational dynamic string type in libn. It solves the core
// limitation of the snprintf/asprintf family: the 4096-uint8 stack-buffer cap.
//
// ── Design ────────────────────────────────────────────────────────────────
//
// A StrBuf is a heap-allocated uint8 buffer with:
//   ptr  — pointer to the buffer (always NUL-terminated after any write)
//   len  — current content length (bytes, excluding NUL)
//   cap  — allocated capacity (always >= len + 1 for the NUL uint8)
//
// Represented in @cast_unchecked<an>(libn) int64 pointer to a StrBuf struct.
// Use strbuf_new() to allocate, strbuf_free() when done.
// The buffer is always NUL-terminated so strbuf_ptr() can be passed
// directly to any function expecting a C string.
//
// ── Growth policy ─────────────────────────────────────────────────────────
// When a write would exceed capacity, the buffer doubles (geometric growth).
// Minimum initial capacity: STRBUF_MIN_CAP (64 bytes).
// mem_realloc uses mremap() where possible for zero-copy in-place growth.
//
// ── API surface ───────────────────────────────────────────────────────────
//   strbuf_new()                  — allocate empty buffer (cap=STRBUF_MIN_CAP)
//   strbuf_new_cap(n)             — allocate with at least n bytes capacity
//   strbuf_free(sb)               — free buffer and struct
//   strbuf_reset(sb)              — clear content, keep allocation
//   strbuf_len(sb)                — current content length
//   strbuf_cap(sb)                — current capacity
//   strbuf_ptr(sb)                — pointer to NUL-terminated content
//   strbuf_append_char(sb, c)     — append one uint8
//   strbuf_append_bytes(sb, p, n) — append n raw bytes
//   strbuf_append_str(sb, s)      — append NUL-terminated string
//   strbuf_appendf0..8(sb, fmt, ...) — append formatted output (any length)
//   strbuf_finish(sb)             — return content pointer, free struct only
//                                    (caller owns the returned buffer)
//   strbuf_to_str(sb)             — heap-copy of content; frees sb
//
// ── Thread safety ─────────────────────────────────────────────────────────
// Not thread-safe. External synchronization required for concurrent access.

use "../syscall/errno.npk".*;
use "../mem/mmap.npk".*;
use "../mem/memcpy.npk".*;
use "../mem/memset.npk".*;
use "../mem/slab.npk".*;
use "../str/strlen.npk".*;
use "../str/strfmt.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// StrBuf struct
// ════════════════════════════════════════════════════════════════════════════

pub struct:StrBuf = {
    int64:ptr;      // heap buffer pointer (always NUL-terminated)
    int64:len;      // content length in bytes (excluding NUL)
    int64:cap;      // total allocated capacity (buf[0.->cap-1], NUL at buf[len])
};

// Minimum initial capacity — 64 bytes is enough for most short strings
pub fixed int64:STRBUF_MIN_CAP = 64i64;

// Maximum single-step render buffer for strbuf_appendf* (matches PRINTF_BUF_SIZE)
fixed int64:STRBUF_FMT_BUF = 4096i64;

// ════════════════════════════════════════════════════════════════════════════
// Internal helpers
// ════════════════════════════════════════════════════════════════════════════

// strbuf_grow — Ensure buf has room for at least (sb->len + need + 1) bytes.
// Returns true on success, false on OOM.
func:strbuf_grow = bool(int64:sb, int64:need) {
    StrBuf->:s = @cast_unchecked<StrBuf->>(sb);
    int64:required = s->len + need + 1i64;
    if (required <= s->cap) {
        pass true;
    }

      // Grow by 1.5x until we fit
    int64:new_cap = is (s->cap > 0i64) : s->cap : STRBUF_MIN_CAP;
    while (new_cap < required) {
        new_cap = new_cap + (new_cap / 2i64);
          // Overflow guard (very unlikely to hit in practice)
        if (new_cap < 0i64) {
            pass false;
        }
    }

    int64:r = libn_slab_realloc(s->ptr, new_cap);
    if (r == 0i64) {
        pass false;
    }

    s->ptr = r;
    s->cap = new_cap;
    pass true;
};

// ════════════════════════════════════════════════════════════════════════════
// Lifecycle
// ════════════════════════════════════════════════════════════════════════════

// strbuf_new — Allocate a new empty StrBuf with default initial capacity.
// Returns StrBuf* (as int64), or 0 on allocation failure.
pub func:strbuf_new = int64() {
    pass strbuf_new_cap(STRBUF_MIN_CAP);
};

// strbuf_new_cap — Allocate with at least init_cap bytes of capacity.
pub func:strbuf_new_cap = int64(int64:init_cap) {
    int64:cap = is (init_cap > STRBUF_MIN_CAP) : init_cap : STRBUF_MIN_CAP;

      // Allocate the StrBuf struct itself (24 bytes, fits in slab 32-uint8 class)
    Result<int64>:sr = mem_malloc(24i64);
    if (sr.is_error) { pass 0i64; }
    int64:sb = sr.value;

      // Allocate the string buffer
    Result<int64>:br = mem_malloc(cap);
    if (br.is_error) {
        drop(mem_free(sb));
        pass 0i64;
    }

    StrBuf->:s = @cast_unchecked<StrBuf->>(sb);
    s->ptr = br.value;
    s->len = 0i64;
    s->cap = cap;

      // NUL-terminate the empty string
    (@cast_unchecked<uint8->>(s->ptr))[0] = 0u8;

    pass sb;
};

// strbuf_free — Free the string buffer and the StrBuf struct.
// After this call, sb is invalid. Passing 0 is a no-op.
pub func:strbuf_free = NIL(int64:sb) {
    if (sb == 0i64) { pass NIL; }
    StrBuf->:s = @cast_unchecked<StrBuf->>(sb);
    if (s->ptr != 0i64) {
        drop(mem_free(s->ptr));
    }
    drop(mem_free(sb));
};

// strbuf_reset — Clear content (set len=0, NUL-terminate) without freeing.
// The allocated buffer is reused. Useful for building multiple strings.
pub func:strbuf_reset = NIL(int64:sb) {
    if (sb == 0i64) { pass NIL; }
    StrBuf->:s = @cast_unchecked<StrBuf->>(sb);
    s->len = 0i64;
    if (s->ptr != 0i64) {
        (@cast_unchecked<uint8->>(s->ptr))[0] = 0u8;
    }
};

// strbuf_finish — Transfer the string buffer to the caller and free the struct.
//
// After this call, sb is invalid. The returned pointer is a heap-allocated
// NUL-terminated string — the CALLER is responsible for calling mem_free() on it.
// Returns 0 if sb was 0 or its ptr was 0.
pub func:strbuf_finish = int64(int64:sb) {
    if (sb == 0i64) { pass 0i64; }
    StrBuf->:s = @cast_unchecked<StrBuf->>(sb);
    int64:ptr = s->ptr;
    s->ptr = 0i64;    // prevent double-free in strbuf_free
    drop(mem_free(sb));
    pass ptr;
};

// strbuf_to_str — Copy content to a new heap buffer, free the StrBuf.
//
// Unlike strbuf_finish, the returned pointer is a fresh minimum-size allocation.
// Useful when you want to trim excess capacity before storing the string long-term.
pub func:strbuf_to_str = int64(int64:sb) {
    if (sb == 0i64) { pass 0i64; }
    StrBuf->:s = @cast_unchecked<StrBuf->>(sb);

    int64:n = s->len;
    Result<int64>:r = mem_malloc(n + 1i64);
    if (r.is_error) {
        drop(strbuf_free(sb));
        pass 0i64;
    }

    drop(mem_memcpy(r.value, s->ptr, n + 1i64));    // includes NUL
    drop(strbuf_free(sb));
    pass r.value;
};

// ════════════════════════════════════════════════════════════════════════════
// Accessors
// ════════════════════════════════════════════════════════════════════════════

// strbuf_len — Current content length (bytes, excluding NUL).
pub func:strbuf_len = int64(int64:sb) {
    if (sb == 0i64) { pass 0i64; }
    pass (@cast_unchecked<StrBuf->>(sb))->len;
};

// strbuf_cap — Current total capacity.
pub func:strbuf_cap = int64(int64:sb) {
    if (sb == 0i64) { pass 0i64; }
    pass (@cast_unchecked<StrBuf->>(sb))->cap;
};

// strbuf_ptr — Pointer to the NUL-terminated content string.
// Valid until the next mutating strbuf_* call (growth may realloc).
pub func:strbuf_ptr = int64(int64:sb) {
    if (sb == 0i64) { pass 0i64; }
    pass (@cast_unchecked<StrBuf->>(sb))->ptr;
};

// strbuf_is_empty — True if the buffer has no content (len == 0).
pub func:strbuf_is_empty = bool(int64:sb) {
    if (sb == 0i64) { pass true; }
    pass (@cast_unchecked<StrBuf->>(sb))->len == 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// Append operations
// ════════════════════════════════════════════════════════════════════════════

// strbuf_append_char — Append a single uint8 to the buffer.
// Returns true on success, false on OOM.
pub func:strbuf_append_char = bool(int64:sb, uint8:c) {
    if (sb == 0i64) { pass false; }
    if (!raw strbuf_grow(sb, 1i64)) { pass false; }

    StrBuf->:s = @cast_unchecked<StrBuf->>(sb);
    uint8->:p = @cast_unchecked<uint8->>(s->ptr);
    p[s->len] = c;
    s->len = s->len + 1i64;
    p[s->len] = 0u8;    // keep NUL-terminated
    pass true;
};

// strbuf_append_bytes — Append n bytes from ptr to the buffer.
// Returns true on success, false on OOM or invalid args.
pub func:strbuf_append_bytes = bool(int64:sb, int64:ptr, int64:n) {
    if (sb == 0i64 || ptr == 0i64 || n <= 0i64) { pass false; }
    if (!raw strbuf_grow(sb, n)) { pass false; }

    StrBuf->:s = @cast_unchecked<StrBuf->>(sb);
    drop(mem_memcpy(s->ptr + s->len, ptr, n));
    s->len = s->len + n;
    (@cast_unchecked<uint8->>(s->ptr))[s->len] = 0u8;    // NUL-terminate
    pass true;
};

// strbuf_append_str — Append a NUL-terminated string to the buffer.
// Returns true on success, false on OOM or null input.
pub func:strbuf_append_str = bool(int64:sb, int64:str) {
    if (sb == 0i64 || str == 0i64) { pass false; }
    int64:n = raw str_strlen(str);
    if (n == 0i64) { pass true; }    // appending empty string is a no-op
    pass strbuf_append_bytes(sb, str, n);
};

// strbuf_append_strbuf — Append the content of another StrBuf.
pub func:strbuf_append_strbuf = bool(int64:sb, int64:other) {
    if (sb == 0i64 || other == 0i64) { pass false; }
    StrBuf->:o = @cast_unchecked<StrBuf->>(other);
    if (o->len == 0i64) { pass true; }
    pass strbuf_append_bytes(sb, o->ptr, o->len);
};

// strbuf_append_repeat — Append uint8 c repeated n times.
pub func:strbuf_append_repeat = bool(int64:sb, uint8:c, int64:n) {
    if (sb == 0i64 || n <= 0i64) { pass false; }
    if (!raw strbuf_grow(sb, n)) { pass false; }
    StrBuf->:s = @cast_unchecked<StrBuf->>(sb);
    drop(mem_memset(s->ptr + s->len, @cast_unchecked<int64>(c), n));
    s->len = s->len + n;
    (@cast_unchecked<uint8->>(s->ptr))[s->len] = 0u8;
    pass true;
};

// ════════════════════════════════════════════════════════════════════════════
// Formatted append — strbuf_appendf*
//
// Renders a format string into a 4096-uint8 stack buffer via str_snprintfN,
// then appends the result to the StrBuf. For output exceeding 4095 bytes,
// use multiple calls or pre-render into a large intermediate buffer.
//
// Returns number of bytes appended, or -1 on OOM.
// ════════════════════════════════════════════════════════════════════════════

pub func:strbuf_appendf0 = int64(int64:sb, int64:fmt) {
    if (sb == 0i64) { pass -1i64; }
    stack uint8[4096]:tmp;
    int64:tmp_ptr = @cast_unchecked<int64>(@tmp);
    drop(str_snprintf0(tmp_ptr, STRBUF_FMT_BUF, fmt));
    int64:n = raw str_strlen(tmp_ptr);
    if (n == 0i64) { pass 0i64; }
    if (!raw strbuf_append_bytes(sb, tmp_ptr, n)) { pass -1i64; }
    pass n;
};

pub func:strbuf_appendf1 = int64(int64:sb, int64:fmt, int64:a0) {
    if (sb == 0i64) { pass -1i64; }
    stack uint8[4096]:tmp;
    int64:tmp_ptr = @cast_unchecked<int64>(@tmp);
    drop(str_snprintf1(tmp_ptr, STRBUF_FMT_BUF, fmt, a0));
    int64:n = raw str_strlen(tmp_ptr);
    if (n == 0i64) { pass 0i64; }
    if (!raw strbuf_append_bytes(sb, tmp_ptr, n)) { pass -1i64; }
    pass n;
};

pub func:strbuf_appendf2 = int64(int64:sb, int64:fmt, int64:a0, int64:a1) {
    if (sb == 0i64) { pass -1i64; }
    stack uint8[4096]:tmp;
    int64:tmp_ptr = @cast_unchecked<int64>(@tmp);
    drop(str_snprintf2(tmp_ptr, STRBUF_FMT_BUF, fmt, a0, a1));
    int64:n = raw str_strlen(tmp_ptr);
    if (n == 0i64) { pass 0i64; }
    if (!raw strbuf_append_bytes(sb, tmp_ptr, n)) { pass -1i64; }
    pass n;
};

pub func:strbuf_appendf3 = int64(int64:sb, int64:fmt,
                                  int64:a0, int64:a1, int64:a2) {
    if (sb == 0i64) { pass -1i64; }
    stack uint8[4096]:tmp;
    int64:tmp_ptr = @cast_unchecked<int64>(@tmp);
    drop(str_snprintf3(tmp_ptr, STRBUF_FMT_BUF, fmt, a0, a1, a2));
    int64:n = raw str_strlen(tmp_ptr);
    if (n == 0i64) { pass 0i64; }
    if (!raw strbuf_append_bytes(sb, tmp_ptr, n)) { pass -1i64; }
    pass n;
};

pub func:strbuf_appendf4 = int64(int64:sb, int64:fmt,
                                  int64:a0, int64:a1, int64:a2, int64:a3) {
    if (sb == 0i64) { pass -1i64; }
    stack uint8[4096]:tmp;
    int64:tmp_ptr = @cast_unchecked<int64>(@tmp);
    drop(str_snprintf4(tmp_ptr, STRBUF_FMT_BUF, fmt, a0, a1, a2, a3));
    int64:n = raw str_strlen(tmp_ptr);
    if (n == 0i64) { pass 0i64; }
    if (!raw strbuf_append_bytes(sb, tmp_ptr, n)) { pass -1i64; }
    pass n;
};

pub func:strbuf_appendf5 = int64(int64:sb, int64:fmt,
                                  int64:a0, int64:a1, int64:a2, int64:a3, int64:a4) {
    if (sb == 0i64) { pass -1i64; }
    stack uint8[4096]:tmp;
    int64:tmp_ptr = @cast_unchecked<int64>(@tmp);
    drop(str_snprintf5(tmp_ptr, STRBUF_FMT_BUF, fmt, a0, a1, a2, a3, a4));
    int64:n = raw str_strlen(tmp_ptr);
    if (n == 0i64) { pass 0i64; }
    if (!raw strbuf_append_bytes(sb, tmp_ptr, n)) { pass -1i64; }
    pass n;
};

pub func:strbuf_appendf6 = int64(int64:sb, int64:fmt,
                                  int64:a0, int64:a1, int64:a2, int64:a3,
                                  int64:a4, int64:a5) {
    if (sb == 0i64) { pass -1i64; }
    stack uint8[4096]:tmp;
    int64:tmp_ptr = @cast_unchecked<int64>(@tmp);
    drop(str_snprintf6(tmp_ptr, STRBUF_FMT_BUF, fmt, a0, a1, a2, a3, a4, a5));
    int64:n = raw str_strlen(tmp_ptr);
    if (n == 0i64) { pass 0i64; }
    if (!raw strbuf_append_bytes(sb, tmp_ptr, n)) { pass -1i64; }
    pass n;
};

pub func:strbuf_appendf7 = int64(int64:sb, int64:fmt,
                                  int64:a0, int64:a1, int64:a2, int64:a3,
                                  int64:a4, int64:a5, int64:a6) {
    if (sb == 0i64) { pass -1i64; }
    stack uint8[4096]:tmp;
    int64:tmp_ptr = @cast_unchecked<int64>(@tmp);
    drop(str_snprintf7(tmp_ptr, STRBUF_FMT_BUF, fmt, a0, a1, a2, a3, a4, a5, a6));
    int64:n = raw str_strlen(tmp_ptr);
    if (n == 0i64) { pass 0i64; }
    if (!raw strbuf_append_bytes(sb, tmp_ptr, n)) { pass -1i64; }
    pass n;
};

pub func:strbuf_appendf8 = int64(int64:sb, int64:fmt,
                                  int64:a0, int64:a1, int64:a2, int64:a3,
                                  int64:a4, int64:a5, int64:a6, int64:a7) {
    if (sb == 0i64) { pass -1i64; }
    stack uint8[4096]:tmp;
    int64:tmp_ptr = @cast_unchecked<int64>(@tmp);
    drop(str_snprintf8(tmp_ptr, STRBUF_FMT_BUF, fmt, a0, a1, a2, a3, a4, a5, a6, a7));
    int64:n = raw str_strlen(tmp_ptr);
    if (n == 0i64) { pass 0i64; }
    if (!raw strbuf_append_bytes(sb, tmp_ptr, n)) { pass -1i64; }
    pass n;
};

// ════════════════════════════════════════════════════════════════════════════
// Truncation and trimming
// ════════════════════════════════════════════════════════════════════════════

// strbuf_truncate — Shorten the content to at most n bytes.
// No-op if n >= current len.
pub func:strbuf_truncate = NIL(int64:sb, int64:n) {
    if (sb == 0i64) { pass NIL; }
    StrBuf->:s = @cast_unchecked<StrBuf->>(sb);
    if (n >= s->len) { pass NIL; }
    if (n < 0i64) { n = 0i64; }
    s->len = n;
    (@cast_unchecked<uint8->>(s->ptr))[s->len] = 0u8;
};

// strbuf_strip_trailing_newline — Remove a trailing '\n' (and optional '\r').
// Useful for cleaning up line-read output.
pub func:strbuf_strip_trailing_newline = NIL(int64:sb) {
    if (sb == 0i64) { pass NIL; }
    StrBuf->:s = @cast_unchecked<StrBuf->>(sb);
    uint8->:p = @cast_unchecked<uint8->>(s->ptr);
    if (s->len > 0i64 && p[s->len - 1i64] == 10u8) {     // '\n'
        s->len = s->len - 1i64;
        p[s->len] = 0u8;
    }
    if (s->len > 0i64 && p[s->len - 1i64] == 13u8) {     // '\r'
        s->len = s->len - 1i64;
        p[s->len] = 0u8;
    }
};

// ════════════════════════════════════════════════════════════════════════════
// I/O integration
// ════════════════════════════════════════════════════════════════════════════

// strbuf_write_to_fd — Write the buffer content to a raw file descriptor.
// Uses libn_write_all for reliable full-write behavior.
// Returns number of bytes written, or -1 on error.
pub func:strbuf_write_to_fd = int64(int64:sb, int64:fd) {
    if (sb == 0i64) { pass 0i64; }
    StrBuf->:s = @cast_unchecked<StrBuf->>(sb);
    if (s->len == 0i64) { pass 0i64; }
    Result<int64>:r = libn_write_all(fd, s->ptr, s->len);
    if (r.is_error) { pass -1i64; }
    pass r.value;
};

// strfmt.npk — vsnprintf, snprintf, str_format (v0.3.7)
//
// Formatted string production. This is the most complex module in the string
// subsystem. snprintf is used everywhere: error messages, log output, protocol
// construction, debugging, telemetry.
//
// Scope at v0.3.7 (complete subset):
//   %d / %i    — signed decimal int64
//   %u         — unsigned decimal int64
//   %x / %X   — lowercase/uppercase hexadecimal
//   %o         — octal
//   %s         — NUL-terminated string
//   %c         — single character
//   %p         — pointer (0x + hex address)
//   %b         — binary (libn extension)
//   %%         — literal percent
//
// Width and precision:
//   %[flags][width][.precision]specifier
//   flags: - (left-align), 0 (zero-pad), + (force sign), ' ' (space for positive)
//   #: alternate form — 0x prefix for %x, 0 prefix for %o
//   * for width/precision: read from va_args
//
// Specifiers NOT included at v0.3.7 (planned for v0.40.x):
//   %f, %e, %g, %a — floating point (requires soft-fp)
//   %n — deliberately excluded (security hazard, CVE history)
//   %S, %ls — wide character (locale module)
//
// Implementation strategy:
//   - All output goes through a single write_char() that manages the output
//     pointer and remaining space. This prevents any buffer overrun.
//   - Number conversion uses a local fixed-size buffer (65 bytes covers all
//     cases: 64 binary digits + sign).
//   - va_args: Nitpick does NOT have variadic functions at v0.3.7.
//     We implement str_format_args() which takes an int64 array of args.
//     A macro-style wrapper snprintf(buf, n, fmt, a, b, c, ...) exists for
//     the common cases (up to 8 args). Full variadic support is in v0.10.x.

use "../syscall/errno.npk".*;
use "../str/strlen.npk".*;
use "../str/strconv.npk".*;
use "../str/strcmp.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// FmtState — Internal formatter state (passed by pointer through helpers)
// ════════════════════════════════════════════════════════════════════════════

struct:FmtState = {
    int64:buf;        // Output buffer pointer
    int64:size;       // Total buffer size
    int64:pos;        // Current write position
};

// fmt_putc — Write one character to the output buffer (or count it if full)
func:fmt_putc = NIL(FmtState->:st, uint8:c) {
    if (st.pos < st.size - 1i64) {
        (@cast_unchecked<uint8->>(st->buf))[st.pos] = c;
    }
    st.pos = st.pos + 1i64;
};

// fmt_puts_n — Write exactly n bytes from ptr to the output buffer
func:fmt_puts_n = NIL(FmtState->:st, int64:ptr, int64:n) {
    uint8->:p = @cast_unchecked<uint8->>(ptr);
    int64:i = 0i64;
    while (i < n) {
        drop(fmt_putc(st, p[i]));
        i = i + 1i64;
    }
};

// fmt_pad — Write n copies of pad_char
func:fmt_pad = NIL(FmtState->:st, uint8:pad_char, int64:n) {
    int64:i = 0i64;
    while (i < n) {
        drop(fmt_putc(st, pad_char));
        i = i + 1i64;
    }
};

// ════════════════════════════════════════════════════════════════════════════
// Number rendering helpers
// ════════════════════════════════════════════════════════════════════════════

// DIGITS — Lowercase and uppercase hex digit tables
fixed int64:DIGITS_LOWER = @cast_unchecked<int64>(@"0123456789abcdef");
fixed int64:DIGITS_UPPER = @cast_unchecked<int64>(@"0123456789ABCDEF");

// render_uint — Render an unsigned value into a small buffer, returns length.
// base must be 2, 8, 10, or 16.
// buf must be at least 66 bytes.
func:render_uint = int64(uint64:v, int64:base, int64:buf, bool:upper) {
    uint8->:b = @cast_unchecked<uint8->>(buf);
    uint8->:digits = @cast_unchecked<uint8->>(is (upper) : DIGITS_UPPER : DIGITS_LOWER);

    if (v == 0u64) {
        b[0] = 48u8;    // '0'
        pass 1i64;
    }

    stack uint8[66]:tmp;
    tmp[0] = 0u8;
    int64:ti = 0i64;
    uint64:u = v;
    uint64:ubase = @cast_unchecked<uint64>(base);

      // Build digits in reverse
    while (u != 0u64) {
        int64:d = 0i64;
        if (base == 16i64) {
            d = @cast_unchecked<int64>(u & 0xFu64);
            u = u >> 4u64;
        } else if (base == 8i64) {
            d = @cast_unchecked<int64>(u & 7u64);
            u = u >> 3u64;
        } else if (base == 2i64) {
            d = @cast_unchecked<int64>(u & 1u64);
            u = u >> 1u64;
        } else {
            d = @cast_unchecked<int64>(u % ubase);
            u = u / ubase;
        }
        tmp[ti] = digits[d];
        ti = ti + 1i64;
    }

      // Copy reversed digits to buf
    int64:len = ti;
    int64:bi = 0i64;
    while (ti > 0i64) {
        ti = ti - 1i64;
        b[bi] = tmp[ti];
        bi = bi + 1i64;
    }

    pass len;
};

// ════════════════════════════════════════════════════════════════════════════
// str_format_args — Core formatter. Takes an array of int64 args.
//
// Parameters:
//   buf:      Output buffer (NUL-terminated on return)
//   buf_size: Size of buf (including space for NUL)
//   fmt:      Format string
//   args:     Array of int64 arguments (cast pointers to int64 for %s)
//   nargs:    Number of elements in args
//
// Returns: total number of characters that would have been written (snprintf semantics).
//          If return >= buf_size, output was truncated.
// ════════════════════════════════════════════════════════════════════════════

pub func:str_format_args = int64(int64:buf, int64:buf_size, int64:fmt,
                                  int64->:args, int64:nargs) {
    if (buf == 0i64 || buf_size <= 0i64) {
        pass 0i64;
    }

    FmtState:st;
    st->buf  = buf;
    st.size = buf_size;
    st.pos  = 0i64;
    FmtState->:stp = @st;

    uint8->:f = @cast_unchecked<uint8->>(fmt);
    int64:fi = 0i64;     // format string position
    int64:ai = 0i64;     // args array index
    stack uint8[68]:nbuf;
    nbuf[0] = 0u8;
    stack uint8[3]:prefix;
    prefix[0] = 0u8;

    while (f[fi] != 0u8) {
        if (f[fi] != 37u8) {    // '%'
            drop(fmt_putc(stp, f[fi]));
            fi = fi + 1i64;
            continue;
        }
        fi = fi + 1i64;    // skip '%'

          // ── Parse flags ──────────────────────────────────────────────
        bool:flag_left    = false;
        bool:flag_zero    = false;
        bool:flag_plus    = false;
        bool:flag_space   = false;
        bool:flag_alt     = false;

        while (true) {
            if (f[fi] == 45u8) { flag_left  = true; fi = fi + 1i64; }    // '-'
            else if (f[fi] == 48u8) { flag_zero  = true; fi = fi + 1i64; }    // '0'
            else if (f[fi] == 43u8) { flag_plus  = true; fi = fi + 1i64; }    // '+'
            else if (f[fi] == 32u8) { flag_space = true; fi = fi + 1i64; }    // ' '
            else if (f[fi] == 35u8) { flag_alt   = true; fi = fi + 1i64; }    // '#'
            else { break; }
        }

          // ── Parse width ──────────────────────────────────────────────
        int64:width = 0i64;
        if (f[fi] == 42u8) {    // '*' — width from args
            if (ai < nargs) { width = args[ai]; ai = ai + 1i64; }
            fi = fi + 1i64;
        } else {
            while (f[fi] >= 48u8 && f[fi] <= 57u8) {
                width = width * 10i64 + @cast_unchecked<int64>((f[fi] - 48u8));
                fi = fi + 1i64;
            }
        }

          // ── Parse precision ──────────────────────────────────────────
        int64:precision  = -1i64;    // -1 means "not specified"
        if (f[fi] == 46u8) {    // '.'
            fi = fi + 1i64;
            precision = 0i64;
            if (f[fi] == 42u8) {
                if (ai < nargs) { precision = args[ai]; ai = ai + 1i64; }
                fi = fi + 1i64;
            } else {
                while (f[fi] >= 48u8 && f[fi] <= 57u8) {
                    precision = precision * 10i64 + @cast_unchecked<int64>((f[fi] - 48u8));
                    fi = fi + 1i64;
                }
            }
        }

          // ── Parse length modifier (skip — we always use int64) ────────
        if (f[fi] == 108u8) { fi = fi + 1i64; }    // 'l'
        if (f[fi] == 108u8) { fi = fi + 1i64; }    // 'll'
        if (f[fi] == 122u8) { fi = fi + 1i64; }    // 'z'
        if (f[fi] == 104u8) { fi = fi + 1i64; }    // 'h'
        if (f[fi] == 104u8) { fi = fi + 1i64; }    // 'hh'

          // ── Specifier ────────────────────────────────────────────────
        uint8:spec = f[fi];
        fi = fi + 1i64;

        int64:arg_val = 0i64;
        if (ai < nargs) { arg_val = args[ai]; ai = ai + 1i64; }

        if (spec == 37u8) {    // '%%'
            drop(fmt_putc(stp, 37u8));
            continue;
        }

        if (spec == 99u8) {    // '%c'
            if (!flag_left) { drop(fmt_pad(stp, 32u8, width - 1i64)); }
            drop(fmt_putc(stp, @cast_unchecked<uint8>(arg_val)));
            if (flag_left) { drop(fmt_pad(stp, 32u8, width - 1i64)); }
            continue;
        }

        if (spec == 115u8) {    // '%s'
            int64:sptr = arg_val;
            int64:slen = 0i64;
            if (sptr == 0i64) {
                sptr = @cast_unchecked<int64>(@"(null)");
                slen = 6i64;
            } else {
                slen = raw str_strlen(sptr);
            }
            if (precision >= 0i64 && slen > precision) {
                slen = precision;
            }
            int64:pad = 0i64;
            if (width > slen) { pad = width - slen; }
            if (!flag_left) { drop(fmt_pad(stp, 32u8, pad)); }
            drop(fmt_puts_n(stp, sptr, slen));
            if (flag_left) { drop(fmt_pad(stp, 32u8, pad)); }
            continue;
        }

          // Numeric specifiers: %d, %i, %u, %x, %X, %o, %p, %b
        bool:is_signed = spec == 100u8 || spec == 105u8;    // 'd' or 'i'
        bool:is_upper   = spec == 88u8;     // 'X'
        int64:num_base  = 10i64;
        if (spec == 120u8 || spec == 88u8) { num_base = 16i64; }    // 'x' or 'X'
        else if (spec == 111u8) { num_base = 8i64; }                 // 'o'
        else if (spec == 98u8)  { num_base = 2i64; }                 // 'b' (extension)
        else if (spec == 112u8) {                                     // 'p' — pointer
            num_base = 16i64;
            flag_alt = true;
            is_signed = false;
        }

          // Build number string
        // nbuf is declared outside the loop to prevent stack bloat
        int64:nlen = 0i64;
        bool:is_neg = is_signed && arg_val < 0i64;
        int64:uval = arg_val;
        if (is_neg) { uval = 0i64 - arg_val; }

        nlen = raw render_uint(@cast_unchecked<uint64>(uval), num_base, @cast_unchecked<int64>(@nbuf), is_upper);

          // Alternate form prefix
        int64:prefix_len = 0i64;
        // prefix is declared outside the loop to prevent stack bloat
        if (is_neg) {
            prefix[0] = 45u8; prefix_len = 1i64;     // '-'
        } else if (flag_plus) {
            prefix[0] = 43u8; prefix_len = 1i64;     // '+'
        } else if (flag_space) {
            prefix[0] = 32u8; prefix_len = 1i64;     // ' '
        }
        if (flag_alt && num_base == 16i64 && arg_val != 0i64) {
            prefix[prefix_len] = 48u8;    // '0'
            prefix[prefix_len + 1i64] = is (is_upper) : 88u8 : 120u8;    // 'X' or 'x'
            prefix_len = prefix_len + 2i64;
        } else if (flag_alt && num_base == 8i64) {
              // Only add '0' prefix if not already starting with 0
            if (nlen == 0i64 || nbuf[0] != 48u8) {
                prefix[prefix_len] = 48u8;
                prefix_len = prefix_len + 1i64;
            }
        }

        int64:total_num_len = prefix_len + nlen;
        int64:pad_total = 0i64;
        if (width > total_num_len) { pad_total = width - total_num_len; }

        uint8:pad_char = 32u8;    // space
        if (flag_zero && !flag_left) { pad_char = 48u8; }    // '0'

        if (flag_left) {
              // Left-align: prefix, digits, then space-pad
            drop(fmt_puts_n(stp, @cast_unchecked<int64>(@prefix), prefix_len));
            drop(fmt_puts_n(stp, @cast_unchecked<int64>(@nbuf), nlen));
            drop(fmt_pad(stp, 32u8, pad_total));
        } else if (flag_zero) {
              // Zero-pad: prefix first, then zeros, then digits
            drop(fmt_puts_n(stp, @cast_unchecked<int64>(@prefix), prefix_len));
            drop(fmt_pad(stp, 48u8, pad_total));
            drop(fmt_puts_n(stp, @cast_unchecked<int64>(@nbuf), nlen));
        } else {
              // Space-pad: spaces, then prefix, then digits
            drop(fmt_pad(stp, 32u8, pad_total));
            drop(fmt_puts_n(stp, @cast_unchecked<int64>(@prefix), prefix_len));
            drop(fmt_puts_n(stp, @cast_unchecked<int64>(@nbuf), nlen));
        }
    }

      // NUL-terminate
    if (st.size > 0i64) {
        int64:nul_pos = st.pos;
        if (nul_pos >= st.size) { nul_pos = st.size - 1i64; }
        (@cast_unchecked<uint8->>(st->buf))[nul_pos] = 0u8;
    }

    pass st.pos;
};

// ════════════════════════════════════════════════════════════════════════════
// str_snprintf — Convenience wrapper for up to 8 integer/pointer arguments.
//
// args are @cast_unchecked<an>(passed) int64 array via stack-constructed temporary.
// ════════════════════════════════════════════════════════════════════════════

// Zero-arg version
pub func:str_snprintf0 = int64(int64:buf, int64:buf_size, int64:fmt) {
    pass str_format_args(buf, buf_size, fmt, @cast_unchecked<int64->>(0i64), 0i64);
};

// One-arg version
pub func:str_snprintf1 = int64(int64:buf, int64:buf_size, int64:fmt, int64:a0) {
    stack int64[1]:a;
    a[0] = a0;
    pass str_format_args(buf, buf_size, fmt, @cast_unchecked<int64->>(@a), 1i64);
};

// Two-arg version
pub func:str_snprintf2 = int64(int64:buf, int64:buf_size, int64:fmt, int64:a0, int64:a1) {
    stack int64[2]:a;
    a[0] = a0; a[1] = a1;
    pass str_format_args(buf, buf_size, fmt, @cast_unchecked<int64->>(@a), 2i64);
};

// Three-arg version
pub func:str_snprintf3 = int64(int64:buf, int64:buf_size, int64:fmt,
                                int64:a0, int64:a1, int64:a2) {
    stack int64[3]:a;
    a[0] = a0; a[1] = a1; a[2] = a2;
    pass str_format_args(buf, buf_size, fmt, @cast_unchecked<int64->>(@a), 3i64);
};

// Four-arg version
pub func:str_snprintf4 = int64(int64:buf, int64:buf_size, int64:fmt,
                                int64:a0, int64:a1, int64:a2, int64:a3) {
    stack int64[4]:a;
    a[0] = a0; a[1] = a1; a[2] = a2; a[3] = a3;
    pass str_format_args(buf, buf_size, fmt, @cast_unchecked<int64->>(@a), 4i64);
};

// Six-arg version
pub func:str_snprintf6 = int64(int64:buf, int64:buf_size, int64:fmt,
                                int64:a0, int64:a1, int64:a2,
                                int64:a3, int64:a4, int64:a5) {
    stack int64[6]:a;
    a[0]=a0; a[1]=a1; a[2]=a2; a[3]=a3; a[4]=a4; a[5]=a5;
    pass str_format_args(buf, buf_size, fmt, @cast_unchecked<int64->>(@a), 6i64);
};

// Eight-arg version
pub func:str_snprintf8 = int64(int64:buf, int64:buf_size, int64:fmt,
                                int64:a0, int64:a1, int64:a2, int64:a3,
                                int64:a4, int64:a5, int64:a6, int64:a7) {
    stack int64[8]:a;
    a[0]=a0; a[1]=a1; a[2]=a2; a[3]=a3;
    a[4]=a4; a[5]=a5; a[6]=a6; a[7]=a7;
    pass str_format_args(buf, buf_size, fmt, @cast_unchecked<int64->>(@a), 8i64);
};

// Five-arg version
pub func:str_snprintf5 = int64(int64:buf, int64:buf_size, int64:fmt,
                                int64:a0, int64:a1, int64:a2,
                                int64:a3, int64:a4) {
    stack int64[5]:a;
    a[0]=a0; a[1]=a1; a[2]=a2; a[3]=a3; a[4]=a4;
    pass str_format_args(buf, buf_size, fmt, @cast_unchecked<int64->>(@a), 5i64);
};

// Seven-arg version
pub func:str_snprintf7 = int64(int64:buf, int64:buf_size, int64:fmt,
                                int64:a0, int64:a1, int64:a2, int64:a3,
                                int64:a4, int64:a5, int64:a6) {
    stack int64[7]:a;
    a[0]=a0; a[1]=a1; a[2]=a2; a[3]=a3;
    a[4]=a4; a[5]=a5; a[6]=a6;
    pass str_format_args(buf, buf_size, fmt, @cast_unchecked<int64->>(@a), 7i64);
};

// path.npk — Path string manipulation utilities (v0.5.1)
//
// Pure string-level path operations. No syscalls, no fd access. All functions
// work on NUL-terminated uint8 strings @cast_unchecked<int64>(passed) pointers, matching the
// rest of libn's ABI convention. All outputs are written into caller-supplied
// buffers to avoid allocation.
//
// Path semantics:
//   - Paths are POSIX uint8 strings. "/" is the root. "." is the cwd.
//   - Trailing slashes are normalized away (except for the root "/").
//   - Empty string and NULL pointer both return an empty-path error (ERR_BADARG).
//
// Functions:
//   path_is_abs(path)              → 1 if absolute (starts with '/'), else 0
//   path_join(a, b, out, out_sz)   → join two path segments with '/'
//   path_dirname(path, out, out_sz)→ parent directory component
//   path_basename(path, out, out_sz)→ final component (filename)
//   path_ext(path)                 → pointer to '.' of extension, or NULL
//   path_normalize(path, out, out_sz) → collapse "//" and "/./" segments
//   path_depth(path)               → count '/' separators
//   path_has_trailing_slash(path)  → 1 if path ends with '/' (and len > 1)
//   path_strip_trailing_slash(path, out, out_sz) → copy with trailing '/' removed

use "../syscall/errno.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// Internal helpers (non-pub)
// ════════════════════════════════════════════════════════════════════════════

// path_strlen — Inline strlen for path strings.
func:path_strlen = int64(int64:s) {
    if (s == 0i64) {
        pass 0i64;
    }
    uint8->:p = @cast_unchecked<uint8->>(s);
    int64:n = 0i64;
    while (p[n] != 0u8) {
        n = n + 1i64;
    }
    pass n;
};

// path_copy_n — Copy at most n bytes from src to dst, always NUL-terminates.
// Returns number of bytes copied (not counting NUL).
func:path_copy_n = int64(int64:dst, int64:src, int64:n) {
    uint8->:d = @cast_unchecked<uint8->>(dst);
    uint8->:s = @cast_unchecked<uint8->>(src);
    int64:i = 0i64;
    while (i < n && s[i] != 0u8) {
        d[i] = s[i];
        i = i + 1i64;
    }
    d[i] = 0u8;
    pass i;
};

// ════════════════════════════════════════════════════════════════════════════
// path_is_abs — Test whether a path is absolute (starts with '/').
//
// Returns:
//   Ok(1) — path is absolute
//   Ok(0) — path is relative
//   Err(ERR_BADARG) — path is NULL or empty
// ════════════════════════════════════════════════════════════════════════════

pub func:path_is_abs = int64(int64:path) {
    if (path == 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    uint8->:p = @cast_unchecked<uint8->>(path);
    if (p[0] == 0u8) {
        pass 0i64;     // empty string is relative
    }
    if (p[0] == 47u8) {    // '/'
        pass 1i64;
    }
    pass 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// path_join — Join two path segments, inserting exactly one '/' between them.
//
// Rules:
//   - If b is absolute (starts with '/'), b is returned as-is (mirrors Python
//     os.path.join semantics: absolute b discards a).
//   - If a is empty, b is returned as-is.
//   - Otherwise: strip trailing '/' from a, prepend '/' if a doesn't end_idx in
//     one, then append b.
//
// Parameters:
//   a:      first path segment (NUL-terminated, @cast_unchecked<int64>(pointer))
//   b:      second path segment (NUL-terminated, @cast_unchecked<int64>(pointer))
//   out:    destination buffer
//   out_sz: size of out (including NUL slot)
//
// Returns:
//   Ok(n)           — n bytes written to out (not counting NUL)
//   Err(ERR_BADARG) — NULL pointer or out_sz < 1
//   Err(ENAMETOOLONG) — result would exceed out_sz-1 bytes
// ════════════════════════════════════════════════════════════════════════════

pub func:path_join = int64(int64:a, int64:b, int64:out, int64:out_sz) {
    if (a == 0i64 || b == 0i64 || out == 0i64 || out_sz < 1i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }

    uint8->:ob = @cast_unchecked<uint8->>(out);
    uint8->:ab = @cast_unchecked<uint8->>(a);
    uint8->:bb = @cast_unchecked<uint8->>(b);

      // If b is absolute, return b directly.
    if (bb[0] == 47u8) {    // '/'
        int64:blen = raw path_strlen(b);
        if (blen >= out_sz) {
            fail @cast_unchecked<tbb32>(ENAMETOOLONG);
        }
        drop(path_copy_n(out, b, blen));
        pass blen;
    }

    int64:alen = raw path_strlen(a);
    int64:blen = raw path_strlen(b);

      // If a is empty, return b as-is.
    if (alen == 0i64) {
        if (blen >= out_sz) {
            fail @cast_unchecked<tbb32>(ENAMETOOLONG);
        }
        drop(path_copy_n(out, b, blen));
        pass blen;
    }

      // Strip trailing slashes from a.
    int64:a_end = alen;
    while (a_end > 1i64 && ab[a_end - 1i64] == 47u8) {    // not root
        a_end = a_end - 1i64;
    }

      // If b is empty, just copy a (stripped).
    if (blen == 0i64) {
        if (a_end >= out_sz) {
            fail @cast_unchecked<tbb32>(ENAMETOOLONG);
        }
        drop(path_copy_n(out, a, a_end));
        ob[a_end] = 0u8;
        pass a_end;
    }

      // Total: a_end + 1 (slash) + blen
    int64:total = a_end + 1i64 + blen;
    if (total >= out_sz) {
        fail @cast_unchecked<tbb32>(ENAMETOOLONG);
    }

      // Write a (stripped), then '/', then b.
    int64:i = 0i64;
    while (i < a_end) {
        ob[i] = ab[i];
        i = i + 1i64;
    }
    ob[i] = 47u8;    // '/'
    i = i + 1i64;
    int64:j = 0i64;
    while (j < blen) {
        ob[i] = bb[j];
        i = i + 1i64;
        j = j + 1i64;
    }
    ob[i] = 0u8;
    pass total;
};

// ════════════════════════════════════════════════════════════════════════════
// path_dirname — Return the directory component of path (like POSIX dirname).
//
// Examples:
//   "/usr/lib/libc.so" → "/usr/lib"
//   "/usr/lib/"        → "/usr/lib"
//   "/usr"             → "/"
//   "lib"              → "."
//   "/"                → "/"
//   ""                 → "."
//
// Parameters:
//   path:   source path
//   out:    destination buffer
//   out_sz: size of out
//
// Returns Ok(n) bytes written (not counting NUL), or Err.
// ════════════════════════════════════════════════════════════════════════════

pub func:path_dirname = int64(int64:path, int64:out, int64:out_sz) {
    if (path == 0i64 || out == 0i64 || out_sz < 2i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }

    uint8->:p  = @cast_unchecked<uint8->>(path);
    uint8->:ob = @cast_unchecked<uint8->>(out);

    int64:len = raw path_strlen(path);

      // Empty path → "."
    if (len == 0i64) {
        ob[0] = 46u8;    // '.'
        ob[1] = 0u8;
        pass 1i64;
    }

      // Find the rightmost non-trailing slash.
      // Step 1: strip trailing slashes (POSIX says: @cast_unchecked<if>(treat) not there)
    int64:end_idx = len;
    while (end_idx > 1i64 && p[end_idx - 1i64] == 47u8) {
        end_idx = end_idx - 1i64;
    }

      // Step 2: scan backwards for the last slash
    int64:last_slash = -1i64;
    int64:i = end_idx - 1i64;
    while (i >= 0i64) {
        if (p[i] == 47u8) {
            last_slash = i;
            break;
        }
        i = i - 1i64;
    }

    if (last_slash < 0i64) {
          // No slash found — dirname is "."
        ob[0] = 46u8;    // '.'
        ob[1] = 0u8;
        pass 1i64;
    }

    if (last_slash == 0i64) {
          // The only slash is the root
        ob[0] = 47u8;    // '/'
        ob[1] = 0u8;
        pass 1i64;
    }

      // dirname is path[0..last_slash], stripping any trailing slashes from that too
    int64:dir_end = last_slash;
    while (dir_end > 1i64 && p[dir_end - 1i64] == 47u8) {
        dir_end = dir_end - 1i64;
    }

    if (dir_end >= out_sz) {
        fail @cast_unchecked<tbb32>(ENAMETOOLONG);
    }

    drop(path_copy_n(out, path, dir_end));
    ob[dir_end] = 0u8;
    pass dir_end;
};

// ════════════════════════════════════════════════════════════════════════════
// path_basename — Return the final component of a path (like POSIX basename).
//
// Examples:
//   "/usr/lib/libc.so" → "libc.so"
//   "/usr/lib/"        → "lib"
//   "/usr"             → "usr"
//   "/"                → "/"
//   ""                 → "."
//
// Returns Ok(n) bytes written (not counting NUL), or Err.
// ════════════════════════════════════════════════════════════════════════════

pub func:path_basename = int64(int64:path, int64:out, int64:out_sz) {
    if (path == 0i64 || out == 0i64 || out_sz < 2i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }

    uint8->:p  = @cast_unchecked<uint8->>(path);
    uint8->:ob = @cast_unchecked<uint8->>(out);

    int64:len = raw path_strlen(path);

      // Empty → "."
    if (len == 0i64) {
        ob[0] = 46u8;    // '.'
        ob[1] = 0u8;
        pass 1i64;
    }

      // "/" → "/"
    if (len == 1i64 && p[0] == 47u8) {
        ob[0] = 47u8;
        ob[1] = 0u8;
        pass 1i64;
    }

      // Strip trailing slashes
    int64:end_idx = len;
    while (end_idx > 1i64 && p[end_idx - 1i64] == 47u8) {
        end_idx = end_idx - 1i64;
    }

      // Find last slash before end_idx
    int64:last_slash = -1i64;
    int64:i = end_idx - 1i64;
    while (i >= 0i64) {
        if (p[i] == 47u8) {
            last_slash = i;
            break;
        }
        i = i - 1i64;
    }

    int64:start = 0i64;
    if (last_slash >= 0i64) {
        start = last_slash + 1i64;
    }

    int64:blen = end_idx - start;
    if (blen <= 0i64) {
          // Should not happen after the checks above, but be safe
        ob[0] = 47u8;
        ob[1] = 0u8;
        pass 1i64;
    }

    if (blen >= out_sz) {
        fail @cast_unchecked<tbb32>(ENAMETOOLONG);
    }

    int64:j = 0i64;
    while (j < blen) {
        ob[j] = p[start + j];
        j = j + 1i64;
    }
    ob[j] = 0u8;
    pass blen;
};

// ════════════════════════════════════════════════════════════════════════════
// path_ext — Return pointer to the start of the file extension (the dot).
//
// Returns the int64 address of the LAST '.' in the basename component,
// or 0 (NULL) if there is no extension.
//
// The caller can do: if ext != 0 { uint8->:ep = @cast_unchecked<uint8->>(ext); ... }
//
// Examples:
//   "foo.tar.gz" → pointer to ".gz"
//   ".hidden"    → 0 (leading dot is not an extension)
//   "no_ext"     → 0
//   "/path/to/a.b" → pointer to ".b"
// ════════════════════════════════════════════════════════════════════════════

pub func:path_ext = int64(int64:path) {
    if (path == 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }

    uint8->:p = @cast_unchecked<uint8->>(path);
    int64:len = raw path_strlen(path);

    if (len == 0i64) {
        pass 0i64;
    }

      // Find start of basename (skip directory prefix)
    int64:base_start = 0i64;
    int64:i = len - 1i64;
    while (i >= 0i64) {
        if (p[i] == 47u8) {    // '/'
            base_start = i + 1i64;
            break;
        }
        i = i - 1i64;
    }

      // Look for last '.' in the basename, excluding a leading '.'
      // (i.e., ".hidden" is not considered to have an extension)
    int64:last_dot = -1i64;
    int64:j = base_start + 1i64;     // +1 to skip leading dot of hidden files
    while (j < len) {
        if (p[j] == 46u8) {    // '.'
            last_dot = j;
        }
        j = j + 1i64;
    }

    if (last_dot < 0i64) {
        pass 0i64;     // no extension
    }

    pass path + last_dot;
};

// ════════════════════════════════════════════════════════════════════════════
// path_depth — Count the number of path components (separated by '/').
//
// Trailing and duplicate slashes are ignored. Root "/" has depth 1.
//
// Examples:
//   "/usr/lib/x86_64-linux-gnu" → 4
//   "foo/bar/baz"               → 3
//   "/"                         → 1
//   ""                          → 0
// ════════════════════════════════════════════════════════════════════════════

pub func:path_depth = int64(int64:path) {
    if (path == 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }

    uint8->:p = @cast_unchecked<uint8->>(path);
    int64:len = raw path_strlen(path);

    if (len == 0i64) {
        pass 0i64;
    }

    int64:depth = 0i64;
    int64:in_component = 0i64;
    int64:i = 0i64;

    while (i < len) {
        if (p[i] == 47u8) {    // '/'
            if (in_component != 0i64) {
                depth = depth + 1i64;
                in_component = 0i64;
            } else if (i == 0i64) {
                  // Leading slash = root component
                depth = depth + 1i64;
            }
        } else {
            in_component = 1i64;
        }
        i = i + 1i64;
    }

      // Flush last component
    if (in_component != 0i64) {
        depth = depth + 1i64;
    }

    pass depth;
};

// ════════════════════════════════════════════════════════════════════════════
// path_has_trailing_slash — Test whether path ends with '/' (and len > 1).
//
// Returns:
//   Ok(1) — ends with '/' (and is not just "/")
//   Ok(0) — does not end_idx with '/', or is "/" or empty
// ════════════════════════════════════════════════════════════════════════════

pub func:path_has_trailing_slash = int64(int64:path) {
    if (path == 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }

    uint8->:p = @cast_unchecked<uint8->>(path);
    int64:len = raw path_strlen(path);

    if (len <= 1i64) {
        pass 0i64;
    }

    if (p[len - 1i64] == 47u8) {    // '/'
        pass 1i64;
    }
    pass 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// path_strip_trailing_slash — Copy path with trailing '/' removed.
//
// If path is "/" or has no trailing slash, copies unchanged.
// Always NUL-terminates out.
//
// Returns Ok(n) bytes written (not counting NUL), or Err.
// ════════════════════════════════════════════════════════════════════════════

pub func:path_strip_trailing_slash = int64(int64:path, int64:out, int64:out_sz) {
    if (path == 0i64 || out == 0i64 || out_sz < 2i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }

    uint8->:p  = @cast_unchecked<uint8->>(path);
    uint8->:ob = @cast_unchecked<uint8->>(out);

    int64:len = raw path_strlen(path);

    if (len == 0i64) {
        ob[0] = 0u8;
        pass 0i64;
    }

    int64:end_idx = len;
    while (end_idx > 1i64 && p[end_idx - 1i64] == 47u8) {
        end_idx = end_idx - 1i64;
    }

    if (end_idx >= out_sz) {
        fail @cast_unchecked<tbb32>(ENAMETOOLONG);
    }

    drop(path_copy_n(out, path, end_idx));
    ob[end_idx] = 0u8;
    pass end_idx;
};

// ════════════════════════════════════════════════════════════════════════════
// path_normalize — Collapse redundant slashes and "/./" sequences.
//
// Rules applied:
//   - Multiple consecutive '/' → single '/'
//   - "/./" → "/"  (current-directory segments are removed)
//   - Leading '/' preserved for absolute paths
//   - Trailing slash preserved only for root
//   - Does NOT resolve ".." (that requires stat() and is done by path_realpath
//     in a future module)
//
// Examples:
//   "//usr//lib/"  → "/usr/lib"
//   "./foo/./bar"  → "foo/bar"
//   "/a/./b//c/"  → "/a/b/c"
//
// Returns Ok(n) bytes written (not counting NUL), or Err.
// ════════════════════════════════════════════════════════════════════════════

pub func:path_normalize = int64(int64:path, int64:out, int64:out_sz) {
    if (path == 0i64 || out == 0i64 || out_sz < 2i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }

    uint8->:p  = @cast_unchecked<uint8->>(path);
    uint8->:ob = @cast_unchecked<uint8->>(out);

    int64:len = raw path_strlen(path);

    if (len == 0i64) {
        ob[0] = 46u8;    // '.'
        ob[1] = 0u8;
        pass 1i64;
    }

    int64:out_pos  = 0i64;
    int64:in_pos   = 0i64;
    int64:is_abs   = 0i64;

      // Handle leading '/'
    if (p[0] == 47u8) {
        is_abs = 1i64;
        if (out_pos >= out_sz - 1i64) {
            fail @cast_unchecked<tbb32>(ENAMETOOLONG);
        }
        ob[out_pos] = 47u8;
        out_pos = out_pos + 1i64;
          // Skip all leading slashes
        while (in_pos < len && p[in_pos] == 47u8) {
            in_pos = in_pos + 1i64;
        }
    }

    int64:component_start = in_pos;

    while (in_pos <= len) {
        uint8:ch = 0u8;
        if (in_pos < len) {
            ch = p[in_pos];
        }

        if (ch == 47u8 || in_pos == len) {
              // End of a component [component_start..in_pos)
            int64:comp_len = in_pos - component_start;

            if (comp_len == 0i64) {
                  // Empty component (double slash) — skip
            } else if (comp_len == 1i64 && p[component_start] == 46u8) {
                  // "." component — skip
            } else {
                  // Real component — emit slash separator if needed
                if (out_pos > 0i64 && ob[out_pos - 1i64] != 47u8) {
                    if (out_pos >= out_sz - 1i64) {
                        fail @cast_unchecked<tbb32>(ENAMETOOLONG);
                    }
                    ob[out_pos] = 47u8;
                    out_pos = out_pos + 1i64;
                }
                  // Emit the component
                int64:k = 0i64;
                while (k < comp_len) {
                    if (out_pos >= out_sz - 1i64) {
                        fail @cast_unchecked<tbb32>(ENAMETOOLONG);
                    }
                    ob[out_pos] = p[component_start + k];
                    out_pos = out_pos + 1i64;
                    k = k + 1i64;
                }
            }

              // Advance past slashes
            in_pos = in_pos + 1i64;
            while (in_pos < len && p[in_pos] == 47u8) {
                in_pos = in_pos + 1i64;
            }
            component_start = in_pos;
        } else {
            in_pos = in_pos + 1i64;
        }
    }

      // If nothing was emitted (e.g. input was "./" or all "./")
    if (out_pos == 0i64) {
        ob[0] = 46u8;    // '.'
        ob[1] = 0u8;
        pass 1i64;
    }

    ob[out_pos] = 0u8;
    pass out_pos;
};

pub struct:timespec = {
    int64:tv_sec;
    int64:tv_nsec;
};
pub struct:timeval = {
    int64:tv_sec;
    int64:tv_usec;
};

use "time_types.npk".*;
use "../syscall/syscall.npk".*;
use "../syscall/syscall_numbers.npk".*;
use "../syscall/errno.npk".*;

pub func:clock_gettime = int64(int64:clockid, timespec->:tp) {
    if (@cast_unchecked<int64>(tp) == 0i64) {
        drop(errno_set(14i64)); pass -1i64;     // EFAULT
    }
    Result<int64>:r = sys_safe(SYS_CLOCK_GETTIME, clockid, @cast_unchecked<int64>(tp), 0i64, 0i64, 0i64, 0i64);
    if (r.is_error) {
        drop(errno_set(@cast_unchecked<int64>(r.error))); pass -1i64;
    }
    pass 0i64;
};
pub func:clock_getres = int64(int64:clockid, timespec->:res) {
    if (@cast_unchecked<int64>(res) == 0i64) {
        drop(errno_set(14i64)); pass -1i64;     // EFAULT
    }
    Result<int64>:r = sys_safe(SYS_CLOCK_GETRES, clockid, @cast_unchecked<int64>(res), 0i64, 0i64, 0i64, 0i64);
    if (r.is_error) {
        drop(errno_set(@cast_unchecked<int64>(r.error))); pass -1i64;
    }
    pass 0i64;
};
pub func:clock_settime = int64(int64:clockid, timespec->:tp) {
    if (@cast_unchecked<int64>(tp) == 0i64) {
        drop(errno_set(14i64)); pass -1i64;     // EFAULT
    }
    Result<int64>:r = sys_safe(SYS_CLOCK_SETTIME, clockid, @cast_unchecked<int64>(tp), 0i64, 0i64, 0i64, 0i64);
    if (r.is_error == true) {
        drop(errno_set(@cast_unchecked<int64>(r.error))); pass -1i64;
    }
    pass 0i64;
};

use "time_types.npk".*;
use "../syscall/syscall.npk".*;
use "../syscall/syscall_numbers.npk".*;
use "../syscall/errno.npk".*;

pub func:gettimeofday = int64(timeval->:tv, int64:tz) {
    if (@cast_unchecked<int64>(tv) == 0i64) {
        drop(errno_set(14i64)); pass -1i64;     // EFAULT
    }
    Result<int64>:r = sys_safe(SYS_GETTIMEOFDAY, @cast_unchecked<int64>(tv), tz, 0i64, 0i64, 0i64, 0i64);
    if (r.is_error) {
        drop(errno_set(@cast_unchecked<int64>(r.error))); pass -1i64;
    }
    pass 0i64;
};
pub func:settimeofday = int64(timeval->:tv, int64:tz) {
    if (@cast_unchecked<int64>(tv) == 0i64) {
        drop(errno_set(14i64)); pass -1i64;     // EFAULT
    }
    Result<int64>:r = sys_safe(SYS_SETTIMEOFDAY, @cast_unchecked<int64>(tv), tz, 0i64, 0i64, 0i64, 0i64);
    if (r.is_error) {
        drop(errno_set(@cast_unchecked<int64>(r.error))); pass -1i64;
    }
    pass 0i64;
};

use "time_types.npk".*;
use "../syscall/syscall.npk".*;
use "../syscall/syscall_numbers.npk".*;
use "../syscall/errno.npk".*;

pub func:nanosleep = int64(timespec->:req, timespec->:rem) {
    if (@cast_unchecked<int64>(req) == 0i64) {
        drop(errno_set(14i64)); pass -1i64;     // EFAULT
    }
    
    stack int64[2]:creq;
    stack int64[2]:crem;
    crem[0] = 0i64;
    crem[1] = 0i64;
    int64->:req_arr = @cast_unchecked<int64->>(req);
    creq[0] = req_arr[0];
    creq[1] = req_arr[1];

    while (true) {
        Result<int64>:r = sys_safe(SYS_NANOSLEEP, @cast_unchecked<int64>(@creq), @cast_unchecked<int64>(@crem), 0i64, 0i64, 0i64, 0i64);
        if (r.is_error == false) { break; }
        
        int64:err = @cast_unchecked<int64>(r.error);
        if (err != 4i64) { // 4 is EINTR
            drop(errno_set(err)); 
            if (@cast_unchecked<int64>(rem) != 0i64) {
                int64->:rem_arr = @cast_unchecked<int64->>(rem);
                rem_arr[0] = crem[0];
                rem_arr[1] = crem[1];
            }
            pass -1i64;
        }
        
        creq[0] = crem[0];
        creq[1] = crem[1];
    }
    
    if (@cast_unchecked<int64>(rem) != 0i64) {
        int64->:rem_arr = @cast_unchecked<int64->>(rem);
        rem_arr[0] = 0i64;
        rem_arr[1] = 0i64;
    }
    pass 0i64;
};

// env.npk — getenv, setenv, unsetenv, clearenv, putenv, environ (v0.11.4)
//
// Environment variable access and manipulation.
//
// ── environ — the global environment ──────────────────────────────────────
// On Linux, the process starts with a pointer to the environment in the
// auxiliary vector area. The C runtime (_start) typically sets:
//   extern char **environ;
// to point at the envp array passed to main().
//
// In Nitpick, environ is an int64 pointing to a NULL-terminated array of
// int64 pointers, each pointing to a NUL-terminated "KEY=VALUE" string.
//
// libn's _start (v0.12.x) will initialize this. For now, setenv/unsetenv
// maintain a SEPARATE heap-allocated environment that shadows the original.
//
// ── getenv semantics ──────────────────────────────────────────────────────
// getenv() scans environ from the end backward (last definition wins,
// matching glibc). Returns pointer into the environ string — do NOT modify.
//
// ── setenv / unsetenv ─────────────────────────────────────────────────────
// These rebuild the environ array on the heap. The original envp passed
// to main() is never mutated. The heap-built array is pointed to by
// _env_heap_envp; environ is updated to point there.
//
// Capacity: starts at ENV_INITIAL_CAP (64) entries, @cast_unchecked<needed>(grows).
//
// ── Thread safety ─────────────────────────────────────────────────────────
// Not thread-safe. Concurrent getenv/setenv requires external locking.

use "../syscall/errno.npk".*;
use "../mem/mmap.npk".*;
use "../mem/memcpy.npk".*;
use "../str/strlen.npk".*;
use "../str/strcpy.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// Global environ pointer
//
// Initialized to 0 (NULL) until proc_env_init() is called (from _start).
// After init, points to the process's environment.
// ════════════════════════════════════════════════════════════════════════════

pub int64:environ = 0i64;

// ── Internal heap environ management ──────────────────────────────────────
fixed int64:ENV_INITIAL_CAP = 64i64;

int64:_env_heap_envp  = 0i64;
int64:_env_heap_is_alloc = 0i64;    // pointer to heap-allocated int64[] array
int64:_env_heap_count = 0i64;    // number of live entries (excludes NULL terminator)
int64:_env_heap_cap   = 0i64;    // allocated capacity (in entries, excludes terminator)

// ════════════════════════════════════════════════════════════════════════════
// proc_env_init — Called by _start to snapshot the initial envp.
//
// Copies the envp pointer array (not the strings) into the heap environ.
// The string pointers are references into the original envp region.
// ════════════════════════════════════════════════════════════════════════════

pub func:proc_env_init = NIL(int64:envp) {
    if (envp == 0i64) {
        environ = 0i64;
        pass NIL;
    }

      // Count entries
    int64->:ep = @cast_unchecked<int64->>(envp);
    int64:n = 0i64;
    while (ep[n] != 0i64) { n = n + 1i64; }

      // Allocate heap array with extra headroom
    int64:cap = n + ENV_INITIAL_CAP;
    Result<int64>:r = mem_malloc((cap + 1i64) * 8i64);    // +1 for NULL terminator
    Result<int64>:r2 = mem_malloc((cap + 1i64) * 8i64);
    if (r.is_error) { environ = envp; pass NIL; }
    if (r2.is_error) {
        drop(mem_free(r.value));
        environ = envp;    // fallback: use original (immutable) envp
        pass NIL;
    }

    _env_heap_envp  = r.value;
    _env_heap_is_alloc = r2.value;
    _env_heap_count = n;
    _env_heap_cap   = cap;

    int64->:hp = @cast_unchecked<int64->>(_env_heap_envp);
    int64:i = 0i64;
    while (i < n) {
        hp[i] = ep[i];
        (@cast_unchecked<int64->>(_env_heap_is_alloc))[i] = 0i64;
        i = i + 1i64;
    }
    hp[n] = 0i64;
    (@cast_unchecked<int64->>(_env_heap_is_alloc))[n] = 0i64;

    environ = _env_heap_envp;
};

// ════════════════════════════════════════════════════════════════════════════
// getenv — Return the value of environment variable name, or 0 if not set.
//
// Returns a pointer INTO the environment string (after the '=').
// The returned pointer is valid until the next setenv/unsetenv/clearenv call.
// Do NOT modify or free the returned pointer.
// ════════════════════════════════════════════════════════════════════════════

pub func:getenv = int64(int64:name) {
    if (name == 0i64 || environ == 0i64) { pass 0i64; }

    int64:nlen = raw str_strlen(name);
    if (nlen == 0i64) { pass 0i64; }

    int64->:ep = @cast_unchecked<int64->>(environ);
    uint8->:np = @cast_unchecked<uint8->>(name);

      // Scan forward to find count, then scan backward (last definition wins)
    int64:count = 0i64;
    while (ep[count] != 0i64) { count = count + 1i64; }

    int64:i = count - 1i64;
    while (i >= 0i64) {
        int64:entry = ep[i];
        uint8->:es = @cast_unchecked<uint8->>(entry);
          // Compare key part: entry[0..nlen) == name && entry[nlen] == '='
        int64:j = 0i64;
        bool:match = true;
        while (j < nlen) {
            if (es[j] != np[j]) { match = false; break; }
            j = j + 1i64;
        }
        if (match && es[nlen] == 61u8) {    // '='
            pass entry + nlen + 1i64;
        }
        i = i - 1i64;
    }

    pass 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// _env_ensure_heap — Ensure we have a writable heap environ to modify.
// If environ still points to the original (non-heap) envp, snapshot it.
// ════════════════════════════════════════════════════════════════════════════

func:_env_ensure_heap = bool() {
    if (_env_heap_envp != 0i64) { pass true; }
      // Not initialized via proc_env_init — snapshot current environ now
    drop(proc_env_init(environ));
    pass _env_heap_envp != 0i64;
};

// ── Grow the heap envp array if needed ────────────────────────────────────
func:_env_grow = bool() {
    if (_env_heap_count < _env_heap_cap) { pass true; }
    int64:new_cap = _env_heap_cap * 2i64;
    if (new_cap < ENV_INITIAL_CAP) { new_cap = ENV_INITIAL_CAP; }
    Result<int64>:r = mem_realloc(_env_heap_envp, (new_cap + 1i64) * 8i64);
    Result<int64>:r2 = mem_realloc(_env_heap_is_alloc, (new_cap + 1i64) * 8i64);
    if (r.is_error) { pass false; }
    if (r2.is_error) { pass false; }
    _env_heap_envp = r.value;
    _env_heap_is_alloc = r2.value;
    _env_heap_cap  = new_cap;
    environ = _env_heap_envp;
    pass true;
};

// ════════════════════════════════════════════════════════════════════════════
// setenv — Set or overwrite an environment variable.
//
// name:      variable name (must not contain '=')
// value:     new value string
// overwrite: if 0 and the variable already exists, return 0 without changing it.
//
// Returns 0 on success, -1 on error (EINVAL for bad name, ENOMEM for OOM).
// ════════════════════════════════════════════════════════════════════════════

pub func:setenv = int64(int64:name, int64:value, int64:overwrite) {
    if (name == 0i64 || value == 0i64) { drop(errno_set(EINVAL)); pass -1i64; }
    int64:nlen = raw str_strlen(name);
    if (nlen == 0i64) { drop(errno_set(EINVAL)); pass -1i64; }

      // Validate: name must not contain '=' or NUL (already enforced by strlen, '=' check)
    uint8->:np = @cast_unchecked<uint8->>(name);
    int64:ci = 0i64;
    while (ci < nlen) {
        if (np[ci] == 61u8) { drop(errno_set(EINVAL)); pass -1i64; }    // '='
        ci = ci + 1i64;
    }

    if (!raw _env_ensure_heap()) { drop(errno_set(ENOMEM)); pass -1i64; }

      // If variable exists and overwrite==0, return success (no change)
    if (overwrite == 0i64 && raw getenv(name) != 0i64) { pass 0i64; }

      // Build "NAME=VALUE" string on heap
    int64:vlen = raw str_strlen(value);
    int64:total = nlen + 1i64 + vlen + 1i64;    // "NAME" + "=" + "VALUE" + NUL
    Result<int64>:sr = mem_malloc(total);
    if (sr.is_error) { drop(errno_set(ENOMEM)); pass -1i64; }
    int64:entry = sr.value;
    drop(mem_memcpy(entry, name, nlen));
    (@cast_unchecked<uint8->>(entry))[nlen] = 61u8;    // '='
    drop(mem_memcpy(entry + nlen + 1i64, value, vlen + 1i64));    // includes NUL

      // Replace existing entry or append new one
    int64->:ep = @cast_unchecked<int64->>(_env_heap_envp);
    int64:i = 0i64;
    while (ep[i] != 0i64) {
        int64:existing = ep[i];
        uint8->:es = @cast_unchecked<uint8->>(existing);
        int64:j = 0i64;
        bool:match = true;
        while (j < nlen) {
            if (es[j] != np[j]) { match = false; break; }
            j = j + 1i64;
        }
        if (match && es[nlen] == 61u8) {
              // Found: replace the pointer and free if allocated
            if ((@cast_unchecked<int64->>(_env_heap_is_alloc))[i] == 1i64) {
                drop(mem_free(ep[i]));
            }
            ep[i] = entry;
            (@cast_unchecked<int64->>(_env_heap_is_alloc))[i] = 1i64;
            pass 0i64;
        }
        i = i + 1i64;
    }

      // Not found: append
    if (!raw _env_grow()) { 
        drop(mem_free(entry));
        drop(errno_set(ENOMEM)); 
        pass -1i64; 
    }
    ep = @cast_unchecked<int64->>(_env_heap_envp);    // re-fetch after possible realloc
      // re-scan to find the end
    i = 0i64;
    while (ep[i] != 0i64) { i = i + 1i64; }
    ep[i] = entry;
    (@cast_unchecked<int64->>(_env_heap_is_alloc))[i] = 1i64;
    ep[i + 1i64] = 0i64;
    (@cast_unchecked<int64->>(_env_heap_is_alloc))[i + 1i64] = 0i64;
    _env_heap_count = _env_heap_count + 1i64;

    pass 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// unsetenv — Remove an environment variable by name.
//
// Returns 0 on success, -1 on error (EINVAL for empty or '='-containing name).
// It is not an error if the variable is not set.
// ════════════════════════════════════════════════════════════════════════════

pub func:unsetenv = int64(int64:name) {
    if (name == 0i64) { drop(errno_set(EINVAL)); pass -1i64; }
    int64:nlen = raw str_strlen(name);
    if (nlen == 0i64) { drop(errno_set(EINVAL)); pass -1i64; }
    uint8->:np = @cast_unchecked<uint8->>(name);
    int64:ci = 0i64;
    while (ci < nlen) {
        if (np[ci] == 61u8) { drop(errno_set(EINVAL)); pass -1i64; }
        ci = ci + 1i64;
    }

    if (!raw _env_ensure_heap()) { pass 0i64; }    // no heap → nothing to remove

    int64->:ep = @cast_unchecked<int64->>(_env_heap_envp);
    int64:count = 0i64;
    while (ep[count] != 0i64) { count = count + 1i64; }

    int64:i = 0i64;
    while (i < count) {
        int64:existing = ep[i];
        uint8->:es = @cast_unchecked<uint8->>(existing);
        int64:j = 0i64;
        bool:match = true;
        while (j < nlen) {
            if (es[j] != np[j]) { match = false; break; }
            j = j + 1i64;
        }
        if (match && es[nlen] == 61u8) {
              // Compact: free if alloc'd, then shift entries down
            if ((@cast_unchecked<int64->>(_env_heap_is_alloc))[i] == 1i64) { drop(mem_free(ep[i])); }
            int64:k = i;
            while (k < count - 1i64) {
                ep[k] = ep[k + 1i64];
                (@cast_unchecked<int64->>(_env_heap_is_alloc))[k] = (@cast_unchecked<int64->>(_env_heap_is_alloc))[k + 1i64];
                k = k + 1i64;
            }
            ep[count - 1i64] = 0i64;
            _env_heap_count = _env_heap_count - 1i64;
            count = count - 1i64;
              // Don't increment i — re-check position i (now holds next entry)
        } else {
            i = i + 1i64;
        }
    }

    pass 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// putenv — Add or change an environment variable.
//
// Takes a "NAME=VALUE" string directly. The string itself is stored in environ
// — do NOT pass a stack-allocated string. putenv does NOT copy the string.
// POSIX: modifying the string after putenv has undefined effects.
//
// Returns 0 on success, -1 on error.
// ════════════════════════════════════════════════════════════════════════════

pub func:putenv = int64(int64:entry) {
    if (entry == 0i64) { drop(errno_set(EINVAL)); pass -1i64; }

      // Find '=' to separate name from value
    uint8->:ep = @cast_unchecked<uint8->>(entry);
    int64:eq_pos = -1i64;
    int64:i = 0i64;
    while (ep[i] != 0u8) {
        if (ep[i] == 61u8) { eq_pos = i; break; }
        i = i + 1i64;
    }
    if (eq_pos < 0i64) {
          // No '=': @cast_unchecked<unsetenv>(treat)(entry)
        pass unsetenv(entry);
    }

    if (!raw _env_ensure_heap()) { drop(errno_set(ENOMEM)); pass -1i64; }

    int64->:hp = @cast_unchecked<int64->>(_env_heap_envp);
    int64:count = 0i64;
    while (hp[count] != 0i64) { count = count + 1i64; }

      // Check for existing key
    int64:j = 0i64;
    while (j < count) {
        int64:existing = hp[j];
        uint8->:es = @cast_unchecked<uint8->>(existing);
        int64:k = 0i64;
        bool:match = true;
        while (k < eq_pos) {
            if (es[k] != ep[k]) { match = false; break; }
            k = k + 1i64;
        }
        if (match && es[eq_pos] == 61u8) {
            if ((@cast_unchecked<int64->>(_env_heap_is_alloc))[j] == 1i64) { drop(mem_free(hp[j])); }
            hp[j] = entry;
            (@cast_unchecked<int64->>(_env_heap_is_alloc))[j] = 0i64;   // putenv string is NOT owned by us
            pass 0i64;
        }
        j = j + 1i64;
    }

      // Append
    if (!raw _env_grow()) { drop(errno_set(ENOMEM)); pass -1i64; }
    hp = @cast_unchecked<int64->>(_env_heap_envp);
    count = 0i64;
    while (hp[count] != 0i64) { count = count + 1i64; }
    hp[count] = entry;
    (@cast_unchecked<int64->>(_env_heap_is_alloc))[count] = 0i64;
    hp[count + 1i64] = 0i64;
    (@cast_unchecked<int64->>(_env_heap_is_alloc))[count + 1i64] = 0i64;
    _env_heap_count = _env_heap_count + 1i64;

    pass 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// clearenv — Remove all environment variables.
//
// Resets the environ array to a single NULL entry.
// POSIX: After clearenv(), environ points to an empty array, not NULL itself.
// ════════════════════════════════════════════════════════════════════════════

pub func:clearenv = int64() {
    if (_env_heap_envp == 0i64) {
        if (!raw _env_ensure_heap()) { drop(errno_set(ENOMEM)); pass -1i64; }
    }
    int64->:hp = @cast_unchecked<int64->>(_env_heap_envp);
    int64:i = 0i64;
    while (i < _env_heap_count) {
        if ((@cast_unchecked<int64->>(_env_heap_is_alloc))[i] == 1i64) {
            drop(mem_free(hp[i]));
        }
        i = i + 1i64;
    }
    hp[0] = 0i64;
    _env_heap_count = 0i64;
    environ = _env_heap_envp;
    pass 0i64;
};

// proc.npk — Top-level process control module re-export (v0.11.0)
//
// Import this file to get the complete process control subsystem in one shot.
// Consumers may also import individual sub-modules for finer dependency control.
//
// ── Module history ─────────────────────────────────────────────────────────
//   v0.11.0  exit.npk   — exit, _exit, abort, atexit, at_quick_exit, quick_exit
//   v0.11.1  fork.npk   — fork, vfork, getpid/ppid, uid/gid, setpgid, setsid
//   v0.11.2  exec.npk   — execve, execv, execvp, execvpe, execl0-8, execlp1-4
//   v0.11.3  wait.npk   — waitpid, wait, wait3, WIF* decode, proc_run, proc_wait_all
//   v0.11.4  env.npk    — getenv, setenv, unsetenv, clearenv, putenv, environ
//   v0.11.5  signal.npk — kill, raise, killpg, signal, sigaction, sigprocmask
//
// ── Future ─────────────────────────────────────────────────────────────────
//   v0.12.x  start.npk  — _start, C runtime bootstrap, argc/argv/envp setup
//   v0.13.x  alarm.npk  — alarm, setitimer, SIGALRM integration
//   v0.14.x  thread.npk — pthread-compatible threads (clone-based)

use "../proc/exit.npk".*;
use "../proc/fork.npk".*;
use "../proc/exec.npk".*;
use "../proc/wait.npk".*;
use "../proc/env.npk".*;
use "../proc/signal.npk".*;

// signal.npk — kill, raise, sigaction, signal, sigprocmask (v0.11.5)
//
// POSIX signal delivery.
//
// ── Signal safety ─────────────────────────────────────────────────────────
// Signal handlers are inherently asynchronous. Only "async-signal-safe"
// functions may be called from within a signal handler. From libn, these are:
//   - _exit(), _Exit()               (immediate exit)
//   - kill(), raise()                (send signals)
//   - sys_raw()                      (direct syscall)
//   - Any function that only reads/writes to local variables
//
// DO NOT call from a signal handler:
//   - malloc/free (allocator uses non-reentrant state)
//   - exit() (calls atexit handlers, not async-signal-safe)
//   - stdio (buffered I/O, not async-signal-safe)
//
// ── sigaction vs signal() ─────────────────────────────────────────────────
// Always prefer sigaction() over signal(). signal() has different semantics
// across UNIX variants (SA_RESETHAND vs SA_RESTART behavior). sigaction()
// is fully specified by POSIX.
//
// ── Struct: KernelSigAction (struct sigaction layout on x86-64 Linux) ─────
//
// struct:kernel_sigaction = {
//     void (*sa_handler)(int);     // handler pointer or SIG_DFL/SIG_IGN
//     unsigned long sa_flags;      // SA_* flags
//     void (*sa_restorer)(void);   // MANDATORY on x86-64 (libc provides this)
//     sigset_t sa_mask;            // signals to block during handler
// };
//
// Size: 8 + 8 + 8 + 8 = 32 bytes on x86-64 (sigset_t is 8 bytes for 64 sigs)
//
// ── sa_restorer ────────────────────────────────────────────────────────────
// On x86-64 Linux, SA_RESTORER must be set and sa_restorer must point to
// the signal trampoline (rt_sigreturn). libn provides proc_sigreturn_tramp
//@cast_unchecked<a>() minimal inline trampoline that calls SYS_RT_SIGRETURN.
//
// ── sigset_t ───────────────────────────────────────────────────────────────
// On x86-64 Linux, sigset_t is 64 bits (one bit per signal, signals 1-64).
// We represent @cast_unchecked<int64>(it). Bit (signo-1) corresponds to signal signo.

use "../syscall/syscall.npk".*;
use "../syscall/syscall_numbers.npk".*;
use "../syscall/posix_constants.npk".*;
use "../syscall/errno.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// Sigset helpers — manipulate int64 signal masks
// ════════════════════════════════════════════════════════════════════════════

// sigemptyset — Clear all signals from the mask.
pub func:sigemptyset = int64() {
    pass 0i64;
};

// sigfillset — Set all signals in the mask.
pub func:sigfillset = int64() {
    pass -1i64;    // all bits set
};

// sigaddset — Add signal signo to mask.
pub func:sigaddset = int64(int64:mask, int64:signo) {
    if (signo < 1i64 || signo > 64i64) { pass mask; }
    pass mask | (1i64 << (signo - 1i64));
};

// sigdelset — Remove signal signo from mask.
pub func:sigdelset = int64(int64:mask, int64:signo) {
    if (signo < 1i64 || signo > 64i64) { pass mask; }
    pass mask & ~(1i64 << (signo - 1i64));
};

// sigismember — True if signo is in mask.
pub func:sigismember = bool(int64:mask, int64:signo) {
    if (signo < 1i64 || signo > 64i64) { pass false; }
    pass (mask & (1i64 << (signo - 1i64))) != 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// KernelSigAction — in-memory layout of struct sigaction on x86-64 Linux
//
// We use a 32-uint8 stack allocation and encode fields manually.
// Fields at uint8 offsets:
//   0:  sa_handler  (int64 — function pointer or SIG_DFL/SIG_IGN)
//   8:  sa_flags    (int64 — SA_* bitmask)
//   16: sa_restorer (int64 — function pointer, MUST be set with SA_RESTORER)
//   24: sa_mask     (int64 — sigset_t: signals to block during handler)
// ════════════════════════════════════════════════════════════════════════════

pub fixed int64:SIGACTION_SIZE = 32i64;

// proc_sigreturn_tramp — Minimal signal return trampoline for x86-64.
// After the kernel invokes our handler, it uses this to call rt_sigreturn.
// Must be pure machine code: mov rax, SYS_RT_SIGRETURN; syscall.
// We embed @cast_unchecked<a>(it) Nitpick raw stub.
pub func:proc_sigreturn_tramp = NIL() {
    drop(asm!!!<int64>("x86_64", "movq $15, %rax\n\tsyscall", ""));
    pass NIL;
};

// ── Encode a KernelSigAction into a 32-uint8 stack buffer ──────────────────
func:_sigact_encode = NIL(int64:buf, int64:handler, int64:flags,
                            int64:mask) {
    int64->:p = @cast_unchecked<int64->>(buf);
    p[0] = handler;
    p[1] = flags | SA_RESTORER;
    p[2] = @cast_unchecked<int64>(@proc_sigreturn_tramp);
    p[3] = mask;
};

// ── Decode a KernelSigAction from a 32-uint8 buffer ────────────────────────
func:_sigact_handler = int64(int64:buf) {
    pass (@cast_unchecked<int64->>(buf))[0];
};

// ════════════════════════════════════════════════════════════════════════════
// sigaction — Examine and/or change the action for signal signo.
//
// new_handler:  SIG_DFL, SIG_IGN, or a function pointer (void handler(int))
// new_flags:    SA_* flags (SA_RESTART, SA_NOCLDSTOP, etc.)
// new_mask:     signals to block during handler (int64 sigset)
// old_buf:      pointer to 32-uint8 buffer to receive previous action, or 0
//
// Returns 0 on success, -1 on error (errno set).
// ════════════════════════════════════════════════════════════════════════════

pub func:sigaction = int64(int64:signo, int64:new_handler, int64:new_flags,
                            int64:new_mask, int64:old_buf) {
      // Build new action on stack
    stack uint8[32]:new_act;
    drop(_sigact_encode(@cast_unchecked<int64>(@new_act), new_handler, new_flags, new_mask));

      // old_act buffer (may be 0 → pass 0 to kernel)
    stack uint8[32]:old_act;
    int64:old_ptr = is (old_buf != 0i64) : @cast_unchecked<int64>(@old_act) : 0i64;

      // SYS_RT_SIGACTION: (signo, newact*, oldact*, sigsetsize)
      // sigsetsize must be 8 on x86-64 (sizeof(sigset_t))
    Result<int64>:r = sys!!(SYS_RT_SIGACTION,
                             signo,
                             @cast_unchecked<int64>(@new_act),
                             old_ptr,
                             8i64,
                             0i64, 0i64);
    if (r.is_error) {
        drop(errno_set(@cast_unchecked<int64>(r.error)));
        pass -1i64;
    }

    if (old_buf != 0i64) {
          // Copy old action to caller's buffer
        int64->:op = @cast_unchecked<int64->>(@old_act);
        int64->:cp = @cast_unchecked<int64->>(old_buf);
        cp[0] = op[0];
        cp[1] = op[1];
        cp[2] = op[2];
        cp[3] = op[3];
    }

    pass 0i64;
};

// ── signal — Simplified sigaction: set handler for signo, SA_RESTART style.
// Returns the previous handler (SIG_DFL, SIG_IGN, or function pointer).
// Returns SIG_ERR on failure.
pub func:signal = int64(int64:signo, int64:handler) {
    stack uint8[32]:old_act;
    int64:flags = SA_RESTART;
    int64:r = raw sigaction(signo, handler, flags, sigemptyset(), @cast_unchecked<int64>(@old_act));
    if (r < 0i64) { pass SIG_ERR; }
    pass _sigact_handler(@cast_unchecked<int64>(@old_act));
};

// ── SIG_DFL / SIG_IGN helpers (convenience) ────────────────────────────────

// sig_ignore — Ignore signal signo (SIG_IGN).
pub func:sig_ignore = int64(int64:signo) {
    pass signal(signo, SIG_IGN);
};

// sig_default — Restore default action for signal signo.
pub func:sig_default = int64(int64:signo) {
    pass signal(signo, SIG_DFL);
};

// ════════════════════════════════════════════════════════════════════════════
// sigprocmask — Examine and/or change the blocked signals mask.
//
// how:  SIG_BLOCK, SIG_UNBLOCK, or SIG_SETMASK
// set:  signal mask to apply (int64 sigset)
// old:  pointer to int64 to receive previous mask, or 0
//
// Returns 0 on success, -1 on error.
// ════════════════════════════════════════════════════════════════════════════

pub fixed int64:SIG_BLOCK   = 0i64;
pub fixed int64:SIG_UNBLOCK = 1i64;
pub fixed int64:SIG_SETMASK = 2i64;

pub func:sigprocmask = int64(int64:how, int64:set, int64:old_ptr) {
      // SYS_RT_SIGPROCMASK: (how, set*, old*, sigsetsize)
      // set and old are pointers to sigset_t (int64 here)
    stack int64:set_val;
    set_val = set;
    stack int64:old_val;
    old_val = 0i64;
    int64:old_p = is (old_ptr != 0i64) : @cast_unchecked<int64>(@old_val) : 0i64;

    Result<int64>:r = sys!!(SYS_RT_SIGPROCMASK,
                             how,
                             @set_val,
                             old_p,
                             8i64,
                             0i64, 0i64);
    if (r.is_error) {
        drop(errno_set(@cast_unchecked<int64>(r.error)));
        pass -1i64;
    }

    if (old_ptr != 0i64) {
        (@cast_unchecked<int64->>(old_ptr))[0] = old_val;
    }

    pass 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// kill — Send signal signo to process (or process group) pid.
//
// pid:
//   > 0  — send to process with that PID
//   = 0  — send to every process in the same process group
//   = -1 — send to every process the caller has permission to signal
//   < -1 — send to every process in process group abs(pid)
//
// Returns 0 on success, -1 on error (errno: EPERM, ESRCH, EINVAL).
// ════════════════════════════════════════════════════════════════════════════

pub func:kill = int64(int64:pid, int64:signo) {
    Result<int64>:r = sys!!(SYS_KILL, pid, signo, 0i64, 0i64, 0i64, 0i64);
    if (r.is_error) {
        drop(errno_set(@cast_unchecked<int64>(r.error)));
        pass -1i64;
    }
    pass 0i64;
};

// raise — Send signal signo to the calling process.
// Equivalent to kill(getpid(), signo).
pub func:raise = int64(int64:signo) {
      // Use tkill(gettid(), signo) for correct per-thread delivery.
      // Since we're single-threaded, getpid()==gettid(). Use SYS_TKILL.
    Result<int64>:pid_r = sys_safe(SYS_GETPID, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64);
    int64:tid = pid_r ?! 1i64;
    Result<int64>:r = sys!!(SYS_TKILL, tid, signo, 0i64, 0i64, 0i64, 0i64);
    if (r.is_error) {
        drop(errno_set(@cast_unchecked<int64>(r.error)));
        pass -1i64;
    }
    pass 0i64;
};

// killpg — Send signal signo to process group pgrp.
pub func:killpg = int64(int64:pgrp, int64:signo) {
    pass kill(0i64 - pgrp, signo);
};

// wait.npk — waitpid, wait, wait3, WIF* status macros (v0.11.3)
//
// Wait for child process state changes and decode their exit status.
//
// ── Wait status format (Linux x86-64 / POSIX) ─────────────────────────────
// The raw status integer returned by wait4/waitpid is 32 bits:
//
//   Bits 7:0  — signal number that killed the process (if signaled)
//   Bit  7    — core dump flag (if killed by signal)
//   Bits 15:8 — exit code from _exit() (if exited normally)
//   Bits 7:0  — 0x7F if the process was stopped by a signal
//   Bits 15:8 — signal that stopped the process (if stopped)
//
// The WIF*/WEXITSTATUS/WTERMSIG functions decode this correctly.
// They accept the raw @cast_unchecked<int64>(status) (Nitpick convention).
//
// ── Usage pattern ─────────────────────────────────────────────────────────
//   int64:pid = fork();
//   if pid == 0 {
//       // child
//       execlp1("ls"@cast_unchecked<int64>(), "ls"@cast_unchecked<int64>());
//       _exit(1i64);
//   }
//   int64:status = 0i64;
//   int64:w = waitpid(pid, @cast_unchecked<int64>(@status), 0i64);
//   if wait_exited(status) {
//       int64:code = wait_exit_code(status);
//   }

use "../syscall/syscall.npk".*;
use "../syscall/syscall_numbers.npk".*;
use "../syscall/posix_constants.npk".*;
use "../syscall/errno.npk".*;
use "../proc/env.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// Wait status decode functions (POSIX WIFEXITED @cast_unchecked<Nitpick>(etc.) functions)
//
// All take the raw int32 status @cast_unchecked<int64>(value) (zero-extended).
// ════════════════════════════════════════════════════════════════════════════

// wait_exited — True if the child exited normally via exit() or _exit().
pub func:wait_exited = bool(int64:status) {
    pass (status & 0x7Fi64) == 0i64;
};

// wait_exit_code — The exit code from exit() / _exit() (0-255).
// Only valid when wait_exited() is true.
pub func:wait_exit_code = int64(int64:status) {
    pass (status >> 8i64) & 0xFFi64;
};

// wait_signaled — True if the child was killed by a signal.
pub func:wait_signaled = bool(int64:status) {
    int64:low7 = status & 0x7Fi64;
    pass low7 != 0i64 && low7 != 0x7Fi64;
};

// wait_termsig — The signal number that killed the child.
// Only valid when wait_signaled() is true.
pub func:wait_termsig = int64(int64:status) {
    pass status & 0x7Fi64;
};

// wait_coredump — True if the child produced a core dump.
pub func:wait_coredump = bool(int64:status) {
    pass (status & 0x80i64) != 0i64;
};

// wait_stopped — True if the child was stopped by a signal (WUNTRACED).
pub func:wait_stopped = bool(int64:status) {
    pass (status & 0xFFi64) == 0x7Fi64;
};

// wait_stopsig — The signal that stopped the child.
// Only valid when wait_stopped() is true.
pub func:wait_stopsig = int64(int64:status) {
    pass (status >> 8i64) & 0xFFi64;
};

// wait_continued — True if the child was resumed by SIGCONT (WCONTINUED).
pub func:wait_continued = bool(int64:status) {
    pass status == 0xFFFFi64;
};

// ════════════════════════════════════════════════════════════════════════════
// waitpid — Wait for state change of specific child (or child group).
//
// pid:
//   > 0   — wait for the specific child with that PID
//   = -1  — wait for any child (@cast_unchecked<wait>(same)())
//   = 0   — wait for any child in the same process group
//   < -1  — wait for any child in process group abs(pid)
//
// status_ptr: pointer to int64 to receive the status word (may be 0/NULL).
// options: 0, WNOHANG, WUNTRACED, WCONTINUED, or combinations.
//
// Returns: PID of the child whose state changed, 0 if WNOHANG and no child
//          ready, or -1 on error (errno set).
// ════════════════════════════════════════════════════════════════════════════

pub func:waitpid = int64(int64:pid, int64:status_ptr, int64:options) {
      // SYS_WAIT4: wait4(pid, status, options, rusage)
      // We pass 0 for rusage (not collecting resource usage here)
    Result<int64>:r = sys!!(SYS_WAIT4, pid, status_ptr, options, 0i64, 0i64, 0i64);
    if (r.is_error) {
        drop(errno_set(@cast_unchecked<int64>(r.error)));
        pass -1i64;
    }
    pass r.value;
};

// wait — Wait for any child; equivalent to waitpid(-1, status_ptr, 0).
pub func:wait = int64(int64:status_ptr) {
    pass waitpid(-1i64, status_ptr, 0i64);
};

// wait3 — waitpid(-1, status_ptr, options) without resource usage collection.
// GNU/BSD extension; commonly used for non-blocking child reaping.
pub func:wait3 = int64(int64:status_ptr, int64:options) {
    pass waitpid(-1i64, status_ptr, options);
};

// ════════════════════════════════════════════════════════════════════════════
// proc_wait_all — Reap all terminated children, ignoring their status.
//
// Useful in signal handlers or cleanup code to prevent zombie accumulation.
// Loops WNOHANG until no children remain.
// Returns the number of children reaped.
// ════════════════════════════════════════════════════════════════════════════

pub func:proc_wait_all = int64() {
    int64:count = 0i64;
    while (true) {
        int64:r = raw waitpid(-1i64, 0i64, WNOHANG);
        if (r <= 0i64) { break; }
        count = count + 1i64;
    }
    pass count;
};

// ════════════════════════════════════════════════════════════════════════════
// proc_run — High-level fork+exec+wait helper.
//
// Fork, exec the given argv (via execve), wait for the child to exit.
// Returns the child's exit code (0-255), or -1 on fork/exec failure.
//
// The first element of argv must be the path to the executable.
// envp may be 0 (uses inherited environ).
//
// This is the equivalent of system() but without going through a shell.
// ════════════════════════════════════════════════════════════════════════════

use "../proc/fork.npk".*;
use "../proc/exec.npk".*;
use "../proc/exit.npk".*;

pub func:proc_run = int64(int64:path, int64:argv, int64:envp) {
    int64:pid = raw fork();
    if (pid < 0i64) { pass -1i64; }

    if (pid == 0i64) {
          // Child
        if (envp != 0i64) {
            drop(execve(path, argv, envp));
        } else {
            drop(execv(path, argv));
        }
        drop(_exit(127i64));    // exec failed — 127 is shell's "command not found"
    }

      // Parent: wait for child
    int64:status = 0i64;
    int64:w = raw waitpid(pid, @cast_unchecked<int64>(@status), 0i64);
    if (w < 0i64) { pass -1i64; }

    if (raw wait_exited(status)) {
        pass wait_exit_code(status);
    }
    if (raw wait_signaled(status)) {
          // Return 128 + signal number (shell convention)
        pass 128i64 + raw wait_termsig(status);
    }
    pass -1i64;
};

// exit.npk — exit, _exit, abort, atexit, at_quick_exit (v0.11.0)
//
// Process termination. All paths ultimately call SYS_EXIT_GROUP which
// terminates the entire thread group (all threads), matching C99/POSIX exit().
//
// ── Execution order on exit() ─────────────────────────────────────────────
// POSIX exit() must:
//   1. Call functions registered via atexit() in LIFO order
//   2. Flush and close all open stdio streams (flushed via bio_flush_all)
//   3. Call _exit() — which calls SYS_EXIT_GROUP, no further cleanup
//
// This module implements the atexit registry. The stdio flush is performed
// by bio_flush_all() from src/io/bio/stdfiles.npk.
//
// ── atexit capacity ───────────────────────────────────────────────────────
// We support up to ATEXIT_MAX (32) handlers without heap allocation.
// This matches the POSIX minimum of 32. If you need more, the registry
// will silently discard excess registrations (and return -1 from atexit()).
//
// ── Thread safety ─────────────────────────────────────────────────────────
// The atexit registry is a global array — not thread-safe. In Nitpick's
// single-threaded use cases this is fine. Multi-threaded protection is
// deferred to the threading module (v0.14.x).

use "../syscall/syscall.npk".*;
use "../syscall/syscall_numbers.npk".*;
use "../syscall/posix_constants.npk".*;
use "../io/bio/stdfiles.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// atexit registry
// ════════════════════════════════════════════════════════════════════════════

pub fixed int64:ATEXIT_MAX = 32i64;

// Function pointer type: atexit handlers take no arguments and return void.
// @cast_unchecked<raw>(Stored) int64 (pointer to function).
int64[32]:_atexit_handlers;
int64:_atexit_count = 0i64;

// Same for at_quick_exit (C11) — separate registry, same capacity.
int64[32]:_atqexit_handlers;
int64:_atqexit_count = 0i64;

// ── atexit — Register a function to be called at normal process exit ───────
//
// Returns 0 on success, -1 if the registry is full (POSIX).
// Handlers are called in LIFO order (last-registered, first-called).
pub func:atexit = int64(int64:fn_ptr) {
    if (_atexit_count >= ATEXIT_MAX) {
        pass -1i64;
    }
    _atexit_handlers[_atexit_count] = fn_ptr;
    _atexit_count = _atexit_count + 1i64;
    pass 0i64;
};

// at_quick_exit — Register a handler called only by quick_exit(), not exit().
pub func:at_quick_exit = int64(int64:fn_ptr) {
    if (_atqexit_count >= ATEXIT_MAX) {
        pass -1i64;
    }
    _atqexit_handlers[_atqexit_count] = fn_ptr;
    _atqexit_count = _atqexit_count + 1i64;
    pass 0i64;
};

// ── _proc_run_atexit — Internal: call atexit handlers in LIFO order ────────
// Not for external use.
func:_proc_run_atexit = NIL() {
    int64:i = _atexit_count - 1i64;
    while (i >= 0i64) {
        int64:fn = _atexit_handlers[i];
        if (fn != 0i64) {
            drop(asm!!!<int64>("x86_64", "call *%0", "r", fn));
        }
        i = i - 1i64;
    }
};

func:_proc_run_atqexit = NIL() {
    int64:i = _atqexit_count - 1i64;
    while (i >= 0i64) {
        int64:fn = _atqexit_handlers[i];
        if (fn != 0i64) {
            drop(asm!!!<int64>("x86_64", "call *%0", "r", fn));
        }
        i = i - 1i64;
    }
};

// ════════════════════════════════════════════════════════════════════════════
// _exit — Immediate process termination (no atexit, no stdio flush)
//
// Equivalent to POSIX _exit(). Calls SYS_EXIT_GROUP.
// This is the ONLY way to exit from a forked child before exec — any other
// path risks double-flushing stdio buffers from the parent.
// ════════════════════════════════════════════════════════════════════════════

pub func:_exit = NIL(int64:code) {
    drop sys!!(SYS_EXIT_GROUP, code, 0i64, 0i64, 0i64, 0i64, 0i64);
    pass NIL;
      // Unreachable — but the type system needs a pass
};

// Alias: _Exit() is the C99 name for _exit()
pub func:_Exit = NIL(int64:code) {
    drop(_exit(code));
    pass NIL;
};

// ════════════════════════════════════════════════════════════════════════════
// exit — Normal process termination with cleanup
//
// Steps:
//   1. Run atexit handlers (LIFO)
//   2. Flush all stdio buffers
//   3. Call _exit(code)
// ════════════════════════════════════════════════════════════════════════════

pub func:exit = NIL(int64:code) {
    drop(_proc_run_atexit());
    drop(bio_flush_all());
    drop(_exit(code));
    pass NIL;
};

// quick_exit — C11: run at_quick_exit handlers but NOT atexit, no stdio flush.
pub func:quick_exit = NIL(int64:code) {
    drop(_proc_run_atqexit());
    drop(_exit(code));
    pass NIL;
};

// ════════════════════════════════════════════════════════════════════════════
// abort — Abnormal termination
//
// Sends SIGABRT to the calling process. If the signal is not caught (or
// the handler returns), terminates with a signal-caught status.
// POSIX: abort() must unblock SIGABRT and re-raise it after calling any
// SIGABRT handler (to allow the debugger to catch it). We implement the
// simplified version: raise SIGABRT, then force-exit if it returns.
// ════════════════════════════════════════════════════════════════════════════

pub func:abort = NIL() {
      // Raise SIGABRT to ourselves
    drop sys!!(SYS_KILL, 0i64, SIGABRT, 0i64, 0i64, 0i64, 0i64);
      // If a handler caught it and returned, force exit with failure
    drop(_exit(134i64));
    pass NIL;    // 128 + SIGABRT(6) = 134, the shell exit code for SIGABRT
};

// fork.npk — fork, vfork, getpid, getppid, process groups, sessions (v0.11.1)
//
// ── fork() rules for safe child processes ────────────────────────────────
//
// After fork(), the child has a COPY of the parent's memory but shares
// nothing with it. Critical rules:
//
//   1. Call _exit() (not exit()) in the child after exec failure.
//      exit() would flush the parent's stdio buffers — double-flush.
//
//   2. Do NOT use the parent's heap in the child (allocator state is copied
//      but not safe to share — mutex state, etc.).
//
//   3. Signal handlers, file descriptors, and memory mappings are inherited.
//      File descriptor flags (O_CLOEXEC) control what survives exec.
//
//   4. fork() in a multi-threaded program creates a child with only ONE
//      thread — the caller's thread. This is a common source of deadlocks
//      (mutexes locked by other threads in the parent are still locked).
//      libn is currently single-threaded so this does not apply yet.
//
// ── Return values ─────────────────────────────────────────────────────────
//   fork()  returns child PID to parent, 0 to child, -1 on error.
//
// ── vfork() ───────────────────────────────────────────────────────────────
//   vfork() shares the parent's address space with the child until the
//   child calls exec() or _exit(). The parent is SUSPENDED until then.
//   Only safe operations in the child after vfork: execve, _exit.
//   All other use is undefined behavior.

use "../syscall/syscall.npk".*;
use "../syscall/syscall_numbers.npk".*;
use "../syscall/errno.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// fork — Create a child process by duplicating the calling process.
//
// Returns:
//   > 0  — in parent: the child's PID
//   = 0  — in child
//   = -1 — error (errno set); common: EAGAIN (process limit), ENOMEM
// ════════════════════════════════════════════════════════════════════════════

pub func:fork = int64() {
    Result<int64>:r = sys!!(SYS_FORK, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64);
    if (r.is_error) {
        drop(errno_set(@cast_unchecked<int64>(r.error)));
        pass -1i64;
    }
    pass r.value;
};

// ════════════════════════════════════════════════════════════════════════════
// vfork — Create child sharing parent's address space (exec-or-exit only).
//
// After vfork(), the child MUST call execve() or _exit() before the parent
// resumes. Writing to any parent variables from the child is undefined.
// ════════════════════════════════════════════════════════════════════════════

pub func:vfork = int64() {
    Result<int64>:r = sys!!(SYS_VFORK, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64);
    if (r.is_error) {
        drop(errno_set(@cast_unchecked<int64>(r.error)));
        pass -1i64;
    }
    pass r.value;
};

// ════════════════════════════════════════════════════════════════════════════
// Process identity
// ════════════════════════════════════════════════════════════════════════════

// getpid — Return the process ID of the calling process.
pub func:getpid = int64() {
    Result<int64>:r = sys!!(SYS_GETPID, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64);
    if (r.is_error) { pass -1i64; }
    pass r.value;
};

// getppid — Return the parent's process ID.
pub func:getppid = int64() {
    Result<int64>:r = sys!!(SYS_GETPPID, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64);
    if (r.is_error) { pass -1i64; }
    pass r.value;
};

// getuid — Return real user ID.
pub func:getuid = int64() {
    Result<int64>:r = sys!!(SYS_GETUID, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64);
    if (r.is_error) { pass -1i64; }
    pass r.value;
};

// geteuid — Return effective user ID.
pub func:geteuid = int64() {
    Result<int64>:r = sys!!(SYS_GETEUID, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64);
    if (r.is_error) { pass -1i64; }
    pass r.value;
};

// getgid — Return real group ID.
pub func:getgid = int64() {
    Result<int64>:r = sys!!(SYS_GETGID, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64);
    if (r.is_error) { pass -1i64; }
    pass r.value;
};

// getegid — Return effective group ID.
pub func:getegid = int64() {
    Result<int64>:r = sys!!(SYS_GETEGID, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64);
    if (r.is_error) { pass -1i64; }
    pass r.value;
};

// ════════════════════════════════════════════════════════════════════════════
// Process groups and sessions
// ════════════════════════════════════════════════════════════════════════════

// setpgid — Set the process group ID of pid to pgid.
// If pid == 0: affects calling process. If pgid == 0: pgid = pid.
// Returns 0 on success, -1 on error (errno set).
pub func:setpgid = int64(int64:pid, int64:pgid) {
    Result<int64>:r = sys!!(SYS_SETPGID, pid, pgid, 0i64, 0i64, 0i64, 0i64);
    if (r.is_error) {
        drop(errno_set(@cast_unchecked<int64>(r.error)));
        pass -1i64;
    }
    pass 0i64;
};

// getpgid — Return the process group ID of pid (0 = calling process).
pub func:getpgid = int64(int64:pid) {
    Result<int64>:r = sys!!(SYS_GETPGID, pid, 0i64, 0i64, 0i64, 0i64, 0i64);
    if (r.is_error) {
        drop(errno_set(@cast_unchecked<int64>(r.error)));
        pass -1i64;
    }
    pass r.value;
};

// getpgrp — Return the process group ID of the calling process.
pub func:getpgrp = int64() {
    pass getpgid(0i64);
};

// setsid — Create a new session and set the calling @cast_unchecked<session>(process) leader.
// Returns the new session ID, or -1 on error (already a process group leader).
pub func:setsid = int64() {
    Result<int64>:r = sys!!(SYS_SETSID, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64);
    if (r.is_error) {
        drop(errno_set(@cast_unchecked<int64>(r.error)));
        pass -1i64;
    }
    pass r.value;
};

// getsid — Return the session ID of pid (0 = calling process).
pub func:getsid = int64(int64:pid) {
    Result<int64>:r = sys!!(SYS_GETSID, pid, 0i64, 0i64, 0i64, 0i64, 0i64);
    if (r.is_error) {
        drop(errno_set(@cast_unchecked<int64>(r.error)));
        pass -1i64;
    }
    pass r.value;
};

// exec.npk — execve, execv, execvp, execle, execl, execvpe (v0.11.2)
//
// Process image replacement. After a successful exec:
//   - The calling process is replaced by the new program image
//   - File descriptors without O_CLOEXEC are inherited
//   - Signal dispositions are reset to SIG_DFL (for caught signals)
//   - Memory, code, stack are completely replaced
//
// execve() NEVER returns on success. It only returns -1 on failure.
//
// ── ABI note ──────────────────────────────────────────────────────────────
// execve takes:
//   path: NUL-terminated filename
//   argv: NULL-terminated array of NUL-terminated argument strings
//   envp: NULL-terminated array of NUL-terminated "KEY=VALUE" strings
//
// In Nitpick all three are int64 (pointer to array of int64 pointer values).
//
// ── Variadic wrappers ─────────────────────────────────────────────────────
// execl/execlp/execle take argument lists inline (explicit-arity pattern).
// The _N suffix means N additional arguments after the mandatory ones.
// execl0(path, arg0) — execute path with argv = {arg0, NULL}
// execl1(path, arg0, arg1) — argv = {arg0, arg1, NULL}
// ... up to execl8
//
// execvp searches PATH for the executable (like the shell does).
// execvpe is GNU extension: execvp + custom envp.
//
// ── exec with fork — canonical pattern ────────────────────────────────────
//
//   int64:pid = fork();
//   if pid == 0 {
//       // child
//       stack int64[3]:argv;
//       argv[0] = "/bin/ls"@cast_unchecked<int64>();
//       argv[1] = "-l"@cast_unchecked<int64>();
//       argv[2] = 0i64;
//       drop(execv("/bin/ls"@cast_unchecked<int64>(), @cast_unchecked<int64>(@argv)));
//       _exit(1i64);  // exec failed
//   }
//   // parent continues...

use "../syscall/syscall.npk".*;
use "../syscall/syscall_numbers.npk".*;
use "../syscall/errno.npk".*;
use "../str/strlen.npk".*;
use "../proc/env.npk".*;

// ── External environ pointer (defined in env.npk, resolved at link time) ──
// Used by execvp when it needs the current environment.
// extern int64:environ;   // NULL-terminated array of "KEY=VAL" strings

// ════════════════════════════════════════════════════════════════════════════
// execve — Core exec: replace process image with path, argv, envp.
//
// Returns -1 on failure (errno set). Never returns on success.
// ════════════════════════════════════════════════════════════════════════════

pub func:execve = int64(int64:path, int64:argv, int64:envp) {
    Result<int64>:r = sys!!(SYS_EXECVE, path, argv, envp, 0i64, 0i64, 0i64);
    if (r.is_error) {
        drop(errno_set(@cast_unchecked<int64>(r.error)));
        pass -1i64;
    }
    pass 0i64;    // unreachable on success
};

// ════════════════════════════════════════════════════════════════════════════
// execv — execve with inherited environment (current environ).
// ════════════════════════════════════════════════════════════════════════════

pub func:execv = int64(int64:path, int64:argv) {
    pass execve(path, argv, environ);
};

// ════════════════════════════════════════════════════════════════════════════
// execvp — Like execv but searches PATH for the executable name.
//
// If path contains a '/', it is used directly (no PATH search).
// Otherwise, each directory in PATH is tried: PATH_dir + "/" + path.
//
// Uses a 4096-uint8 stack buffer for constructing candidate paths.
// ════════════════════════════════════════════════════════════════════════════

pub func:execvp = int64(int64:name, int64:argv) {
    pass execvpe(name, argv, environ);
};

// ════════════════════════════════════════════════════════════════════════════
// execvpe — execvp with explicit envp (GNU extension).
// ════════════════════════════════════════════════════════════════════════════

pub func:execvpe = int64(int64:name, int64:argv, int64:envp) {
    if (name == 0i64 || argv == 0i64) {
        drop(errno_set(EINVAL));
        pass -1i64;
    }

    int64:name_len = raw str_strlen(name);
    if (name_len == 0i64) {
        drop(errno_set(ENOENT));
        pass -1i64;
    }

      // If name contains '/', use directly — no PATH search
    int64:i = 0i64;
    uint8->:np = @cast_unchecked<uint8->>(name);
    while (i < name_len) {
        if (np[i] == 47u8) {    // '/'
            pass execve(name, argv, envp);
        }
        i = i + 1i64;
    }

    int64:path_key = @cast_unchecked<int64>(@"PATH");
    int64:default_path = @cast_unchecked<int64>(@"/usr/local/bin:/usr/bin:/bin");
      // Search PATH environment variable
    int64:path_str = raw proc_getenv_from(envp, path_key);
    if (path_str == 0i64) {
          // No PATH → try /usr/local/bin:/usr/bin:/bin
        path_str = default_path;
    }

      // Iterate PATH directories separated by ':'
    stack uint8[4096]:candidate;
    uint8->:pp = @cast_unchecked<uint8->>(path_str);
    int64:p_start = 0i64;
    int64:p_len = raw str_strlen(path_str);
    int64:last_err = ENOENT;

    while (p_start <= p_len) {
          // Find next ':' or end of string
        int64:p_end = p_start;
        while (p_end < p_len && pp[p_end] != 58u8) {    // ':'
            p_end = p_end + 1i64;
        }

        int64:dir_len = p_end - p_start;
          // Build: dir + "/" + name + NUL
        int64:total = dir_len + 1i64 + name_len + 1i64;
        if (total <= 4096i64) {
            if (dir_len > 0i64) {
                int64:ci = 0i64;
                while (ci < dir_len) {
                    candidate[ci] = pp[p_start + ci];
                    ci = ci + 1i64;
                }
                candidate[dir_len] = 47u8;    // '/'
            } else {
                  // Empty PATH component means current directory (".")
                candidate[0] = 46u8;    // '.'
                candidate[1] = 47u8;    // '/'
                dir_len = 1i64;
            }
            int64:ni = 0i64;
            while (ni < name_len) {
                candidate[dir_len + 1i64 + ni] = np[ni];
                ni = ni + 1i64;
            }
            candidate[dir_len + 1i64 + name_len] = 0u8;

              // Try to exec
            int64:ret = raw execve(@cast_unchecked<int64>(@candidate), argv, envp);
              // If we get here, exec failed
            int64:e = raw libn_errno_get();
            if (e != ENOENT && e != EACCES) {
                  // A real error (not "not found" or "permission denied") — stop
                pass ret;
            }
            last_err = e;
        }

        if (p_end >= p_len) { break; }
        p_start = p_end + 1i64;
    }

    drop(errno_set(last_err));
    pass -1i64;
};

// ════════════════════════════════════════════════════════════════════════════
// proc_getenv_from — Look up a key in a custom envp array.
// Returns pointer to the value part ("KEY=VALUE" → pointer to "VALUE"),
// or 0 if not found.
// Internal helper for execvpe. Also exported for use by env.npk.
// ════════════════════════════════════════════════════════════════════════════

pub func:proc_getenv_from = int64(int64:envp, int64:key) {
    if (envp == 0i64 || key == 0i64) { pass 0i64; }
    int64:klen = raw str_strlen(key);
    int64->:ep = @cast_unchecked<int64->>(envp);
    int64:i = 0i64;
    while (ep[i] != 0i64) {
        int64:entry = ep[i];
        uint8->:ep_str = @cast_unchecked<uint8->>(entry);
          // Check if entry starts with "KEY="
        int64:j = 0i64;
        uint8->:kp = @cast_unchecked<uint8->>(key);
        bool:match = true;
        while (j < klen) {
            if (ep_str[j] != kp[j]) { match = false; break; }
            j = j + 1i64;
        }
        if (match && ep_str[klen] == 61u8) {    // '='
            pass entry + klen + 1i64;    // pointer past '='
        }
        i = i + 1i64;
    }
    pass 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// execl* — Inline argument list variants (explicit arity 0-8)
//
// Convention: execlN(path, arg0, arg1, ..., argN-1)
//   argv is built on the stack as {arg0, ..., argN-1, NULL}
//   path is always the executable.
//   The first argument is conventionally the executable name (arg0 = path).
// ════════════════════════════════════════════════════════════════════════════

pub func:execl0 = int64(int64:path) {
    stack int64[1]:argv;
    argv[0] = 0i64;
    pass execve(path, @cast_unchecked<int64>(@argv), environ);
};

pub func:execl1 = int64(int64:path, int64:a0) {
    stack int64[2]:argv;
    argv[0] = a0;
    argv[1] = 0i64;
    pass execve(path, @cast_unchecked<int64>(@argv), environ);
};

pub func:execl2 = int64(int64:path, int64:a0, int64:a1) {
    stack int64[3]:argv;
    argv[0] = a0; argv[1] = a1; argv[2] = 0i64;
    pass execve(path, @cast_unchecked<int64>(@argv), environ);
};

pub func:execl3 = int64(int64:path, int64:a0, int64:a1, int64:a2) {
    stack int64[4]:argv;
    argv[0] = a0; argv[1] = a1; argv[2] = a2; argv[3] = 0i64;
    pass execve(path, @cast_unchecked<int64>(@argv), environ);
};

pub func:execl4 = int64(int64:path, int64:a0, int64:a1, int64:a2, int64:a3) {
    stack int64[5]:argv;
    argv[0] = a0; argv[1] = a1; argv[2] = a2; argv[3] = a3; argv[4] = 0i64;
    pass execve(path, @cast_unchecked<int64>(@argv), environ);
};

pub func:execl5 = int64(int64:path, int64:a0, int64:a1, int64:a2,
                         int64:a3, int64:a4) {
    stack int64[6]:argv;
    argv[0] = a0; argv[1] = a1; argv[2] = a2;
    argv[3] = a3; argv[4] = a4; argv[5] = 0i64;
    pass execve(path, @cast_unchecked<int64>(@argv), environ);
};

pub func:execl6 = int64(int64:path, int64:a0, int64:a1, int64:a2,
                         int64:a3, int64:a4, int64:a5) {
    stack int64[7]:argv;
    argv[0] = a0; argv[1] = a1; argv[2] = a2;
    argv[3] = a3; argv[4] = a4; argv[5] = a5; argv[6] = 0i64;
    pass execve(path, @cast_unchecked<int64>(@argv), environ);
};

pub func:execl7 = int64(int64:path, int64:a0, int64:a1, int64:a2,
                         int64:a3, int64:a4, int64:a5, int64:a6) {
    stack int64[8]:argv;
    argv[0] = a0; argv[1] = a1; argv[2] = a2; argv[3] = a3;
    argv[4] = a4; argv[5] = a5; argv[6] = a6; argv[7] = 0i64;
    pass execve(path, @cast_unchecked<int64>(@argv), environ);
};

pub func:execl8 = int64(int64:path, int64:a0, int64:a1, int64:a2, int64:a3,
                         int64:a4, int64:a5, int64:a6, int64:a7) {
    stack int64[9]:argv;
    argv[0] = a0; argv[1] = a1; argv[2] = a2; argv[3] = a3;
    argv[4] = a4; argv[5] = a5; argv[6] = a6; argv[7] = a7; argv[8] = 0i64;
    pass execve(path, @cast_unchecked<int64>(@argv), environ);
};

// execlp* — Like execl* but search PATH (use execvp semantics)
pub func:execlp1 = int64(int64:name, int64:a0) {
    stack int64[2]:argv;
    argv[0] = a0; argv[1] = 0i64;
    pass execvp(name, @cast_unchecked<int64>(@argv));
};

pub func:execlp2 = int64(int64:name, int64:a0, int64:a1) {
    stack int64[3]:argv;
    argv[0] = a0; argv[1] = a1; argv[2] = 0i64;
    pass execvp(name, @cast_unchecked<int64>(@argv));
};

pub func:execlp3 = int64(int64:name, int64:a0, int64:a1, int64:a2) {
    stack int64[4]:argv;
    argv[0] = a0; argv[1] = a1; argv[2] = a2; argv[3] = 0i64;
    pass execvp(name, @cast_unchecked<int64>(@argv));
};

pub func:execlp4 = int64(int64:name, int64:a0, int64:a1, int64:a2, int64:a3) {
    stack int64[5]:argv;
    argv[0] = a0; argv[1] = a1; argv[2] = a2; argv[3] = a3; argv[4] = 0i64;
    pass execvp(name, @cast_unchecked<int64>(@argv));
};

// io.npk — Top-level I/O module re-export (v0.4.8)
//
// Import this file to get the complete I/O subsystem in one shot.
//
// Module hierarchy:
//   v0.4.1  write.npk  — io_write_n, io_write_str, io_write_char, io_print*
//   v0.4.2  read.npk   — io_read_n, io_read_some, io_read_line, io_read_char
//   v0.4.3  printf.npk — io_fprintf*, io_printf*, io_eprintf*, io_sprintf*,
//                         io_dprintf*, io_perror
//   v0.4.4  open.npk   — io_open, io_openat, io_creat, io_close, io_close_nointr,
//                         io_open_tmp, io_open_inheritable, MODE_FILE_DEFAULT, ...
//   v0.4.5  seek.npk   — io_seek, io_seek_cur, io_seek_end, io_tell,
//                         io_rewind, io_file_size, io_lseek
//   v0.4.6  dup.npk    — io_dup, io_dup_cloexec, io_dup2, io_dup3, io_redirect
//   v0.4.7  pipe.npk   — io_pipe, io_pipe_nonblock, io_pipe_raw,
//                         io_pipe_read_fd, io_pipe_write_fd, PIPE_BUF
//   v0.4.8  fcntl.npk  — io_set_nonblocking, io_set_blocking, io_is_nonblocking,
//                         io_set_cloexec, io_get_cloexec, io_set_append,
//                         io_dupfd, io_dupfd_cloexec, io_fcntl, ...
//
// File descriptor constants (from write.npk):
//   STDIN_FD  = 0
//   STDOUT_FD = 1
//   STDERR_FD = 2
//
// Future:
//   v0.4.9  ioctl.npk    — libn_ioctl wrappers (TIOCGWINSZ, FIONREAD, etc.)
//   v0.4.10 poll.npk     — io_poll, io_select wrappers
//   v0.4.11 strerror.npk — strerror() string table (errno → human-readable)

use "../io/write.npk".*;
use "../io/read.npk".*;
use "../io/printf.npk".*;
use "../io/open.npk".*;
use "../io/seek.npk".*;
use "../io/dup.npk".*;
use "../io/pipe.npk".*;
use "../io/fcntl.npk".*;
use "../syscall/syscall_numbers.npk".*;


// pipe.npk — Pipe and FIFO creation (v0.4.7)
//
// Pipes are the simplest form of IPC: an anonymous, unidirectional uint8 stream.
// Created by the @cast_unchecked<a>(kernel) (read_fd, write_fd) pair. Data written to write_fd
// can be read from read_fd. When all write ends are closed, read_fd returns EOF.
//
// Usage pattern:
//
//   stack int64[2]:fds;
//   io_pipe(@fds)?;
//   // fds[0] = read end, fds[1] = write end
//   // ... fork, exec, @cast_unchecked<needed>(redirect) ...
//   io_close(fds[0]);   // close the end you don't need in each process
//   io_close(fds[1]);
//
// Default flags: O_CLOEXEC is set on both fds. To pass a pipe end to a child
// process through exec(), use io_redirect() which clears O_CLOEXEC before exec.
//
// Pipe buffer:
//   Linux default pipe buffer: 65536 bytes (64 KiB).
//   Writes up to PIPE_BUF (4096 bytes) are atomic.
//   Writes larger than PIPE_BUF may be split and interleaved.

use "../syscall/errno.npk".*;
use "../syscall/posix_constants.npk".*;
use "../syscall/syscall.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// PIPE_BUF — Maximum atomic write size to a pipe.
// Writes up to this size will not be interleaved with writes from other processes.
// ════════════════════════════════════════════════════════════════════════════

pub fixed int64:PIPE_BUF = 4096i64;

// ════════════════════════════════════════════════════════════════════════════
// io_pipe — Create a pipe with O_CLOEXEC on both ends.
//
// Parameters:
//   fds: pointer to int64[2] — written with [read_fd, write_fd]
//        (fds must point to at least 16 bytes of writable memory)
//
// Returns Ok(0) on success.
// ════════════════════════════════════════════════════════════════════════════

pub func:io_pipe = int64(int64:fds) {
    if (fds == 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
      // O_CLOEXEC: both ends close on exec by default (correct default).
      // Use io_redirect() to clear O_CLOEXEC on a specific end before exec().
    pass libn_pipe2(fds, O_CLOEXEC);
};

// ════════════════════════════════════════════════════════════════════════════
// io_pipe_nonblock — Create a pipe with O_CLOEXEC and O_NONBLOCK on both ends.
//
// Both read and write ends will not block: reads return EAGAIN when the pipe
// is empty, writes return EAGAIN when the pipe buffer is full.
//
// Use for async I/O multiplexed via poll/epoll.
// ════════════════════════════════════════════════════════════════════════════

pub func:io_pipe_nonblock = int64(int64:fds) {
    if (fds == 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    pass libn_pipe2(fds, O_CLOEXEC | O_NONBLOCK);
};

// ════════════════════════════════════════════════════════════════════════════
// io_pipe_raw — Create a pipe without O_CLOEXEC (inherits across exec).
//
// Use ONLY when you explicitly need the pipe fd(s) to survive exec().
// Document why at the call site.
// ════════════════════════════════════════════════════════════════════════════

pub func:io_pipe_raw = int64(int64:fds) {
    if (fds == 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    pass libn_pipe2(fds, 0i64);
};

// ════════════════════════════════════════════════════════════════════════════
// io_pipe_read_fd / io_pipe_write_fd — Extract individual ends from fds array.
//
// Convenience accessors so callers don't have to remember which index
// is which (avoids bugs from swapping read/write ends).
// ════════════════════════════════════════════════════════════════════════════

pub func:io_pipe_read_fd = int64(int64:fds) {
    pass (@cast_unchecked<int64->>(fds))[0];
};

pub func:io_pipe_write_fd = int64(int64:fds) {
    pass (@cast_unchecked<int64->>(fds))[1];
};

// ════════════════════════════════════════════════════════════════════════════
// io_socketpair_pipe — Create a socket-backed bidirectional pipe.
//
// Not yet implemented — requires the net/ subsystem (v0.25.x).
// Placeholder for API surface consistency.
// ════════════════════════════════════════════════════════════════════════════

// pub func:io_socketpair = int64(int64:fds) { ... }   // v0.25.x

// fcntl.npk — File control operations and non-blocking I/O (v0.4.8)
//
// fcntl() is the Swiss-army knife of fd attribute manipulation. This module
// provides named wrappers for the most common fcntl operations rather than
// requiring callers to remember the F_* command constants.
//
// Covered here:
//   - Status flags: get/set O_NONBLOCK, O_APPEND, O_ASYNC
//   - Descriptor flags: get/set FD_CLOEXEC
//   - Fd duplication with minimum fd number (F_DUPFD / F_DUPFD_CLOEXEC)
//   - Signal-driven I/O ownership: F_SETOWN / F_GETOWN (basis for SIGIO)
//
// NOT covered here (deferred):
//   - Record locking (F_GETLK/F_SETLK/F_SETLKW) — see src/io/lock.npk (v0.57.x)
//   - OFD locks (F_OFD_GETLK etc.) — same module
//   - F_SEAL* / memfd sealing — see src/mem/ (v0.38.x)
//   - F_ADD_SEALS / F_GET_SEALS — same

use "../syscall/errno.npk".*;
use "../syscall/posix_constants.npk".*;
use "../syscall/syscall.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// Descriptor flags (FD_* — per-fd, not per-open-file-description)
// These are NOT shared between dup'd fds.
// ════════════════════════════════════════════════════════════════════════════

// io_get_cloexec — Return true if FD_CLOEXEC is set on fd.
pub func:io_get_cloexec = bool(int64:fd) {
    if (fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    Result<int64>:r = libn_fcntl(fd, F_GETFD, 0i64);
    if (r.is_error) {
        fail r.error;
    }
    pass (r.value & FD_CLOEXEC) != 0i64;
};

// io_set_cloexec — Set or clear FD_CLOEXEC on fd.
//
// enable=true:  fd is closed when this process calls exec*()
// enable=false: fd survives exec*() (inheritable — use deliberately)
pub func:io_set_cloexec = int64(int64:fd, bool:enable) {
    if (fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    Result<int64>:r = libn_fcntl(fd, F_GETFD, 0i64);
    if (r.is_error) {
        fail r.error;
    }
    int64:flags = r.value;
    if (enable) {
        flags = flags | FD_CLOEXEC;
    } else {
        flags = flags & (0i64 - 1i64 ^ FD_CLOEXEC);
    }
    pass libn_fcntl(fd, F_SETFD, flags);
};

// ════════════════════════════════════════════════════════════════════════════
// Status flags (O_* — per-open-file-description, shared between dup'd fds)
// These are shared between all fds that refer to the same open file description.
// ════════════════════════════════════════════════════════════════════════════

// io_get_status_flags — Return the current O_* status flags for fd.
//
// Useful for querying: O_RDONLY/O_WRONLY/O_RDWR, O_NONBLOCK, O_APPEND,
// O_ASYNC, O_DIRECT, O_SYNC, etc.
pub func:io_get_status_flags = int64(int64:fd) {
    if (fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    pass libn_fcntl(fd, F_GETFL, 0i64);
};

// io_set_status_flags — Set the O_* status flags for fd.
//
// Note: O_RDONLY/O_WRONLY/O_RDWR, O_CREAT, O_TRUNC, O_EXCL cannot be changed
// after open — only O_NONBLOCK, O_APPEND, O_ASYNC, O_DIRECT, O_NOATIME can.
pub func:io_set_status_flags = int64(int64:fd, int64:flags) {
    if (fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    pass libn_fcntl(fd, F_SETFL, flags);
};

// ════════════════════════════════════════════════════════════════════════════
// Non-blocking I/O control
//
// Non-blocking fds return EAGAIN/EWOULDBLOCK immediately if an I/O operation
// would block (e.g., read from empty pipe, write to full pipe, accept when
// no connection is pending). Used with poll/epoll for async I/O.
// ════════════════════════════════════════════════════════════════════════════

// io_set_nonblocking — Enable O_NONBLOCK on fd.
pub func:io_set_nonblocking = int64(int64:fd) {
    if (fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    Result<int64>:r = libn_fcntl(fd, F_GETFL, 0i64);
    if (r.is_error) { fail r.error; }
    pass libn_fcntl(fd, F_SETFL, r.value | O_NONBLOCK);
};

// io_set_blocking — Remove O_NONBLOCK from fd (restore blocking mode).
pub func:io_set_blocking = int64(int64:fd) {
    if (fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    Result<int64>:r = libn_fcntl(fd, F_GETFL, 0i64);
    if (r.is_error) { fail r.error; }
    pass libn_fcntl(fd, F_SETFL, r.value & (0i64 - 1i64 ^ O_NONBLOCK));
};

// io_is_nonblocking — Return true if fd is in non-blocking mode.
pub func:io_is_nonblocking = bool(int64:fd) {
    if (fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    Result<int64>:r = libn_fcntl(fd, F_GETFL, 0i64);
    if (r.is_error) { fail r.error; }
    pass (r.value & O_NONBLOCK) != 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// Append mode control
// ════════════════════════════════════════════════════════════════════════════

// io_set_append — Enable O_APPEND on fd (all writes go to end of file atomically).
pub func:io_set_append = int64(int64:fd) {
    if (fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    Result<int64>:r = libn_fcntl(fd, F_GETFL, 0i64);
    if (r.is_error) { fail r.error; }
    pass libn_fcntl(fd, F_SETFL, r.value | O_APPEND);
};

// io_clear_append — Remove O_APPEND from fd.
pub func:io_clear_append = int64(int64:fd) {
    if (fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    Result<int64>:r = libn_fcntl(fd, F_GETFL, 0i64);
    if (r.is_error) { fail r.error; }
    pass libn_fcntl(fd, F_SETFL, r.value & (0i64 - 1i64 ^ O_APPEND));
};

// ════════════════════════════════════════════════════════════════════════════
// Fd duplication with minimum fd number
//
// These are useful for ensuring a dup'd fd lands at or above a specific
// number, e.g., to avoid stomping on stdin/stdout/stderr (0/1/2).
// ════════════════════════════════════════════════════════════════════════════

// io_dupfd — Duplicate fd to the lowest available fd number >= min_fd.
//
// The resulting fd does NOT have O_CLOEXEC.
// Use io_dupfd_cloexec() to get a close-on-exec duplicate.
pub func:io_dupfd = int64(int64:fd, int64:min_fd) {
    if (fd < 0i64 || min_fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    pass libn_fcntl(fd, F_DUPFD, min_fd);
};

// io_dupfd_cloexec — Duplicate fd to lowest fd >= min_fd with O_CLOEXEC.
pub func:io_dupfd_cloexec = int64(int64:fd, int64:min_fd) {
    if (fd < 0i64 || min_fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    pass libn_fcntl(fd, F_DUPFD_CLOEXEC, min_fd);
};

// ════════════════════════════════════════════════════════════════════════════
// Signal-driven I/O
//
// F_SETOWN sets the process or process group that will receive SIGIO and
// SIGURG signals when async I/O is ready on fd. F_GETOWN queries the owner.
// ════════════════════════════════════════════════════════════════════════════

// io_fcntl_setown — Set the owner PID/PGID for SIGIO/SIGURG on fd.
//
// pid > 0: send SIGIO to process pid
// pid < 0: send SIGIO to process group (-pid)
pub func:io_fcntl_setown = int64(int64:fd, int64:pid) {
    if (fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    pass libn_fcntl(fd, F_SETOWN, pid);
};

// io_fcntl_getown — Get the owner PID/PGID for SIGIO/SIGURG on fd.
pub func:io_fcntl_getown = int64(int64:fd) {
    if (fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    pass libn_fcntl(fd, F_GETOWN, 0i64);
};

// ════════════════════════════════════════════════════════════════════════════
// io_fcntl — Raw fcntl escape hatch for operations not covered above.
//
// Use this only for F_* commands not wrapped by the above functions.
// Examples: F_SEAL_*, F_ADD_SEALS, F_GET_PIPE_SZ, F_SET_PIPE_SZ.
// ════════════════════════════════════════════════════════════════════════════

pub func:io_fcntl = int64(int64:fd, int64:cmd, int64:arg) {
    if (fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    pass libn_fcntl(fd, cmd, arg);
};

// dup.npk — File descriptor duplication: dup, dup2, dup3, dup_cloexec (v0.4.6)
//
// Fd duplication is used in three main scenarios:
//
//   1. Shell-style stdin/stdout/stderr redirection before exec:
//      io_dup2(file_fd, STDIN_FD)   — redirect stdin to a file
//      io_dup2(pipe_fd[1], STDOUT_FD) — redirect stdout to a pipe
//
//   2. Saving and restoring file descriptors across temporary redirections:
//      int64:saved_stdout = io_dup(STDOUT_FD)  — save original stdout
//      io_dup2(log_fd, STDOUT_FD)              — redirect stdout
//      ... do work ...
//      io_dup2(saved_stdout, STDOUT_FD)        — restore
//      io_close(saved_stdout)
//
//   3. Creating aliased fds for concurrent access or passing to library APIs.
//
// The new fd returned by io_dup/io_dup2/io_dup3 shares:
//   - The same open file description (position, flags, underlying file)
//   - NOT a new open: writes on one fd affect the position of the other
//
// Always use io_dup_cloexec() instead of io_dup() when the dup'd fd will
// NOT be passed to a child process — it avoids O_CLOEXEC hygiene issues.

use "../syscall/errno.npk".*;
use "../syscall/posix_constants.npk".*;
use "../syscall/syscall.npk".*;
use "../io/write.npk".*;     // STDIN_FD, STDOUT_FD, STDERR_FD

// ════════════════════════════════════════════════════════════════════════════
// io_dup — Duplicate fd to the lowest available fd number.
//
// The new fd does NOT have O_CLOEXEC set (inherits across exec by default).
// Prefer io_dup_cloexec() unless you need an inheritable duplicate.
//
// Returns the new fd on success.
// ════════════════════════════════════════════════════════════════════════════

pub func:io_dup = int64(int64:fd) {
    if (fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    pass libn_dup(fd);
};

// ════════════════════════════════════════════════════════════════════════════
// io_dup_cloexec — Duplicate fd with O_CLOEXEC set on the new fd.
//
// Use this in preference to io_dup() unless the new fd must be inherited
// by a child process. This is implemented with F_DUPFD_CLOEXEC.
// ════════════════════════════════════════════════════════════════════════════

pub func:io_dup_cloexec = int64(int64:fd) {
    if (fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
      // F_DUPFD_CLOEXEC: find the lowest fd >= 0 and set O_CLOEXEC atomically
    pass libn_fcntl(fd, F_DUPFD_CLOEXEC, 0i64);
};

// ════════════════════════════════════════════════════════════════════════════
// io_dup2 — Duplicate fd onto newfd.
//
// If newfd is already open, it is closed first (atomically).
// If fd == newfd, no operation is performed (POSIX: return newfd unchanged).
//
// NOTE: The resulting fd does NOT have O_CLOEXEC set, regardless of fd's flags.
// For redirecting stdin/stdout/stderr before exec() this is correct behavior
// (you WANT those fds to survive exec). For any other use, prefer io_dup3()
// with O_CLOEXEC.
//
// Returns newfd on success.
// ════════════════════════════════════════════════════════════════════════════

pub func:io_dup2 = int64(int64:fd, int64:newfd) {
    if (fd < 0i64 || newfd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    if (fd == newfd) {
          // Already the same fd — validate fd is open by probing with F_GETFD
        Result<int64>:chk = libn_fcntl(fd, F_GETFD, 0i64);
        if (chk.is_error) {
            fail chk.error;
        }
        pass newfd;
    }
    pass libn_dup2(fd, newfd);
};

// ════════════════════════════════════════════════════════════════════════════
// io_dup3 — Duplicate fd onto newfd with explicit flags.
//
// flags: O_CLOEXEC (the only flag currently accepted by the Linux kernel).
//        Pass 0 for no flags (same @cast_unchecked<dup2>(behavior), but fd must != newfd).
//
// fd and newfd must be different — if fd == newfd, the kernel returns EINVAL.
// (This differs from dup2 which silently returns newfd in that case.)
// ════════════════════════════════════════════════════════════════════════════

pub func:io_dup3 = int64(int64:fd, int64:newfd, int64:flags) {
    if (fd < 0i64 || newfd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    if (fd == newfd) {
        fail @cast_unchecked<tbb32>(EINVAL);
    }
    pass libn_dup3(fd, newfd, flags);
};

// ════════════════════════════════════════════════════════════════════════════
// io_redirect — Redirect src_fd onto target_fd (stdin/stdout/stderr pattern).
//
// This is the standard "open file, dup2 to std fd, close original" idiom.
// After this call:
//   - target_fd refers to the same @cast_unchecked<src_fd>(file)
//   - src_fd is closed
//   - target_fd does NOT have O_CLOEXEC (correct for std fd inheritance)
//
// Typical use before exec():
//   io_redirect(pipe_read_end,  STDIN_FD)   — stdin from pipe
//   io_redirect(pipe_write_end, STDOUT_FD)  — stdout to pipe
//   io_redirect(log_fd,         STDERR_FD)  — stderr to log file
//
// Returns Ok(target_fd) on success.
// ════════════════════════════════════════════════════════════════════════════

pub func:io_redirect = int64(int64:src_fd, int64:target_fd) {
    if (src_fd < 0i64 || target_fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }

      // If they're already the same, just clear O_CLOEXEC if it's set
      // (so the fd survives exec), then we're done.
    if (src_fd == target_fd) {
        drop(libn_fcntl(target_fd, F_SETFD, 0i64));    // clear FD_CLOEXEC
        pass target_fd;
    }

      // dup2: atomically close target_fd (if open) and point it at src_fd
    Result<int64>:r = libn_dup2(src_fd, target_fd);
    if (r.is_error) {
        fail r.error;
    }

      // Close the original src_fd — target_fd is now the live handle
      // Ignore close errors here — the dup2 succeeded, don't obscure that.
    drop(libn_close(src_fd));

    pass target_fd;
};

// seek.npk — File seek operations: lseek, io_tell, io_rewind (v0.4.5)
//
// Provides the seek/position layer for libn file descriptors.
//
// POSIX lseek:
//   SEEK_SET — seek to absolute position (offset from start of file)
//   SEEK_CUR — seek relative to current position (offset can be 0 to query pos)
//   SEEK_END — seek relative to end of file (use negative offset to seek backward)
//   SEEK_DATA — seek to next data region in a sparse file (Linux extension)
//   SEEK_HOLE — seek to next hole in a sparse file (Linux extension)
//
// All return the new absolute file offset from the beginning of the file,
// or Err on failure.

use "../syscall/errno.npk".*;
use "../syscall/posix_constants.npk".*;
use "../syscall/syscall.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// io_seek — Seek to absolute position (SEEK_SET).
//
// The most common seek: go to a specific uint8 offset from the start of file.
// Returns the new file position on success.
// ════════════════════════════════════════════════════════════════════════════

pub func:io_seek = int64(int64:fd, int64:offset) {
    if (fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    pass libn_lseek(fd, offset, SEEK_SET);
};

// ════════════════════════════════════════════════════════════════════════════
// io_seek_cur — Seek relative to current position.
//
// A positive offset moves forward; a negative offset moves backward.
// An offset of 0 returns the current position without moving (see io_tell).
// ════════════════════════════════════════════════════════════════════════════

pub func:io_seek_cur = int64(int64:fd, int64:offset) {
    if (fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    pass libn_lseek(fd, offset, SEEK_CUR);
};

// ════════════════════════════════════════════════════════════════════════════
// io_seek_end — Seek relative to end of file.
//
// Typically used with a negative or zero offset:
//   io_seek_end(fd, 0)  — position at end-of-file
//   io_seek_end(fd, -4) — 4 bytes before end
// Positive offsets create a "hole" beyond the end (sparse file).
// ════════════════════════════════════════════════════════════════════════════

pub func:io_seek_end = int64(int64:fd, int64:offset) {
    if (fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    pass libn_lseek(fd, offset, SEEK_END);
};

// ════════════════════════════════════════════════════════════════════════════
// io_tell — Return the current file position without moving it.
//
// Equivalent to lseek(fd, 0, SEEK_CUR).
// Returns the current uint8 offset from the beginning of the file.
// ════════════════════════════════════════════════════════════════════════════

pub func:io_tell = int64(int64:fd) {
    if (fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    pass libn_lseek(fd, 0i64, SEEK_CUR);
};

// ════════════════════════════════════════════════════════════════════════════
// io_rewind — Seek to the beginning of the file (offset 0 from start).
//
// Never fails except for invalid fd. Returns 0 (new position) on success.
// ════════════════════════════════════════════════════════════════════════════

pub func:io_rewind = int64(int64:fd) {
    if (fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    pass libn_lseek(fd, 0i64, SEEK_SET);
};

// ════════════════════════════════════════════════════════════════════════════
// io_file_size — Return the size of an open file in bytes.
//
// Implemented by seeking to the end and then restoring the original position.
// This is a portable way to get the file size without stat().
//
// Note: the returned size is the size at the moment of the call. For files
// being written concurrently, use statx() instead for an atomic size query.
// ════════════════════════════════════════════════════════════════════════════

pub func:io_file_size = int64(int64:fd) {
    if (fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }

      // Save current position
    Result<int64>:saved = libn_lseek(fd, 0i64, SEEK_CUR);
    if (saved.is_error) {
        fail saved.error;
    }

      // Seek to end
    Result<int64>:end_pos = libn_lseek(fd, 0i64, SEEK_END);
    if (end_pos.is_error) {
          // Best effort: try to restore, but return the end error
        drop(libn_lseek(fd, saved.value, SEEK_SET));
        fail end_pos.error;
    }

      // Restore original position
    Result<int64>:restore = libn_lseek(fd, saved.value, SEEK_SET);
    if (restore.is_error) {
          // Position is now at the end, not restored — but we got the size
          // Log-worthy but not fatal; return the size
        pass end_pos.value;
    }

    pass end_pos.value;
};

// ════════════════════════════════════════════════════════════════════════════
// io_lseek — Raw lseek with explicit whence argument.
//
// Use this when you need SEEK_DATA or SEEK_HOLE, or when you want to
// be explicit about the whence argument in a context where a named variant
// would obscure intent.
// ════════════════════════════════════════════════════════════════════════════

pub func:io_lseek = int64(int64:fd, int64:offset, int64:whence) {
    if (fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    if (whence < SEEK_SET || whence > SEEK_HOLE) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    pass libn_lseek(fd, offset, whence);
};

// read.npk — Raw fd-level read primitives (v0.4.2)
//
// Fd-level reads: blocking exact reads, non-blocking single reads, line reads.
//
// Design:
//   - io_read_n:      blocking — retries until exactly n bytes read or EOF/error.
//   - io_read_some:   non-blocking single call — returns however many bytes the
//                     kernel gave us (may be < n).
//   - io_read_line:   reads bytes one-at-a-time until LF, NUL, or EOF.
//                     Strips trailing CR (for CRLF streams). NUL-terminates.
//   - io_read_exact:  alias for io_read_n (name matches POSIX convention for
//                     "read exactly n bytes or fail").
//   - io_read_until:  reads until a delimiter uint8, buffer-fills return, or EOF.
//
// Error codes:
//   ERR_EOF     — clean EOF (0 bytes read when bytes expected)
//   ERR_BADARG  — NULL buf / negative n / bad fd
//   EAGAIN      — io_read_some on non-blocking fd with no data
//   Other errno — kernel error propagated directly

use "../syscall/errno.npk".*;
use "../syscall/syscall.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// io_read_some — Single read(2) call, returns however many bytes were read.
//
// For blocking fds: may return less than n (partial read is valid).
// For non-blocking fds: returns Err(EAGAIN) when no data available.
//
// Returns:
//   Ok(k)       — k bytes written into buf (0 < k ≤ n)
//   Ok(0)       — EOF (fd closed on remote end)
//   Err(EAGAIN) — non-blocking fd, no data available
//   Err(e)      — kernel error
// ════════════════════════════════════════════════════════════════════════════

pub func:io_read_some = int64(int64:fd, int64:buf, int64:n) {
    if (fd < 0i64 || buf == 0i64 || n <= 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }

    Result<int64>:r = libn_read(fd, buf, n);
    if (r.is_error) {
        fail r.error;
    }
    pass r.value;
};

// ════════════════════════════════════════════════════════════════════════════
// io_read_n — Blocking: read exactly n bytes into buf.
//
// Retries on EINTR and partial reads until all n bytes are in buf or a
// genuine error occurs. EOF mid-read is @cast_unchecked<an>(treated) error (ERR_EOF).
//
// Parameters:
//   fd:  file descriptor
//   buf: destination buffer (must have room for at least n bytes)
//   n:   exact number of bytes to read
//
// Returns:
//   Ok(n)       — exactly n bytes read
//   Err(ERR_EOF)— EOF before n bytes were available
//   Err(e)      — I/O error
// ════════════════════════════════════════════════════════════════════════════

pub func:io_read_n = int64(int64:fd, int64:buf, int64:n) {
    if (fd < 0i64 || buf == 0i64 || n < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    if (n == 0i64) {
        pass 0i64;
    }

    int64:total = 0i64;

    while (total < n) {
        int64:remaining = n - total;
        Result<int64>:r = libn_read(fd, buf + total, remaining);

        if (r.is_error) {
            int64:e = @cast_unchecked<int64>(r.error);
            if (e == EINTR) {
                continue;
            }
            fail r.error;
        }

        if (r.value == 0i64) {
              // EOF before we got all n bytes
            fail @cast_unchecked<tbb32>(ERR_EOF);
        }

        total = total + r.value;
    }

    pass total;
};

// ════════════════════════════════════════════════════════════════════════════
// io_read_exact — Alias for io_read_n (explicit naming convention).
// ════════════════════════════════════════════════════════════════════════════

pub func:io_read_exact = int64(int64:fd, int64:buf, int64:n) {
    pass io_read_n(fd, buf, n);
};

// ════════════════════════════════════════════════════════════════════════════
// io_read_line — Read a line from fd into buf, up to buf_size-1 bytes.
//
// Reads one uint8 at a time until:
//   - '\n' is encountered (LF consumed, not stored in buf)
//   - buf_size-1 bytes have been read (line truncated)
//   - EOF (returns what was read, even if no LF seen)
//   - Read error
//
// CRLF handling: if the last stored uint8 before LF is CR ('\r'), the CR
// is removed from the output. This makes the function transparent for both
// Unix (LF-only) and Windows/Telnet (CRLF) line endings.
//
// Always NUL-terminates buf (even on truncation or EOF).
//
// Parameters:
//   fd:       file descriptor
//   buf:      destination buffer
//   buf_size: total size of buf (including NUL terminator slot)
//
// Returns:
//   Ok(k)        — k bytes stored in buf (not counting NUL), line complete
//   Ok(0)        — EOF with no bytes read (clean EOF)
//   Err(ERR_EOF) — EOF after some bytes (partial line) — buf is still valid
//   Err(e)       — I/O error
// ════════════════════════════════════════════════════════════════════════════

pub func:io_read_line = int64(int64:fd, int64:buf, int64:buf_size) {
    if (fd < 0i64 || buf == 0i64 || buf_size <= 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }

    uint8->:dst = @cast_unchecked<uint8->>(buf);
    int64:count = 0i64;
    int64:max_store = buf_size - 1i64;    // leave room for NUL
    stack uint8[1]:one;
    one[0] = 0u8;

    while (count < max_store) {
        Result<int64>:r = libn_read(fd, @cast_unchecked<int64>(@one), 1i64);

        if (r.is_error) {
            int64:e = @cast_unchecked<int64>(r.error);
            if (e == EINTR) { continue; }
              // Store NUL then propagate error
            dst[count] = 0u8;
            fail r.error;
        }

        if (r.value == 0i64) {
              // EOF
            dst[count] = 0u8;
            if (count == 0i64) {
                pass 0i64;     // clean EOF, nothing read
            }
              // Partial line at EOF — still useful, return count
              // (caller distinguishes via checking for '\n' at end if they care)
            pass count;
        }

        uint8:c = one[0];

        if (c == 10u8) {    // '\n'
              // Strip trailing CR if present (CRLF → LF)
            if (count > 0i64 && dst[count - 1i64] == 13u8) {    // '\r'
                count = count - 1i64;
            }
            dst[count] = 0u8;
            pass count;
        }

        dst[count] = c;
        count = count + 1i64;
    }

      // Buffer full — NUL-terminate and return truncated result
    dst[count] = 0u8;
    pass count;
};

// ════════════════════════════════════════════════════════════════════════════
// io_read_until — Read until delimiter uint8, buffer full, or EOF.
//
// Like io_read_line but for arbitrary delimiters (e.g., '\0', '>', '\t').
// The delimiter uint8 is consumed but NOT stored in buf.
// Always NUL-terminates buf.
//
// Returns:
//   Ok(k)        — k bytes read, delimiter reached
//   Ok(0)        — EOF with 0 bytes
//   Err(ERR_EOF) — EOF reached before delimiter, partial content in buf
//   Err(e)       — I/O error
// ════════════════════════════════════════════════════════════════════════════

pub func:io_read_until = int64(int64:fd, int64:buf, int64:buf_size, uint8:delim) {
    if (fd < 0i64 || buf == 0i64 || buf_size <= 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }

    uint8->:dst = @cast_unchecked<uint8->>(buf);
    int64:count = 0i64;
    int64:max_store = buf_size - 1i64;
    stack uint8[1]:one;
    one[0] = 0u8;

    while (count < max_store) {
        Result<int64>:r = libn_read(fd, @cast_unchecked<int64>(@one), 1i64);

        if (r.is_error) {
            int64:e = @cast_unchecked<int64>(r.error);
            if (e == EINTR) { continue; }
            dst[count] = 0u8;
            fail r.error;
        }

        if (r.value == 0i64) {
            dst[count] = 0u8;
            if (count == 0i64) { pass 0i64; }
            pass count;
        }

        uint8:c = one[0];

        if (c == delim) {
            dst[count] = 0u8;
            pass count;
        }

        dst[count] = c;
        count = count + 1i64;
    }

    dst[count] = 0u8;
    pass count;
};

// ════════════════════════════════════════════════════════════════════════════
// io_read_char — Read a single uint8 from fd.
//
// Returns:
//   Ok(byte_value_as_int64)  — uint8 read (0–255)
//   Ok(-1)                   — EOF
//   Err(e)                   — error
// ════════════════════════════════════════════════════════════════════════════

pub func:io_read_char = int64(int64:fd) {
    if (fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }

    stack uint8[1]:b;
    b[0] = 0u8;

    while (true) {
        Result<int64>:r = libn_read(fd, @cast_unchecked<int64>(@b), 1i64);
        if (r.is_error) {
            int64:e = @cast_unchecked<int64>(r.error);
            if (e == EINTR) { continue; }
            fail r.error;
        }
        if (r.value == 0i64) {
            pass -1i64;     // EOF sentinel, like getchar() returning EOF
        }
        pass @cast_unchecked<int64>(b[0]);
    }

      // unreachable
    fail @cast_unchecked<tbb32>(ERR_BADARG);
};

// write.npk — Raw fd-level write primitives (v0.4.1)
//
// These are the lowest-level write operations in libn. Everything higher
// (printf, bio, logging) builds on these.
//
// Design:
//   - All writes go through the kernel write(2) syscall directly.
//   - No buffering at this layer — buffering lives in bio/ (v0.6.x).
//   - Partial-write retry loop: POSIX allows write(2) to return fewer bytes
//     than requested (EINTR, signal delivery, pipe limits). We retry until
//     all bytes are written or a genuine error occurs.
//   - EINTR is transparently retried.
//   - Non-blocking fds: EAGAIN/EWOULDBLOCK returns the bytes-written-so-far
//     count in an Err result so callers can drain and retry.
//
// Standard file descriptors:
//   STDOUT_FD = 1
//   STDERR_FD = 2
//
// All functions return Result<int64> where .value is bytes written.

use "../syscall/errno.npk".*;
use "../syscall/syscall.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// Standard fd constants
// ════════════════════════════════════════════════════════════════════════════

pub fixed int64:STDIN_FD  = 0i64;
pub fixed int64:STDOUT_FD = 1i64;
pub fixed int64:STDERR_FD = 2i64;

// ════════════════════════════════════════════════════════════════════════════
// io_write_n — Write exactly n bytes from buf to fd, retrying on EINTR.
//
// This is the canonical low-level write. It loops until all n bytes are
// sent or a genuine error (not EINTR) occurs.
//
// Parameters:
//   fd:  file descriptor to write to
//   buf: pointer to uint8 data
//   n:   number of bytes to write
//
// Returns:
//   Ok(n)        — all n bytes written successfully
//   Err(EAGAIN)  — fd is non-blocking and would block; partial bytes written
//                  are not tracked (caller must handle non-blocking separately)
//   Err(e)       — write error
//
// For non-blocking fds, prefer io_write_nonblock which returns partial counts.
// ════════════════════════════════════════════════════════════════════════════

pub func:io_write_n = int64(int64:fd, int64:buf, int64:n) {
    if (fd < 0i64 || buf == 0i64 || n < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    if (n == 0i64) {
        pass 0i64;
    }

    int64:total = 0i64;

    while (total < n) {
        int64:remaining = n - total;
        Result<int64>:r = libn_write(fd, buf + total, remaining);

        if (r.is_error) {
            int64:e = @cast_unchecked<int64>(r.error);
              // EINTR: interrupted by signal — retry transparently
            if (e == EINTR) {
                continue;
            }
              // Any other error: return what we've written so far plus the error
            fail r.error;
        } else {
            if (r.value == 0i64) {
              // Wrote 0 bytes without error — @cast_unchecked<pipe>(treat)/fd closed
                fail @cast_unchecked<tbb32>(ERR_EOF);
            }
            total = total + r.value;
        }
    }

    pass total;
};

// ════════════════════════════════════════════════════════════════════════════
// io_write_nonblock — Write up to n bytes, returning actual bytes written.
//
// Unlike io_write_n, this does NOT retry on partial writes or EAGAIN.
// It makes exactly one write(2) call and returns the result.
// Used for non-blocking fds (sockets, pipes, ttys in non-blocking mode).
//
// Returns:
//   Ok(k)         — k bytes were written (0 ≤ k ≤ n)
//   Err(EAGAIN)   — fd would block, 0 bytes written
//   Err(e)        — error
// ════════════════════════════════════════════════════════════════════════════

pub func:io_write_nonblock = int64(int64:fd, int64:buf, int64:n) {
    if (fd < 0i64 || buf == 0i64 || n < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    if (n == 0i64) {
        pass 0i64;
    }

    Result<int64>:r = libn_write(fd, buf, n);
    if (r.is_error) {
        fail r.error;
    }
    pass r.value;
};

// ════════════════════════════════════════════════════════════════════════════
// io_write_str — Write a NUL-terminated string to fd.
//
// Computes strlen internally. For cases where you already have the length,
// use io_write_n directly to avoid the extra scan.
//
// Returns Ok(bytes_written) or Err.
// ════════════════════════════════════════════════════════════════════════════

pub func:io_write_str = int64(int64:fd, int64:s) {
    if (s == 0i64) {
        pass 0i64;
    }

      // Inline strlen to avoid circular dependency
    uint8->:p = @cast_unchecked<uint8->>(s);
    int64:len = 0i64;
    while (p[len] != 0u8) {
        len = len + 1i64;
    }

    pass io_write_n(fd, s, len);
};

// ════════════════════════════════════════════════════════════════════════════
// io_write_char — Write a single uint8 to fd.
// ════════════════════════════════════════════════════════════════════════════

pub func:io_write_char = int64(int64:fd, uint8:c) {
    stack uint8[1]:b;
    b[0] = c;
    pass io_write_n(fd, @cast_unchecked<int64>(@b), 1i64);
};

// ════════════════════════════════════════════════════════════════════════════
// io_write_cstr_n — Write exactly the first n bytes of a string (no strlen).
//
// For fixed-length fields where the NUL terminator must not be emitted.
// ════════════════════════════════════════════════════════════════════════════

pub func:io_write_cstr_n = int64(int64:fd, int64:s, int64:n) {
    pass io_write_n(fd, s, n);
};

// ════════════════════════════════════════════════════════════════════════════
// io_write_newline — Write a single LF to fd.
// ════════════════════════════════════════════════════════════════════════════

pub func:io_write_newline = int64(int64:fd) {
    pass io_write_char(fd, 10u8);    // '\n'
};

// ════════════════════════════════════════════════════════════════════════════
// io_write_strln — Write a NUL-terminated string followed by LF.
// ════════════════════════════════════════════════════════════════════════════

pub func:io_write_strln = int64(int64:fd, int64:s) {
    int64:r = raw io_write_str(fd, s);
    if (r < 0i64) { pass r; }
    int64:r2 = raw io_write_newline(fd);
    if (r2 < 0i64) { pass r2; }
    pass r + 1i64;
};

// ════════════════════════════════════════════════════════════════════════════
// Convenience: stdout / stderr shorthands
// ════════════════════════════════════════════════════════════════════════════

pub func:io_print = int64(int64:s) {
    pass io_write_str(STDOUT_FD, s);
};

pub func:io_println = int64(int64:s) {
    pass io_write_strln(STDOUT_FD, s);
};

pub func:io_eprint = int64(int64:s) {
    pass io_write_str(STDERR_FD, s);
};

pub func:io_eprintln = int64(int64:s) {
    pass io_write_strln(STDERR_FD, s);
};

// open.npk — File open, close, and creat operations (v0.4.4)
//
// This module provides the ergonomic open/close API for libn.
// All calls delegate to the syscall wrappers in syscall.npk, which in turn
// call the kernel. O_CLOEXEC is set by default on all new fds — see below.
//
// Safety model:
//   - O_CLOEXEC is added automatically to prevent fd leaks across exec().
//     This is the correct default for new code. If you deliberately need an
//     inheritable fd, use io_open_inheritable() and document why.
//   - Mode is only meaningful when O_CREAT or O_TMPFILE is in flags.
//     For opens without O_CREAT, pass MODE_DEFAULT (0i64).
//   - libn_close() checks for EIO and propagates it — callers must not ignore
//     the return value on close(). Data loss is possible on NFS/CIFS.
//
// Common flag combinations:
//   io_open(path, O_RDONLY,              0)          — read-only
//   io_open(path, O_WRONLY | O_CREAT | O_TRUNC, 0o644) — write, create/truncate
//   io_open(path, O_RDWR,                0)          — read-write
//   io_open(path, O_WRONLY | O_CREAT | O_APPEND, 0o644) — append
//   io_open(path, O_RDONLY | O_DIRECTORY, 0)         — directory fd

use "../syscall/errno.npk".*;
use "../syscall/posix_constants.npk".*;
use "../syscall/syscall.npk".*;
use "../syscall/syscall_numbers.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// Default mode for O_CREAT — rw-r--r-- (0644)
// Override by passing your own mode constant.
// ════════════════════════════════════════════════════════════════════════════

pub fixed int64:MODE_DEFAULT      = 0i64;
pub fixed int64:MODE_FILE_DEFAULT = 0o644i64;     // rw-r--r--
pub fixed int64:MODE_DIR_DEFAULT  = 0o755i64;     // rwxr-xr-x
pub fixed int64:MODE_SECRET       = 0o600i64;     // rw------- (keys, credentials)

// ════════════════════════════════════════════════════════════════════════════
// io_open — Open or create a file.
//
// Automatically adds O_CLOEXEC to flags (safe default for most programs).
//
// Parameters:
//   path:  NUL-terminated file path (as int64 pointer)
//   flags: O_RDONLY | O_WRONLY | O_RDWR | O_CREAT | O_TRUNC | O_APPEND ...
//          Do NOT include O_CLOEXEC; it's added automatically.
//   mode:  Permission bits (S_IRUSR etc.), masked by umask.
//          Only used when O_CREAT is set. Pass MODE_DEFAULT (0) otherwise.
//
// Returns: file descriptor (>= 0) on success, or Err on failure.
// ════════════════════════════════════════════════════════════════════════════

pub func:io_open = int64(int64:path, int64:flags, int64:mode) {
    if (path == 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    pass libn_open(path, flags, mode);
};

// io_open_inheritable — Open without O_CLOEXEC (fd survives exec).
//
// Use only when you deliberately need the child process to inherit this fd
// (e.g., when setting up stdin/stdout/stderr before exec). Document the call.
pub func:io_open_inheritable = int64(int64:path, int64:flags, int64:mode) {
    if (path == 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
      // libn_open adds O_CLOEXEC; we need to strip it for truly inheritable fds.
      // Use openat with AT_FDCWD instead to bypass the automatic flag.
    int64:safe_flags = flags & (0i64 - 1i64 ^ O_CLOEXEC);    // flags without O_CLOEXEC
    Result<int64>:r = sys_safe(SYS_OPEN, path, safe_flags, mode, 0i64, 0i64, 0i64);
    return r;
};

// ════════════════════════════════════════════════════════════════════════════
// io_openat — Open relative to a directory fd.
//
// Use AT_FDCWD for dirfd to open relative to the current working directory.
// This is preferred over io_open for security-sensitive code because it avoids
// TOCTOU races when working within a known directory fd.
// ════════════════════════════════════════════════════════════════════════════

pub func:io_openat = int64(int64:dirfd, int64:path, int64:flags, int64:mode) {
    if (path == 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    pass libn_openat(dirfd, path, flags, mode);
};

// ════════════════════════════════════════════════════════════════════════════
// io_creat — Create or truncate a file (shorthand).
//
// Equivalent to: io_open(path, O_WRONLY | O_CREAT | O_TRUNC, mode)
// This is the traditional creat() function from early UNIX.
// ════════════════════════════════════════════════════════════════════════════

pub func:io_creat = int64(int64:path, int64:mode) {
    pass io_open(path, O_WRONLY | O_CREAT | O_TRUNC, mode);
};

// ════════════════════════════════════════════════════════════════════════════
// io_close — Close a file descriptor.
//
// IMPORTANT: Always check this return value. close() can fail with EIO on
// networked filesystems (NFS, CIFS), meaning buffered kernel writes were
// lost. Ignoring close() errors is a data-loss bug.
//
// Returns Ok(0) on success, Err on failure.
// ════════════════════════════════════════════════════════════════════════════

pub func:io_close = int64(int64:fd) {
    if (fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    pass libn_close(fd);
};

// io_close_nointr — Close, retrying if interrupted by a signal.
//
// On most systems, close() is NOT restarted on EINTR — the fd is closed
// even when EINTR is returned (Linux behavior since kernel 3.4). This
// wrapper handles that correctly: on EINTR, the fd IS closed, return Ok(0).
//
// See: https://ewontfix.com/4/ — "Don't retry close(2) after EINTR on Linux"
pub func:io_close_nointr = int64(int64:fd) {
    if (fd < 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
    Result<int64>:r = libn_close(fd);
    if (r.is_error) {
        int64:e = @cast_unchecked<int64>(r.error);
          // On Linux: even on EINTR, the fd is closed. Return success.
        if (e == EINTR) {
            pass 0i64;
        }
        fail r.error;
    }
    pass 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// io_open_tmp — Create a temporary file.
//
// Opens a new anonymous file in dir_path using O_TMPFILE | O_RDWR.
// The file has no name and is automatically deleted when all fds are closed.
// If O_TMPFILE is not supported by the filesystem, falls back to mkstemp-style
// creation (not yet implemented — fails with ENOSYS in that case).
//
// Returns fd on success.
// ════════════════════════════════════════════════════════════════════════════

pub func:io_open_tmp = int64(int64:dir_path) {
    if (dir_path == 0i64) {
        fail @cast_unchecked<tbb32>(ERR_BADARG);
    }
      // O_TMPFILE requires O_WRONLY or O_RDWR in flags
      // Mode 0600: only owner can read/write the temp file
    Result<int64>:r = libn_openat(AT_FDCWD, dir_path, O_TMPFILE | O_RDWR, MODE_SECRET);
    return r;
};

// printf.npk — Formatted output to file descriptors (v0.4.3)
//
// This module provides printf-family functions for libn. It is built on two
// pillars:
//
//   1. src/str/strfmt.npk   — format-string rendering engine
//   2. src/io/write.npk     — fd-level write primitives
//
// The API mirrors the standard C printf family:
//
//   io_printf(fmt, ...)        → stdout
//   io_fprintf(fd, fmt, ...)   → arbitrary fd
//   io_dprintf(fd, fmt, ...)   → alias for fprintf (Linux convention)
//   io_eprintf(fmt, ...)       → stderr
//   io_sprintf(buf, n, fmt, ...) → into buffer (delegates to str_snprintf*)
//
// Variadic encoding:
//   Nitpick does not have a true varargs ABI. We use the same explicit-arity
//   @cast_unchecked<strfmt>(pattern).npk: io_fprintf0 through io_fprintf8. The top-level
//   io_fprintf is a macro-like alias for the most common arities.
//
//   In practice, call io_fprintf_N(fd, fmt, arg0, arg1, ..., argN-1) where
//   N is the number of format arguments (not counting fmt itself).
//
// Buffer strategy:
//   We render into a fixed 4096-uint8 stack buffer. If the rendered string
//   would exceed 4095 bytes, it is silently truncated (snprintf semantics).
//   For large output, use the buffered I/O layer (bio/, v0.6.x).
//
// Thread safety:
//   Not thread-safe at this layer. Concurrent writes to the same fd may
//   interleave. Use bio/ or a mutex for concurrent output.

use "../syscall/errno.npk".*;
use "../io/write.npk".*;
use "../str/strfmt.npk".*;

// Internal render buffer size. 4 KiB is adequate for a single formatted line.
// Large formatted output should use bio/ instead.
pub fixed int64:PRINTF_BUF_SIZE = 4096i64;

// ════════════════════════════════════════════════════════════════════════════
// Internal helper — render into stack buffer, write to fd.
//
// All io_fprintfN functions render via str_snprintfN into a 4096-uint8 stack
// buffer, then emit the result in a single io_write_n call.
//
// Returns Ok(bytes_written) or Err from write.
// ════════════════════════════════════════════════════════════════════════════

// ────────────────────────────────────────────────────────────────────────────
// 0 format arguments
// ────────────────────────────────────────────────────────────────────────────

pub func:io_fprintf0 = int64(int64:fd, int64:fmt) {
    stack uint8[4096]:buf;
    int64:buf_ptr = @cast_unchecked<int64>(@buf);
    drop(str_snprintf0(buf_ptr, PRINTF_BUF_SIZE, fmt));
    pass io_write_str(fd, buf_ptr);
};

pub func:io_printf0 = int64(int64:fmt) {
    pass io_fprintf0(STDOUT_FD, fmt);
};

pub func:io_eprintf0 = int64(int64:fmt) {
    pass io_fprintf0(STDERR_FD, fmt);
};

// ────────────────────────────────────────────────────────────────────────────
// 1 format argument
// ────────────────────────────────────────────────────────────────────────────

pub func:io_fprintf1 = int64(int64:fd, int64:fmt, int64:a0) {
    stack uint8[4096]:buf;
    int64:buf_ptr = @cast_unchecked<int64>(@buf);
    drop(str_snprintf1(buf_ptr, PRINTF_BUF_SIZE, fmt, a0));
    pass io_write_str(fd, buf_ptr);
};

pub func:io_printf1 = int64(int64:fmt, int64:a0) {
    pass io_fprintf1(STDOUT_FD, fmt, a0);
};

pub func:io_eprintf1 = int64(int64:fmt, int64:a0) {
    pass io_fprintf1(STDERR_FD, fmt, a0);
};

// ────────────────────────────────────────────────────────────────────────────
// 2 format arguments
// ────────────────────────────────────────────────────────────────────────────

pub func:io_fprintf2 = int64(int64:fd, int64:fmt, int64:a0, int64:a1) {
    stack uint8[4096]:buf;
    int64:buf_ptr = @cast_unchecked<int64>(@buf);
    drop(str_snprintf2(buf_ptr, PRINTF_BUF_SIZE, fmt, a0, a1));
    pass io_write_str(fd, buf_ptr);
};

pub func:io_printf2 = int64(int64:fmt, int64:a0, int64:a1) {
    pass io_fprintf2(STDOUT_FD, fmt, a0, a1);
};

pub func:io_eprintf2 = int64(int64:fmt, int64:a0, int64:a1) {
    pass io_fprintf2(STDERR_FD, fmt, a0, a1);
};

// ────────────────────────────────────────────────────────────────────────────
// 3 format arguments
// ────────────────────────────────────────────────────────────────────────────

pub func:io_fprintf3 = int64(int64:fd, int64:fmt, int64:a0, int64:a1, int64:a2) {
    stack uint8[4096]:buf;
