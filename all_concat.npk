    drop(str_snprintf4(buf_ptr, PRINTF_BUF_SIZE, fmt, a0, a1, a2, a3));
    pass io_write_str(fd, buf_ptr);
};

pub func:io_printf4 = int64(int64:fmt, int64:a0, int64:a1, int64:a2, int64:a3) {
