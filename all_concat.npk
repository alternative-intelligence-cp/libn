// errno.npk — Error propagation model for libn (v0.1.2)
//
// This module defines the libn error type, errno constants (all ~140 Linux/POSIX
// errno codes), and the conversion from raw syscall return values to typed errors.
//
// Architecture:
//   Linux syscalls return negative errno values on failure (e.g., -ENOENT = -2).
//   libn's sys() / sys!!() wrappers convert these to Result<int64>{err, val, is_error}.
//   This module provides:
//     - All errno @cast_unchecked<pub>(constants) fixed int64
//     - err_from_syscall(ret int64) Result<int64>   — converts raw syscall return
//     - errno_is_retriable(e int64) bool             — EAGAIN/EINTR check
//     - err_str(e int64) *uint8                       — static error string (no alloc)
//
// Thread safety:
//   errno is stored in the per-thread TCB (v0.13.6). At this stage (v0.1.x),
//   before TLS exists, libn_errno is a placeholder global. It will be promoted
//   to a TLS variable in v0.13.6.
//
// Usage:
//   use "../syscall/errno.npk".*;
//   Result<int64>:r = err_from_syscall(raw_ret);
//   if r.is_error { /* r.error is the errno code */ }

// ════════════════════════════════════════════════════════════════════════════
// ERRNO CONSTANTS  (linux/errno.h, asm-generic/errno-base.h, errno.h)
// All values for x86-64 Linux.
// ════════════════════════════════════════════════════════════════════════════

pub fixed int64:EPERM    = 1i64;      // Operation not permitted
pub fixed int64:ENOENT   = 2i64;      // No such file or directory
pub fixed int64:ESRCH    = 3i64;      // No such process
pub fixed int64:EINTR    = 4i64;      // Interrupted system call
pub fixed int64:EIO      = 5i64;      // Input/output error
pub fixed int64:ENXIO    = 6i64;      // No such device or address
pub fixed int64:E2BIG    = 7i64;      // Argument list too long
pub fixed int64:ENOEXEC  = 8i64;      // Exec format error
pub fixed int64:EBADF    = 9i64;      // Bad file descriptor
pub fixed int64:ECHILD   = 10i64;     // No child processes
pub fixed int64:EAGAIN   = 11i64;     // Resource temporarily unavailable (try again)
pub fixed int64:ENOMEM   = 12i64;     // Out of memory
pub fixed int64:EACCES   = 13i64;     // Permission denied
pub fixed int64:EFAULT   = 14i64;     // Bad address
pub fixed int64:ENOTBLK  = 15i64;     // Block device required
pub fixed int64:EBUSY    = 16i64;     // Device or resource busy
pub fixed int64:EEXIST   = 17i64;     // File exists
pub fixed int64:EXDEV    = 18i64;     // Cross-device link
pub fixed int64:ENODEV   = 19i64;     // No such device
pub fixed int64:ENOTDIR  = 20i64;     // Not a directory
pub fixed int64:EISDIR   = 21i64;     // Is a directory
pub fixed int64:EINVAL   = 22i64;     // Invalid argument
pub fixed int64:ENFILE   = 23i64;     // Too many open files in system
pub fixed int64:EMFILE   = 24i64;     // Too many open files (per process)
pub fixed int64:ENOTTY   = 25i64;     // Inappropriate ioctl for device
pub fixed int64:ETXTBSY  = 26i64;     // Text file busy
pub fixed int64:EFBIG    = 27i64;     // File too large
pub fixed int64:ENOSPC   = 28i64;     // No space left on device
pub fixed int64:ESPIPE   = 29i64;     // Illegal seek
pub fixed int64:EROFS    = 30i64;     // Read-only file system
pub fixed int64:EMLINK   = 31i64;     // Too many links
pub fixed int64:EPIPE    = 32i64;     // Broken pipe
pub fixed int64:EDOM     = 33i64;     // Math argument out of domain
pub fixed int64:ERANGE   = 34i64;     // Math result not representable

