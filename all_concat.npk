// posix_constants.npk — Complete POSIX/Linux constants for libn (v0.1.1)
//
// No C shims. All values sourced from:
//   - POSIX.1-2017 (IEEE Std 1003.1-2017)
//   - Linux kernel headers: include/uapi/linux/
//   - glibc headers: bits/fcntl.h, bits/mman.h, bits/signum.h, etc.
//   - Architecture: x86-64 (Linux ABI)
//
// Usage:
//   use "../syscall/posix_constants.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// FILE OPEN FLAGS  (fcntl.h, O_* values for x86-64 Linux)
// ════════════════════════════════════════════════════════════════════════════

pub fixed int64:O_RDONLY    = 0i64;           // Open for reading only
pub fixed int64:O_WRONLY    = 1i64;           // Open for writing only
