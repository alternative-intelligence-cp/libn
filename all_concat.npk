    @cast_unchecked<int64>(@"Socket operation on non-socket"),
    @cast_unchecked<int64>(@"Destination address required"),
    @cast_unchecked<int64>(@"Message too long"),
    @cast_unchecked<int64>(@"Protocol wrong type for socket"),
    @cast_unchecked<int64>(@"Protocol not available"),
    @cast_unchecked<int64>(@"Protocol not supported"),
    0i64,
    @cast_unchecked<int64>(@"Operation not supported"),
    0i64,
    @cast_unchecked<int64>(@"Address family not supported by protocol"),
    @cast_unchecked<int64>(@"Address already in use"),
    @cast_unchecked<int64>(@"Cannot assign requested address"),
    @cast_unchecked<int64>(@"Network is down"),
    @cast_unchecked<int64>(@"Network is unreachable"),
    @cast_unchecked<int64>(@"Network dropped connection on reset"),
    @cast_unchecked<int64>(@"Software caused connection abort"),
    @cast_unchecked<int64>(@"Connection reset by peer"),
    @cast_unchecked<int64>(@"No buffer space available"),
    @cast_unchecked<int64>(@"Transport endpoint is already connected"),
    @cast_unchecked<int64>(@"Transport endpoint is not connected"),
    0i64,
    0i64,
    @cast_unchecked<int64>(@"Connection timed out"),
    @cast_unchecked<int64>(@"Connection refused"),
    0i64,
    @cast_unchecked<int64>(@"No route to host"),
    @cast_unchecked<int64>(@"Operation already in progress"),
    @cast_unchecked<int64>(@"Operation now in progress"),
    @cast_unchecked<int64>(@"Stale file handle"),
    0i64,
    0i64,
    0i64,
    0i64,
    0i64,
    0i64,
    0i64,
    0i64,
    @cast_unchecked<int64>(@"Operation canceled"),
    0i64,
    0i64,
    0i64,
    0i64,
    @cast_unchecked<int64>(@"Owner died"),
    @cast_unchecked<int64>(@"State not recoverable"),
    0i64,
    0i64,
    0i64
];


// ════════════════════════════════════════════════════════════════════════════
// strerror — Return a string describing the given errno value.
//
// Returns a pointer to a static string (must NOT be modified by the caller).
// Thread-safe: the table is read-only; no locking needed.
//
// For unknown errno values, the returned string is stored in a small internal
// buffer (NOT thread-safe for concurrent unknown-errno calls — fixed in v0.21.x).
// ════════════════════════════════════════════════════════════════════════════

// Internal buffer for "Unknown error N" fallback (not thread-safe)
uint8[64]:g_strerror_unknown_buf;

pub func:strerror = int64(int64:errnum) {
    if (errnum >= 0i64 && errnum <= 134i64) {
        int64:msg = errno_table[errnum];
        if (msg != 0i64) {
            pass msg;
        }
    }
    uint8->:dst = @cast_unchecked<uint8->>(@g_strerror_unknown_buf);
    fixed int64:prefix = @cast_unchecked<int64>(@"Unknown error ");
    int64:prefix_len = raw str_strlen(@cast_unchecked<int64>(prefix));
    drop(mem_memcpy(@cast_unchecked<int64>(@dst), @cast_unchecked<int64>(prefix), prefix_len));
    stack uint8[24]:num;
    int64:num_len = raw str_itoa(errnum, @cast_unchecked<int64>(@num), 24i64);
    drop(mem_memcpy((@cast_unchecked<int64>(dst)) + prefix_len, @cast_unchecked<int64>(@num), num_len + 1i64));
    pass @cast_unchecked<int64>(@g_strerror_unknown_buf);
};

// ════════════════════════════════════════════════════════════════════════════
// strerror_r — Thread-safe variant: write the message into caller's buffer.
//
// buf:     destination buffer
// buflen:  buffer size in bytes (must be >= 1)
//
// Returns 0 on success, ERANGE if buf is too small (message truncated with NUL),
// EINVAL if errnum is not recognized (writes "Unknown error N" anyway).
// ════════════════════════════════════════════════════════════════════════════

pub func:strerror_r = int64(int64:errnum, int64:buf, int64:buflen) {
    if (buf == 0i64 || buflen <= 0i64) {
        pass EINVAL;
    }

    int64:msg = 0i64;
    if (errnum >= 0i64 && errnum <= 134i64) {
        msg = errno_table[errnum];
    }
    
    if (msg != 0i64) {
        int64:msg_len = raw str_strlen(msg);
        if (msg_len + 1i64 > buflen) {
            drop(mem_memcpy(buf, msg, buflen - 1i64));
            (@cast_unchecked<uint8->>(buf))[buflen - 1i64] = 0u8;
            pass ERANGE;
        }
        drop(mem_memcpy(buf, msg, msg_len + 1i64));
        pass 0i64;
    }

    // Unknown error rendering securely into caller buffer
    fixed int64:prefix = @cast_unchecked<int64>(@"Unknown error ");
    int64:prefix_len = raw str_strlen(@cast_unchecked<int64>(prefix));
    
    stack uint8[24]:num;
    int64:num_len = raw str_itoa(errnum, @cast_unchecked<int64>(@num), 24i64);
    
    int64:total_len = prefix_len + num_len;
    if (total_len + 1i64 > buflen) {
        // Truncation required for unknown error
        int64:copy1 = prefix_len;
        if (copy1 > buflen - 1i64) { copy1 = buflen - 1i64; }
        drop(mem_memcpy(buf, @cast_unchecked<int64>(prefix), copy1));
        
        int64:copy2 = buflen - 1i64 - copy1;
        if (copy2 > 0i64) {
            drop(mem_memcpy(buf + copy1, @cast_unchecked<int64>(@num), copy2));
        }
        (@cast_unchecked<uint8->>(buf))[buflen - 1i64] = 0u8;
        pass ERANGE;
    }
    
    drop(mem_memcpy(buf, @cast_unchecked<int64>(prefix), prefix_len));
    drop(mem_memcpy(buf + prefix_len, @cast_unchecked<int64>(@num), num_len + 1i64));
    pass EINVAL;
};

// ════════════════════════════════════════════════════════════════════════════
// perror — Write "prefix: error description\n" to stderr.
//
// Reads the current global errno value (libn_errno from errno.npk).
// If prefix is non-NULL and non-empty, writes "prefix: msg\n".
// If prefix is NULL or empty, writes just "msg\n".
//
// This supersedes the placeholder in io_perror() in printf.npk.
// ════════════════════════════════════════════════════════════════════════════

pub func:perror = NIL(int64:prefix) {
    drop(bio_ensure_std_init());

    if (prefix != 0i64 && (@cast_unchecked<uint8->>(prefix))[0] != 0u8) {
        drop(fputs(prefix, stderr_fp));
        drop(fputc(58i64, stderr_fp));     // ':'
        drop(fputc(32i64, stderr_fp));     // ' '
    }

    stack uint8[256]:msg_buf;
    int64:errnum = @cast_unchecked<int64>(libn_errno);
    drop(strerror_r(errnum, @cast_unchecked<int64>(@msg_buf), 256i64));
    
    drop(fputs(@cast_unchecked<int64>(@msg_buf), stderr_fp));
    drop(fputc(10i64, stderr_fp));     // '\n'
    drop(fflush(stderr_fp));
};

// file.npk — FILE struct definition, constants, and internal helpers (v0.5.0)
//
// This is the foundation of the buffered I/O subsystem. All stdio functions
// operate on a *FILE (represented in @cast_unchecked<int64>(libn) — a pointer to a FILE struct).
//
// ── Design decisions ─────────────────────────────────────────────────────────
//
// All fields are int64 to avoid alignment surprises and simplify pointer arithmetic.
// sizeof(FILE) = 10 * 8 = 80 bytes — fits in the 128-uint8 slab class.
//
// Buffer model (two modes, never simultaneously active):
//
//   READ mode:
//     buf[0..buf_len]   — kernel bytes loaded into buffer
//     buf[buf_pos..]    — not yet consumed by caller
//     logical position  = kernel_pos - (buf_len - buf_pos)
//     fread reads from buf[buf_pos], increments buf_pos; refills when buf_pos == buf_len
//
//   WRITE mode:
//     buf[0..buf_pos]   — caller data not yet flushed to kernel
//     buf[buf_pos..]    — available space
//     logical position  = kernel_pos + buf_pos
//     fwrite fills buf[buf_pos], increments buf_pos; flushes when buf_pos == buf_cap
//
// Switching direction (POSIX: must fflush or fseek between read→write or write→read)
// is handled by bio_flush_if_dirty() / drop(bio_discard_read_buf() in the internal helpers.
//
// unget:
//   One character of pushback via ungetc(). Stored in the FILE struct.
//   @cast_unchecked<int64>(Represented): -1 means "no unget char", 0..255 means pending char.
//   ungetc pushes the char); the next fgetc/fread consumes it first.
//
// stdin/stdout/stderr:
//   @cast_unchecked<module>(Declared)-level FILE structs in stdfiles.npk.
//   Not heap-allocated — they live in the BSS segment.
//   Lazy initialization is triggered by bio_ensure_init() on first access.
//
// ── Buffering modes ──────────────────────────────────────────────────────────
//   _IOFBF = 0  Fully buffered: flush only when buffer is full or fflush() called.
//               Default for regular files.
//   _IOLBF = 1  Line buffered: flush on every '\n' written or buffer full.
//               Default for stdout when connected to a terminal.
//   _IONBF = 2  Unbuffered: every fread/fwrite goes straight to the kernel.
//               Default for stderr.

use "../../mem/mmap.npk".*;
use "../../syscall/syscall_numbers.npk".*;
use "../../syscall/syscall.npk".*;
use "../../syscall/errno.npk".*;
use "../../syscall/posix_constants.npk".*;
use "../../syscall/syscall.npk".*;
use "../../mem/slab.npk".*;
use "../../mem/memset.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// FILE struct
//
// In libn, FILE* is @cast_unchecked<int64>(represented) (a pointer). Cast with `as FILE->`.
// ════════════════════════════════════════════════════════════════════════════

pub struct:FILE = {
    int64:fd;          // underlying file descriptor (-1 = not open / not initialized)
    int64:buf;         // pointer to I/O buffer (heap or user-supplied; 0 = unbuffered)
    int64:buf_cap;     // total buffer capacity in bytes
    int64:buf_pos;     // read: index of next unread uint8 / write: bytes pending flush
    int64:buf_len;     // read: valid bytes loaded from kernel / write: @cast_unchecked<buf_pos>(same)
    int64:file_pos;    // logical file @cast_unchecked<seen>(position) by caller (bytes from file start)
    int64:mode;        // FILE_MODE_* bitmask: r/w/a/update flags
    int64:buf_mode;    // _IOFBF / _IOLBF / _IONBF
    int64:flags;       // FILE_FLAG_* bitmask: EOF, ERROR, BUF_OWN, WRITE_MODE, INIT
    int64:unget;       // ungetc storage: -1 = none, 0..255 = pending char
    int64:next_global;
};

// ════════════════════════════════════════════════════════════════════════════
// Constants
// ════════════════════════════════════════════════════════════════════════════

// Buffering mode constants (POSIX names)
pub fixed int64:_IOFBF = 0i64;      // fully buffered
pub fixed int64:_IOLBF = 1i64;      // line buffered
pub fixed int64:_IONBF = 2i64;      // unbuffered

// Default buffer size — 8 KiB (matches glibc BUFSIZ default)
pub fixed int64:BUFSIZ = 8192i64;

// Maximum number of open FILE streams (includes stdin/stdout/stderr)
pub fixed int64:FOPEN_MAX = 64i64;

// Maximum file name length for tmpnam/tmpfile
pub fixed int64:L_tmpnam = 20i64;

// FILE mode flags (what kind of I/O is permitted on the stream)
pub fixed int64:FILE_MODE_READ   = 0x01i64;    // opened for reading
pub fixed int64:FILE_MODE_WRITE  = 0x02i64;    // opened for writing
pub fixed int64:FILE_MODE_APPEND = 0x04i64;    // opened in append mode (O_APPEND)
pub fixed int64:FILE_MODE_UPDATE = 0x08i64;    // '+': both read and write permitted
pub fixed int64:FILE_MODE_BINARY = 0x10i64;    // 'b': binary mode (no-op on Linux)

// FILE internal state flags
pub fixed int64:FILE_FLAG_EOF       = 0x01i64;    // end-of-file indicator
pub fixed int64:FILE_FLAG_ERROR     = 0x02i64;    // error indicator (cleared by clearerr)
pub fixed int64:FILE_FLAG_BUF_OWN   = 0x04i64;    // libn owns the buffer (free on fclose)
pub fixed int64:FILE_FLAG_WRITE_MODE= 0x08i64;    // buffer is in write mode (dirty)
pub fixed int64:FILE_FLAG_INIT      = 0x10i64;    // struct has been initialized

// Sentinel for "no ungetc char pending"
pub fixed int64:FILE_UNGET_EMPTY = -1i64;

// EOF sentinel value (returned by fgetc/getc on end-of-file or error)
pub fixed int64:FILE_EOF = -1i64;

// ════════════════════════════════════════════════════════════════════════════
// Internal helpers — used by fopen, fread, fwrite, fclose, etc.
// Not part of the public stdio API.
// ════════════════════════════════════════════════════════════════════════════

// bio_alloc_file — Allocate a zeroed FILE struct from the slab allocator.
// Returns pointer-as-int64 or 0 on allocation failure.
pub func:bio_alloc_file = int64() {
    Result<int64>:r_p = libn_slab_alloc_zero(80i64);    // 80 bytes = sizeof(FILE), goes in 128-uint8 class
    if (r_p.is_error) { pass 0i64; }
    int64:p = r_p.value;
    if (p == 0i64) {
        pass 0i64;
    }
      // Initialize fd to -1 (unset), unget to empty
    FILE->:f = @cast_unchecked<FILE->>(p);
    f->fd    = -1i64;
    f->unget = FILE_UNGET_EMPTY;
    f->next_global = 0i64;
    pass p;
};

// bio_free_file — Return a FILE struct to the slab allocator.
// Does NOT close the fd or free the buffer — callers must do that first.
pub func:bio_free_file = NIL(int64:fp) {
    if (fp == 0i64) { pass NIL; }
    drop(libn_slab_free(fp));
};

// bio_alloc_buf — Allocate an I/O buffer. Uses slab for BUFSIZ (8192 falls
// outside slab max of 4096, so uses mem_malloc for the default size).
// Returns allocated pointer or 0 on failure.
pub func:bio_alloc_buf = int64(int64:size) {
    if (size <= 0i64) {
        pass 0i64;
    }
    if (size <= 4096i64) {
        pass libn_slab_alloc_zero(size);
    }
      // For BUFSIZ (8192) and larger, use the direct-mmap allocator
    pass mem_malloc(size);
};

// bio_free_buf — Free an I/O buffer allocated by bio_alloc_buf.
pub func:bio_free_buf = NIL(int64:buf, int64:size) {
    if (buf == 0i64) { pass NIL; }
    if (size <= 4096i64) {
        drop(libn_slab_free(buf));
    } else {
        drop(mem_free(buf));
    }
};

// bio_flush_write_buf — Flush the write buffer to the kernel.
// Writes all buf[0..buf_pos] bytes to fd, retrying on short writes and EINTR.
// Returns Ok(0) on success, or Err on I/O error.
pub func:bio_flush_write_buf = int64(int64:fp) {
    FILE->:f = @cast_unchecked<FILE->>(fp);
    if (f->buf_pos == 0i64) {
        pass 0i64;    // nothing to flush
    }

    int64:remaining = f->buf_pos;
    int64:ptr = f->buf;

    while (remaining > 0i64) {
        Result<int64>:r = sys_safe(SYS_WRITE, f->fd, ptr, remaining, 0i64, 0i64, 0i64);
        if (r.is_error) {
            int64:e = @cast_unchecked<int64>(r.error);
            if (e == EINTR) { continue; }
            f->flags = f->flags | FILE_FLAG_ERROR;
            fail r.error;
        }
        if (r.value == 0i64) {
            f->flags = f->flags | FILE_FLAG_ERROR;
            fail @cast_unchecked<tbb32>(ERR_EOF);
        }
        ptr = ptr + r.value;
        f->file_pos = f->file_pos + r.value;
        remaining = remaining - r.value;
    }

    f->buf_pos = 0i64;
    f->buf_len = 0i64;
    f->flags = f->flags & (0i64 - 1i64 ^ FILE_FLAG_WRITE_MODE);
    pass 0i64;
};

// bio_discard_read_buf — Discard unread bytes in the read buffer.
// Adjusts the kernel file position backward so the logical position stays correct.
// This is called when switching from read to write mode (fseek, fwrite after fread).
pub func:bio_discard_read_buf = int64(int64:fp) {
    FILE->:f = @cast_unchecked<FILE->>(fp);
    int64:unread = f->buf_len - f->buf_pos;
    if (unread <= 0i64) {
        f->buf_pos = 0i64;
        f->buf_len = 0i64;
        pass 0i64;
    }

      // Seek backward by the number of buffered but unconsumed bytes
      // (only possible on seekable fds — for pipes/sockets this will fail, which is OK)
    Result<int64>:r = sys_safe(SYS_LSEEK, f->fd, 0i64 - unread, SEEK_CUR, 0i64, 0i64, 0i64);
    if (r.is_error) {
          // Non-seekable fd — just discard the buffer (may lose data if re-reading)
          // This is correct behavior for pipes; POSIX leaves it undefined.
    }

    f->buf_pos = 0i64;
    f->buf_len = 0i64;
    pass 0i64;
};

// bio_refill_read_buf — Fill the read buffer from the kernel.
// Called when buf_pos >= buf_len (buffer exhausted).
// Returns number of bytes loaded (0 = EOF, negative = error via flags).
pub func:bio_refill_read_buf = int64(int64:fp) {
    FILE->:f = @cast_unchecked<FILE->>(fp);

      // If unbuffered, there's nothing to fill (callers handle _IONBF specially)
    if (f->buf_mode == _IONBF || f->buf == 0i64 || f->buf_cap == 0i64) {
        pass 0i64;
    }

    f->buf_pos = 0i64;
    f->buf_len = 0i64;

    while (true) {
        Result<int64>:r = sys_safe(SYS_READ, f->fd, f->buf, f->buf_cap, 0i64, 0i64, 0i64);
        if (r.is_error) {
            int64:e = @cast_unchecked<int64>(r.error);
            if (e == EINTR) { continue; }
            f->flags = f->flags | FILE_FLAG_ERROR;
            fail r.error;
        }
        f->buf_len = r.value;
        if (r.value == 0i64) {
            f->flags = f->flags | FILE_FLAG_EOF;
        }
        pass r.value;
    }

      // unreachable
    fail @cast_unchecked<tbb32>(ERR_BADARG);
};

// bio_parse_mode — Parse an fopen mode string into FILE_MODE_* flags and O_* flags.
// Returns FILE_MODE_* in the low 16 bits, O_* open flags in the high bits via
// two output parameters.
// mode_str: "r", "w", "a", "r+", "w+", "a+", "rb", "wb", etc.
// out_file_mode: pointer to int64 — receives FILE_MODE_* flags
// out_open_flags: pointer to int64 — receives O_* flags for open()
// Returns 0 on success, -1 on invalid mode string.
pub func:bio_parse_mode = int64(int64:mode_str, int64:out_file_mode, int64:out_open_flags) {
    uint8->:m = @cast_unchecked<uint8->>(mode_str);
    int64->:fmode = @cast_unchecked<int64->>(out_file_mode);
    int64->:oflags = @cast_unchecked<int64->>(out_open_flags);

    fmode[0]  = 0i64;
    oflags[0] = 0i64;

    if (m[0] == 0u8) { pass -1i64; }    // empty string

    uint8:first = m[0];
    bool:has_plus = false;
    bool:has_b    = false;
    int64:i = 1i64;

      // Scan for '+' and 'b' modifiers
    while (m[i] != 0u8) {
        if (m[i] == 43u8) { has_plus = true; }     // '+'
        if (m[i] == 98u8) { has_b    = true; }     // 'b'
        i = i + 1i64;
    }

    if (has_b) {
        fmode[0] = fmode[0] | FILE_MODE_BINARY;
    }
    if (has_plus) {
        fmode[0] = fmode[0] | FILE_MODE_UPDATE;
    }

    if (first == 114u8) {    // 'r'
        fmode[0]  = fmode[0] | FILE_MODE_READ;
if (has_plus) {
            oflags[0] = O_RDWR;
        } else {
            oflags[0] = O_RDONLY;
        }
        if (has_plus) { fmode[0] = fmode[0] | FILE_MODE_WRITE; }
    } else if (first == 119u8) {    // 'w'
        fmode[0]  = fmode[0] | FILE_MODE_WRITE;
        oflags[0] = O_WRONLY | O_CREAT | O_TRUNC;
        if (has_plus) {
            fmode[0]  = fmode[0] | FILE_MODE_READ;
            oflags[0] = O_RDWR | O_CREAT | O_TRUNC;
        }
    } else if (first == 97u8) {    // 'a'
        fmode[0]  = fmode[0] | FILE_MODE_WRITE | FILE_MODE_APPEND;
        oflags[0] = O_WRONLY | O_CREAT | O_APPEND;
        if (has_plus) {
            fmode[0]  = fmode[0] | FILE_MODE_READ;
            oflags[0] = O_RDWR | O_CREAT | O_APPEND;
        }
    } else {
        pass -1i64;    // unrecognized mode
    }

    pass 0i64;
};
pub int64:g_open_files = 0i64;

// stdfiles.npk — stdin, stdout, stderr global streams (v0.5.10)
//
// Provides the three standard stdio @cast_unchecked<globally>(streams) accessible FILE structs.
//
// In a proper C runtime, these are initialized during __libc_start_main (v0.12.x).
// At v0.5.10, they are lazily initialized on first access via bio_ensure_std_init().
//
// Naming:
//   libn uses suffixed names to avoid colliding with C macro names in mixed
//   environments. The "standard" names (stdin, stdout, stderr) are provided as
//   int64 constants that hold the pointer to the respective FILE struct.
//
//   Users include this module and refer to: stdin_fp, stdout_fp, stderr_fp.
//   Once the preprocessor/macro system exists (v1.x), true stdin/stdout/stderr
//   macro aliases will be added.
//
// Lifecycle:
//   These FILE structs are statically allocated (BSS segment). fclose() on them
//   flushes but does NOT close fd 0/1/2 and does NOT free the struct.
//   This matches glibc and musl behavior.

use "../../mem/mmap.npk".*;
use "../../syscall/syscall_numbers.npk".*;
use "../../syscall/syscall.npk".*;
use "../../syscall/errno.npk".*;
use "../../syscall/posix_constants.npk".*;
use "../../io/bio/file.npk".*;
use "../../io/bio/fopen.npk".*;
use "../../io/bio/fio.npk".*;
use "../../io/bio/fchar.npk".*;
use "../../io/bio/fstr.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// Static FILE struct storage for the three standard streams.
//
// Fields start at zero (BSS). bio_ensure_std_init() populates them on first use.
// ════════════════════════════════════════════════════════════════════════════

FILE:g_stdin_file;
FILE:g_stdout_file;
FILE:g_stderr_file;


// Lazy-init guard (0 = not yet initialized)
int64:g_std_init_done = 0i64;

// ════════════════════════════════════════════════════════════════════════════
// Public stdin/stdout/stderr pointers (as int64 = FILE*).
//
// These are the pointers callers use. They point into the BSS structs above.
// ════════════════════════════════════════════════════════════════════════════

pub int64:stdin_fp  = 0i64;    // set by bio_ensure_std_init()
pub int64:stdout_fp = 0i64;
pub int64:stderr_fp = 0i64;

// ════════════════════════════════════════════════════════════════════════════
// isatty — Check if a file descriptor refers to a terminal.
// Returns 1 if true, 0 if false.
// ════════════════════════════════════════════════════════════════════════════

pub func:isatty = int64(int64:fd) {
    stack uint8[60]:termios_buf;
    Result<int64>:r = sys_safe(SYS_IOCTL, fd, TCGETS, @cast_unchecked<int64>(@termios_buf), 0i64, 0i64, 0i64);
    if (r.is_error) { pass 0i64; }
    pass 1i64;
};

// ════════════════════════════════════════════════════════════════════════════
// bio_ensure_std_init — Lazy initializer for standard streams.
//
// Called at the start of any function that uses stdin_fp/stdout_fp/stderr_fp.
// Safe to call multiple times (idempotent).
//
// Initializes:
//   stdin  — fd 0, read-only,  _IOFBF (8 KiB buffer)
//   stdout — fd 1, write-only, _IOLBF if tty else _IOFBF
//   stderr — fd 2, write-only, _IONBF (unbuffered, immediate output)
// ════════════════════════════════════════════════════════════════════════════

pub func:bio_ensure_std_init = NIL() {
    if (g_std_init_done != 0i64) {
        pass NIL;
    }
    g_std_init_done = 1i64;

      // stdin — fd 0, read-only
    FILE->:sin = @cast_unchecked<FILE->>(@g_stdin_file);
    sin->fd       = 0i64;
    sin->mode     = FILE_MODE_READ;
    sin->buf_mode = _IOFBF;
    sin->flags    = FILE_FLAG_INIT;
    sin->unget    = FILE_UNGET_EMPTY;
    int64:stdin_buf = raw bio_alloc_buf(BUFSIZ);
    if (stdin_buf != 0i64) {
        sin->buf     = stdin_buf;
        sin->buf_cap = BUFSIZ;
        sin->flags   = sin->flags | FILE_FLAG_BUF_OWN;
    } else {
        sin->buf_mode = _IONBF;    // fallback: unbuffered if alloc fails
    }
    stdin_fp = @cast_unchecked<int64>(@g_stdin_file);

      // stdout — fd 1, write-only, line-buffered if tty else fully-buffered
    FILE->:sout = @cast_unchecked<FILE->>(@g_stdout_file);
    sout->fd       = 1i64;
    sout->mode     = FILE_MODE_WRITE;
    sout->buf_mode = is (raw isatty(1i64) != 0i64) : _IOLBF : _IOFBF;
    sout->flags    = FILE_FLAG_INIT;
    sout->unget    = FILE_UNGET_EMPTY;
    int64:stdout_buf = raw bio_alloc_buf(BUFSIZ);
    if (stdout_buf != 0i64) {
        sout->buf     = stdout_buf;
        sout->buf_cap = BUFSIZ;
        sout->flags   = sout->flags | FILE_FLAG_BUF_OWN;
    } else {
        sout->buf_mode = _IONBF;
    }
    stdout_fp = @cast_unchecked<int64>(@g_stdout_file);

      // stderr — fd 2, write-only, unbuffered
    FILE->:serr = @cast_unchecked<FILE->>(@g_stderr_file);
    serr->fd       = 2i64;
    serr->mode     = FILE_MODE_WRITE;
    serr->buf_mode = _IONBF;
    serr->flags    = FILE_FLAG_INIT;
    serr->unget    = FILE_UNGET_EMPTY;
    serr->buf      = 0i64;
    serr->buf_cap  = 0i64;
    stderr_fp = @cast_unchecked<int64>(@g_stderr_file);
    sin->next_global = stdout_fp;
    sout->next_global = stderr_fp;
    serr->next_global = g_open_files;
    g_open_files = stdin_fp;
};

// ════════════════════════════════════════════════════════════════════════════
// getchar — Read one character from stdin.
// putchar — Write one character to stdout.
// puts    — Write string + newline to stdout.
// ════════════════════════════════════════════════════════════════════════════

pub func:getchar = int64() {
    drop(bio_ensure_std_init());
    pass fgetc(stdin_fp);
};

pub func:putchar = int64(int64:c) {
    drop(bio_ensure_std_init());
    pass fputc(c, stdout_fp);
};

pub func:puts = int64(int64:s) {
    drop(bio_ensure_std_init());
    if (s == 0i64) {
        pass FILE_EOF;
    }
    int64:r = raw fputs(s, stdout_fp);
    if (r == FILE_EOF) {
        pass FILE_EOF;
    }
    pass fputc(10i64, stdout_fp);    // '\n'
};

// ════════════════════════════════════════════════════════════════════════════
// bio_flush_stdout — Flush stdout (called before process exit, prompt, etc.)
// bio_flush_stderr — Flush stderr (no-op since unbuffered, provided for symmetry)
// bio_flush_all    — Flush all standard streams
// ════════════════════════════════════════════════════════════════════════════

pub func:bio_flush_stdout = int64() {
    drop(bio_ensure_std_init());
    pass fflush(stdout_fp);
};

pub func:bio_flush_stderr = int64() {
    drop(bio_ensure_std_init());
    pass fflush(stderr_fp);    // no-op for unbuffered; here for completeness
};

pub func:bio_flush_all = int64() {
    drop(bio_ensure_std_init());
    int64:r1 = raw fflush(stdin_fp);
    int64:r2 = raw fflush(stdout_fp);
    int64:r3 = raw fflush(stderr_fp);
    if (r1 == FILE_EOF || r2 == FILE_EOF || r3 == FILE_EOF) {
        pass FILE_EOF;
    }
    pass 0i64;
};

// fstate.npk — feof, ferror, clearerr, setvbuf, setbuf (v0.5.8 / v0.5.11)
//
// Stream state query and buffer configuration.
//
// feof(fp):    Returns non-zero if the end-of-file indicator is set.
// ferror(fp):  Returns non-zero if the error indicator is set.
// clearerr(fp): Clears both the EOF and error indicators.
//
// Note: feof() returns non-zero only AFTER a read attempt has encountered EOF.
// It is NOT a look-ahead (unlike feof in some educational contexts). The correct
// idiom is:
//   while fgetc(fp) != FILE_EOF { ... }
//   if ferror(fp) { /* error */ } else { /* normal EOF */ }
//
// setvbuf — set buffering mode and optionally supply a user buffer.
// setbuf  — simplified interface (buf=NULL for unbuffered, else BUFSIZ-buffered).

use "../../mem/mmap.npk".*;
use "../../syscall/syscall_numbers.npk".*;
use "../../syscall/syscall.npk".*;
use "../../syscall/errno.npk".*;
use "../../mem/slab.npk".*;
use "../../io/bio/file.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// feof — Test the end-of-file indicator.
//
// Returns non-zero if FILE_FLAG_EOF is set, zero otherwise.
// ════════════════════════════════════════════════════════════════════════════

pub func:feof = int64(int64:fp) {
    if (fp == 0i64) {
        pass 0i64;
    }
    FILE->:f = @cast_unchecked<FILE->>(fp);
    if ((f->flags & FILE_FLAG_EOF) != 0i64) {
        pass 1i64;
    }
    pass 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// ferror — Test the error indicator.
//
// Returns non-zero if FILE_FLAG_ERROR is set, zero otherwise.
// ════════════════════════════════════════════════════════════════════════════

pub func:ferror = int64(int64:fp) {
    if (fp == 0i64) {
        pass 0i64;
    }
    FILE->:f = @cast_unchecked<FILE->>(fp);
    if ((f->flags & FILE_FLAG_ERROR) != 0i64) {
        pass 1i64;
    }
    pass 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// clearerr — Clear both the EOF and error indicators.
//
// After clearerr(), feof(fp) and ferror(fp) both return 0.
// The next read or write operation will re-try from the current position.
// ════════════════════════════════════════════════════════════════════════════

pub func:clearerr = NIL(int64:fp) {
    if (fp == 0i64) { pass NIL; }
    FILE->:f = @cast_unchecked<FILE->>(fp);
    f->flags = f->flags & (0i64 - 1i64 ^ FILE_FLAG_EOF ^ FILE_FLAG_ERROR);
};

// ════════════════════════════════════════════════════════════════════════════
// setvbuf — Set buffering mode and optionally supply a buffer.
//
// Must be called BEFORE any I/O on fp (typically right after fopen).
// Calling setvbuf after I/O has occurred has undefined behavior per POSIX.
//
// Parameters:
//   fp:      FILE* (as int64)
//   buf:     user-supplied buffer pointer (as int64), or 0 to let libn allocate
//   mode:    _IOFBF / _IOLBF / _IONBF
//   size:    buffer size (ignored if mode == _IONBF or if buf != 0 and we don't own it)
//
// Returns 0 on success, non-zero on error.
// ════════════════════════════════════════════════════════════════════════════

pub func:setvbuf = int64(int64:fp, int64:buf, int64:mode, int64:size) {
    if (fp == 0i64) {
        pass -1i64;
    }
    if (mode != _IOFBF && mode != _IOLBF && mode != _IONBF) {
        drop(errno_set(EINVAL));
        pass -1i64;
    }

    FILE->:f = @cast_unchecked<FILE->>(fp);

      // Free any existing libn-owned buffer
    if ((f->flags & FILE_FLAG_BUF_OWN) != 0i64 && f->buf != 0i64) {
        drop(bio_free_buf(f->buf, f->buf_cap));
        f->buf     = 0i64;
        f->buf_cap = 0i64;
        f->flags   = f->flags & (0i64 - 1i64 ^ FILE_FLAG_BUF_OWN);
    }

    f->buf_pos  = 0i64;
    f->buf_len  = 0i64;
    f->buf_mode = mode;

    if (mode == _IONBF) {
          // Unbuffered: no buffer needed
        f->buf     = 0i64;
        f->buf_cap = 0i64;
        pass 0i64;
    }

    if (buf != 0i64) {
          // Caller supplies the buffer — libn does NOT own it (won't free on fclose)
        int64:cap = is (size > 0i64) : size : BUFSIZ;
        f->buf     = buf;
        f->buf_cap = cap;
          // No FILE_FLAG_BUF_OWN — caller is responsible for the buffer lifetime
    } else {
          // Allocate a new buffer
        int64:cap = is (size > 0i64) : size : BUFSIZ;
        int64:newbuf = raw bio_alloc_buf(cap);
        if (newbuf == 0i64) {
            drop(errno_set(ENOMEM));
            pass -1i64;
        }
        f->buf     = newbuf;
        f->buf_cap = cap;
        f->flags   = f->flags | FILE_FLAG_BUF_OWN;
    }

    pass 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// setbuf — Simplified buffer configuration.
//
// setbuf(fp, buf):
//   buf != 0: fully buffered with caller's buf (must be >= BUFSIZ bytes)
//   buf == 0: unbuffered
//
// Equivalent to:
//   buf ? setvbuf(fp, buf, _IOFBF, BUFSIZ) : setvbuf(fp, NULL, _IONBF, 0)
// ════════════════════════════════════════════════════════════════════════════

pub func:setbuf = NIL(int64:fp, int64:buf) {
    if (buf != 0i64) {
        drop(setvbuf(fp, buf, _IOFBF, BUFSIZ));
    } else {
        drop(setvbuf(fp, 0i64, _IONBF, 0i64));
    }
};

// ════════════════════════════════════════════════════════════════════════════
// setlinebuf — Set stream to line-buffered mode (BSD extension).
//
// Equivalent to setvbuf(fp, NULL, _IOLBF, 0).
// Commonly used on stdout when output is piped.
// ════════════════════════════════════════════════════════════════════════════

pub func:setlinebuf = NIL(int64:fp) {
    drop(setvbuf(fp, 0i64, _IOLBF, 0i64));
};

// fopen.npk — fopen, fclose, fdopen, freopen, fileno (v0.5.1)
//
// Stream lifecycle management. Every FILE* in libn is backed by an fd.
// The lifecycle is:
//
//   fopen(path, mode)   → allocates FILE struct + I/O buffer, opens the fd
//   fdopen(fd, mode)    → wraps an existing fd in a FILE struct
//   freopen(path, mode, fp) → re-opens a stream in-place (path change or mode change)
//   fileno(fp)          → returns the underlying fd
//   fclose(fp)          → flushes, closes fd, frees buffer and FILE struct
//
// stdin/stdout/stderr are special-cased: their FILE structs are statically
// allocated in stdfiles.npk. fclose() on them flushes but does NOT close fd 0/1/2
// and does NOT free their structs (they're not heap-allocated).
//
// Thread safety: NOT thread-safe at v0.5.x. Concurrent access to the same FILE*
// requires external synchronization. Thread-safe wrappers (flockfile/funlockfile)
// are planned for v0.14.x.

use "../../mem/mmap.npk".*;
use "../../syscall/syscall_numbers.npk".*;
use "../../syscall/syscall.npk".*;
use "../../syscall/errno.npk".*;
use "../../syscall/posix_constants.npk".*;
use "../../syscall/syscall.npk".*;
use "../../mem/slab.npk".*;
use "../../io/bio/file.npk".*;


// ════════════════════════════════════════════════════════════════════════════
// Default mode for file creation via fopen "w", "a"
// ════════════════════════════════════════════════════════════════════════════

fixed int64:FOPEN_CREAT_MODE = 0o666i64;    // masked by umask at open() time

// ════════════════════════════════════════════════════════════════════════════
// bio_init_stream — Initialize a FILE struct for a given fd and mode.
//
// Sets up the buffer, mode flags, and buffer mode. Called by fopen/fdopen.
// Assumes the FILE struct fields are zeroed (out of bio_alloc_file or BSS).
//
// is_static: true if this FILE struct is NOT heap-allocated (stdin/stdout/stderr)
//            so fclose() knows not to call libn_slab_free() on it.
// ════════════════════════════════════════════════════════════════════════════

func:bio_init_stream = int64(int64:fp, int64:fd, int64:file_mode, bool:is_static) {
    FILE->:f = @cast_unchecked<FILE->>(fp);

    f->fd       = fd;
    f->mode     = file_mode;
    f->unget    = FILE_UNGET_EMPTY;
    f->flags    = FILE_FLAG_INIT;
    f->file_pos = 0i64;
    f->buf_pos  = 0i64;
    f->buf_len  = 0i64;

    if (is_static) {
          // Don't set BUF_OWN — the struct is in BSS, not slab
          // (buf ownership is separate from struct ownership)
    }

      // Choose default buffering mode:
      //   stderr (fd == 2): _IONBF — unbuffered for immediate error output
      //   stdout (fd == 1): _IOLBF — line-buffered (we can't detect tty here yet;
      //                              v0.30.x will upgrade to isatty() check)
      //   everything else:  _IOFBF — fully buffered
    if (fd == 2i64) {
        f->buf_mode = _IONBF;
        f->buf      = 0i64;
        f->buf_cap  = 0i64;
        pass 0i64;
    }

    if (fd == 1i64) {
        f->buf_mode = _IOLBF;
    } else {
        f->buf_mode = _IOFBF;
    }

      // Allocate buffer
    int64:buf = raw bio_alloc_buf(BUFSIZ);
    if (buf == 0i64) {
        fail @cast_unchecked<tbb32>(ENOMEM);
    }

    f->buf     = buf;
    f->buf_cap = BUFSIZ;
    f->flags   = f->flags | FILE_FLAG_BUF_OWN;

    pass 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// fopen — Open a @cast_unchecked<a>(file) buffered stdio stream.
//
// Parameters:
//   path: NUL-terminated file path (as int64 pointer)
//   mode: mode string: "r", "w", "a", "r+", "w+", "a+", and optional "b"
//
// Returns: FILE* (as int64) on success, or 0 (NULL) on error.
//
// On error: errno is set (ENOENT, EACCES, ENOMEM, etc.)
// ════════════════════════════════════════════════════════════════════════════

pub func:fopen = int64(int64:path, int64:mode) {
    if (path == 0i64 || mode == 0i64) {
        drop(errno_set(EINVAL));
        pass 0i64;
    }

      // Parse mode string
    stack int64[1]:file_mode_out;
    file_mode_out[0] = 0i64;
    stack int64[1]:open_flags_out;
    open_flags_out[0] = 0i64;
    int64:parse_ok = raw bio_parse_mode(mode, @cast_unchecked<int64>(@file_mode_out), @cast_unchecked<int64>(@open_flags_out));
    if (parse_ok != 0i64) {
        drop(errno_set(EINVAL));
        pass 0i64;
    }

    int64:file_mode  = file_mode_out[0];
    int64:open_flags = open_flags_out[0];

      // Open the file (O_CLOEXEC added automatically by libn_open)
    Result<int64>:r = libn_open(path, open_flags, FOPEN_CREAT_MODE);
    if (r.is_error) {
        drop(errno_set(@cast_unchecked<int64>(r.error)));
        pass 0i64;
    }
    int64:fd = r.value;

      // Allocate FILE struct
    int64:fp = raw bio_alloc_file();
    if (fp == 0i64) {
        drop(libn_close(fd));
        drop(errno_set(ENOMEM));
        pass 0i64;
    }

      // Initialize the stream
    Result<int64>:init_r = bio_init_stream(fp, fd, file_mode, false);
    if (init_r.is_error) {
        drop(libn_close(fd));
        drop(bio_free_file(fp));
        drop(errno_set(ENOMEM));
        pass 0i64;
    }

    FILE->:f = @cast_unchecked<FILE->>(fp);
    f->next_global = g_open_files;
    g_open_files = fp;
    pass fp;
};

// ════════════════════════════════════════════════════════════════════════════
// fdopen — Create a FILE stream from an existing file descriptor.
//
// The mode must be compatible with the fd's open flags:
//   - If fd was opened O_RDONLY, mode must not include writing.
//   - libn does NOT verify compatibility at v0.5.1 (deferred to v0.5.x conformance).
//
// The stream takes ownership of fd: fclose() will close it.
//
// Returns FILE* (as int64) on success, or 0 on error.
// ════════════════════════════════════════════════════════════════════════════

pub func:fdopen = int64(int64:fd, int64:mode) {
    if (fd < 0i64 || mode == 0i64) {
        drop(errno_set(EINVAL));
        pass 0i64;
    }

    stack int64[1]:file_mode_out;
    file_mode_out[0] = 0i64;
    stack int64[1]:open_flags_out;
    open_flags_out[0] = 0i64;
    int64:parse_ok = raw bio_parse_mode(mode, @cast_unchecked<int64>(@file_mode_out), @cast_unchecked<int64>(@open_flags_out));
    if (parse_ok != 0i64) {
        drop(errno_set(EINVAL));
        pass 0i64;
    }

    int64:fp = raw bio_alloc_file();
    if (fp == 0i64) {
        drop(errno_set(ENOMEM));
        pass 0i64;
    }

    Result<int64>:init_r = bio_init_stream(fp, fd, file_mode_out[0], false);
    if (init_r.is_error) {
        drop(bio_free_file(fp));
        drop(errno_set(ENOMEM));
        pass 0i64;
    }

    FILE->:f = @cast_unchecked<FILE->>(fp);
    f->next_global = g_open_files;
    g_open_files = fp;
    pass fp;
};

// ════════════════════════════════════════════════════════════════════════════
// freopen — Re-open a stream with a new path or mode.
//
// If path is non-NULL: flush and close old stream, open new path, reuse struct.
// If path is NULL: flush, change mode flags on the same fd (limited support).
//
// Returns fp on success (same pointer), or 0 on error (fp is NOT valid after error).
// ════════════════════════════════════════════════════════════════════════════

pub func:freopen = int64(int64:path, int64:mode, int64:fp) {
    if (mode == 0i64 || fp == 0i64) {
        drop(errno_set(EINVAL));
        pass 0i64;
    }

    FILE->:f = @cast_unchecked<FILE->>(fp);

      // Parse new mode
    stack int64[1]:file_mode_out;
    file_mode_out[0] = 0i64;
    stack int64[1]:open_flags_out;
    open_flags_out[0] = 0i64;
    int64:parse_ok = raw bio_parse_mode(mode, @cast_unchecked<int64>(@file_mode_out), @cast_unchecked<int64>(@open_flags_out));
    if (parse_ok != 0i64) {
        drop(fclose(fp));
        drop(errno_set(EINVAL));
        pass 0i64;
    }

      // Flush existing write buffer
    if ((f->flags & FILE_FLAG_WRITE_MODE) != 0i64) {
        drop(bio_flush_write_buf(fp));
    }

    int64:old_fd = f->fd;
    bool:buf_owned = (f->flags & FILE_FLAG_BUF_OWN) != 0i64;

    if (path != 0i64) {
          // Open new path
        Result<int64>:r = libn_open(path, open_flags_out[0], FOPEN_CREAT_MODE);
        if (r.is_error) {
              // POSIX: freopen closes fp even on error
            drop(libn_close(old_fd));
            if (buf_owned) { drop(bio_free_buf(f->buf, f->buf_cap)); }
            if (g_open_files == fp) {
                g_open_files = f->next_global;
            } else {
                int64:curr = g_open_files;
                while (curr != 0i64) {
                    FILE->:curr_f = @cast_unchecked<FILE->>(curr);
                    if (curr_f->next_global == fp) {
                        curr_f->next_global = f->next_global;
                        break;
                    }
                    curr = curr_f->next_global;
                }
            }
            drop(bio_free_file(fp));
            drop(errno_set(@cast_unchecked<int64>(r.error)));
            pass 0i64;
        }

          // Close old fd, install new one
        drop(libn_close(old_fd));
        f->fd = r.value;
    }

      // Reset stream state
    f->mode     = file_mode_out[0];
    f->buf_pos  = 0i64;
    f->buf_len  = 0i64;
    f->file_pos = 0i64;
    f->unget    = FILE_UNGET_EMPTY;
    f->flags    = (f->flags & FILE_FLAG_BUF_OWN) | FILE_FLAG_INIT;    // preserve buf ownership

    FILE->:f = @cast_unchecked<FILE->>(fp);
    f->next_global = g_open_files;
    g_open_files = fp;
    pass fp;
};

// ════════════════════════════════════════════════════════════════════════════
// fclose — Flush and close a FILE stream.
//
// Flushes any buffered writes, closes the underlying fd, frees the I/O buffer
// (if owned), and frees the FILE struct (if heap-allocated).
//
// Returns 0 on success, EOF on error (POSIX: fclose sets errno on error).
//
// After fclose(), fp is invalid — do not use it.
// Closing stdin/stdout/stderr: flushes but does NOT close fd 0/1/2, and does
// NOT free the statically allocated FILE structs.
// ════════════════════════════════════════════════════════════════════════════

pub func:fclose = int64(int64:fp) {
    if (fp == 0i64) {
        drop(errno_set(EINVAL));
        pass FILE_EOF;
    }

    FILE->:f = @cast_unchecked<FILE->>(fp);
    int64:ret = 0i64;

      // Flush write buffer
    if ((f->flags & FILE_FLAG_WRITE_MODE) != 0i64 && f->buf_pos > 0i64) {
        Result<int64>:r = bio_flush_write_buf(fp);
        if (r.is_error) {
            drop(errno_set(@cast_unchecked<int64>(r.error)));
            ret = FILE_EOF;
              // Continue with close even on flush error
        }
    }

      // Close the fd (skip for stdin/stdout/stderr)
    int64:fd = f->fd;
    bool:is_std = (fd == 0i64 || fd == 1i64 || fd == 2i64);
    if (!is_std && fd >= 0i64) {
        Result<int64>:r = libn_close(fd);
        if (r.is_error && ret == 0i64) {
            drop(errno_set(@cast_unchecked<int64>(r.error)));
            ret = FILE_EOF;
        }
    }

    f->fd = -1i64;

      // Free I/O buffer if we own it
    if ((f->flags & FILE_FLAG_BUF_OWN) != 0i64 && f->buf != 0i64) {
        drop(bio_free_buf(f->buf, f->buf_cap));
        f->buf     = 0i64;
        f->buf_cap = 0i64;
    }

      // Free FILE struct if heap-allocated (not stdin/stdout/stderr)
    if (!is_std) {
        if (g_open_files == fp) {
            g_open_files = f->next_global;
        } else {
            int64:curr = g_open_files;
            while (curr != 0i64) {
                FILE->:curr_f = @cast_unchecked<FILE->>(curr);
                if (curr_f->next_global == fp) {
                    curr_f->next_global = f->next_global;
                    break;
                }
                curr = curr_f->next_global;
            }
        }
        drop(bio_free_file(fp));
    } else {
          // Reset std stream to allow re-init if needed
        f->flags    = 0i64;
        f->buf_pos  = 0i64;
        f->buf_len  = 0i64;
        f->file_pos = 0i64;
        f->unget    = FILE_UNGET_EMPTY;
    }

    pass ret;
};

// ════════════════════════════════════════════════════════════════════════════
// fileno — Return the underlying file descriptor for a stream.
//
// Returns the fd on success, or -1 with errno=EBADF if fp is invalid.
// ════════════════════════════════════════════════════════════════════════════

pub func:fileno = int64(int64:fp) {
    if (fp == 0i64) {
        drop(errno_set(EBADF));
        pass -1i64;
    }
    FILE->:f = @cast_unchecked<FILE->>(fp);
    if (f->fd < 0i64) {
        drop(errno_set(EBADF));
        pass -1i64;
    }
    pass f->fd;
};

// fseek.npk — fseek, ftell, rewind, fgetpos, fsetpos (v0.5.4)
//
// Stream position control.
//
// fseek:
//   Moves the file position indicator for fp. Discards the ungetc pushback char.
//   Clears the EOF flag (seeking to a valid position makes the stream readable again).
//   If fp is in write mode, flushes the write buffer before seeking.
//   If fp is in read mode, discards the unread bytes in the read buffer.
//
// ftell:
//   Returns the current logical file position (bytes from start of file).
//   Accounts for buffered but unread bytes (subtracts them from kernel position).
//   Accounts for pending unget char.
//
// rewind:
//   Equivalent to fseek(fp, 0, SEEK_SET) + clearerr(fp).
//   Unlike fseek, rewind does not return an error value.
//
// fgetpos / fsetpos:
//   POSIX variants that use an opaque fpos_t type. In libn at v0.5.4,
//   fpos_t is just int64 (uint8 offset). Wide-character streams and locale-aware
//   position state are deferred to v0.31.x.

use "../../mem/mmap.npk".*;
use "../../syscall/syscall_numbers.npk".*;
use "../../syscall/syscall.npk".*;
use "../../syscall/errno.npk".*;
use "../../syscall/posix_constants.npk".*;
use "../../syscall/syscall.npk".*;
use "../../io/bio/file.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// fseek — Move the file position indicator.
//
// Parameters:
//   fp:     FILE* (as int64)
//   offset: signed uint8 offset (interpreted relative to whence)
//   whence: SEEK_SET (from start), SEEK_CUR (from current), SEEK_END (from end)
//
// Returns 0 on success, -1 on error (errno set).
// ════════════════════════════════════════════════════════════════════════════

pub func:fseek = int64(int64:fp, int64:offset, int64:whence) {
    if (fp == 0i64) {
        drop(errno_set(EINVAL));
        pass -1i64;
    }
    if (whence < SEEK_SET || whence > SEEK_END) {
        drop(errno_set(EINVAL));
        pass -1i64;
    }

    FILE->:f = @cast_unchecked<FILE->>(fp);

    if (f->fd < 0i64) {
        drop(errno_set(EBADF));
        pass -1i64;
    }

      // Flush write buffer if dirty
    if ((f->flags & FILE_FLAG_WRITE_MODE) != 0i64 && f->buf_pos > 0i64) {
        Result<int64>:r = bio_flush_write_buf(fp);
        if (r.is_error) {
            drop(errno_set(@cast_unchecked<int64>(r.error)));
            pass -1i64;
        }
    }

      // For SEEK_CUR: adjust for unread buffered bytes to get the true logical offset
    int64:real_offset = offset;
    if (whence == SEEK_CUR) {
          // The kernel's position is ahead by (buf_len - buf_pos) unread bytes
        int64:buffered_ahead = f->buf_len - f->buf_pos;
        if (f->unget != FILE_UNGET_EMPTY) {
            buffered_ahead = buffered_ahead + 1i64;
        }
        real_offset = offset - buffered_ahead;
    }

      // Discard read buffer (kernel will be moved to new position)
    f->buf_pos = 0i64;
    f->buf_len = 0i64;

      // Discard ungetc pushback (POSIX: fseek cancels ungetc)
    f->unget = FILE_UNGET_EMPTY;

      // Issue the actual lseek
    Result<int64>:r = sys_safe(SYS_LSEEK, f->fd, real_offset, whence, 0i64, 0i64, 0i64);
    if (r.is_error) {
        drop(errno_set(@cast_unchecked<int64>(r.error)));
        pass -1i64;
    }

      // Update logical file position
    f->file_pos = r.value;

      // Clear EOF flag — a successful seek makes the stream readable
    f->flags = f->flags & (0i64 - 1i64 ^ FILE_FLAG_EOF);
      // Clear write-mode flag (position is now clean)
    f->flags = f->flags & (0i64 - 1i64 ^ FILE_FLAG_WRITE_MODE);

    pass 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// ftell — Return the current file @cast_unchecked<a>(position) uint8 offset from the start.
//
// Returns the @cast_unchecked<int64>(position) (>= 0), or -1 on error (errno set).
//
// Accounts for:
//   - Buffered unread data (subtracts it from the kernel position)
//   - Pending write buffer (adds buf_pos to kernel position)
//   - Pushed-back unget char (subtracts 1 from position)
// ════════════════════════════════════════════════════════════════════════════

pub func:ftell = int64(int64:fp) {
    if (fp == 0i64) {
        drop(errno_set(EINVAL));
        pass -1i64;
    }

    FILE->:f = @cast_unchecked<FILE->>(fp);

    if (f->fd < 0i64) {
        drop(errno_set(EBADF));
        pass -1i64;
    }

      // Use the logical position we track — this avoids a syscall for the common case
      // and is always accurate as @cast_unchecked<our>(long) buffer tracking is correct.
    int64:pos = f->file_pos;

      // Unget char moves the position back by 1
    if (f->unget != FILE_UNGET_EMPTY) {
        pos = pos - 1i64;
    }

    if (pos < 0i64) {
        pos = 0i64;
    }

    pass pos;
};

// ════════════════════════════════════════════════════════════════════════════
// rewind — Seek to the beginning of the file and clear error/EOF flags.
//
// rewind() does not have a return value — it silently ignores seek errors
// on non-seekable streams (POSIX). Use fseek() if you need error propagation.
// ════════════════════════════════════════════════════════════════════════════

pub func:rewind = NIL(int64:fp) {
    if (fp == 0i64) { pass NIL; }
    FILE->:f = @cast_unchecked<FILE->>(fp);

      // Flush write buffer
    if ((f->flags & FILE_FLAG_WRITE_MODE) != 0i64) {
        drop(bio_flush_write_buf(fp));
    }

      // Discard read buffer and unget
    f->buf_pos = 0i64;
    f->buf_len = 0i64;
    f->unget   = FILE_UNGET_EMPTY;

      // Seek to start (ignore error)
    drop(sys_safe(SYS_LSEEK, f->fd, 0i64, SEEK_SET, 0i64, 0i64, 0i64));
    f->file_pos = 0i64;

      // Clear all error and EOF flags (this is what distinguishes rewind from fseek)
    f->flags = f->flags & (0i64 - 1i64 ^ FILE_FLAG_EOF ^ FILE_FLAG_ERROR ^ FILE_FLAG_WRITE_MODE);
};

// ════════════════════════════════════════════════════════════════════════════
// fgetpos — Store the current position in *pos.
//
// In libn at v0.5.4, fpos_t is simply int64 (a uint8 offset).
// pos: pointer to int64 — receives the current position.
//
// Returns 0 on success, -1 on error.
// ════════════════════════════════════════════════════════════════════════════

pub func:fgetpos = int64(int64:fp, int64:pos) {
    if (fp == 0i64 || pos == 0i64) {
        drop(errno_set(EINVAL));
        pass -1i64;
    }

    int64:p = raw ftell(fp);
    if (p < 0i64) {
        pass -1i64;
    }

    (@cast_unchecked<int64->>(pos))[0] = p;
    pass 0i64;
};

// ════════════════════════════════════════════════════════════════════════════
// fsetpos — Restore a position stored by fgetpos.
//
// pos: pointer to int64 holding the saved position.
// Returns 0 on success, -1 on error.
// ════════════════════════════════════════════════════════════════════════════

pub func:fsetpos = int64(int64:fp, int64:pos) {
    if (fp == 0i64 || pos == 0i64) {
        drop(errno_set(EINVAL));
        pass -1i64;
    }

    int64:target = (@cast_unchecked<int64->>(pos))[0];
    pass fseek(fp, target, SEEK_SET);
};

// fchar.npk — fgetc, fputc, getc, putc, getchar, putchar, ungetc (v0.5.5)
//
// Character-level I/O built on top of the FILE buffer.
//
// fgetc and fputc are the primitive character I/O functions. All other
// character-level functions (getc, putc, getchar, putchar) are thin wrappers.
//
// ungetc:
//   Pushes a character back into the stream's input queue. The pushed-back
//   character is returned by the next fgetc/fread call. Only ONE character
//   of pushback is guaranteed by POSIX; libn stores it in FILE.unget.
//   Calling ungetc after fseek/fsetpos discards the pushed-back char (POSIX).
//
// Performance note:
//   In a production implementation, getc/putc would be @cast_unchecked<macros>(implemented)
//   that inline the buffer fast-path, bypassing the function call overhead.
//   At v0.5.5, they are functions. The macro form is planned for v0.6.x when
//   libn has a header/include system.

use "../../mem/mmap.npk".*;
use "../../syscall/syscall_numbers.npk".*;
use "../../syscall/syscall.npk".*;
use "../../syscall/errno.npk".*;
use "../../syscall/posix_constants.npk".*;
use "../../syscall/syscall.npk".*;
use "../../io/bio/file.npk".*;
use "../../io/bio/fio.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// fgetc — Read one character from fp.
//
// Returns the @cast_unchecked<an>(character) unsigned uint8 value (0–255) cast to int64,
// or FILE_EOF (-1) on end-of-file or error.
//
// This is the fundamental character-read primitive. It consumes from the
// read buffer first, refilling if needed.
// ════════════════════════════════════════════════════════════════════════════

pub func:fgetc = int64(int64:fp) {
    if (fp == 0i64) {
        pass FILE_EOF;
    }

    FILE->:f = @cast_unchecked<FILE->>(fp);

      // EOF/error already set
    if ((f->flags & FILE_FLAG_EOF) != 0i64) {
        pass FILE_EOF;
    }
    if ((f->flags & FILE_FLAG_ERROR) != 0i64) {
        pass FILE_EOF;
    }

      // Not readable
    if ((f->mode & FILE_MODE_READ) == 0i64) {
        f->flags = f->flags | FILE_FLAG_ERROR;
        drop(errno_set(EBADF));
        pass FILE_EOF;
    }

      // Flush write buffer if we were writing
    if ((f->flags & FILE_FLAG_WRITE_MODE) != 0i64) {
        Result<int64>:r = bio_flush_write_buf(fp);
        if (r.is_error) {
            pass FILE_EOF;
        }
    }

      // Consume unget char first
    if (f->unget != FILE_UNGET_EMPTY) {
        int64:ch = f->unget;
        f->unget    = FILE_UNGET_EMPTY;
        f->file_pos = f->file_pos + 1i64;
        pass ch;
    }

      // Unbuffered: read one uint8 directly from kernel
    if (f->buf_mode == _IONBF || f->buf == 0i64) {
        stack uint8[1]:one;
        while (true) {
            Result<int64>:r = sys_safe(SYS_READ, f->fd, @cast_unchecked<int64>(@one), 1i64, 0i64, 0i64, 0i64);
            if (r.is_error) {
                int64:e = @cast_unchecked<int64>(r.error);
                if (e == EINTR) { continue; }
                f->flags = f->flags | FILE_FLAG_ERROR;
                pass FILE_EOF;
            }
            if (r.value == 0i64) {
                f->flags = f->flags | FILE_FLAG_EOF;
                pass FILE_EOF;
            }
            f->file_pos = f->file_pos + 1i64;
            pass @cast_unchecked<int64>(one[0]);
        }
          // unreachable
        pass FILE_EOF;
    }

      // Buffered: refill if exhausted
    if (f->buf_pos >= f->buf_len) {
        Result<int64>:r = bio_refill_read_buf(fp);
        if (r.is_error) { pass FILE_EOF; }
        if (r.value == 0i64) {
            pass FILE_EOF;
        }
    }

      // Return next uint8 from buffer
    uint8:ch = (@cast_unchecked<uint8->>(f->buf))[f->buf_pos];
    f->buf_pos  = f->buf_pos + 1i64;
    f->file_pos = f->file_pos + 1i64;
    pass @cast_unchecked<int64>(ch);
};

// ════════════════════════════════════════════════════════════════════════════
// fputc — Write one character c to fp.
//
// Returns c on success, or FILE_EOF (-1) on error.
//
// For line-buffered streams: triggers a flush if c is '\n'.
// ════════════════════════════════════════════════════════════════════════════

pub func:fputc = int64(int64:c, int64:fp) {
    if (fp == 0i64) {
        pass FILE_EOF;
    }

    FILE->:f = @cast_unchecked<FILE->>(fp);

    if ((f->mode & FILE_MODE_WRITE) == 0i64) {
        f->flags = f->flags | FILE_FLAG_ERROR;
        drop(errno_set(EBADF));
        pass FILE_EOF;
    }

      // If read buffer has pending bytes, discard before writing
    if ((f->flags & FILE_FLAG_WRITE_MODE) == 0i64 && f->buf_len > f->buf_pos) {
        drop(bio_discard_read_buf(fp));
    }
    f->flags = f->flags | FILE_FLAG_WRITE_MODE;

    uint8:b = @cast_unchecked<uint8>(c);

      // Unbuffered: single-uint8 write directly to kernel
    if (f->buf_mode == _IONBF || f->buf == 0i64) {
        stack uint8[1]:one;
        one[0] = b;
        while (true) {
            Result<int64>:r = sys_safe(SYS_WRITE, f->fd, @cast_unchecked<int64>(@one), 1i64, 0i64, 0i64, 0i64);
            if (r.is_error) {
                int64:e = @cast_unchecked<int64>(r.error);
                if (e == EINTR) { continue; }
                f->flags = f->flags | FILE_FLAG_ERROR;
                pass FILE_EOF;
            }
            f->file_pos = f->file_pos + 1i64;
            pass c & 0xFFi64;
        }
          // unreachable
        pass FILE_EOF;
    }

      // Buffer full: flush first
    if (f->buf_pos >= f->buf_cap) {
        Result<int64>:r = bio_flush_write_buf(fp);
        if (r.is_error) {
            pass FILE_EOF;
        }
    }

      // Write to buffer
    (@cast_unchecked<uint8->>(f->buf))[f->buf_pos] = b;
    f->buf_pos = f->buf_pos + 1i64;
    f->buf_len = f->buf_pos;

      // Line-buffered: flush on '\n'
    if (f->buf_mode == _IOLBF && b == 10u8) {
        Result<int64>:r = bio_flush_write_buf(fp);
        if (r.is_error) {
            pass FILE_EOF;
        }
    }

    pass c & 0xFFi64;
};

// ════════════════════════════════════════════════════════════════════════════
// getc / putc — Aliases for fgetc / fputc.
//
// In C, these are typically macros that inline the buffer fast path.
// In libn at v0.5.5 they are function wrappers. The macro/inline optimization
// is deferred to v0.6.x.
// ════════════════════════════════════════════════════════════════════════════

pub func:getc = int64(int64:fp) {
    pass fgetc(fp);
};

pub func:putc = int64(int64:c, int64:fp) {
    pass fputc(c, fp);
};

// ════════════════════════════════════════════════════════════════════════════
// getchar / putchar — Read/write one character from/to stdin/stdout.
//
// These reference the global stdin/stdout from stdfiles.npk.
// The dependency is declared via use "../../io/bio/stdfiles.npk".* in bio.npk;
// here we forward-reference via the extern pattern common in libn.
// ════════════════════════════════════════════════════════════════════════════

// getchar and putchar are defined in stdfiles.npk where stdin/stdout are available.
// See bio.npk for the wiring.

// ════════════════════════════════════════════════════════════════════════════
// ungetc — Push a character back into the stream's input.
//
// The pushed-back character will be returned by the NEXT call to fgetc/fread.
// Only one character of pushback is guaranteed (POSIX minimum).
//
// ungetc(EOF, fp) is a no-op and returns EOF.
// Calling fseek/fsetpos discards any pushed-back character.
//
// Returns the character pushed back (as unsigned uint8 value), or EOF on error.
// ════════════════════════════════════════════════════════════════════════════

pub func:ungetc = int64(int64:c, int64:fp) {
    if (fp == 0i64) {
        pass FILE_EOF;
    }

      // ungetc(EOF) is always a no-op
    if (c == FILE_EOF || c < 0i64) {
        pass FILE_EOF;
    }

    FILE->:f = @cast_unchecked<FILE->>(fp);

    if ((f->mode & FILE_MODE_READ) == 0i64) {
        pass FILE_EOF;
    }

      // Only one pushback slot available
    if (f->unget != FILE_UNGET_EMPTY) {
          // Already have a pushed-back character — POSIX doesn't require more.
        pass FILE_EOF;
    }

    f->unget = c & 0xFFi64;

      // Un-advance the logical file position (POSIX: ungetc moves position back one)
    if (f->file_pos > 0i64) {
        f->file_pos = f->file_pos - 1i64;
    }

      // Clear EOF flag — stream is now readable again (POSIX requirement)
    f->flags = f->flags & (0i64 - 1i64 ^ FILE_FLAG_EOF);

    pass c & 0xFFi64;
};

// fstr.npk — fgets, fputs, fgetln (v0.5.6)
//
// String-level I/O built on top of fgetc/fputc.
//
// fgets:
//   Reads at most size-1 characters from fp into buf, stopping at '\n' (which IS
//   stored in buf), EOF, or the buffer limit. Always NUL-terminates on success.
//   Returns buf pointer (as int64) on success, or 0 (NULL) on EOF or error.
//
// fputs:
//   Writes the NUL-terminated string s to fp (without the NUL terminator).
//   Does NOT append a newline (unlike puts()).
//   Returns a non-negative number on success, EOF on error.
//
// puts:
//   Writes s to stdout followed by a newline '\n'. Equivalent to:
//     fputs(s, stdout); fputc('\n', stdout);
//   Returns non-negative on success, EOF on error.
//
// gets: INTENTIONALLY OMITTED — gets() is removed from C11 and is unsafe.
//       Use fgets(buf, size, stdin) instead.

use "../../mem/mmap.npk".*;
use "../../syscall/syscall_numbers.npk".*;
use "../../syscall/syscall.npk".*;
use "../../syscall/errno.npk".*;
use "../../mem/memcpy.npk".*;
use "../../mem/memutil.npk".*;
use "../../str/strlen.npk".*;
use "../../io/bio/file.npk".*;
use "../../io/bio/fio.npk".*;
use "../../io/bio/fchar.npk".*;

// ════════════════════════════════════════════════════════════════════════════
// fgets — Read a line from fp into buf.
//
// Reads at most (size - 1) characters. Stops at '\n' (inclusive) or EOF.
// Always NUL-terminates the buffer if any characters were read.
//
// Returns buf (as int64) on success, or 0 on EOF (with no characters read)
// or on error.
//
// Unlike io_read_line (which works on raw fds), fgets goes through the FILE
// buffer and correctly handles unget chars and EOF state.
// ════════════════════════════════════════════════════════════════════════════

pub func:fgets = int64(int64:buf, int64:size, int64:fp) {
    if (buf == 0i64 || size <= 0i64 || fp == 0i64) {
        pass 0i64;
    }
    if (size == 1i64) {
          // Only room for the NUL terminator — store it and return buf
        (@cast_unchecked<uint8->>(buf))[0] = 0u8;
        pass buf;
    }

    FILE->:f = @cast_unchecked<FILE->>(fp);

      // Already at EOF with nothing to give
    if ((f->flags & FILE_FLAG_EOF) != 0i64 && f->unget == FILE_UNGET_EMPTY && f->buf_len <= f->buf_pos) {
        pass 0i64;
    }

    uint8->:dst = @cast_unchecked<uint8->>(buf);
    int64:max = size - 1i64;    // leave room for NUL
    int64:count = 0i64;

    if (f->unget != FILE_UNGET_EMPTY) {
        int64:c = f->unget;
        f->unget = FILE_UNGET_EMPTY;
        f->file_pos = f->file_pos + 1i64;
        dst[count] = @cast_unchecked<uint8>(c);
        count = count + 1i64;
        if (c == 10i64) {
            dst[count] = 0u8;
            pass buf;
        }
    }

    while (count < max) {
        int64:avail = f->buf_len - f->buf_pos;
        if (avail <= 0i64) {
            Result<int64>:rr = bio_refill_read_buf(fp);
            if (rr.is_error) {
                if (count == 0i64) { pass 0i64; }
                break;
            }
            if (rr.value == 0i64) {
                if (count == 0i64) { pass 0i64; }
                break;
            }
            avail = f->buf_len - f->buf_pos;
        }

        int64:needed = max - count;
        int64:chunk = is (avail < needed) : avail : needed;

        int64:nl_ptr = raw mem_memchr(f->buf + f->buf_pos, 10i64, chunk);
        if (nl_ptr != 0i64) {
            chunk = nl_ptr - (f->buf + f->buf_pos) + 1i64;
        }

        drop(mem_memcpy(buf + count, f->buf + f->buf_pos, chunk));
        f->buf_pos = f->buf_pos + chunk;
        f->file_pos = f->file_pos + chunk;
        count = count + chunk;

        if (nl_ptr != 0i64) {
            break;
        }
    }

    dst[count] = 0u8;    // NUL terminate
    pass buf;
};

// ════════════════════════════════════════════════════════════════════════════
// fputs — Write a NUL-terminated string to fp (without NUL terminator).
//
// Returns a non-negative value on success (libn returns the uint8 count written),
// or EOF on error.
//
// Does NOT append a newline. For newline-terminated output use puts() or
// fputc('\n', fp) explicitly.
// ════════════════════════════════════════════════════════════════════════════

pub func:fputs = int64(int64:s, int64:fp) {
    if (s == 0i64 || fp == 0i64) {
        pass FILE_EOF;
    }

    FILE->:f = @cast_unchecked<FILE->>(fp);

    if ((f->mode & FILE_MODE_WRITE) == 0i64) {
        f->flags = f->flags | FILE_FLAG_ERROR;
        drop(errno_set(EBADF));
        pass FILE_EOF;
    }

      // Use fwrite for bulk efficiency
    int64:len = raw str_strlen(s);
    if (len == 0i64) {
        pass 0i64;
    }

    int64:r = raw fwrite(s, 1i64, len, fp);
    if (r < len) {
        pass FILE_EOF;
    }
    pass len;
};

// ════════════════════════════════════════════════════════════════════════════
// puts — Write string to stdout, followed by a newline.
//
// Equivalent to: fputs(s, stdout); fputc('\n', stdout);
// Returns non-negative on success, EOF on error.
//
// The stdout reference is resolved by bio.npk which imports both this module
// and stdfiles.npk.
// ════════════════════════════════════════════════════════════════════════════

// puts is defined in stdfiles.npk where stdout is available.
// See that module and bio.npk.

// fio.npk — fread, fwrite, fflush (v0.5.2 / v0.5.3)
//
// Core buffered I/O: block reads and writes through the FILE buffer.
//
// fread:
//   1. Drain any unget char first.
//   2. Copy from read buffer until request satisfied or buffer empty.
//   3. If buffer empty: refill from kernel. For large requests (>= buf_cap),
//      bypass the buffer and read directly to caller's memory.
//   4. Track EOF and errors via FILE flags.
//
// fwrite:
//   1. If write-mode buffer not yet active (was in read mode), discard read buf.
//   2. Copy to write buffer until full, then flush.
//   3. For large requests (>= buf_cap), flush then write directly to kernel.
//   4. For line-buffered streams, flush on each '\n'.
//
// fflush:
//   For write-mode streams: flush write buffer to kernel.
//   For read-mode streams: seek back to discard prefetched bytes (POSIX-defined).
//   fflush(NULL): flush all open streams (not yet tracked at v0.5.x; flushes nothing extra).

use "../../mem/mmap.npk".*;
use "../../syscall/syscall_numbers.npk".*;
use "../../syscall/syscall.npk".*;
use "../../syscall/errno.npk".*;
use "../../syscall/posix_constants.npk".*;
use "../../syscall/syscall.npk".*;
use "../../mem/memcpy.npk".*;
use "../../io/bio/file.npk".*;


// ════════════════════════════════════════════════════════════════════════════
// fread — Read nmemb items of size bytes each from fp into buf.
//
// Returns the number of ITEMS (not bytes) successfully read.
// On short read: sets ferror or feof flag. Returns < nmemb.
//
// POSIX: fread() does not distinguish between EOF and error; use
// feof()/ferror() to find out which happened.
//
// Parameters:
//   buf:    destination memory pointer (as int64)
//   size:   size of each item in bytes
//   nmemb:  number of items to read
//   fp:     FILE* (as int64)
// ════════════════════════════════════════════════════════════════════════════

pub func:fread = int64(int64:buf, int64:size, int64:nmemb, int64:fp) {
    if (fp == 0i64 || buf == 0i64) {
        pass 0i64;
    }
    if (size == 0i64 || nmemb == 0i64) {
        pass 0i64;
    }

    FILE->:f = @cast_unchecked<FILE->>(fp);

      // Not readable?
    if ((f->mode & FILE_MODE_READ) == 0i64) {
        f->flags = f->flags | FILE_FLAG_ERROR;
        pass 0i64;
    }

      // If buffer is in write mode, we need to flush before switching to read
    if ((f->flags & FILE_FLAG_WRITE_MODE) != 0i64) {
        Result<int64>:r = bio_flush_write_buf(fp);
        if (r.is_error) {
            pass 0i64;
        }
    }

    int64:total_bytes = size * nmemb;
    int64:bytes_read  = 0i64;
    int64:dst         = buf;

      // 1. Consume any pending unget char
    if (f->unget != FILE_UNGET_EMPTY) {
        if (total_bytes > 0i64) {
            (@cast_unchecked<uint8->>(dst))[0] = @cast_unchecked<uint8>(f->unget);
            dst = dst + 1i64;
            bytes_read = bytes_read + 1i64;
            total_bytes = total_bytes - 1i64;
            f->unget = FILE_UNGET_EMPTY;
            f->file_pos = f->file_pos + 1i64;
        }
    }

      // 2. Copy from read buffer
    while (bytes_read < size * nmemb && (f->flags & (FILE_FLAG_EOF | FILE_FLAG_ERROR)) == 0i64) {
        int64:buffered = f->buf_len - f->buf_pos;

        if (buffered > 0i64) {
              // Bytes available in the buffer
            int64:remaining = size * nmemb - bytes_read;
            int64:to_copy = is (buffered < remaining) : buffered : remaining;
            drop(mem_memcpy(dst, f->buf + f->buf_pos, to_copy));
            f->buf_pos  = f->buf_pos + to_copy;
            f->file_pos = f->file_pos + to_copy;
            dst        = dst + to_copy;
            bytes_read = bytes_read + to_copy;
        } else {
              // Buffer exhausted — refill or bypass for large requests
            int64:remaining = size * nmemb - bytes_read;

            if (f->buf_mode == _IONBF || (f->buf != 0i64 && remaining >= f->buf_cap)) {
                  // Large request or unbuffered: read directly to caller's buffer
                Result<int64>:r = sys_safe(SYS_READ, f->fd, dst, remaining, 0i64, 0i64, 0i64);
                if (r.is_error) {
                    int64:e = @cast_unchecked<int64>(r.error);
                    if (e == EINTR) { continue; }
                    f->flags = f->flags | FILE_FLAG_ERROR;
                    break;
                }
                if (r.value == 0i64) {
                    f->flags = f->flags | FILE_FLAG_EOF;
                    break;
                }
                f->file_pos = f->file_pos + r.value;
                dst        = dst + r.value;
                bytes_read = bytes_read + r.value;
            } else {
                  // Normal: refill the buffer
                Result<int64>:r = bio_refill_read_buf(fp);
                if (r.is_error) {
                    break;    // flags already set by bio_refill_read_buf
                }
                if (r.value == 0i64) {
                    break;    // EOF
                }
                  // Loop around to copy from the newly filled buffer
            }
        }
    }

      // Return number of COMPLETE items read
    pass bytes_read / size;
};

// ════════════════════════════════════════════════════════════════════════════
// fwrite — Write nmemb items of size bytes from buf to fp.
//
// Returns the number of ITEMS (not bytes) successfully written.
// On short write: sets ferror flag. Returns < nmemb.
//
// For line-buffered streams: flushes the buffer on every '\n' encountered.
// For fully-buffered streams: flushes only when the buffer fills.
// For unbuffered streams: writes directly to the kernel each call.
// ════════════════════════════════════════════════════════════════════════════

pub func:fwrite = int64(int64:buf, int64:size, int64:nmemb, int64:fp) {
    if (fp == 0i64 || buf == 0i64) {
        pass 0i64;
    }
    if (size == 0i64 || nmemb == 0i64) {
        pass 0i64;
    }

    FILE->:f = @cast_unchecked<FILE->>(fp);

      // Not writable?
    if ((f->mode & FILE_MODE_WRITE) == 0i64) {
        f->flags = f->flags | FILE_FLAG_ERROR;
        pass 0i64;
    }

      // If read buffer has pending bytes, discard them before switching to write
    if ((f->flags & FILE_FLAG_WRITE_MODE) == 0i64 && f->buf_len > f->buf_pos) {
        drop(bio_discard_read_buf(fp));
    }
    f->flags = f->flags | FILE_FLAG_WRITE_MODE;

    int64:total_bytes  = size * nmemb;
    int64:bytes_written = 0i64;
    int64:src           = buf;

      // Unbuffered: write directly to kernel in one shot
    if (f->buf_mode == _IONBF || f->buf == 0i64) {
        while (bytes_written < total_bytes) {
            int64:remaining = total_bytes - bytes_written;
            Result<int64>:r = sys_safe(SYS_WRITE, f->fd, src, remaining, 0i64, 0i64, 0i64);
            if (r.is_error) {
                int64:e = @cast_unchecked<int64>(r.error);
                if (e == EINTR) { continue; }
                f->flags = f->flags | FILE_FLAG_ERROR;
                break;
            }
            f->file_pos    = f->file_pos + r.value;
            src            = src + r.value;
            bytes_written  = bytes_written + r.value;
        }
        pass bytes_written / size;
    }

      // Buffered write
    while (bytes_written < total_bytes && (f->flags & FILE_FLAG_ERROR) == 0i64) {
        int64:remaining  = total_bytes - bytes_written;
        int64:buf_space  = f->buf_cap - f->buf_pos;

        if (buf_space == 0i64) {
              // Buffer full — flush
            Result<int64>:r = bio_flush_write_buf(fp);
            if (r.is_error) {
                break;
            }
            continue;
        }

          // For large writes that exceed the buffer, flush and write directly
        if (remaining >= f->buf_cap && f->buf_pos == 0i64) {
            Result<int64>:wr = sys_safe(SYS_WRITE, f->fd, src, remaining, 0i64, 0i64, 0i64);
            if (wr.is_error) {
                int64:e = @cast_unchecked<int64>(wr.error);
                if (e == EINTR) { continue; }
                f->flags = f->flags | FILE_FLAG_ERROR;
                break;
            }
            f->file_pos    = f->file_pos + wr.value;
            src            = src + wr.value;
            bytes_written  = bytes_written + wr.value;
            continue;
        }

          // Copy into write buffer
        int64:to_copy = is (buf_space < remaining) : buf_space : remaining;

          // For line-buffered: scan for '\n' within the copy range
        if (f->buf_mode == _IOLBF) {
            int64:nl_pos = -1i64;
            int64:si = 0i64;
            while (si < to_copy) {
                if ((@cast_unchecked<uint8->>(src))[si] == 10u8) {    // '\n'
                    nl_pos = si;
                    break;
                }
                si = si + 1i64;
            }
            if (nl_pos >= 0i64) {
                  // Copy up to and including the newline, then flush
                int64:copy_to_nl = nl_pos + 1i64;
                drop(mem_memcpy(f->buf + f->buf_pos, src, copy_to_nl));
                f->buf_pos     = f->buf_pos + copy_to_nl;
                f->buf_len     = f->buf_pos;
                src           = src + copy_to_nl;
                bytes_written = bytes_written + copy_to_nl;
                  // Flush on '\n'
                drop(bio_flush_write_buf(fp));
                continue;
            }
        }

          // Normal copy into buffer
        drop(mem_memcpy(f->buf + f->buf_pos, src, to_copy));
        f->buf_pos     = f->buf_pos + to_copy;
        f->buf_len     = f->buf_pos;
        src           = src + to_copy;
        bytes_written = bytes_written + to_copy;
    }

    pass bytes_written / size;
};

// ════════════════════════════════════════════════════════════════════════════
// fflush — Flush buffered writes to the kernel.
//
// For write-mode streams: flush buf[0..buf_pos] to fd.
// For read-mode streams: seek back over unread buffered bytes (POSIX behavior;
//                        fails silently on non-seekable fds).
// fflush(0 / NULL): at v0.5.3, this is a no-op (no global stream list yet).
//                   v0.5.10 will implement proper global fflush.
//
// Returns 0 on success, EOF on error.
// ════════════════════════════════════════════════════════════════════════════

pub func:fflush = int64(int64:fp) {
    if (fp == 0i64) {
        int64:curr = g_open_files;
        int64:err_ret = 0i64;
        while (curr != 0i64) {
            FILE->:curr_f = @cast_unchecked<FILE->>(curr);
            if ((curr_f->flags & FILE_FLAG_WRITE_MODE) != 0i64) {
                Result<int64>:r = bio_flush_write_buf(curr);
                if (r.is_error) { err_ret = FILE_EOF; }
            }
            curr = curr_f->next_global;
        }
        pass err_ret;
    }

    FILE->:f = @cast_unchecked<FILE->>(fp);

    if (f->fd < 0i64) {
        drop(errno_set(EBADF));
        pass FILE_EOF;
    }

    if ((f->flags & FILE_FLAG_WRITE_MODE) != 0i64) {
          // Flush write buffer
        Result<int64>:r = bio_flush_write_buf(fp);
        if (r.is_error) {
            drop(errno_set(@cast_unchecked<int64>(r.error)));
            pass FILE_EOF;
        }
    } else {
          // Read mode: seek back over unconsumed read buffer
        drop(bio_discard_read_buf(fp));
    }

    pass 0i64;
};

// fprintf.npk — fprintf, printf, asprintf to FILE* streams (v0.6.0)
//
// Provides the stream-aware formatted output family, parallel to the fd-level
// io_fprintf* family in src/io/printf.npk.
//
// Architecture:
//   Each function renders into a 4096-uint8 stack buffer via the existing
//   str_snprintfN engine, then emits the result via fwrite().
//   This reuses all format specifier logic from strfmt.npk without duplication.
//
// Naming:
//   fprintf0..8  — FILE* versions of io_fprintf (fp + fmt + N args)
//   printf0..8   — to stdout (std stream, not raw fd)
//   eprintf0..8  — to stderr (std stream, not raw fd)
//
// vs. the existing io_printf* family:
//   io_printf* in printf.npk targets raw fds (int64:fd).
//   fprintf* here targets FILE* streams (int64:fp), going through the
//   FILE buffer and eventually the bio/ write path.
//   Use fprintf* for code that already uses FILE* streams; io_fprintf* for
//   code that works at the raw fd level.
//
// asprintf:
//   Renders into a heap-allocated buffer sized to exactly fit the output.
//   The caller is responsible for freeing the returned buffer via mem_free().
//   Returns the buffer pointer (as int64) and writes the length to *out_len.
//
// Thread safety: inherits FILE*'s non-thread-safe status at v0.6.x.

use "../../mem/mmap.npk".*;
use "../../mem/memcpy.npk".*;
use "../../syscall/syscall_numbers.npk".*;
use "../../syscall/syscall.npk".*;
use "../../syscall/errno.npk".*;
use "../../str/strfmt.npk".*;
use "../../str/strlen.npk".*;
use "../../mem/slab.npk".*;
use "../../io/bio/file.npk".*;
use "../../io/bio/fio.npk".*;
use "../../io/bio/stdfiles.npk".*;

// Internal render buffer — @cast_unchecked<printf>(same).npk
fixed int64:FPRINTF_BUF_SIZE = 4096i64;

// ════════════════════════════════════════════════════════════════════════════
// Internal helper: render into stack buffer, emit via fwrite.
//
// Returns number of bytes written, or -1 on error.
// We use int64 (not Result) for direct POSIX-style return value.
// ════════════════════════════════════════════════════════════════════════════

func:bio_fprint_rendered = int64(int64:fp, int64:rendered_buf, int64:len) {
    if (len <= 0i64) {
        pass 0i64;
    }
    int64:written = raw fwrite(rendered_buf, 1i64, len, fp);
    if (written < len) {
        pass -1i64;
    }
    pass written;
};

// ════════════════════════════════════════════════════════════════════════════
// fprintf — Write a formatted string to a FILE* stream.
//
// 0 format arguments
// ════════════════════════════════════════════════════════════════════════════

pub func:fprintf0 = int64(int64:fp, int64:fmt) {
    drop(bio_ensure_std_init());
    stack uint8[4096]:buf;
    int64:buf_ptr = @cast_unchecked<int64>(@buf);
    int64:len = raw str_snprintf0(buf_ptr, FPRINTF_BUF_SIZE, fmt);
    pass bio_fprint_rendered(fp, buf_ptr, len);
};

pub func:printf0 = int64(int64:fmt) {
    drop(bio_ensure_std_init());
    pass fprintf0(stdout_fp, fmt);
};

pub func:eprintf0 = int64(int64:fmt) {
    drop(bio_ensure_std_init());
    pass fprintf0(stderr_fp, fmt);
};

// ────────────────────────────────────────────────────────────────────────────
// 1 format argument
// ────────────────────────────────────────────────────────────────────────────

pub func:fprintf1 = int64(int64:fp, int64:fmt, int64:a0) {
    drop(bio_ensure_std_init());
    stack uint8[4096]:buf;
    int64:buf_ptr = @cast_unchecked<int64>(@buf);
    int64:len = raw str_snprintf1(buf_ptr, FPRINTF_BUF_SIZE, fmt, a0);
    pass bio_fprint_rendered(fp, buf_ptr, len);
};

pub func:printf1 = int64(int64:fmt, int64:a0) {
    drop(bio_ensure_std_init());
    pass fprintf1(stdout_fp, fmt, a0);
};

pub func:eprintf1 = int64(int64:fmt, int64:a0) {
    drop(bio_ensure_std_init());
    pass fprintf1(stderr_fp, fmt, a0);
};

// ────────────────────────────────────────────────────────────────────────────
// 2 format arguments
// ────────────────────────────────────────────────────────────────────────────

pub func:fprintf2 = int64(int64:fp, int64:fmt, int64:a0, int64:a1) {
    drop(bio_ensure_std_init());
    stack uint8[4096]:buf;
    int64:buf_ptr = @cast_unchecked<int64>(@buf);
    int64:len = raw str_snprintf2(buf_ptr, FPRINTF_BUF_SIZE, fmt, a0, a1);
    pass bio_fprint_rendered(fp, buf_ptr, len);
};

pub func:printf2 = int64(int64:fmt, int64:a0, int64:a1) {
    drop(bio_ensure_std_init());
    pass fprintf2(stdout_fp, fmt, a0, a1);
};

