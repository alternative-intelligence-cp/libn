// test_mem.npk — Memory primitive test suite (v0.2.x)
//
// Tests for v0.2.0 through v0.2.5:
//   - Page alignment helpers (page_align_up/down, is_page_aligned)
//   - Direct-mmap allocator (mem_malloc, mem_free, mem_calloc, mem_realloc)
//   - Allocation header integrity (user_size, map_size reads)
//   - NULL-free is a no-op
//   - Double-free detection
//   - Guard page allocation
//   - Slab allocator (slab_alloc, slab_free) for all 9 size classes
//   - Slab zero-init (slab_alloc_zero)
//   - Slab large-object fallback to direct mmap
//   - mem_memset: basic fill, word-aligned fill, zero fill, tail bytes
//   - mem_bzero: equivalent to memset(ptr, 0, n)
//   - mem_memset_explicit: fills correctly (volatility not directly testable)
//   - mem_memcpy: forward copy, byte-by-byte, word-aligned, n=0
//   - mem_memmove: non-overlapping, forward overlap, backward overlap
//   - mem_mempcpy: returns dst+n
//   - mem_memcmp: equal, less-than, greater-than, word-aligned, n=0
//   - mem_memcmp_ct: same as memcmp but always full scan
//   - mem_memchr: found at start, middle, end, not found, n=0
//   - mem_memrchr: found, last of duplicates, not found
//   - mem_memmem: found, not found, needle=haystack, zero-len needle
//   - mem_is_zero: all-zero, non-zero, partial
//   - mem_swap: non-overlapping, word-aligned
//   - mem_reverse: even length, odd length, single byte, empty
//   - mem_align_ptr, mem_is_aligned

use "tests/harness/test_harness.npk".*;
use "src/syscall/errno.npk".*;
use "src/syscall/posix_constants.npk".*;
use "src/mem/mmap.npk".*;
use "src/mem/slab.npk".*;
use "src/mem/memset.npk".*;
use "src/mem/memcpy.npk".*;
use "src/mem/memutil.npk".*;

// ── helpers ──────────────────────────────────────────────────────────────

// fill_seq — Fill buf with bytes 0, 1, 2, ..., n-1 (mod 256).
func:fill_seq = void(*byte:buf, int64:n) {
    int64:i = 0i64;
    while i < n {
        buf[i] = (i % 256i64) as byte;
        i = i + 1i64;
    }
}

func:main = int32(argc, argv) {
    t_begin("v0.2.x — Memory Primitives");

    // ── v0.2.0: Page alignment helpers ──────────────────────────────────
    t_section("Page alignment helpers");

    t_assert_eq_i64(raw page_align_up(0i64),    0i64,    "page_align_up(0)==0");
    t_assert_eq_i64(raw page_align_up(1i64),    4096i64, "page_align_up(1)==4096");
    t_assert_eq_i64(raw page_align_up(4095i64), 4096i64, "page_align_up(4095)==4096");
    t_assert_eq_i64(raw page_align_up(4096i64), 4096i64, "page_align_up(4096)==4096");
    t_assert_eq_i64(raw page_align_up(4097i64), 8192i64, "page_align_up(4097)==8192");
    t_assert_eq_i64(raw page_align_up(8192i64), 8192i64, "page_align_up(8192)==8192");

    t_assert_eq_i64(raw page_align_down(0i64),    0i64,    "page_align_down(0)==0");
    t_assert_eq_i64(raw page_align_down(4096i64), 4096i64, "page_align_down(4096)==4096");
    t_assert_eq_i64(raw page_align_down(4095i64), 0i64,    "page_align_down(4095)==0");
    t_assert_eq_i64(raw page_align_down(4097i64), 4096i64, "page_align_down(4097)==4096");
    t_assert_eq_i64(raw page_align_down(8191i64), 4096i64, "page_align_down(8191)==4096");

    t_assert(raw is_page_aligned(0i64),    "is_page_aligned(0)");
    t_assert(raw is_page_aligned(4096i64), "is_page_aligned(4096)");
    t_assert(!raw is_page_aligned(1i64),   "!is_page_aligned(1)");
    t_assert(!raw is_page_aligned(4095i64),"!is_page_aligned(4095)");

    t_assert_eq_i64(raw size_align_up(0i64, 8i64),  0i64,  "size_align_up(0,8)==0");
    t_assert_eq_i64(raw size_align_up(1i64, 8i64),  8i64,  "size_align_up(1,8)==8");
    t_assert_eq_i64(raw size_align_up(7i64, 8i64),  8i64,  "size_align_up(7,8)==8");
    t_assert_eq_i64(raw size_align_up(8i64, 8i64),  8i64,  "size_align_up(8,8)==8");
    t_assert_eq_i64(raw size_align_up(9i64, 8i64),  16i64, "size_align_up(9,8)==16");
    t_assert_eq_i64(raw size_align_up(3i64, 16i64), 16i64, "size_align_up(3,16)==16");

    // ── v0.2.1: Direct-mmap allocator ────────────────────────────────────
    t_section("mem_malloc / mem_free");

    // Basic allocation — must succeed and return valid pointer
    Result<int64>:r1 = mem_malloc(1i64);
    t_assert_ok(r1, "mem_malloc(1) succeeds");
    t_assert(r1.value != 0i64, "mem_malloc(1) != NULL");

    // The returned memory must be zero-initialized (mmap guarantees this)
    *byte:p1 = r1.value as *byte;
    t_assert(p1[0] == 0u8, "mem_malloc: first byte is zero");

    // Write to it and read back
    p1[0] = 0x42u8;
    t_assert(p1[0] == 0x42u8, "mem_malloc: write+read byte 0");

    // header: user_size must equal what we requested
    Result<int64>:us = mem_malloc_user_size(r1.value);
    t_assert_ok(us, "mem_malloc_user_size succeeds");
    t_assert_eq_i64(us.value, 1i64, "user_size == 1 for mem_malloc(1)");

    // header: map_size must be >= ALLOC_HEADER_SIZE + 1 and page-aligned
    Result<int64>:ms = mem_malloc_map_size(r1.value);
    t_assert_ok(ms, "mem_malloc_map_size succeeds");
    t_assert(ms.value >= 4096i64, "map_size >= PAGE_SIZE");
    t_assert(raw is_page_aligned(ms.value), "map_size is page-aligned");

    // Free it — must succeed
    Result<int64>:fr1 = mem_free(r1.value);
    t_assert_ok(fr1, "mem_free succeeds for 1-byte allocation");

    // Larger allocation
    Result<int64>:r2 = mem_malloc(65536i64);
    t_assert_ok(r2, "mem_malloc(64KB) succeeds");
    *byte:p2 = r2.value as *byte;
    p2[0]     = 0xAAu8;
    p2[65535] = 0xBBu8;
    t_assert(p2[0] == 0xAAu8,     "mem_malloc(64KB): first byte write");
    t_assert(p2[65535] == 0xBBu8, "mem_malloc(64KB): last byte write");
    Result<int64>:us2 = mem_malloc_user_size(r2.value);
    t_assert_eq_i64(us2.value, 65536i64, "user_size==65536 for mem_malloc(64KB)");
    mem_free(r2.value);

    // NULL free is a no-op
    Result<int64>:nfr = mem_free(0i64);
    t_assert_ok(nfr, "mem_free(NULL) is a no-op (returns success)");

    // mem_calloc
    t_section("mem_calloc");
    Result<int64>:rc = mem_calloc(4i64, 16i64);  // 64 bytes
    t_assert_ok(rc, "mem_calloc(4, 16) succeeds");
    *byte:pc = rc.value as *byte;
    bool:all_zero = true;
    int64:ci = 0i64;
    while ci < 64i64 {
        if pc[ci] != 0u8 { all_zero = false; }
        ci = ci + 1i64;
    }
    t_assert(all_zero, "mem_calloc: all 64 bytes are zero");
    mem_free(rc.value);

    // mem_calloc overflow check
    Result<int64>:rcov = mem_calloc(9223372036854775807i64, 2i64);
    t_assert(rcov.is_error, "mem_calloc(MAX_INT64, 2) → overflow error");

    // mem_realloc
    t_section("mem_realloc");
    Result<int64>:rr = mem_malloc(100i64);
    t_assert_ok(rr, "malloc(100) for realloc test");
    *byte:pr = rr.value as *byte;
    pr[0]  = 0x11u8;
    pr[99] = 0x22u8;

    Result<int64>:rr2 = mem_realloc(rr.value, 200i64);
    t_assert_ok(rr2, "mem_realloc(100→200) succeeds");
    *byte:pr2 = rr2.value as *byte;
    t_assert(pr2[0]  == 0x11u8, "realloc: byte[0] preserved");
    t_assert(pr2[99] == 0x22u8, "realloc: byte[99] preserved");
    mem_free(rr2.value);

    // realloc NULL → malloc
    Result<int64>:rr3 = mem_realloc(0i64, 50i64);
    t_assert_ok(rr3, "mem_realloc(NULL, 50) behaves like malloc");
    t_assert(rr3.value != 0i64, "mem_realloc(NULL, 50) non-NULL");
    mem_free(rr3.value);

    // realloc to 0 → free + NULL
    Result<int64>:rr4_alloc = mem_malloc(8i64);
    Result<int64>:rr4 = mem_realloc(rr4_alloc.value, 0i64);
    t_assert_ok(rr4, "mem_realloc(ptr, 0) succeeds");
    t_assert_eq_i64(rr4.value, 0i64, "mem_realloc(ptr, 0) returns NULL");

    // ── v0.2.2: Slab allocator ────────────────────────────────────────────
    t_section("Slab allocator — class boundaries");

    // Class 0: ≤8 bytes
    Result<int64>:s0 = slab_alloc(8i64);
    t_assert_ok(s0, "slab_alloc(8) succeeds");
    t_assert(s0.value != 0i64, "slab_alloc(8) non-NULL");
    *(s0.value as *byte)[0] = 0xAAu8;
    t_assert((s0.value as *byte)[0] == 0xAAu8, "slab class 0: read-after-write");

    // Class 1: ≤16 bytes
    Result<int64>:s1 = slab_alloc(16i64);
    t_assert_ok(s1, "slab_alloc(16) succeeds");

    // Class 4: ≤128 bytes
    Result<int64>:s4 = slab_alloc(128i64);
    t_assert_ok(s4, "slab_alloc(128) succeeds");
    *(s4.value as *byte)[127] = 0xFFu8;
    t_assert((s4.value as *byte)[127] == 0xFFu8, "slab class 4: last byte");

    // Class 8: ≤2048 bytes
    Result<int64>:s8 = slab_alloc(2048i64);
    t_assert_ok(s8, "slab_alloc(2048) succeeds");
    *(s8.value as *byte)[2047] = 0x77u8;
    t_assert((s8.value as *byte)[2047] == 0x77u8, "slab class 8: last byte");

    // Large allocation (>2048): goes through direct mmap
    Result<int64>:sbig = slab_alloc(4096i64);
    t_assert_ok(sbig, "slab_alloc(4096) succeeds (→ direct mmap)");

    // slab_alloc_zero: returned memory must be zeroed
    t_section("slab_alloc_zero");
    Result<int64>:sz = slab_alloc_zero(64i64);
    t_assert_ok(sz, "slab_alloc_zero(64) succeeds");
    bool:slab_zero = true;
    int64:szi = 0i64;
    while szi < 64i64 {
        if (sz.value as *byte)[szi] != 0u8 { slab_zero = false; }
        szi = szi + 1i64;
    }
    t_assert(slab_zero, "slab_alloc_zero(64): all bytes zero");

    // slab_free then re-alloc — freelist recycle
    t_section("Slab freelist recycling");
    int64:recycled_ptr = s0.value;
    slab_free(s0.value);
    Result<int64>:s0b = slab_alloc(7i64);  // same class, should get recycled slot
    t_assert_ok(s0b, "slab_alloc(7) after free succeeds");
    // We can't guarantee the exact pointer returned (slab may have grown)
    // but allocation should succeed and be writable.
    *(s0b.value as *byte)[0] = 0x55u8;
    t_assert((s0b.value as *byte)[0] == 0x55u8, "recycled slab slot: writable");

    // Clean up remaining live slab allocations
    slab_free(s1.value);
    slab_free(s4.value);
    slab_free(s8.value);
    slab_free(sbig.value);
    slab_free(sz.value);
    slab_free(s0b.value);

    // ── v0.2.3: memset ────────────────────────────────────────────────────
    t_section("mem_memset");

    // Allocate a buffer to test on
    Result<int64>:msbuf = mem_malloc(256i64);
    t_assert_ok(msbuf, "malloc(256) for memset tests");
    int64:buf256 = msbuf.value;

    // Fill with 0xAB
    Result<int64>:msr = mem_memset(buf256, 0xABi64, 256i64);
    t_assert_ok(msr, "mem_memset(256, 0xAB) succeeds");
    t_assert_eq_i64(msr.value, buf256, "mem_memset returns ptr");
    *byte:bp256 = buf256 as *byte;
    t_assert(bp256[0]   == 0xABu8, "memset: byte[0] == 0xAB");
    t_assert(bp256[127] == 0xABu8, "memset: byte[127] == 0xAB");
    t_assert(bp256[255] == 0xABu8, "memset: byte[255] == 0xAB");

    // Fill with 0 (zero the buffer)
    mem_memset(buf256, 0i64, 256i64);
    t_assert(raw mem_is_zero(buf256, 256i64), "memset(0): all zero");

    // Fill 1 byte (tail only, no word loop)
    mem_memset(buf256, 0x77i64, 1i64);
    t_assert(bp256[0] == 0x77u8, "memset 1 byte: byte[0]");
    t_assert(bp256[1] == 0x00u8, "memset 1 byte: byte[1] unchanged");

    // Fill unaligned start (5 bytes at offset +3)
    // Reset first
    mem_memset(buf256, 0i64, 256i64);
    mem_memset(buf256 + 3i64, 0xCCi64, 5i64);
    t_assert(bp256[2] == 0x00u8, "memset offset 3..7: byte[2] untouched");
    t_assert(bp256[3] == 0xCCu8, "memset offset 3..7: byte[3] == 0xCC");
    t_assert(bp256[7] == 0xCCu8, "memset offset 3..7: byte[7] == 0xCC");
    t_assert(bp256[8] == 0x00u8, "memset offset 3..7: byte[8] untouched");

    // mem_bzero
    t_section("mem_bzero");
    mem_memset(buf256, 0xFFi64, 256i64);  // fill with 0xFF first
    mem_bzero(buf256, 256i64);
    t_assert(raw mem_is_zero(buf256, 256i64), "mem_bzero: all zero");

    // ── v0.2.4: memcpy / memmove ──────────────────────────────────────────
    t_section("mem_memcpy");

    Result<int64>:srcbuf = mem_malloc(256i64);
    Result<int64>:dstbuf = mem_malloc(256i64);
    t_assert_ok(srcbuf, "malloc src buffer");
    t_assert_ok(dstbuf, "malloc dst buffer");
    int64:srcp = srcbuf.value;
    int64:dstp = dstbuf.value;

    // Fill src with sequential pattern
    fill_seq(srcp as *byte, 256i64);

    // Copy 256 bytes
    Result<int64>:cp1 = mem_memcpy(dstp, srcp, 256i64);
    t_assert_ok(cp1, "mem_memcpy(256) succeeds");
    t_assert_eq_i64(cp1.value, dstp, "mem_memcpy returns dst");
    t_assert(raw mem_memcmp(dstp, srcp, 256i64) == 0i64, "mem_memcpy: 256-byte match");

    // n=0: no memory access, returns dst
    Result<int64>:cp0 = mem_memcpy(dstp, srcp, 0i64);
    t_assert_ok(cp0, "mem_memcpy(n=0) succeeds");
    t_assert_eq_i64(cp0.value, dstp, "mem_memcpy(n=0) returns dst");

    // Copy 1 byte
    mem_bzero(dstp, 256i64);
    mem_memcpy(dstp, srcp, 1i64);
    t_assert((dstp as *byte)[0] == (srcp as *byte)[0], "mem_memcpy(1): byte[0]");
    t_assert((dstp as *byte)[1] == 0u8, "mem_memcpy(1): byte[1] untouched");

    // Unaligned src (src+3) → dst
    mem_bzero(dstp, 256i64);
    Result<int64>:cpu = mem_memcpy(dstp, srcp + 3i64, 13i64);
    t_assert_ok(cpu, "mem_memcpy(unaligned src) succeeds");
    t_assert((dstp as *byte)[0]  == (srcbuf.value as *byte)[3],  "memcpy unaligned: byte[0]");
    t_assert((dstp as *byte)[12] == (srcbuf.value as *byte)[15], "memcpy unaligned: byte[12]");
    t_assert((dstp as *byte)[13] == 0u8, "memcpy unaligned: byte[13] untouched");

    // mem_mempcpy returns dst+n
    t_section("mem_mempcpy");
    mem_bzero(dstp, 256i64);
    fill_seq(srcp as *byte, 256i64);
    Result<int64>:cpp = mem_mempcpy(dstp, srcp, 10i64);
    t_assert_ok(cpp, "mem_mempcpy(10) succeeds");
    t_assert_eq_i64(cpp.value, dstp + 10i64, "mem_mempcpy returns dst+n");
    t_assert((dstp as *byte)[9] == (srcbuf.value as *byte)[9], "mem_mempcpy: last byte correct");

    // mem_memmove — no overlap
    t_section("mem_memmove — non-overlapping");
    fill_seq(srcbuf.value as *byte, 256i64);
    mem_bzero(dstp, 256i64);
    Result<int64>:mv1 = mem_memmove(dstp, srcbuf.value, 256i64);
    t_assert_ok(mv1, "mem_memmove(256, no overlap) succeeds");
    t_assert(raw mem_memcmp(dstp, srcbuf.value, 256i64) == 0i64, "memmove: 256-byte match");

    // mem_memmove — forward overlap (dst < src, dst within src's range)
    t_section("mem_memmove — forward overlap (dst < src, overlapping)");
    // Use a single buffer. Pattern: 0,1,2,...,127 in [0..127]
    Result<int64>:ovbuf = mem_malloc(256i64);
    t_assert_ok(ovbuf, "malloc(256) for overlap test");
    *byte:ov = ovbuf.value as *byte;
    fill_seq(ovbuf.value as *byte, 128i64);
    // memmove(buf+0, buf+10, 100): copies bytes 10..109 to 0..99
    // dst < src, no clobber risk — forward copy is fine
    mem_memmove(ovbuf.value, ovbuf.value + 10i64, 100i64);
    t_assert(ov[0] == 10u8, "memmove fwd overlap: byte[0]==10");
    t_assert(ov[99] == 109u8, "memmove fwd overlap: byte[99]==109");

    // mem_memmove — backward overlap (dst > src, within overlap)
    t_section("mem_memmove — backward overlap (dst > src, clobber risk)");
    fill_seq(ovbuf.value as *byte, 128i64);
    // memmove(buf+10, buf+0, 100): copies 0..99 to 10..109
    // dst > src, regions overlap → must copy backward
    mem_memmove(ovbuf.value + 10i64, ovbuf.value, 100i64);
    t_assert(ov[10] == 0u8,  "memmove bwd overlap: dst[0]==0");
    t_assert(ov[109] == 99u8, "memmove bwd overlap: dst[99]==99");

    mem_free(ovbuf.value);

    // ── v0.2.5: memcmp / memchr / memutil ────────────────────────────────
    t_section("mem_memcmp");

    // Equal arrays
    fill_seq(srcbuf.value as *byte, 64i64);
    fill_seq(dstbuf.value as *byte, 64i64);
    t_assert_eq_i64(raw mem_memcmp(srcbuf.value, dstbuf.value, 64i64), 0i64, "memcmp equal == 0");

    // n=0: always equal
    t_assert_eq_i64(raw mem_memcmp(srcbuf.value, dstbuf.value, 0i64), 0i64, "memcmp(n=0) == 0");

    // First byte differs: a < b
    (srcbuf.value as *byte)[0] = 0u8;
    (dstbuf.value as *byte)[0] = 1u8;
    t_assert(raw mem_memcmp(srcbuf.value, dstbuf.value, 64i64) < 0i64, "memcmp a<b returns <0");

    // First byte differs: a > b
    t_assert(raw mem_memcmp(dstbuf.value, srcbuf.value, 64i64) > 0i64, "memcmp a>b returns >0");

    // Last byte differs
    fill_seq(srcbuf.value as *byte, 64i64);
    fill_seq(dstbuf.value as *byte, 64i64);
    (srcbuf.value as *byte)[63] = 0xFFu8;
    t_assert(raw mem_memcmp(srcbuf.value, dstbuf.value, 64i64) > 0i64, "memcmp last byte differs");

    // mem_memcmp_ct
    t_section("mem_memcmp_ct (constant-time)");
    fill_seq(srcbuf.value as *byte, 32i64);
    fill_seq(dstbuf.value as *byte, 32i64);
    t_assert_eq_i64(raw mem_memcmp_ct(srcbuf.value, dstbuf.value, 32i64), 0i64, "memcmp_ct equal == 0");
    (dstbuf.value as *byte)[15] = 0xFFu8;
    t_assert(raw mem_memcmp_ct(srcbuf.value, dstbuf.value, 32i64) != 0i64, "memcmp_ct differ != 0");

    // mem_memchr
    t_section("mem_memchr");
    fill_seq(srcbuf.value as *byte, 64i64);  // bytes 0..63

    // Find byte 0 at position 0
    int64:ch0 = raw mem_memchr(srcbuf.value, 0i64, 64i64);
    t_assert_eq_i64(ch0, srcbuf.value, "memchr: find byte[0]==0 at position 0");

    // Find byte 63 at position 63
    int64:ch63 = raw mem_memchr(srcbuf.value, 63i64, 64i64);
    t_assert_eq_i64(ch63, srcbuf.value + 63i64, "memchr: find byte[63]==63 at position 63");

    // Not found
    int64:chnf = raw mem_memchr(srcbuf.value, 0xFFi64, 64i64);
    t_assert_eq_i64(chnf, 0i64, "memchr: 0xFF not in 0..63 → NULL");

    // n=0: not found
    int64:chn0 = raw mem_memchr(srcbuf.value, 0i64, 0i64);
    t_assert_eq_i64(chn0, 0i64, "memchr(n=0) → NULL");

    // mem_memrchr (last occurrence)
    t_section("mem_memrchr");
    // Buffer: [0, 1, 2, 0, 4, 5, 0, 7]
    stack byte:rcbuf[8];
    rcbuf[0] = 0u8; rcbuf[1] = 1u8; rcbuf[2] = 2u8; rcbuf[3] = 0u8;
    rcbuf[4] = 4u8; rcbuf[5] = 5u8; rcbuf[6] = 0u8; rcbuf[7] = 7u8;
    int64:rcbase = &rcbuf[0] as int64;

    int64:rc_last = raw mem_memrchr(rcbase, 0i64, 8i64);
    t_assert_eq_i64(rc_last, rcbase + 6i64, "memrchr: last 0x00 at index 6");

    int64:rc_notfound = raw mem_memrchr(rcbase, 0xFFi64, 8i64);
    t_assert_eq_i64(rc_notfound, 0i64, "memrchr: 0xFF not found → NULL");

    // mem_memmem
    t_section("mem_memmem");
    // Haystack: "hello world hello"
    stack byte:hay[18];
    hay[0]='h'; hay[1]='e'; hay[2]='l'; hay[3]='l'; hay[4]='o'; hay[5]=' ';
    hay[6]='w'; hay[7]='o'; hay[8]='r'; hay[9]='l'; hay[10]='d'; hay[11]=' ';
    hay[12]='h'; hay[13]='e'; hay[14]='l'; hay[15]='l'; hay[16]='o'; hay[17]=0u8;
    stack byte:ndl_hello[5];
    ndl_hello[0]='h'; ndl_hello[1]='e'; ndl_hello[2]='l'; ndl_hello[3]='l'; ndl_hello[4]='o';
    stack byte:ndl_world[5];
    ndl_world[0]='w'; ndl_world[1]='o'; ndl_world[2]='r'; ndl_world[3]='l'; ndl_world[4]='d';
    stack byte:ndl_xyz[3];
    ndl_xyz[0]='x'; ndl_xyz[1]='y'; ndl_xyz[2]='z';

    int64:hayp = &hay[0] as int64;
    int64:mm1 = raw mem_memmem(hayp, 17i64, &ndl_hello[0] as int64, 5i64);
    t_assert_eq_i64(mm1, hayp, "memmem: 'hello' found at index 0");

    int64:mm2 = raw mem_memmem(hayp, 17i64, &ndl_world[0] as int64, 5i64);
    t_assert_eq_i64(mm2, hayp + 6i64, "memmem: 'world' found at index 6");

    int64:mm3 = raw mem_memmem(hayp, 17i64, &ndl_xyz[0] as int64, 3i64);
    t_assert_eq_i64(mm3, 0i64, "memmem: 'xyz' not found → NULL");

    // Zero-length needle: returns haystack start
    int64:mm4 = raw mem_memmem(hayp, 17i64, &ndl_xyz[0] as int64, 0i64);
    t_assert_eq_i64(mm4, hayp, "memmem: zero-length needle → haystack start");

    // mem_is_zero
    t_section("mem_is_zero");
    mem_bzero(dstbuf.value, 256i64);
    t_assert(raw mem_is_zero(dstbuf.value, 256i64), "mem_is_zero: all-zero buffer");
    (dstbuf.value as *byte)[128] = 1u8;
    t_assert(!raw mem_is_zero(dstbuf.value, 256i64), "mem_is_zero: one non-zero byte → false");
    t_assert(raw mem_is_zero(dstbuf.value, 0i64), "mem_is_zero(n=0) → true");

    // mem_swap
    t_section("mem_swap");
    stack byte:swbuf[16];
    int64:sw1 = &swbuf[0] as int64;
    int64:sw2 = &swbuf[8] as int64;
    // Fill first 8: 0..7, second 8: 8..15
    int64:swi = 0i64;
    while swi < 16i64 { swbuf[swi] = swi as byte; swi = swi + 1i64; }
    mem_swap(sw1, sw2, 8i64);
    t_assert(swbuf[0] == 8u8,  "mem_swap: a[0] got b's first byte");
    t_assert(swbuf[7] == 15u8, "mem_swap: a[7] got b's last byte");
    t_assert(swbuf[8] == 0u8,  "mem_swap: b[0] got a's first byte");
    t_assert(swbuf[15] == 7u8, "mem_swap: b[7] got a's last byte");

    // mem_reverse
    t_section("mem_reverse");
    stack byte:revbuf[8];
    revbuf[0]=1u8; revbuf[1]=2u8; revbuf[2]=3u8; revbuf[3]=4u8;
    revbuf[4]=5u8; revbuf[5]=6u8; revbuf[6]=7u8; revbuf[7]=8u8;
    mem_reverse(&revbuf[0] as int64, 8i64);
    t_assert(revbuf[0]==8u8 && revbuf[7]==1u8 && revbuf[3]==5u8 && revbuf[4]==4u8,
             "mem_reverse(8): 1..8 → 8..1");
    // Odd length
    stack byte:revbuf5[5];
    revbuf5[0]=1u8; revbuf5[1]=2u8; revbuf5[2]=3u8; revbuf5[3]=4u8; revbuf5[4]=5u8;
    mem_reverse(&revbuf5[0] as int64, 5i64);
    t_assert(revbuf5[0]==5u8 && revbuf5[2]==3u8 && revbuf5[4]==1u8,
             "mem_reverse(5): 1..5 → 5..1");

    // mem_align_ptr
    t_section("mem_align_ptr / mem_is_aligned");
    t_assert_eq_i64(raw mem_align_ptr(0i64,  16i64), 0i64,  "align_ptr(0,16)==0");
    t_assert_eq_i64(raw mem_align_ptr(1i64,  16i64), 16i64, "align_ptr(1,16)==16");
    t_assert_eq_i64(raw mem_align_ptr(15i64, 16i64), 16i64, "align_ptr(15,16)==16");
    t_assert_eq_i64(raw mem_align_ptr(16i64, 16i64), 16i64, "align_ptr(16,16)==16");
    t_assert_eq_i64(raw mem_align_ptr(17i64, 16i64), 32i64, "align_ptr(17,16)==32");
    t_assert(raw mem_is_aligned(0i64,    8i64), "is_aligned(0,8)");
    t_assert(raw mem_is_aligned(8i64,    8i64), "is_aligned(8,8)");
    t_assert(!raw mem_is_aligned(3i64,   8i64), "!is_aligned(3,8)");
    t_assert(raw mem_is_aligned(4096i64, 4096i64), "is_aligned(4096,4096)");

    // Cleanup
    mem_free(srcbuf.value);
    mem_free(dstbuf.value);
    mem_free(msbuf.value);

    // ── Summary ──────────────────────────────────────────────────────────
    t_end();
    exit raw t_exit_code() as int32;
}
